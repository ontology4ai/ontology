# Environment Variables for Docker Deployment
# Copy this file to .env and fill in your actual values

# Application Environment
APP_ENVIRONMENT=production

# Database Passwords
MYSQL_ROOT_PASSWORD=your-mysql-root-password
MYSQL_PASSWORD=your-mysql-app-password
NEO4J_PASSWORD=your-neo4j-password
QDRANT_PASSWORD=your-qdrant-password



# Optional: External Database Hosts (if not using Docker containers)
# CONFIG_DATABASES__MYSQL__HOST=mysql.external.com
# CONFIG_DATABASES__NEO4J__HOST=neo4j.external.com
# CONFIG_DATABASES__QDRANT__HOST=qdrant.external.com

