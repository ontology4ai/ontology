      "stepConfig": "{\"scriptText\":\"\\n\\nimport com.asiainfo.modo.dataps.EsSearchSqlUtil;\\nimport com.asiainfo.modo.dataps.DatapsHumpHelper;\\nimport io.github.suanchou.utils.SpringJdbcUtil;\\nimport org.apache.commons.collections.MapUtils;\\nimport org.apache.commons.lang3.StringUtils;\\nimport org.elasticsearch.client.RestHighLevelClient;\\nimport org.springframework.jdbc.core.namedparam.NamedParameterJdbcTemplate;\\n\\nimport java.util.HashMap;\\nimport java.util.List;\\nimport java.util.Map;\\n\\n\\n\\n    public Object delete(Map\u003cString, Object\u003e params) throws Exception {\\n        NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\\n        String esHost \u003d \\\"\\\";\\n        List\u003cMap\u003cString, Object\u003e\u003e list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\\\"select prop_label from dacp_meta_property where prop_name\u003d\u0027tabArchEsSyncHost\u0027\\\", params));\\n        for (Map\u003cString, Object\u003e map : list) {\\n            esHost \u003d MapUtils.getString(map, \\\"propLabel\\\");\\n        }\\n        String userInfo \u003d \\\"\\\";\\n        String username \u003d null;\\n        String password \u003d null;\\n        list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\\\"select prop_label from dacp_meta_property where prop_name\u003d\u0027tabArchEsSyncUserInfo\u0027\\\", params));\\n        for (Map\u003cString, Object\u003e map : list) {\\n            userInfo \u003d MapUtils.getString(map, \\\"propLabel\\\");\\n        }\\n        if (StringUtils.isNotBlank(userInfo) \u0026\u0026 userInfo.indexOf(\\\":\\\") \u003e -1) {\\n            username \u003d userInfo.split(\\\":\\\")[0];\\n            password \u003d userInfo.split(\\\":\\\")[1];\\n        }\\n        RestHighLevelClient client \u003d EsSearchSqlUtil.createClient(esHost, \\\"http\\\", new HashMap\u003c\u003e(), username, password);\\n        EsSearchSqlUtil.deleteIndex(client, MapUtils.getString(params, \\\"index\\\"));\\n        EsSearchSqlUtil.createIndex(client, MapUtils.getString(params, \\\"index\\\"));\\n        EsSearchSqlUtil.closeClient(client);\\n        return \\\"success\\\";\\n    }\\n\\n\\nreturn delete(params);\",\"label\":\"2.执行脚本\"}",
      "createUser": "chengkai3",
