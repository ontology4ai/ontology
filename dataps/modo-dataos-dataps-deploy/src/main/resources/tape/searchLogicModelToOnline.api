      "stepConfigMap": {
        "label": "10.执行脚本",
        "scriptText": "import com.asiainfo.modo.app.web.TapeController;\nimport io.github.suanchou.utils.JsonUtil;\nimport io.github.suanchou.utils.SpringContextUtil;\nimport io.github.suanchou.web.Response;\nimport org.apache.commons.collections.MapUtils;\nimport org.apache.commons.lang3.StringUtils;\n\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\n\n\nMap\u003cString, Object\u003e binding \u003d new HashMap();\nbinding.put(\"params\", params);\nString state \u003d MapUtils.getString(params, \"state\");\nif (StringUtils.isNotBlank(state)) {\n    params.put(\"state\", state.replaceAll(\";\", \",\"));\n}\nTapeController tapeController \u003d (TapeController) SpringContextUtil.getBean(\"tapeController\");\nResponse tapeResult \u003d (Response) tapeController.execByTapeName(\"logicModelOnlineSelect\", binding);\nObject dataObj \u003d tapeResult.getData();\nMap\u003cString, Object\u003e data \u003d JsonUtil.getInstance().read(JsonUtil.getInstance().write(dataObj), Map.class);\nList\u003cMap\u003cString, Object\u003e\u003e tables \u003d (List\u003cMap\u003cString, Object\u003e\u003e) data.get(\"content\");\ntables.forEach(table -\u003e {\n    table.put(\"name\", MapUtils.getString(table, \"modelName\"));\n    table.put(\"label\", MapUtils.getString(table, \"modelLabel\"));\n});\nreturn data;"
