  "serviceType": "api",
  "apiInputParams": "{\"body\":[{\"name\":\"root\",\"required\":\"1\",\"type\":\"object\",\"desc\":\"\",\"disabled\":true,\"id\":\"1\",\"children\":[{\"name\":\"teamName\",\"id\":\"f2bb2c92-ff1c-4a17-9f6e-81bef9e962e3\",\"required\":\"1\",\"type\":\"string\",\"desc\":\"\",\"disabled\":false},{\"name\":\"nodeIds\",\"id\":\"795d54eb-3450-4af1-8aef-c11aedfa526f\",\"required\":\"1\",\"type\":\"array\",\"desc\":\"\",\"disabled\":false,\"children\":[{\"name\":\"items\",\"required\":\"0\",\"type\":\"string\",\"desc\":\"\",\"disabled\":true,\"id\":\"6db37a0a-40fd-4ffa-ac12-5d1258d1965c\"}]}]}],\"headers\":[],\"query\":[]}",
  "apiOutputParams": "{\"mockJson\":\"\",\"responseBody\":[{\"name\":\"root\",\"required\":\"1\",\"type\":\"object\",\"desc\":\"\",\"disabled\":true,\"id\":\"1\",\"children\":[]}]}",
