  "tapeStepList": [
    {
      "id": "232874881633968128",
      "stepSeq": "2",
      "parentStepId": "-1",
      "label": "2.执行脚本",
      "graphId": "212940907481542656",
      "stepInst": "script",
      "preStepId": "-1",
      "nextStepId": "-1",
      "successStepId": "-1",
      "failStepId": "-1",
      "completeStepId": "-1",
      "stepConfig": "{\"scriptText\":\"\\n\\nimport com.asiainfo.modo.dataps.DatapsHumpHelper;\\nimport io.github.suanchou.utils.SpringJdbcUtil;\\nimport org.apache.commons.collections.MapUtils;\\nimport org.springframework.jdbc.core.namedparam.NamedParameterJdbcTemplate;\\n\\nimport java.util.*;\\n\\n\\n\\n    public Object ListArchModelNum(Map\u003cString, Object\u003e body) {\\n        NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\\n        Set\u003cString\u003e numIds \u003d new HashSet\u003c\u003e();\\n        List\u003cMap\u003cString, Object\u003e\u003e list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\\\"select p.prop_value, count(*) num from dataps_model_busi_prop_draft p left join dataps_logic_model_draft t on p.model_id\u003dt.id where t.team_name\u003d:teamName and p.prop_value in (:nodeIds) group by prop_value\\\", body));\\n        list.forEach(map -\u003e {\\n            int num \u003d MapUtils.getIntValue(map, \\\"num\\\", 0);\\n            if (num \u003e 0) {\\n                numIds.add(MapUtils.getString(map, \\\"propValue\\\"));\\n            }\\n        });\\n        list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\\\"select p.prop_value, count(*) num from dataps_model_busi_prop p left join dataps_logic_model t on p.model_id\u003dt.id where t.team_name\u003d:teamName and p.prop_value in (:nodeIds) group by prop_value\\\", body));\\n        list.forEach(map -\u003e {\\n            int num \u003d MapUtils.getIntValue(map, \\\"num\\\", 0);\\n            if (num \u003e 0) {\\n                numIds.add(MapUtils.getString(map, \\\"propValue\\\"));\\n            }\\n        });\\n        return new ArrayList\u003c\u003e(numIds);\\n    }\\n\\n\\nreturn ListArchModelNum(body);\",\"label\":\"2.执行脚本\"}",
      "createUser": "chengkai3",
      "appName": "dataps",
      "stepConfigMap": {
        "scriptText": "\n\nimport com.asiainfo.modo.dataps.DatapsHumpHelper;\nimport io.github.suanchou.utils.SpringJdbcUtil;\nimport org.apache.commons.collections.MapUtils;\nimport org.springframework.jdbc.core.namedparam.NamedParameterJdbcTemplate;\n\nimport java.util.*;\n\n\n\n    public Object ListArchModelNum(Map\u003cString, Object\u003e body) {\n        NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\n        Set\u003cString\u003e numIds \u003d new HashSet\u003c\u003e();\n        List\u003cMap\u003cString, Object\u003e\u003e list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\"select p.prop_value, count(*) num from dataps_model_busi_prop_draft p left join dataps_logic_model_draft t on p.model_id\u003dt.id where t.team_name\u003d:teamName and p.prop_value in (:nodeIds) group by prop_value\", body));\n        list.forEach(map -\u003e {\n            int num \u003d MapUtils.getIntValue(map, \"num\", 0);\n            if (num \u003e 0) {\n                numIds.add(MapUtils.getString(map, \"propValue\"));\n            }\n        });\n        list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\"select p.prop_value, count(*) num from dataps_model_busi_prop p left join dataps_logic_model t on p.model_id\u003dt.id where t.team_name\u003d:teamName and p.prop_value in (:nodeIds) group by prop_value\", body));\n        list.forEach(map -\u003e {\n            int num \u003d MapUtils.getIntValue(map, \"num\", 0);\n            if (num \u003e 0) {\n                numIds.add(MapUtils.getString(map, \"propValue\"));\n            }\n        });\n        return new ArrayList\u003c\u003e(numIds);\n    }\n\n\nreturn ListArchModelNum(body);",
        "label": "2.执行脚本"
      }
    }
  ]
