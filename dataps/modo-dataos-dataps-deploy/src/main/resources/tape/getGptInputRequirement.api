        "label": "2.执行脚本",
        "scriptText": "import java.util.*;\nimport io.github.suanchou.utils.SpringJdbcUtil;\nimport org.apache.commons.lang3.StringUtils;\nimport io.github.suanchou.utils.SpringContextUtil;\nimport org.apache.commons.collections.MapUtils;\nimport io.github.suanchou.utils.JsonUtil;\nimport java.util.concurrent.Executor;\nimport java.util.concurrent.Executors;\n\n\n\n\n\n    public Object getInfo(Map\u003cString, Object\u003e body) {\n         Executor asyncSearchExecutor \u003d Executors.newFixedThreadPool(8);\n         String taskId\u003dMapUtils.getString(body, \"taskId\");\n         def execGptRequirementService \u003d SpringContextUtil.getBean(\"execGptRequirementService\");\n          asyncSearchExecutor.execute(() -\u003e {\n            try {\n               execGptRequirementService.getGptTabName(taskId,body);\n            } catch (Exception e) {\n                DatapsModoDevLogHelper.error(\"智能补全元数据异常:{}\", ExceptionUtils.getStackTrace(e));\n            }\n        });\n        return taskId;\n    }\n\n  \n\nreturn getInfo(body);"
