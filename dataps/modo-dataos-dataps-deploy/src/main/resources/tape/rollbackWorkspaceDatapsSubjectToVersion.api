      "nextStepId": "-1",
      "successStepId": "-1",
      "failStepId": "-1",
      "completeStepId": "-1",
      "stepConfig": "{\"label\":\"2.执行脚本\",\"scriptText\":\"import io.github.suanchou.utils.SpringContextUtil;\\nimport io.github.suanchou.utils.SpringJdbcUtil;\\nimport org.apache.commons.collections.MapUtils;\\nimport org.apache.commons.collections.map.HashedMap;\\nimport org.springframework.jdbc.core.namedparam.NamedParameterJdbcTemplate;\\nimport org.springframework.transaction.PlatformTransactionManager;\\nimport org.springframework.transaction.TransactionStatus;\\nimport org.springframework.transaction.support.DefaultTransactionDefinition;\\n\\nimport java.util.List;\\nimport java.util.Map;\\nimport java.util.Objects;\\n\\n    public boolean rollbackWorkspaceDatapsSubjectToVersion(Map\u003cString, Object\u003e params) {\\n        String workspaceId \u003d MapUtils.getString(params, \\\"workspaceId\\\");\\n        Objects.requireNonNull(workspaceId, \\\"workspaceId不能为空！\\\");\\n        String versionNumberToRollback \u003d MapUtils.getString(params, \\\"versionNumber\\\");\\n        Objects.requireNonNull(versionNumberToRollback, \\\"versionNumber不能为空！\\\");\\n\\n        PlatformTransactionManager txManager \u003d (PlatformTransactionManager) SpringContextUtil.getBean(\\\"transactionManager\\\");\\n        DefaultTransactionDefinition deff \u003d new DefaultTransactionDefinition();\\n        TransactionStatus transactionStatus \u003d txManager.getTransaction(deff);\\n        try {\\n            NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\\n            Map\u003cString, Object\u003e sqlParams \u003d new HashedMap();\\n            sqlParams.put(\\\"workspaceId\\\", workspaceId);\\n            sqlParams.put(\\\"versionNumberToRollback\\\", versionNumberToRollback);\\n\\n            // 删除草稿表中当前工作空间的编目及其子条目\\n            List\u003cMap\u003cString, Object\u003e\u003e datapsSubjectDraftList \u003d jt.queryForList(\\\"select * from dataps_subject_draft where workspace_id \u003d :workspaceId\\\", sqlParams);\\n            datapsSubjectDraftList.forEach(datapsSubjectDraft -\u003e {\\n                String subjectId \u003d (String) datapsSubjectDraft.get(\\\"subject_id\\\");\\n                String versionNumber \u003d (String) datapsSubjectDraft.get(\\\"version_number\\\");\\n                Map\u003cString, Object\u003e sqlParams4DatapsSubjectItemDraft \u003d new HashedMap();\\n                sqlParams4DatapsSubjectItemDraft.put(\\\"subjectId\\\", subjectId);\\n                sqlParams4DatapsSubjectItemDraft.put(\\\"versionNumber\\\", versionNumber);\\n                jt.update(\\\"delete from dataps_subject_item_draft where subject_id \u003d :subjectId and version_number \u003d :versionNumber\\\", sqlParams4DatapsSubjectItemDraft);\\n            });\\n            jt.update(\\\"delete from dataps_subject_draft where workspace_id \u003d :workspaceId\\\", sqlParams);\\n\\n            // 将正式表中当前工作空间指定版本的所有编目及其子条目全部存到草稿表\\n            jt.update(\\\"insert into dataps_subject_item_draft(item_id, item_descr, item_label, item_name, item_name_abbr, parent_item_id, subject_id, item_seq, version_number) select item_id, item_descr, item_label, item_name, item_name_abbr, parent_item_id, subject_id, item_seq, version_number from dataps_subject_item dsi where dsi.subject_id in (select ds.subject_id from dataps_subject ds where ds.workspace_id \u003d :workspaceId) and dsi.version_number \u003d :versionNumberToRollback\\\", sqlParams);\\n            jt.update(\\\"insert into dataps_subject_draft(subject_id, create_dt, create_user, lastupd, subject_descr, subject_label, subject_name, update_user, workspace_id, version_number, state) select subject_id, create_dt, create_user, lastupd, subject_descr, subject_label, subject_name, update_user, workspace_id, version_number, state from dataps_subject where workspace_id \u003d :workspaceId and version_number \u003d :versionNumberToRollback\\\", sqlParams);\\n\\n            txManager.commit(transactionStatus);\\n        } catch (Exception e) {\\n            txManager.rollback(transactionStatus);\\n            throw new RuntimeException(e);\\n        }\\n        return true;\\n    }\\n\\nreturn rollbackWorkspaceDatapsSubjectToVersion(params);\"}",
      "createUser": "gaopeng3",
      "appName": "dataps",
      "stepConfigMap": {
        "label": "2.执行脚本",
        "scriptText": "import io.github.suanchou.utils.SpringContextUtil;\nimport io.github.suanchou.utils.SpringJdbcUtil;\nimport org.apache.commons.collections.MapUtils;\nimport org.apache.commons.collections.map.HashedMap;\nimport org.springframework.jdbc.core.namedparam.NamedParameterJdbcTemplate;\nimport org.springframework.transaction.PlatformTransactionManager;\nimport org.springframework.transaction.TransactionStatus;\nimport org.springframework.transaction.support.DefaultTransactionDefinition;\n\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Objects;\n\n    public boolean rollbackWorkspaceDatapsSubjectToVersion(Map\u003cString, Object\u003e params) {\n        String workspaceId \u003d MapUtils.getString(params, \"workspaceId\");\n        Objects.requireNonNull(workspaceId, \"workspaceId不能为空！\");\n        String versionNumberToRollback \u003d MapUtils.getString(params, \"versionNumber\");\n        Objects.requireNonNull(versionNumberToRollback, \"versionNumber不能为空！\");\n\n        PlatformTransactionManager txManager \u003d (PlatformTransactionManager) SpringContextUtil.getBean(\"transactionManager\");\n        DefaultTransactionDefinition deff \u003d new DefaultTransactionDefinition();\n        TransactionStatus transactionStatus \u003d txManager.getTransaction(deff);\n        try {\n            NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\n            Map\u003cString, Object\u003e sqlParams \u003d new HashedMap();\n            sqlParams.put(\"workspaceId\", workspaceId);\n            sqlParams.put(\"versionNumberToRollback\", versionNumberToRollback);\n\n            // 删除草稿表中当前工作空间的编目及其子条目\n            List\u003cMap\u003cString, Object\u003e\u003e datapsSubjectDraftList \u003d jt.queryForList(\"select * from dataps_subject_draft where workspace_id \u003d :workspaceId\", sqlParams);\n            datapsSubjectDraftList.forEach(datapsSubjectDraft -\u003e {\n                String subjectId \u003d (String) datapsSubjectDraft.get(\"subject_id\");\n                String versionNumber \u003d (String) datapsSubjectDraft.get(\"version_number\");\n                Map\u003cString, Object\u003e sqlParams4DatapsSubjectItemDraft \u003d new HashedMap();\n                sqlParams4DatapsSubjectItemDraft.put(\"subjectId\", subjectId);\n                sqlParams4DatapsSubjectItemDraft.put(\"versionNumber\", versionNumber);\n                jt.update(\"delete from dataps_subject_item_draft where subject_id \u003d :subjectId and version_number \u003d :versionNumber\", sqlParams4DatapsSubjectItemDraft);\n            });\n            jt.update(\"delete from dataps_subject_draft where workspace_id \u003d :workspaceId\", sqlParams);\n\n            // 将正式表中当前工作空间指定版本的所有编目及其子条目全部存到草稿表\n            jt.update(\"insert into dataps_subject_item_draft(item_id, item_descr, item_label, item_name, item_name_abbr, parent_item_id, subject_id, item_seq, version_number) select item_id, item_descr, item_label, item_name, item_name_abbr, parent_item_id, subject_id, item_seq, version_number from dataps_subject_item dsi where dsi.subject_id in (select ds.subject_id from dataps_subject ds where ds.workspace_id \u003d :workspaceId) and dsi.version_number \u003d :versionNumberToRollback\", sqlParams);\n            jt.update(\"insert into dataps_subject_draft(subject_id, create_dt, create_user, lastupd, subject_descr, subject_label, subject_name, update_user, workspace_id, version_number, state) select subject_id, create_dt, create_user, lastupd, subject_descr, subject_label, subject_name, update_user, workspace_id, version_number, state from dataps_subject where workspace_id \u003d :workspaceId and version_number \u003d :versionNumberToRollback\", sqlParams);\n\n            txManager.commit(transactionStatus);\n        } catch (Exception e) {\n            txManager.rollback(transactionStatus);\n            throw new RuntimeException(e);\n        }\n        return true;\n    }\n\nreturn rollbackWorkspaceDatapsSubjectToVersion(params);"
      }
    }
