  "apiInputParams": "{\"headers\":[],\"query\":[{\"id\":\"05cdff53-25fc-41a0-850f-25008929012b\",\"name\":\"workspaceId\",\"required\":\"1\",\"example\":\"\",\"desc\":\"\",\"value\":\"testWorkspaceId\"},{\"id\":\"127e1d6a-4ee2-4053-809f-4c0d97a172cb\",\"name\":\"versionNumber\",\"required\":\"1\",\"example\":\"\",\"desc\":\"\",\"value\":\"0\"}]}",
