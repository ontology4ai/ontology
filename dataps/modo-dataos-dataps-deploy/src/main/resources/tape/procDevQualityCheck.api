c\":\"\",\"disabled\":false},{\"id\":\"25b35f5f-bef3-404f-9096-9f48befc1ae5\",\"key\":\"03293bbc-448b-49e4-8177-1408a2b5a371\",\"name\":\"strategyTime\",\"required\":\"1\",\"type\":\"string\",\"desc\":\"\",\"disabled\":false},{\"id\":\"232d7130-45e8-441e-9f76-cc7a95b2cc07\",\"key\":\"59fc37b4-8b15-43e4-9ccd-151230c5ba81\",\"name\":\"sourceTab\",\"required\":\"1\",\"type\":\"null\",\"desc\":\"\",\"disabled\":false},{\"id\":\"afee0da7-583f-4aa8-9aa2-2e08b56ce1bd\",\"key\":\"c65b5e16-cb88-4302-b9bf-bc4936b74529\",\"name\":\"isPublic\",\"required\":\"1\",\"type\":\"string\",\"desc\":\"\",\"disabled\":false},{\"id\":\"606ef06f-560a-4520-9973-faec7efd2641\",\"key\":\"5bbd6b1c-2714-41c4-be47-30dce181cebb\",\"name\":\"ownership\",\"required\":\"1\",\"type\":\"string\",\"desc\":\"\",\"disabled\":false},{\"id\":\"6fcc84f2-d54c-4cdc-9d6f-6bda1db96efa\",\"key\":\"834b3eaf-d084-4099-ac6f-093267347438\",\"name\":\"tabSrcs\",\"required\":\"1\",\"type\":\"null\",\"desc\":\"\",\"disabled\":false},{\"id\":\"841be605-c7e7-48e1-9198-f905ea3a8257\",\"key\":\"5da55359-dcd3-449f-aa15-87c4d091529c\",\"name\":\"tabFieldSrcs\",\"required\":\"1\",\"type\":\"null\",\"desc\":\"\",\"disabled\":false},{\"id\":\"397ca56a-2e1d-4599-81a9-0a6f76e25490\",\"key\":\"f2288372-ea8d-4f81-bb2c-9302e0e969cc\",\"name\":\"archName\",\"required\":\"1\",\"type\":\"string\",\"desc\":\"\",\"disabled\":false},{\"id\":\"69c0af47-191e-4854-acf3-81ade107c966\",\"key\":\"b9cb474f-9466-415a-9783-6e0b6dada8fa\",\"name\":\"tabTags\",\"required\":\"1\",\"type\":\"null\",\"desc\":\"\",\"disabled\":false},{\"id\":\"25f4f198-f3e0-4a0b-a2ce-60a4bf0fb95f\",\"key\":\"e20b0847-9f42-4b71-aafe-3147a229d86e\",\"name\":\"createType\",\"required\":\"1\",\"type\":\"string\",\"desc\":\"\",\"disabled\":false},{\"id\":\"135e12cc-4678-4fdf-8bd5-7ac2623ff1e4\",\"key\":\"e8963c84-cc11-47d0-b8b6-7d5624250599\",\"name\":\"clusterGroup\",\"required\":\"1\",\"type\":\"string\",\"desc\":\"\",\"disabled\":false},{\"id\":\"de50de6a-5307-4588-a88f-0