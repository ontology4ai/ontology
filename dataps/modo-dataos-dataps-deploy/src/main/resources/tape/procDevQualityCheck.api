  "apiOutputParams": "{\"mockJson\":\"\",\"responseBody\":[{\"name\":\"root\",\"required\":\"1\",\"type\":\"object\",\"desc\":\"\",\"disabled\":true,\"id\":\"1\",\"children\":[]}]}",
  "appName": "dataps",
  "mockState": "0",
  "tapeStepList": [
    {
      "id": "dataps-139382547892375552",
      "stepSeq": "2",
      "parentStepId": "-1",
      "label": "2.执行脚本",
      "graphId": "dataps-139382547871404032",
      "stepInst": "script",
      "preStepId": "-1",
      "nextStepId": "-1",
      "successStepId": "-1",
      "failStepId": "-1",
      "completeStepId": "-1",
      "stepConfig": "{\"label\":\"2.执行脚本\",\"scriptText\":\"import com.asiainfo.modo.datago.CheckFuncHelper;\\nimport com.asiainfo.modo.datago.CheckFuncHelperForProcScript;\\nimport io.github.suanchou.utils.SpringContextUtil;\\n\\nimport com.fasterxml.jackson.core.type.TypeReference;\\nimport io.github.suanchou.utils.JsonUtil;\\nimport io.github.suanchou.utils.SpringJdbcUtil;\\nimport io.github.suanchou.utils.StringUtil;\\nimport org.apache.commons.collections.MapUtils;\\nimport org.apache.commons.lang3.StringUtils;\\nimport org.slf4j.Logger;\\nimport org.slf4j.LoggerFactory;\\nimport org.springframework.jdbc.core.JdbcTemplate;\\n\\nimport java.lang.reflect.Method;\\nimport java.text.SimpleDateFormat;\\nimport java.util.*;\\nimport java.util.regex.Matcher;\\nimport java.util.regex.Pattern;\\n\\nSystem.out.println(body);\\n// DatagoDevQualityCheckService serv \u003d SpringContextUtil.getBean(DatagoDevQualityCheckService.class);\\n// return serv.checkModel(body);\\n\\n        Map\u003cString, Object\u003e proc \u003d body;\\n\\n        System.out.println(\\\"----------------\\\");\\n        Map\u003cString, Object\u003e result \u003d new HashMap\u003c\u003e();\\n        List\u003cMap\u003cString, Object\u003e\u003e dqRules \u003d getCheckRules(\\\"PROC\\\", \\\"1\\\");\\n        Map\u003cString, Object\u003e procMeta \u003d getProcMeta(proc);\\n        result \u003d doDevCheckItemNotToDb(proc, dqRules, procMeta);\\n        \\n        return result;\\n\\n\\n\\n    private Map\u003cString, Object\u003e getProcMeta(Map\u003cString, Object\u003e proc) {\\n        Map\u003cString, Object\u003e metaMap \u003d proc;\\n\\n        Map\u003cString, Object\u003e meta \u003d new HashMap\u003c\u003e();\\n\\n        String idVal \u003d parseObjectToString(metaMap.get(\\\"id\\\"));\\n        Map\u003cString, Object\u003e idMem \u003d new HashMap\u003c\u003e();\\n        idMem.put(\\\"name\\\",\\\"id\\\");\\n        idMem.put(\\\"value\\\",idVal);\\n        idMem.put(\\\"length\\\",idVal.length());\\n        meta.put(\\\"id\\\",idMem);\\n\\n        String name \u003d parseObjectToString(metaMap.get(\\\"name\\\"));\\n        Map\u003cString, Object\u003e nameMem \u003d new HashMap\u003c\u003e();\\n        nameMem.put(\\\"name\\\",\\\"name\\\");\\n        nameMem.put(\\\"value\\\",name);\\n        nameMem.put(\\\"length\\\",name.length());\\n        meta.put(\\\"name\\\",nameMem);\\n\\n        String label \u003d parseObjectToString(metaMap.get(\\\"label\\\"));\\n        Map\u003cString, Object\u003e labelMem \u003d new HashMap\u003c\u003e();\\n        labelMem.put(\\\"name\\\",\\\"label\\\");\\n        labelMem.put(\\\"value\\\",label);\\n        labelMem.put(\\\"length\\\",label.length());\\n        meta.put(\\\"label\\\",labelMem);\\n\\n        String cycle \u003d parseObjectToString(metaMap.get(\\\"procCycle\\\"));\\n        Map\u003cString, Object\u003e cycleMem \u003d new HashMap\u003c\u003e();\\n        cycleMem.put(\\\"name\\\",\\\"cycle\\\");\\n        cycleMem.put(\\\"value\\\",cycle);\\n        cycleMem.put(\\\"length\\\",cycle.length());\\n        meta.put(\\\"cycle\\\",cycleMem);\\n\\n\\t\\tString procType \u003d parseObjectToString(metaMap.get(\\\"procType\\\"));\\n\\t\\tMap\u003cString, Object\u003e procTypeMem \u003d new HashMap\u003c\u003e();\\n\\t\\tprocTypeMem.put(\\\"name\\\",\\\"procType\\\");\\n        procTypeMem.put(\\\"value\\\",procType);\\n        procTypeMem.put(\\\"length\\\",procType.length());\\n\\t\\tmeta.put(\\\"procType\\\",procTypeMem);\\n\\t\\t// List\u003cMap\u003cString,Object\u003e\u003e steps \u003d jdbc.queryForList(stepSql);\\n        List\u003cMap\u003cString,Object\u003e\u003e steps \u003d (List\u003cMap\u003cString, Object\u003e\u003e) metaMap.get(\\\"steps\\\");\\n        if(steps \u003d\u003d null){\\n            steps \u003d new ArrayList\u003c\u003e();\\n        }\\n\\t\\tMap\u003cString,Object\u003e scriptSteps \u003d new HashMap\u003c\u003e();\\n\\t\\tMap\u003cString, Object\u003e stepMem \u003d new HashMap\u003c\u003e();\\n\\t\\tstepMem.put(\\\"name\\\",\\\"steps\\\");\\t\\t\\n\\t\\tif(\\\"METAPROC\\\".equals(procType)) {\\n\\t\\t\\tstepMem.put(\\\"value\\\",steps);\\n\\t\\t\\tstepMem.put(\\\"length\\\",steps.size());\\n\\t\\t} else {\\n\\t\\t\\tString procScriptType \u003d parseObjectToString(metaMap.get(\\\"procScriptType\\\"));\\n\\t\\t\\tString graph \u003d  parseObjectToString(metaMap.get(\\\"graph\\\"));\\n\\t\\t\\tscriptSteps.put(\\\"procType\\\",procType);\\n\\t\\t\\tscriptSteps.put(\\\"procScriptType\\\", procScriptType);\\n\\t\\t\\tscriptSteps.put(\\\"steps\\\", graph);\\n\\t\\t\\tstepMem.put(\\\"value\\\",scriptSteps);\\n\\t\\t\\tstepMem.put(\\\"length\\\",StringUtils.isNotBlank(graph)?1:0);\\n\\t\\t}\\n\\n        meta.put(\\\"steps\\\",stepMem);\\n        List\u003cString\u003e sourceTabs \u003d new ArrayList\u003cString\u003e();\\n        List\u003cString\u003e targetTabs \u003d new ArrayList\u003cString\u003e();\\n\\n        String extendCfg \u003d parseObjectToString(metaMap.get(\\\"extendCfg\\\"));       \\n        if (StringUtils.isNotBlank(extendCfg)) {\\n            try {\\n                // 直接查询程序配置的输入和输出表\\n                //{\\\"inPutTab\\\":\\\"CMCMHQBASSTB1900000024;\\\",\\\"outPutTab\\\":\\\"CMCMHQBASSTB1900000115;CMCMHQBASSTB1900000116;\\\"}\\n                Map\u003cString, String\u003e extendCfgMap \u003d (Map\u003cString, String\u003e) JsonUtil.getInstance().read(extendCfg);\\n                String inPutTabs \u003d extendCfgMap.get(\\\"inPutTab\\\");\\n                String outPutTabs \u003d extendCfgMap.get(\\\"outPutTab\\\");\\n                if (StringUtils.isNotBlank(inPutTabs)) {\\n                    String[] inPutTabA \u003d inPutTabs.split(\\\";\\\");\\n                    for (String s : inPutTabA) {\\n                        if (StringUtils.isNotBlank(s)) {\\n                            sourceTabs.add(s);\\n                        }\\n                    }\\n                }\\n                if (StringUtils.isNotBlank(outPutTabs)) {\\n                    String[] outPutTabA \u003d outPutTabs.split(\\\";\\\");\\n                    for (String s : outPutTabA) {\\n                        if (StringUtils.isNotBlank(s)) {\\n                            targetTabs.add(s);\\n                        }\\n                    }\\n                }\\n\\n            } catch (Exception e) {\\n                LOG.error(e.getMessage(), e);\\n            }\\n\\n        }\\n        \\n        Map\u003cString,Object\u003e sourceTabsMem \u003d new HashMap\u003c\u003e();\\n        sourceTabsMem.put(\\\"name\\\",\\\"sourceTabs\\\");\\n        sourceTabsMem.put(\\\"value\\\",sourceTabs);\\n        sourceTabsMem.put(\\\"length\\\",sourceTabs.size());\\n        meta.put(\\\"sourceTabs\\\",sourceTabsMem);\\n\\n        Map\u003cString,Object\u003e targetTabsMem \u003d new HashMap\u003c\u003e();\\n        targetTabsMem.put(\\\"name\\\",\\\"targetTabs\\\");\\n        targetTabsMem.put(\\\"value\\\",targetTabs);\\n        targetTabsMem.put(\\\"length\\\",targetTabs.size());\\n        meta.put(\\\"targetTabs\\\",targetTabsMem);\\n\\n\\n        //steps\u0026sourceTabs\u0026targetTabs\\n        Map\u003cString, Object\u003e stepsAndInOutTabs \u003d new HashMap\u003cString, Object\u003e();\\n        if(\\\"METAPROC\\\".equals(procType)) {\\n\\t\\t\\tstepsAndInOutTabs.put(\\\"steps\\\", steps);\\n\\t\\t} else {\\n\\t\\t\\tstepsAndInOutTabs.put(\\\"steps\\\", scriptSteps);\\n\\t\\t}\\n        stepsAndInOutTabs.put(\\\"sourceTabs\\\", sourceTabs);\\n        stepsAndInOutTabs.put(\\\"targetTabs\\\", targetTabs);\\n        Map\u003cString,Object\u003e stepsAndInOutTabsMem \u003d new HashMap\u003c\u003e();\\n        stepsAndInOutTabsMem.put(\\\"name\\\",\\\"stepsAndInOutTabs\\\");\\n        stepsAndInOutTabsMem.put(\\\"value\\\",stepsAndInOutTabs);\\n        stepsAndInOutTabsMem.put(\\\"length\\\",1);\\n        meta.put(\\\"stepsAndInOutTabs\\\",stepsAndInOutTabsMem);\\n\\n        String teamVal \u003d parseObjectToString(metaMap.get(\\\"teamName\\\"));\\n        Map\u003cString,Object\u003e teamMem \u003d new HashMap\u003c\u003e();\\n        teamMem.put(\\\"name\\\",\\\"team\\\");\\n        teamMem.put(\\\"value\\\",teamVal);\\n        teamMem.put(\\\"length\\\",teamVal.length());\\n        meta.put(\\\"team\\\",teamMem);\\n\\t\\t\\n        String teamLabelVal \u003d parseObjectToString(metaMap.get(\\\"teamLabel\\\"));\\n        Map\u003cString,Object\u003e teamLabelMem \u003d new HashMap\u003c\u003e();\\n        teamLabelMem.put(\\\"name\\\",\\\"teamLabel\\\");\\n        teamLabelMem.put(\\\"value\\\",teamLabelVal);\\n        teamLabelMem.put(\\\"length\\\",teamLabelVal.length());\\n        meta.put(\\\"teamLabel\\\",teamLabelMem);\\n\\n        String memberVal \u003d parseObjectToString(metaMap.get(\\\"memberName\\\"));\\n        Map\u003cString,Object\u003e memberMem \u003d new HashMap\u003c\u003e();\\n        memberMem.put(\\\"name\\\",\\\"member\\\");\\n        memberMem.put(\\\"value\\\",memberVal);\\n        memberMem.put(\\\"length\\\",memberVal.length());\\n        meta.put(\\\"member\\\",memberMem);\\n\\n        String userNameVal \u003d parseObjectToString(metaMap.get(\\\"user\\\"));\\n        Map\u003cString,Object\u003e userNameMem \u003d new HashMap\u003c\u003e();\\n        userNameMem.put(\\\"name\\\",\\\"userName\\\");\\n        userNameMem.put(\\\"value\\\",userNameVal);\\n        userNameMem.put(\\\"length\\\",userNameVal.length());\\n        meta.put(\\\"userName\\\",userNameMem);\\n\\n        meta.put(\\\"state\\\", MapUtils.getString(metaMap, \\\"state\\\"));\\n\\n        return meta;\\n    }\\n\\n    public Map\u003cString, Object\u003e doDevCheckItemNotToDb(Map\u003cString, Object\u003e obj, List\u003cMap\u003cString, Object\u003e\u003e dqRules, Map\u003cString, Object\u003e meta) {\\n         Map\u003cString, Object\u003e returnResult \u003d new HashMap\u003c\u003e();\\n        List\u003cMap\u003cString, Object\u003e\u003e results \u003d new ArrayList\u003c\u003e();\\n        String opTime \u003d getCurrentDate(\\\"yyyyMMdd\\\");\\n        Map\u003cString, Object\u003e sum \u003d new HashMap\u003c\u003e();\\n        Map\u003cString, Object\u003e idMeta \u003d (Map\u003cString, Object\u003e) meta.get(\\\"id\\\");\\n        Map\u003cString, Object\u003e nameMeta \u003d (Map\u003cString, Object\u003e) meta.get(\\\"name\\\");\\n        Map\u003cString, Object\u003e labelMeta \u003d (Map\u003cString, Object\u003e) meta.get(\\\"label\\\");\\n        sum.put(\\\"checkResult\\\", \\\"OK\\\");\\n        sum.put(\\\"objName\\\", MapUtils.getString(nameMeta, \\\"value\\\"));\\n        sum.put(\\\"objLabel\\\", MapUtils.getString(labelMeta, \\\"value\\\"));\\n        int okRuleCnt \u003d 0;\\n        int excepRuleCnt \u003d 0;\\n        int errRuleCnt \u003d 0;\\n        int warningRuleCnt \u003d 0;\\n\\n        for (Map\u003cString, Object\u003e dqRule : dqRules) {\\n            Map\u003cString, Object\u003e result \u003d new HashMap\u003c\u003e();\\n            result.putAll(dqRule);\\n            result.put(\\\"dsLabel\\\", MapUtils.getString(obj, \\\"dsLabel\\\"));\\n            result.put(\\\"id\\\", StringUtil.nextId());\\n            result.put(\\\"ruleId\\\", dqRule.get(\\\"id\\\"));\\n            result.put(\\\"opTime\\\", opTime);\\n            result.put(\\\"objId\\\", MapUtils.getString(idMeta, \\\"value\\\"));\\n            result.put(\\\"objName\\\", MapUtils.getString(nameMeta, \\\"value\\\"));\\n            result.put(\\\"objLabel\\\", MapUtils.getString(labelMeta, \\\"value\\\"));\\n            try {\\n                preCheckResult(meta, result);\\n                Map\u003cString, String\u003e funcParasMap \u003d parseFuncPara(MapUtils.getString(result, \\\"funcPara\\\"));\\n                String funcCode \u003d MapUtils.getString(result, \\\"funcCode\\\");\\n                String expectVal \u003d funcParasMap.get(\\\"expectVal\\\");\\n                String realVal \u003d MapUtils.getString(result, \\\"realVal\\\");\\n                Map\u003cString, Object\u003e msg \u003d null;\\n                List\u003cString\u003e procScriptRuleList\u003dArrays.asList(new String[]{\\\"stepsNotIllegalSql\\\",\\\"stepsNotContainSelectA\\\",\\\"stepsSpecChar\\\",\\n\\t                                 \\\"stepsTempStartWithTemp\\\",\\\"stepsContainTempDrop\\\",\\n\\t                                 \\\"stepsExactDate\\\",\\\"stepsOneStepOneSql\\\",\\n\\t                                 \\\"stepsCartesian\\\",\\\"stepsHivePartCond\\\",\\n\\t                                 \\\"targetTabConsistency\\\",\\\"tempContainTemp\\\",\\\"scriptNotContainSpecChar\\\"});\\n                if(\\\"PROC\\\".equalsIgnoreCase(dqRule.get(\\\"objType\\\")) \u0026\u0026 procScriptRuleList.contains(dqRule.get(\\\"ruleSubType\\\"))\\n\\t\\t\\t\\t\\t\\t\u0026\u0026 \\\"taskTypeFunc\\\".equals(((Map\u003cString,Object\u003e)meta.get(\\\"procType\\\")).get(\\\"value\\\"))) {\\n\\t\\t\\t\\t\\tmsg \u003d CheckFuncHelperForProcScript.check(realVal, expectVal, funcCode,MapUtils.getString(dqRule, \\\"objType\\\"),MapUtils.getString(dqRule, \\\"ruleSubType\\\"),MapUtils.getString(dqRule, \\\"state\\\"));\\n\\t\\t\\t\\t} else { \\n\\t\\t\\t\\t\\t msg \u003d CheckFuncHelper.check(realVal, expectVal, funcCode, MapUtils.getString(dqRule, \\\"objType\\\"), MapUtils.getString(dqRule, \\\"ruleSubType\\\"), obj, MapUtils.getString(dqRule, \\\"ruleContent\\\"));\\n\\t\\t\\t\\t} \\n                result.put(\\\"realVal\\\", MapUtils.getString(msg, \\\"realVal\\\"));\\n                String checkResult \u003d MapUtils.getString(msg, \\\"checkResult\\\");\\n                if (\\\"ok\\\".equals(checkResult) \u0026\u0026 \\\"warning\\\".equals(MapUtils.getString(msg, \\\"checkResultLvl\\\"))) {\\n                    result.put(\\\"checkResult\\\", \\\"warning\\\");\\n                } else {\\n                    result.put(\\\"checkResult\\\", checkResult);\\n                }\\n\\n                result.put(\\\"checkDescr\\\", MapUtils.getString(msg, \\\"checkDescr\\\"));\\n                result.put(\\\"checkTime\\\", getCurrentDate(\\\"yyyy-MM-dd HH:mm:ss\\\"));\\n                if (\\\"ok\\\".equals(MapUtils.getString(result, \\\"checkResult\\\"))) {\\n                    okRuleCnt++;\\n                } else if (\\\"error\\\".equals(MapUtils.getString(result, \\\"checkResult\\\"))) {\\n                    errRuleCnt++;\\n                } else if (\\\"warning\\\".equals(MapUtils.getString(result, \\\"checkResult\\\"))) {\\n                    warningRuleCnt++;\\n                }\\n\\n            } catch (Exception e) {\\n                // LOG.error(e.getMessage(), e);\\n                result.put(\\\"checkResult\\\", \\\"exception\\\");\\n                String realVal \u003d MapUtils.getString(result, \\\"realVal\\\");\\n                if (realVal !\u003d null) {\\n                    if (realVal.length() \u003c 800) {\\n                        result.put(\\\"realVal\\\", realVal);\\n                    } else {\\n                        result.put(\\\"realVal\\\", realVal.substring(0, 800) + \\\"...\\\");\\n                    }\\n                }\\n\\n                result.put(\\\"checkDescr\\\", \\\"检查时发生异常:\\\" + e.getMessage());\\n                result.put(\\\"checkTime\\\", getCurrentDate(\\\"yyyy-MM-dd HH:mm:ss\\\"));\\n                excepRuleCnt++;\\n            }\\n\\n            results.add(result);\\n        }\\n        if (dqRules !\u003d null \u0026\u0026 dqRules.size() \u003e 0) {\\n            sum.put(\\\"opTime\\\", opTime);\\n            sum.putAll(dqRules.get(0));\\n            sum.put(\\\"dsLabel\\\", MapUtils.getString(meta, \\\"dsLabel\\\"));\\n            sum.put(\\\"objId\\\", MapUtils.getString(idMeta, \\\"value\\\"));\\n            sum.put(\\\"objName\\\", MapUtils.getString(nameMeta, \\\"value\\\"));\\n            sum.put(\\\"objLabel\\\", MapUtils.getString(labelMeta, \\\"value\\\"));\\n            if (meta.get(\\\"pId\\\") !\u003d null) {\\n                Map\u003cString, Object\u003e pIdMeta \u003d (Map\u003cString, Object\u003e) meta.get(\\\"pId\\\");\\n                sum.put(\\\"pObjId\\\", MapUtils.getString(pIdMeta, \\\"value\\\"));\\n            }\\n            if (meta.get(\\\"pName\\\") !\u003d null) {\\n                Map\u003cString, Object\u003e pNameMeta \u003d (Map\u003cString, Object\u003e) meta.get(\\\"pName\\\");\\n                sum.put(\\\"pObjName\\\", MapUtils.getString(pNameMeta, \\\"value\\\"));\\n            }\\n            if (meta.get(\\\"pLabel\\\") !\u003d null) {\\n                Map\u003cString, Object\u003e pLabelMeta \u003d (Map\u003cString, Object\u003e) meta.get(\\\"pLabel\\\");\\n                sum.put(\\\"pObjLabel\\\", MapUtils.getString(pLabelMeta, \\\"value\\\"));\\n            }\\n            sum.put(\\\"useRuleCnt\\\", dqRules.size());\\n            sum.put(\\\"okRuleCnt\\\", okRuleCnt);\\n            sum.put(\\\"errRuleCnt\\\", errRuleCnt);\\n            sum.put(\\\"excepRuleCnt\\\", excepRuleCnt);\\n            String sumCheckResult \u003d \\\"\\\";\\n            if (MapUtils.getIntValue(sum, \\\"useRuleCnt\\\") \u003d\u003d MapUtils.getIntValue(sum, \\\"okRuleCnt\\\")) {\\n                sumCheckResult \u003d \\\"OK\\\";\\n            } else if (errRuleCnt \u003e 0 || excepRuleCnt \u003e 0) {\\n                sumCheckResult \u003d \\\"ERROR\\\";\\n            } else if (warningRuleCnt \u003e 0) {\\n                sumCheckResult \u003d \\\"WARNING\\\";\\n            } else {\\n                sumCheckResult \u003d \\\"ERROR\\\";\\n            }\\n            sum.put(\\\"checkResult\\\", sumCheckResult);\\n        }\\n        returnResult.put(\\\"sum\\\", sum);\\n        returnResult.put(\\\"dtl\\\", results);\\n        return returnResult;\\n    }\\n\\n    private List\u003cMap\u003cString, Object\u003e\u003e getCheckRules(String objType, String workspaceId) {\\n        String selectSql \u003d \\\" select id,rule_name ruleName,obj_type objType,rule_sub_type ruleSubType,func_para funcPara,func_code funcCode from model_dev_rule where workspace_id \u003d :workspaceId and obj_type \u003d :objType and state \u003d 1 \\\";\\n\\t\\tMap\u003cString, Object\u003e params \u003d new HashMap\u003c\u003e();\\n        params.workspaceId \u003d workspaceId;\\n        params.objType \u003d objType;\\n\\t\\tList\u003cMap\u003cString,Object\u003e\u003e checkRules \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate().queryForList(selectSql,params);\\n        return checkRules;\\n    }\\n\\n    private String getCurrentDate(String format) {\\n        SimpleDateFormat sdf \u003d new SimpleDateFormat(format, Locale.SIMPLIFIED_CHINESE);\\n        return sdf.format(GregorianCalendar.getInstance().getTime());\\n    }\\n\\n    public void preCheckResult(Map\u003cString, Object\u003e meta, Map\u003cString, Object\u003e result) throws Exception {\\n        Map\u003cString, String\u003e funcParasMap \u003d parseFuncPara(MapUtils.getString(result, \\\"funcPara\\\"));\\n        String comparaType \u003d funcParasMap.get(\\\"comparaType\\\");\\n        if (comparaType.equals(\\\"meta-obj\\\")) {\\n            getMeta(meta, result);\\n        } else if (comparaType.equals(\\\"data-sql\\\")) {\\n            getData(meta, result);\\n        }\\n    }\\n\\n    public void getData(Map\u003cString, Object\u003e meta, Map\u003cString, Object\u003e result) throws Exception {\\n        Map\u003cString, String\u003e funcParasMap \u003d parseFuncPara(MapUtils.getString(result, \\\"funcPara\\\"));\\n\\n        String[] paras \u003d funcParasMap.get(\\\"comparaName\\\").split(\\\";\\\");\\n        //sql样例:select count(1) as VAL1 from proc where proc_name \u003d \u0027\\\\${\u0026name.value}\u0027 or proccnname \u003d \u0027\\\\${\u0026name.value}\u0027\\n        String sql \u003d paras[0];\\n        Set\u003cString\u003e replaceSet \u003d new HashSet\u003cString\u003e();\\n        Pattern p \u003d Pattern.compile(\\\"\\\\\\\\\\\\$\\\\\\\\{([^\\\\\\\\}]*)\\\\\\\\}\\\");\\n        Matcher m \u003d p.matcher(sql);\\n        while (m.find()) {\\n            replaceSet.add(m.group());\\n        }\\n        for (String s : replaceSet) {\\n            String keyWord \u003d s.replaceAll(\\\"(\\\\\\\\\\\\$|\\\\\\\\{|\\\\\\\\})\\\", \\\"\\\");\\n            String repExp \u003d \\\"\\\\\\\\\\\\$\\\\\\\\{\\\" + keyWord + \\\"\\\\\\\\}\\\";\\n            sql \u003d sql.replaceAll(repExp, Matcher.quoteReplacement((parseObjectToString(getRealValByMetaAndPara(keyWord, meta)))));\\n        }\\n        JdbcTemplate jdbc \u003d SpringJdbcUtil.getJdbcTemplate();\\n        List\u003cMap\u003cString, Object\u003e\u003e realDataList \u003d jdbc.queryForList(sql);\\n\\n        boolean oneRowOneColFlag \u003d false;\\n        String oneRowOneColValue \u003d \\\"\\\";\\n        if (realDataList !\u003d null \u0026\u0026 realDataList.size() \u003e\u003d 0) {\\n            if (realDataList.size() \u003d\u003d 1) {\\n                Map\u003cString, Object\u003e map \u003d realDataList.get(0);\\n                if (map.size() \u003d\u003d 1) {\\n                    oneRowOneColFlag \u003d true;\\n                    oneRowOneColValue \u003d map.get(\\\"VAL1\\\").toString();\\n                }\\n            }\\n        } else {\\n            oneRowOneColFlag \u003d true;\\n            oneRowOneColValue \u003d \\\"\\\";\\n        }\\n\\n        if (oneRowOneColFlag) {\\n            result.put(\\\"realVal\\\", oneRowOneColValue);\\n        } else {\\n            result.put(\\\"realVal\\\", JsonUtil.getInstance().write(realDataList));\\n        }\\n\\n    }\\n\\n    public Map\u003cString, String\u003e parseFuncPara(String funcPara) {\\n        return JsonUtil.getInstance().read(funcPara, new TypeReference\u003cHashMap\u003cString, String\u003e\u003e() {\\n        });\\n    }\\n\\n    public void getMeta(Map\u003cString, Object\u003e meta, Map\u003cString, Object\u003e result) throws Exception {\\n        Map\u003cString, String\u003e funcParasMap \u003d parseFuncPara(MapUtils.getString(result, \\\"funcPara\\\"));\\n        String paraName \u003d funcParasMap.get(\\\"comparaName\\\");\\n        String realVal \u003d \\\"\\\";\\n        Object obj \u003d getRealValByMetaAndPara(paraName, meta);\\n        if (obj \u003d\u003d null) {\\n            realVal \u003d \\\"\\\";\\n        } else {\\n            if (obj instanceof String) {\\n                realVal \u003d (String) obj;\\n            } else {\\n                realVal \u003d JsonUtil.getInstance().write(obj);\\n            }\\n        }\\n        result.put(\\\"realVal\\\", realVal);\\n    }\\n\\n    public static Object getRealValByMetaAndPara(String paraName, Map\u003cString, Object\u003e meta) throws Exception {\\n        Object obj \u003d null;\\n        String memberName \u003d paraName.replace(\\\"\u0026\\\", \\\"\\\").split(\\\"\\\\\\\\.\\\")[0];\\n        Map\u003cString, Object\u003e member \u003d (Map\u003cString, Object\u003e) meta.get(memberName);\\n        if(member !\u003d null){\\n            String memAttrName \u003d paraName.replace(\\\"\u0026\\\", \\\"\\\").split(\\\"\\\\\\\\.\\\")[1];\\n            obj \u003d member.get(memAttrName)\\n        }\\n        return obj;\\n    }\\n\\n    private String parseObjectToString(Object o) {\\n        return o \u003d\u003d null ? \\\"\\\" : String.valueOf(o);\\n    }\\n\\n\\n\"}",
      "createUser": "xiacj3",
      "appName": "dataps",
      "stepConfigMap": {
        "label": "2.执行脚本",
        "scriptText": "import com.asiainfo.modo.datago.CheckFuncHelper;\nimport com.asiainfo.modo.datago.CheckFuncHelperForProcScript;\nimport io.github.suanchou.utils.SpringContextUtil;\n\nimport com.fasterxml.jackson.core.type.TypeReference;\nimport io.github.suanchou.utils.JsonUtil;\nimport io.github.suanchou.utils.SpringJdbcUtil;\nimport io.github.suanchou.utils.StringUtil;\nimport org.apache.commons.collections.MapUtils;\nimport org.apache.commons.lang3.StringUtils;\nimport org.slf4j.Logger;\nimport org.slf4j.LoggerFactory;\nimport org.springframework.jdbc.core.JdbcTemplate;\n\nimport java.lang.reflect.Method;\nimport java.text.SimpleDateFormat;\nimport java.util.*;\nimport java.util.regex.Matcher;\nimport java.util.regex.Pattern;\n\nSystem.out.println(body);\n// DatagoDevQualityCheckService serv \u003d SpringContextUtil.getBean(DatagoDevQualityCheckService.class);\n// return serv.checkModel(body);\n\n        Map\u003cString, Object\u003e proc \u003d body;\n\n        System.out.println(\"----------------\");\n        Map\u003cString, Object\u003e result \u003d new HashMap\u003c\u003e();\n        List\u003cMap\u003cString, Object\u003e\u003e dqRules \u003d getCheckRules(\"PROC\", \"1\");\n        Map\u003cString, Object\u003e procMeta \u003d getProcMeta(proc);\n        result \u003d doDevCheckItemNotToDb(proc, dqRules, procMeta);\n        \n        return result;\n\n\n\n    private Map\u003cString, Object\u003e getProcMeta(Map\u003cString, Object\u003e proc) {\n        Map\u003cString, Object\u003e metaMap \u003d proc;\n\n        Map\u003cString, Object\u003e meta \u003d new HashMap\u003c\u003e();\n\n        String idVal \u003d parseObjectToString(metaMap.get(\"id\"));\n        Map\u003cString, Object\u003e idMem \u003d new HashMap\u003c\u003e();\n        idMem.put(\"name\",\"id\");\n        idMem.put(\"value\",idVal);\n        idMem.put(\"length\",idVal.length());\n        meta.put(\"id\",idMem);\n\n        String name \u003d parseObjectToString(metaMap.get(\"name\"));\n        Map\u003cString, Object\u003e nameMem \u003d new HashMap\u003c\u003e();\n        nameMem.put(\"name\",\"name\");\n        nameMem.put(\"value\",name);\n        nameMem.put(\"length\",name.length());\n        meta.put(\"name\",nameMem);\n\n        String label \u003d parseObjectToString(metaMap.get(\"label\"));\n        Map\u003cString, Object\u003e labelMem \u003d new HashMap\u003c\u003e();\n        labelMem.put(\"name\",\"label\");\n        labelMem.put(\"value\",label);\n        labelMem.put(\"length\",label.length());\n        meta.put(\"label\",labelMem);\n\n        String cycle \u003d parseObjectToString(metaMap.get(\"procCycle\"));\n        Map\u003cString, Object\u003e cycleMem \u003d new HashMap\u003c\u003e();\n        cycleMem.put(\"name\",\"cycle\");\n        cycleMem.put(\"value\",cycle);\n        cycleMem.put(\"length\",cycle.length());\n        meta.put(\"cycle\",cycleMem);\n\n\t\tString procType \u003d parseObjectToString(metaMap.get(\"procType\"));\n\t\tMap\u003cString, Object\u003e procTypeMem \u003d new HashMap\u003c\u003e();\n\t\tprocTypeMem.put(\"name\",\"procType\");\n        procTypeMem.put(\"value\",procType);\n        procTypeMem.put(\"length\",procType.length());\n\t\tmeta.put(\"procType\",procTypeMem);\n\t\t// List\u003cMap\u003cString,Object\u003e\u003e steps \u003d jdbc.queryForList(stepSql);\n        List\u003cMap\u003cString,Object\u003e\u003e steps \u003d (List\u003cMap\u003cString, Object\u003e\u003e) metaMap.get(\"steps\");\n        if(steps \u003d\u003d null){\n            steps \u003d new ArrayList\u003c\u003e();\n        }\n\t\tMap\u003cString,Object\u003e scriptSteps \u003d new HashMap\u003c\u003e();\n\t\tMap\u003cString, Object\u003e stepMem \u003d new HashMap\u003c\u003e();\n\t\tstepMem.put(\"name\",\"steps\");\t\t\n\t\tif(\"METAPROC\".equals(procType)) {\n\t\t\tstepMem.put(\"value\",steps);\n\t\t\tstepMem.put(\"length\",steps.size());\n\t\t} else {\n\t\t\tString procScriptType \u003d parseObjectToString(metaMap.get(\"procScriptType\"));\n\t\t\tString graph \u003d  parseObjectToString(metaMap.get(\"graph\"));\n\t\t\tscriptSteps.put(\"procType\",procType);\n\t\t\tscriptSteps.put(\"procScriptType\", procScriptType);\n\t\t\tscriptSteps.put(\"steps\", graph);\n\t\t\tstepMem.put(\"value\",scriptSteps);\n\t\t\tstepMem.put(\"length\",StringUtils.isNotBlank(graph)?1:0);\n\t\t}\n\n        meta.put(\"steps\",stepMem);\n        List\u003cString\u003e sourceTabs \u003d new ArrayList\u003cString\u003e();\n        List\u003cString\u003e targetTabs \u003d new ArrayList\u003cString\u003e();\n\n        String extendCfg \u003d parseObjectToString(metaMap.get(\"extendCfg\"));       \n        if (StringUtils.isNotBlank(extendCfg)) {\n            try {\n                // 直接查询程序配置的输入和输出表\n                //{\"inPutTab\":\"CMCMHQBASSTB1900000024;\",\"outPutTab\":\"CMCMHQBASSTB1900000115;CMCMHQBASSTB1900000116;\"}\n                Map\u003cString, String\u003e extendCfgMap \u003d (Map\u003cString, String\u003e) JsonUtil.getInstance().read(extendCfg);\n                String inPutTabs \u003d extendCfgMap.get(\"inPutTab\");\n                String outPutTabs \u003d extendCfgMap.get(\"outPutTab\");\n                if (StringUtils.isNotBlank(inPutTabs)) {\n                    String[] inPutTabA \u003d inPutTabs.split(\";\");\n                    for (String s : inPutTabA) {\n                        if (StringUtils.isNotBlank(s)) {\n                            sourceTabs.add(s);\n                        }\n                    }\n                }\n                if (StringUtils.isNotBlank(outPutTabs)) {\n                    String[] outPutTabA \u003d outPutTabs.split(\";\");\n                    for (String s : outPutTabA) {\n                        if (StringUtils.isNotBlank(s)) {\n                            targetTabs.add(s);\n                        }\n                    }\n                }\n\n            } catch (Exception e) {\n                LOG.error(e.getMessage(), e);\n            }\n\n        }\n        \n        Map\u003cString,Object\u003e sourceTabsMem \u003d new HashMap\u003c\u003e();\n        sourceTabsMem.put(\"name\",\"sourceTabs\");\n        sourceTabsMem.put(\"value\",sourceTabs);\n        sourceTabsMem.put(\"length\",sourceTabs.size());\n        meta.put(\"sourceTabs\",sourceTabsMem);\n\n        Map\u003cString,Object\u003e targetTabsMem \u003d new HashMap\u003c\u003e();\n        targetTabsMem.put(\"name\",\"targetTabs\");\n        targetTabsMem.put(\"value\",targetTabs);\n        targetTabsMem.put(\"length\",targetTabs.size());\n        meta.put(\"targetTabs\",targetTabsMem);\n\n\n        //steps\u0026sourceTabs\u0026targetTabs\n        Map\u003cString, Object\u003e stepsAndInOutTabs \u003d new HashMap\u003cString, Object\u003e();\n        if(\"METAPROC\".equals(procType)) {\n\t\t\tstepsAndInOutTabs.put(\"steps\", steps);\n\t\t} else {\n\t\t\tstepsAndInOutTabs.put(\"steps\", scriptSteps);\n\t\t}\n        stepsAndInOutTabs.put(\"sourceTabs\", sourceTabs);\n        stepsAndInOutTabs.put(\"targetTabs\", targetTabs);\n        Map\u003cString,Object\u003e stepsAndInOutTabsMem \u003d new HashMap\u003c\u003e();\n        stepsAndInOutTabsMem.put(\"name\",\"stepsAndInOutTabs\");\n        stepsAndInOutTabsMem.put(\"value\",stepsAndInOutTabs);\n        stepsAndInOutTabsMem.put(\"length\",1);\n        meta.put(\"stepsAndInOutTabs\",stepsAndInOutTabsMem);\n\n        String teamVal \u003d parseObjectToString(metaMap.get(\"teamName\"));\n        Map\u003cString,Object\u003e teamMem \u003d new HashMap\u003c\u003e();\n        teamMem.put(\"name\",\"team\");\n        teamMem.put(\"value\",teamVal);\n        teamMem.put(\"length\",teamVal.length());\n        meta.put(\"team\",teamMem);\n\t\t\n        String teamLabelVal \u003d parseObjectToString(metaMap.get(\"teamLabel\"));\n        Map\u003cString,Object\u003e teamLabelMem \u003d new HashMap\u003c\u003e();\n        teamLabelMem.put(\"name\",\"teamLabel\");\n        teamLabelMem.put(\"value\",teamLabelVal);\n        teamLabelMem.put(\"length\",teamLabelVal.length());\n        meta.put(\"teamLabel\",teamLabelMem);\n\n        String memberVal \u003d parseObjectToString(metaMap.get(\"memberName\"));\n        Map\u003cString,Object\u003e memberMem \u003d new HashMap\u003c\u003e();\n        memberMem.put(\"name\",\"member\");\n        memberMem.put(\"value\",memberVal);\n        memberMem.put(\"length\",memberVal.length());\n        meta.put(\"member\",memberMem);\n\n        String userNameVal \u003d parseObjectToString(metaMap.get(\"user\"));\n        Map\u003cString,Object\u003e userNameMem \u003d new HashMap\u003c\u003e();\n        userNameMem.put(\"name\",\"userName\");\n        userNameMem.put(\"value\",userNameVal);\n        userNameMem.put(\"length\",userNameVal.length());\n        meta.put(\"userName\",userNameMem);\n\n        meta.put(\"state\", MapUtils.getString(metaMap, \"state\"));\n\n        return meta;\n    }\n\n    public Map\u003cString, Object\u003e doDevCheckItemNotToDb(Map\u003cString, Object\u003e obj, List\u003cMap\u003cString, Object\u003e\u003e dqRules, Map\u003cString, Object\u003e meta) {\n         Map\u003cString, Object\u003e returnResult \u003d new HashMap\u003c\u003e();\n        List\u003cMap\u003cString, Object\u003e\u003e results \u003d new ArrayList\u003c\u003e();\n        String opTime \u003d getCurrentDate(\"yyyyMMdd\");\n        Map\u003cString, Object\u003e sum \u003d new HashMap\u003c\u003e();\n        Map\u003cString, Object\u003e idMeta \u003d (Map\u003cString, Object\u003e) meta.get(\"id\");\n        Map\u003cString, Object\u003e nameMeta \u003d (Map\u003cString, Object\u003e) meta.get(\"name\");\n        Map\u003cString, Object\u003e labelMeta \u003d (Map\u003cString, Object\u003e) meta.get(\"label\");\n        sum.put(\"checkResult\", \"OK\");\n        sum.put(\"objName\", MapUtils.getString(nameMeta, \"value\"));\n        sum.put(\"objLabel\", MapUtils.getString(labelMeta, \"value\"));\n        int okRuleCnt \u003d 0;\n        int excepRuleCnt \u003d 0;\n        int errRuleCnt \u003d 0;\n        int warningRuleCnt \u003d 0;\n\n        for (Map\u003cString, Object\u003e dqRule : dqRules) {\n            Map\u003cString, Object\u003e result \u003d new HashMap\u003c\u003e();\n            result.putAll(dqRule);\n            result.put(\"dsLabel\", MapUtils.getString(obj, \"dsLabel\"));\n            result.put(\"id\", StringUtil.nextId());\n            result.put(\"ruleId\", dqRule.get(\"id\"));\n            result.put(\"opTime\", opTime);\n            result.put(\"objId\", MapUtils.getString(idMeta, \"value\"));\n            result.put(\"objName\", MapUtils.getString(nameMeta, \"value\"));\n            result.put(\"objLabel\", MapUtils.getString(labelMeta, \"value\"));\n            try {\n                preCheckResult(meta, result);\n                Map\u003cString, String\u003e funcParasMap \u003d parseFuncPara(MapUtils.getString(result, \"funcPara\"));\n                String funcCode \u003d MapUtils.getString(result, \"funcCode\");\n                String expectVal \u003d funcParasMap.get(\"expectVal\");\n                String realVal \u003d MapUtils.getString(result, \"realVal\");\n                Map\u003cString, Object\u003e msg \u003d null;\n                List\u003cString\u003e procScriptRuleList\u003dArrays.asList(new String[]{\"stepsNotIllegalSql\",\"stepsNotContainSelectA\",\"stepsSpecChar\",\n\t                                 \"stepsTempStartWithTemp\",\"stepsContainTempDrop\",\n\t                                 \"stepsExactDate\",\"stepsOneStepOneSql\",\n\t                                 \"stepsCartesian\",\"stepsHivePartCond\",\n\t                                 \"targetTabConsistency\",\"tempContainTemp\",\"scriptNotContainSpecChar\"});\n                if(\"PROC\".equalsIgnoreCase(dqRule.get(\"objType\")) \u0026\u0026 procScriptRuleList.contains(dqRule.get(\"ruleSubType\"))\n\t\t\t\t\t\t\u0026\u0026 \"taskTypeFunc\".equals(((Map\u003cString,Object\u003e)meta.get(\"procType\")).get(\"value\"))) {\n\t\t\t\t\tmsg \u003d CheckFuncHelperForProcScript.check(realVal, expectVal, funcCode,MapUtils.getString(dqRule, \"objType\"),MapUtils.getString(dqRule, \"ruleSubType\"),MapUtils.getString(dqRule, \"state\"));\n\t\t\t\t} else { \n\t\t\t\t\t msg \u003d CheckFuncHelper.check(realVal, expectVal, funcCode, MapUtils.getString(dqRule, \"objType\"), MapUtils.getString(dqRule, \"ruleSubType\"), obj, MapUtils.getString(dqRule, \"ruleContent\"));\n\t\t\t\t} \n                result.put(\"realVal\", MapUtils.getString(msg, \"realVal\"));\n                String checkResult \u003d MapUtils.getString(msg, \"checkResult\");\n                if (\"ok\".equals(checkResult) \u0026\u0026 \"warning\".equals(MapUtils.getString(msg, \"checkResultLvl\"))) {\n                    result.put(\"checkResult\", \"warning\");\n                } else {\n                    result.put(\"checkResult\", checkResult);\n                }\n\n                result.put(\"checkDescr\", MapUtils.getString(msg, \"checkDescr\"));\n                result.put(\"checkTime\", getCurrentDate(\"yyyy-MM-dd HH:mm:ss\"));\n                if (\"ok\".equals(MapUtils.getString(result, \"checkResult\"))) {\n                    okRuleCnt++;\n                } else if (\"error\".equals(MapUtils.getString(result, \"checkResult\"))) {\n                    errRuleCnt++;\n                } else if (\"warning\".equals(MapUtils.getString(result, \"checkResult\"))) {\n                    warningRuleCnt++;\n                }\n\n            } catch (Exception e) {\n                // LOG.error(e.getMessage(), e);\n                result.put(\"checkResult\", \"exception\");\n                String realVal \u003d MapUtils.getString(result, \"realVal\");\n                if (realVal !\u003d null) {\n                    if (realVal.length() \u003c 800) {\n                        result.put(\"realVal\", realVal);\n                    } else {\n                        result.put(\"realVal\", realVal.substring(0, 800) + \"...\");\n                    }\n                }\n\n                result.put(\"checkDescr\", \"检查时发生异常:\" + e.getMessage());\n                result.put(\"checkTime\", getCurrentDate(\"yyyy-MM-dd HH:mm:ss\"));\n                excepRuleCnt++;\n            }\n\n            results.add(result);\n        }\n        if (dqRules !\u003d null \u0026\u0026 dqRules.size() \u003e 0) {\n            sum.put(\"opTime\", opTime);\n            sum.putAll(dqRules.get(0));\n            sum.put(\"dsLabel\", MapUtils.getString(meta, \"dsLabel\"));\n            sum.put(\"objId\", MapUtils.getString(idMeta, \"value\"));\n            sum.put(\"objName\", MapUtils.getString(nameMeta, \"value\"));\n            sum.put(\"objLabel\", MapUtils.getString(labelMeta, \"value\"));\n            if (meta.get(\"pId\") !\u003d null) {\n                Map\u003cString, Object\u003e pIdMeta \u003d (Map\u003cString, Object\u003e) meta.get(\"pId\");\n                sum.put(\"pObjId\", MapUtils.getString(pIdMeta, \"value\"));\n            }\n            if (meta.get(\"pName\") !\u003d null) {\n                Map\u003cString, Object\u003e pNameMeta \u003d (Map\u003cString, Object\u003e) meta.get(\"pName\");\n                sum.put(\"pObjName\", MapUtils.getString(pNameMeta, \"value\"));\n            }\n            if (meta.get(\"pLabel\") !\u003d null) {\n                Map\u003cString, Object\u003e pLabelMeta \u003d (Map\u003cString, Object\u003e) meta.get(\"pLabel\");\n                sum.put(\"pObjLabel\", MapUtils.getString(pLabelMeta, \"value\"));\n            }\n            sum.put(\"useRuleCnt\", dqRules.size());\n            sum.put(\"okRuleCnt\", okRuleCnt);\n            sum.put(\"errRuleCnt\", errRuleCnt);\n            sum.put(\"excepRuleCnt\", excepRuleCnt);\n            String sumCheckResult \u003d \"\";\n            if (MapUtils.getIntValue(sum, \"useRuleCnt\") \u003d\u003d MapUtils.getIntValue(sum, \"okRuleCnt\")) {\n                sumCheckResult \u003d \"OK\";\n            } else if (errRuleCnt \u003e 0 || excepRuleCnt \u003e 0) {\n                sumCheckResult \u003d \"ERROR\";\n            } else if (warningRuleCnt \u003e 0) {\n                sumCheckResult \u003d \"WARNING\";\n            } else {\n                sumCheckResult \u003d \"ERROR\";\n            }\n            sum.put(\"checkResult\", sumCheckResult);\n        }\n        returnResult.put(\"sum\", sum);\n        returnResult.put(\"dtl\", results);\n        return returnResult;\n    }\n\n    private List\u003cMap\u003cString, Object\u003e\u003e getCheckRules(String objType, String workspaceId) {\n        String selectSql \u003d \" select id,rule_name ruleName,obj_type objType,rule_sub_type ruleSubType,func_para funcPara,func_code funcCode from model_dev_rule where workspace_id \u003d :workspaceId and obj_type \u003d :objType and state \u003d 1 \";\n\t\tMap\u003cString, Object\u003e params \u003d new HashMap\u003c\u003e();\n        params.workspaceId \u003d workspaceId;\n        params.objType \u003d objType;\n\t\tList\u003cMap\u003cString,Object\u003e\u003e checkRules \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate().queryForList(selectSql,params);\n        return checkRules;\n    }\n\n    private String getCurrentDate(String format) {\n        SimpleDateFormat sdf \u003d new SimpleDateFormat(format, Locale.SIMPLIFIED_CHINESE);\n        return sdf.format(GregorianCalendar.getInstance().getTime());\n    }\n\n    public void preCheckResult(Map\u003cString, Object\u003e meta, Map\u003cString, Object\u003e result) throws Exception {\n        Map\u003cString, String\u003e funcParasMap \u003d parseFuncPara(MapUtils.getString(result, \"funcPara\"));\n        String comparaType \u003d funcParasMap.get(\"comparaType\");\n        if (comparaType.equals(\"meta-obj\")) {\n            getMeta(meta, result);\n        } else if (comparaType.equals(\"data-sql\")) {\n            getData(meta, result);\n        }\n    }\n\n    public void getData(Map\u003cString, Object\u003e meta, Map\u003cString, Object\u003e result) throws Exception {\n        Map\u003cString, String\u003e funcParasMap \u003d parseFuncPara(MapUtils.getString(result, \"funcPara\"));\n\n        String[] paras \u003d funcParasMap.get(\"comparaName\").split(\";\");\n        //sql样例:select count(1) as VAL1 from proc where proc_name \u003d \u0027\\${\u0026name.value}\u0027 or proccnname \u003d \u0027\\${\u0026name.value}\u0027\n        String sql \u003d paras[0];\n        Set\u003cString\u003e replaceSet \u003d new HashSet\u003cString\u003e();\n        Pattern p \u003d Pattern.compile(\"\\\\\\$\\\\{([^\\\\}]*)\\\\}\");\n        Matcher m \u003d p.matcher(sql);\n        while (m.find()) {\n            replaceSet.add(m.group());\n        }\n        for (String s : replaceSet) {\n            String keyWord \u003d s.replaceAll(\"(\\\\\\$|\\\\{|\\\\})\", \"\");\n            String repExp \u003d \"\\\\\\$\\\\{\" + keyWord + \"\\\\}\";\n            sql \u003d sql.replaceAll(repExp, Matcher.quoteReplacement((parseObjectToString(getRealValByMetaAndPara(keyWord, meta)))));\n        }\n        JdbcTemplate jdbc \u003d SpringJdbcUtil.getJdbcTemplate();\n        List\u003cMap\u003cString, Object\u003e\u003e realDataList \u003d jdbc.queryForList(sql);\n\n        boolean oneRowOneColFlag \u003d false;\n        String oneRowOneColValue \u003d \"\";\n        if (realDataList !\u003d null \u0026\u0026 realDataList.size() \u003e\u003d 0) {\n            if (realDataList.size() \u003d\u003d 1) {\n                Map\u003cString, Object\u003e map \u003d realDataList.get(0);\n                if (map.size() \u003d\u003d 1) {\n                    oneRowOneColFlag \u003d true;\n                    oneRowOneColValue \u003d map.get(\"VAL1\").toString();\n                }\n            }\n        } else {\n            oneRowOneColFlag \u003d true;\n            oneRowOneColValue \u003d \"\";\n        }\n\n        if (oneRowOneColFlag) {\n            result.put(\"realVal\", oneRowOneColValue);\n        } else {\n            result.put(\"realVal\", JsonUtil.getInstance().write(realDataList));\n        }\n\n    }\n\n    public Map\u003cString, String\u003e parseFuncPara(String funcPara) {\n        return JsonUtil.getInstance().read(funcPara, new TypeReference\u003cHashMap\u003cString, String\u003e\u003e() {\n        });\n    }\n\n    public void getMeta(Map\u003cString, Object\u003e meta, Map\u003cString, Object\u003e result) throws Exception {\n        Map\u003cString, String\u003e funcParasMap \u003d parseFuncPara(MapUtils.getString(result, \"funcPara\"));\n        String paraName \u003d funcParasMap.get(\"comparaName\");\n        String realVal \u003d \"\";\n        Object obj \u003d getRealValByMetaAndPara(paraName, meta);\n        if (obj \u003d\u003d null) {\n            realVal \u003d \"\";\n        } else {\n            if (obj instanceof String) {\n                realVal \u003d (String) obj;\n            } else {\n                realVal \u003d JsonUtil.getInstance().write(obj);\n            }\n        }\n        result.put(\"realVal\", realVal);\n    }\n\n    public static Object getRealValByMetaAndPara(String paraName, Map\u003cString, Object\u003e meta) throws Exception {\n        Object obj \u003d null;\n        String memberName \u003d paraName.replace(\"\u0026\", \"\").split(\"\\\\.\")[0];\n        Map\u003cString, Object\u003e member \u003d (Map\u003cString, Object\u003e) meta.get(memberName);\n        if(member !\u003d null){\n            String memAttrName \u003d paraName.replace(\"\u0026\", \"\").split(\"\\\\.\")[1];\n            obj \u003d member.get(memAttrName)\n        }\n        return obj;\n    }\n\n    private String parseObjectToString(Object o) {\n        return o \u003d\u003d null ? \"\" : String.valueOf(o);\n    }\n\n\n"
      }
    }
  ]
}