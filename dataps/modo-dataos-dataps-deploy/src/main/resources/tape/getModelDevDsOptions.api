      "failStepId": "-1",
      "completeStepId": "-1",
      "stepConfig": "{\"scriptText\":\"import com.asiainfo.modo.dataps.DatapsHumpHelper;\\nimport io.github.suanchou.utils.SpringJdbcUtil;\\nimport org.apache.commons.collections.MapUtils;\\nimport org.springframework.jdbc.core.namedparam.NamedParameterJdbcTemplate;\\n\\nimport java.util.ArrayList;\\nimport java.util.List;\\nimport java.util.Map;\\n\\n\\n\\n    public Object getDsTypes(Map\u003cString, Object\u003e params) {\\n        NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\\n        List\u003cString\u003e dsTypes \u003d new ArrayList\u003c\u003e();\\n        jt.queryForList(\\\"select name from dataps_sys_enums_def where name like \u0027%FieldDataType\u0027\\\", params).forEach(map -\u003e {\\n            String name \u003d MapUtils.getString(map, \\\"name\\\");\\n            dsTypes.add(name.substring(0, name.indexOf(\\\"FieldDataType\\\")));\\n        });\\n        return dsTypes;\\n    }\\n    \\n    public Object checkDevProSchemaGroup(Map\u003cString, Object\u003e params) {\\n        NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\\n        List\u003cString\u003e dsTypes \u003d new ArrayList\u003c\u003e();\\n        List\u003cMap\u003cString, Object\u003e\u003e list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\\\"select prop_label from dacp_meta_property where prop_name\u003d\u0027devProSchemaGroup\u0027\\\", params));\\n        String devProSchemaGroup \u003d \\\"1\\\";\\n        for (Map\u003cString, Object\u003e map : list) {\\n            devProSchemaGroup \u003d MapUtils.getString(map, \\\"propLabel\\\");\\n        }\\n        return devProSchemaGroup;\\n    }\\n\\ntargetDsTypes \u003d getDsTypes(params);\\ndevProSchemaGroup \u003d checkDevProSchemaGroup(params);\",\"label\":\"2.执行脚本\"}",
      "appName": "dataps",
      "stepConfigMap": {
        "scriptText": "import com.asiainfo.modo.dataps.DatapsHumpHelper;\nimport io.github.suanchou.utils.SpringJdbcUtil;\nimport org.apache.commons.collections.MapUtils;\nimport org.springframework.jdbc.core.namedparam.NamedParameterJdbcTemplate;\n\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Map;\n\n\n\n    public Object getDsTypes(Map\u003cString, Object\u003e params) {\n        NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\n        List\u003cString\u003e dsTypes \u003d new ArrayList\u003c\u003e();\n        jt.queryForList(\"select name from dataps_sys_enums_def where name like \u0027%FieldDataType\u0027\", params).forEach(map -\u003e {\n            String name \u003d MapUtils.getString(map, \"name\");\n            dsTypes.add(name.substring(0, name.indexOf(\"FieldDataType\")));\n        });\n        return dsTypes;\n    }\n    \n    public Object checkDevProSchemaGroup(Map\u003cString, Object\u003e params) {\n        NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\n        List\u003cString\u003e dsTypes \u003d new ArrayList\u003c\u003e();\n        List\u003cMap\u003cString, Object\u003e\u003e list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\"select prop_label from dacp_meta_property where prop_name\u003d\u0027devProSchemaGroup\u0027\", params));\n        String devProSchemaGroup \u003d \"1\";\n        for (Map\u003cString, Object\u003e map : list) {\n            devProSchemaGroup \u003d MapUtils.getString(map, \"propLabel\");\n        }\n        return devProSchemaGroup;\n    }\n\ntargetDsTypes \u003d getDsTypes(params);\ndevProSchemaGroup \u003d checkDevProSchemaGroup(params);",
