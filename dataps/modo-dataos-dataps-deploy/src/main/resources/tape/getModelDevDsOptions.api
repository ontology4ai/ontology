      "nextStepId": "-1",
      "successStepId": "-1",
      "failStepId": "-1",
      "completeStepId": "-1",
      "stepConfig": "{\"label\":\"5.执行脚本\",\"scriptText\":\"import java.util.*;\\nimport io.github.suanchou.utils.SpringJdbcUtil;\\nimport org.apache.commons.lang3.StringUtils;\\nimport io.github.suanchou.utils.SpringContextUtil;\\nimport org.apache.commons.collections.MapUtils;\\nimport io.github.suanchou.utils.JsonUtil;\\nimport io.github.suanchou.utils.StringUtil;\\nimport java.text.SimpleDateFormat;\\nimport java.util.stream.Collectors;\\nimport com.asiainfo.modo.dataps.DatapsHumpHelper;\\nimport io.github.suanchou.utils.SpringJdbcUtil;\\nimport org.apache.commons.collections.MapUtils;\\nimport org.springframework.jdbc.core.namedparam.NamedParameterJdbcTemplate;\\n\\nimport java.util.ArrayList;\\nimport java.util.HashMap;\\nimport java.util.List;\\nimport java.util.Map;\\nimport java.util.stream.Collectors;\\n\\npublic Object getDss(List\u003cString\u003e dsNames, Map\u003cString, Object\u003e params) {\\n    String workspaceId \u003d MapUtils.getString(params, \\\"workspaceId\\\");\\n    String teamName \u003d getWorkspaceTeamName(workspaceId);\\n    params.put(\\\"teamName\\\", teamName);\\n    params.put(\\\"dsNames\\\", dsNames);\\n    NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\\n    List\u003cMap\u003cString, Object\u003e\u003e list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\\\"select ds.ds_category,td.ds_conf,td.ds_schema,ds.ds_type,ds.ds_version,ds.ds_label label,ds.ds_name name from modo_team_ds td left join modo_datasource ds on td.ds_name\u003dds.ds_name where team_name\u003d:teamName and ds.ds_name in (:dsNames) and td.ds_profile\u003d\u0027pro\u0027\\\", params));\\n    return list;\\n}\\n\\nprivate String getWorkspaceTeamName(String workspaceId) {\\n    NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\\n    Map\u003cString, Object\u003e params \u003d new HashMap\u003c\u003e();\\n    params.put(\\\"id\\\", workspaceId);\\n    List\u003cMap\u003cString, Object\u003e\u003e list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\\\"select team_name from dataos_platform_workspace where id\u003d:id\\\", params));\\n    String teamName \u003d null;\\n    for (Map\u003cString, Object\u003e map : list) {\\n        teamName \u003d MapUtils.getString(map, \\\"teamName\\\");\\n    }\\n    return teamName;\\n}\\n\\nreturn result.data.stream().filter(ds-\u003e{\\n    String dsType \u003d MapUtils.getString(ds, \\\"dsType\\\");\\n    return targetDsTypes.contains(dsType);\\n}).collect(Collectors.toList());\\n\"}",
      "appName": "dataps",
      "stepConfigMap": {
        "label": "5.执行脚本",
        "scriptText": "import java.util.*;\nimport io.github.suanchou.utils.SpringJdbcUtil;\nimport org.apache.commons.lang3.StringUtils;\nimport io.github.suanchou.utils.SpringContextUtil;\nimport org.apache.commons.collections.MapUtils;\nimport io.github.suanchou.utils.JsonUtil;\nimport io.github.suanchou.utils.StringUtil;\nimport java.text.SimpleDateFormat;\nimport java.util.stream.Collectors;\nimport com.asiainfo.modo.dataps.DatapsHumpHelper;\nimport io.github.suanchou.utils.SpringJdbcUtil;\nimport org.apache.commons.collections.MapUtils;\nimport org.springframework.jdbc.core.namedparam.NamedParameterJdbcTemplate;\n\nimport java.util.ArrayList;\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.stream.Collectors;\n\npublic Object getDss(List\u003cString\u003e dsNames, Map\u003cString, Object\u003e params) {\n    String workspaceId \u003d MapUtils.getString(params, \"workspaceId\");\n    String teamName \u003d getWorkspaceTeamName(workspaceId);\n    params.put(\"teamName\", teamName);\n    params.put(\"dsNames\", dsNames);\n    NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\n    List\u003cMap\u003cString, Object\u003e\u003e list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\"select ds.ds_category,td.ds_conf,td.ds_schema,ds.ds_type,ds.ds_version,ds.ds_label label,ds.ds_name name from modo_team_ds td left join modo_datasource ds on td.ds_name\u003dds.ds_name where team_name\u003d:teamName and ds.ds_name in (:dsNames) and td.ds_profile\u003d\u0027pro\u0027\", params));\n    return list;\n}\n\nprivate String getWorkspaceTeamName(String workspaceId) {\n    NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\n    Map\u003cString, Object\u003e params \u003d new HashMap\u003c\u003e();\n    params.put(\"id\", workspaceId);\n    List\u003cMap\u003cString, Object\u003e\u003e list \u003d DatapsHumpHelper.lineToHump(jt.queryForList(\"select team_name from dataos_platform_workspace where id\u003d:id\", params));\n    String teamName \u003d null;\n    for (Map\u003cString, Object\u003e map : list) {\n        teamName \u003d MapUtils.getString(map, \"teamName\");\n    }\n    return teamName;\n}\n\nreturn result.data.stream().filter(ds-\u003e{\n    String dsType \u003d MapUtils.getString(ds, \"dsType\");\n    return targetDsTypes.contains(dsType);\n}).collect(Collectors.toList());\n"
      }
