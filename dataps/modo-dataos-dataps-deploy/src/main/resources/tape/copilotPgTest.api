        "label": "2.执行脚本",
        "scriptText": "import java.util.*;\nimport io.github.suanchou.utils.SpringJdbcUtil;\nimport org.apache.commons.lang3.StringUtils;\nimport io.github.suanchou.utils.SpringContextUtil;\nimport org.apache.commons.collections.MapUtils;\nimport io.github.suanchou.utils.JsonUtil;\nimport org.springframework.http.HttpEntity;\nimport org.springframework.http.HttpHeaders;\nimport org.springframework.http.MediaType;\nimport org.springframework.web.client.RestTemplate;\n\nString pgType \u003d MapUtils.getString(body, \"pgType\");\nString url \u003d \"\";\nswitch (pgType) {\n    case \"sqlcompletionsql\":\n        url \u003d \"http://dataps-fengwen.modo.asiainfo.com.cn/dataps/api/open/sql/\" + pgType;\n        break;\n    case \"sqlexplain\":\n        url \u003d \"http://dataps-fengwen.modo.asiainfo.com.cn/dataps/api/open/sql/\" + pgType;\n        break;\n    case \"sqlrevise\":\n        url \u003d \"http://dataps-fengwen.modo.asiainfo.com.cn/dataps/api/open/sql/\" + pgType;\n        break;\n    case \"sqloptimize\":\n        url \u003d \"http://dataps-fengwen.modo.asiainfo.com.cn/dataps/api/open/sql/\" + pgType;\n        break;\n    case \"sqlannotition\":\n        url \u003d \"http://dataps-fengwen.modo.asiainfo.com.cn/dataps/api/open/sql/\" + pgType;\n        break;\n    case \"proc_explain\":\n        url \u003d \"http://dataps-fengwen.modo.asiainfo.com.cn/dataps/api/open/proc/\" + pgType;\n        break;\n}\n\nRestTemplate restTemplate \u003d new RestTemplate();\nHttpHeaders headers \u003d new HttpHeaders();\nheaders.setContentType(MediaType.APPLICATION_JSON);\n\nMap reqBody \u003d new HashMap();\nreqBody.put(\"model\", \"yi-34b-chat-int4\");\nreqBody.put(\"name\", \"数据开发 SQL纠错 v2\");\nreqBody.put(\"meta_db\", \"Data0s副驾\");\nreqBody.put(\"question\", \"select * from test1\");\nHttpEntity\u003cObject\u003e entity \u003d new HttpEntity\u003c\u003e(reqBody, headers);\n\nObject result \u003d restTemplate.postForObject(url, entity, Object.class);\n\nreturn result;\n\n"
