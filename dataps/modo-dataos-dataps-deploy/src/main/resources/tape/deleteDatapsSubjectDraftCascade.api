      "preStepId": "-1",
      "nextStepId": "-1",
      "successStepId": "-1",
      "failStepId": "-1",
      "completeStepId": "-1",
      "stepConfig": "{\"label\":\"2.执行脚本\",\"scriptText\":\"import java.util.*;\\nimport io.github.suanchou.utils.SpringJdbcUtil;\\nimport org.apache.commons.lang3.StringUtils;\\nimport io.github.suanchou.utils.SpringContextUtil;\\nimport org.apache.commons.collections.MapUtils;\\nimport io.github.suanchou.utils.JsonUtil;\\nimport io.github.suanchou.driver.repo.AbstractRepository;\\nimport org.apache.commons.collections.map.HashedMap;\\nimport org.springframework.jdbc.core.namedparam.NamedParameterJdbcTemplate;\\nimport org.springframework.transaction.PlatformTransactionManager;\\nimport org.springframework.transaction.TransactionStatus;\\nimport org.springframework.transaction.support.DefaultTransactionDefinition;\\n\\n    public Object deleteDatapsSubjectDraftCascade(Map\u003cString, Object\u003e params) {\\n        String subjectId \u003d MapUtils.getString(params, \\\"subjectId\\\");\\n        Objects.requireNonNull(subjectId, \\\"subjectId不能为空！\\\");\\n        String workspaceId \u003d MapUtils.getString(params, \\\"workspaceId\\\");\\n        Objects.requireNonNull(workspaceId, \\\"workspaceId不能为空！\\\");\\n\\n        PlatformTransactionManager txManager \u003d (PlatformTransactionManager) SpringContextUtil.getBean(\\\"transactionManager\\\");\\n        DefaultTransactionDefinition deff \u003d new DefaultTransactionDefinition();\\n        TransactionStatus transactionStatus \u003d txManager.getTransaction(deff);\\n        try {\\n            NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\\n            Map\u003cString, Object\u003e sqlParams \u003d new HashedMap();\\n            sqlParams.put(\\\"subjectId\\\", subjectId);\\n            sqlParams.put(\\\"workspaceId\\\", workspaceId);\\n\\n            // 查询指定工作空间的dataps_subject的当前最新版本号\\n            Integer maxVersionNumber \u003d jt.queryForObject(\\\"select max(version_number) from dataps_subject where workspace_id \u003d :workspaceId\\\", sqlParams, Integer.class);\\n            sqlParams.put(\\\"versionNumber\\\", maxVersionNumber);\\n\\n            // 将草稿表当前工作空间中当前编辑的老编目及其子条目删掉\\n            jt.update(\\\"delete from dataps_subject_draft where subject_id \u003d :subjectId and version_number \u003d :versionNumber\\\", sqlParams);\\n            jt.update(\\\"delete from dataps_subject_item_draft where subject_id \u003d :subjectId and version_number \u003d :versionNumber\\\", sqlParams);\\n\\n            // 将正式表中所编辑的编目及其子条目存到草稿表\\n            jt.update(\\\"insert into dataps_subject_item_draft(item_id, item_descr, item_label, item_name, item_name_abbr, parent_item_id, subject_id, item_seq, version_number) select item_id, item_descr, item_label, item_name, item_name_abbr, parent_item_id, subject_id, item_seq, version_number from dataps_subject_item dsi where dsi.subject_id \u003d :subjectId and dsi.version_number \u003d :versionNumber\\\", sqlParams);\\n            jt.update(\\\"insert into dataps_subject_draft(subject_id, create_dt, create_user, lastupd, subject_descr, subject_label, subject_name, update_user, workspace_id, version_number, state) select subject_id, create_dt, create_user, lastupd, subject_descr, subject_label, subject_name, update_user, workspace_id, version_number, state from dataps_subject where subject_id \u003d :subjectId and version_number \u003d :versionNumber\\\", sqlParams);\\n\\n            // 将正式表中的对应编目状态恢复为1即已发布\\n            jt.update(\\\"update dataps_subject set state \u003d \u00271\u0027 where subject_id \u003d :subjectId and version_number \u003d :versionNumber\\\", sqlParams);\\n\\n            txManager.commit(transactionStatus);\\n        } catch (Exception e) {\\n            txManager.rollback(transactionStatus);\\n            throw new RuntimeException(e);\\n        }\\n        return true;\\n    }\\n\\nreturn deleteDatapsSubjectDraftCascade(params);\\n\"}",
      "createUser": "gaopeng3",
      "appName": "dataps",
      "stepConfigMap": {
        "label": "2.执行脚本",
        "scriptText": "import java.util.*;\nimport io.github.suanchou.utils.SpringJdbcUtil;\nimport org.apache.commons.lang3.StringUtils;\nimport io.github.suanchou.utils.SpringContextUtil;\nimport org.apache.commons.collections.MapUtils;\nimport io.github.suanchou.utils.JsonUtil;\nimport io.github.suanchou.driver.repo.AbstractRepository;\nimport org.apache.commons.collections.map.HashedMap;\nimport org.springframework.jdbc.core.namedparam.NamedParameterJdbcTemplate;\nimport org.springframework.transaction.PlatformTransactionManager;\nimport org.springframework.transaction.TransactionStatus;\nimport org.springframework.transaction.support.DefaultTransactionDefinition;\n\n    public Object deleteDatapsSubjectDraftCascade(Map\u003cString, Object\u003e params) {\n        String subjectId \u003d MapUtils.getString(params, \"subjectId\");\n        Objects.requireNonNull(subjectId, \"subjectId不能为空！\");\n        String workspaceId \u003d MapUtils.getString(params, \"workspaceId\");\n        Objects.requireNonNull(workspaceId, \"workspaceId不能为空！\");\n\n        PlatformTransactionManager txManager \u003d (PlatformTransactionManager) SpringContextUtil.getBean(\"transactionManager\");\n        DefaultTransactionDefinition deff \u003d new DefaultTransactionDefinition();\n        TransactionStatus transactionStatus \u003d txManager.getTransaction(deff);\n        try {\n            NamedParameterJdbcTemplate jt \u003d SpringJdbcUtil.getNamedParameterJdbcTemplate();\n            Map\u003cString, Object\u003e sqlParams \u003d new HashedMap();\n            sqlParams.put(\"subjectId\", subjectId);\n            sqlParams.put(\"workspaceId\", workspaceId);\n\n            // 查询指定工作空间的dataps_subject的当前最新版本号\n            Integer maxVersionNumber \u003d jt.queryForObject(\"select max(version_number) from dataps_subject where workspace_id \u003d :workspaceId\", sqlParams, Integer.class);\n            sqlParams.put(\"versionNumber\", maxVersionNumber);\n\n            // 将草稿表当前工作空间中当前编辑的老编目及其子条目删掉\n            jt.update(\"delete from dataps_subject_draft where subject_id \u003d :subjectId and version_number \u003d :versionNumber\", sqlParams);\n            jt.update(\"delete from dataps_subject_item_draft where subject_id \u003d :subjectId and version_number \u003d :versionNumber\", sqlParams);\n\n            // 将正式表中所编辑的编目及其子条目存到草稿表\n            jt.update(\"insert into dataps_subject_item_draft(item_id, item_descr, item_label, item_name, item_name_abbr, parent_item_id, subject_id, item_seq, version_number) select item_id, item_descr, item_label, item_name, item_name_abbr, parent_item_id, subject_id, item_seq, version_number from dataps_subject_item dsi where dsi.subject_id \u003d :subjectId and dsi.version_number \u003d :versionNumber\", sqlParams);\n            jt.update(\"insert into dataps_subject_draft(subject_id, create_dt, create_user, lastupd, subject_descr, subject_label, subject_name, update_user, workspace_id, version_number, state) select subject_id, create_dt, create_user, lastupd, subject_descr, subject_label, subject_name, update_user, workspace_id, version_number, state from dataps_subject where subject_id \u003d :subjectId and version_number \u003d :versionNumber\", sqlParams);\n\n            // 将正式表中的对应编目状态恢复为1即已发布\n            jt.update(\"update dataps_subject set state \u003d \u00271\u0027 where subject_id \u003d :subjectId and version_number \u003d :versionNumber\", sqlParams);\n\n            txManager.commit(transactionStatus);\n        } catch (Exception e) {\n            txManager.rollback(transactionStatus);\n            throw new RuntimeException(e);\n        }\n        return true;\n    }\n\nreturn deleteDatapsSubjectDraftCascade(params);\n"
      }
    }
  ]
