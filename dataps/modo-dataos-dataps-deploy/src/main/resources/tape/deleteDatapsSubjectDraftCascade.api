  "apiInputParams": "{\"headers\":[],\"query\":[{\"id\":\"7b8ff948-0afa-4eb6-9cf5-d57de30e9e3b\",\"name\":\"subjectId\",\"required\":\"1\",\"example\":\"\",\"desc\":\"\",\"value\":\"174910029886099457\"},{\"id\":\"5727b6d5-1311-430b-9392-62f09922578c\",\"name\":\"workspaceId\",\"required\":\"1\",\"example\":\"\",\"desc\":\"\",\"value\":\"testWorkspaceId\"}]}",
