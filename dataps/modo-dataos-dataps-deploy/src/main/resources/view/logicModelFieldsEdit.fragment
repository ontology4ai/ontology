tasourceMap.getSystemProperty({ name: 'customAppSign' });\\r\\n    if ($this.targetData && $this.targetData.length > 0) {\\r\\n        const targetFields = [];\\r\\n        $this.targetData.forEach(item => {\\r\\n            const targetField = {};\\r\\n            for (var k in $this.srcField) {\\r\\n                if (item.hasOwnProperty(k)) {\\r\\n                    targetField[k] = item[k];\\r\\n                }\\r\\n            }\\r\\n            targetFields.push(targetField);\\r\\n        })\\r\\n        $this.setFormData({ fields: targetFields });\\r\\n    } else {\\r\\n        $this.setFormData({ fields: [_.extend({}, $this.srcField)] });\\r\\n    }\\r\\n    if ($this.parent.formData.extendItems && $this.parent.formData.extendItems.hbaseColumnData) {\\r\\n        const targetColumns = [];\\r\\n        $this.parent.formData.extendItems.hbaseColumnData.forEach(item => {\\r\\n            if (targetColumns.indexOf(item.name) == -1) {\\r\\n                targetColumns.push(item.name);\\r\\n            }\\r\\n        });\\r\\n        const targetOptions = [];\\r\\n        targetColumns.forEach(item => {\\r\\n            targetOptions.push({\\r\\n                label: item,\\r\\n                value: item\\r\\n            });\\r\\n        });\\r\\n        $this.setColumnFamilyOptions(targetOptions);\\r\\n    }\\r\\n}\"}},\"type\":\"one-screen-layout\",\"titleVisible\":false,\"vars\":[{\"name\":\"formData\",\"descr\":null,\"value\":\"{\\r\\n    fields: []\\r\\n}\"},{\"name\":\"srcField\",\"descr\":null,\"value\":\"{\\n    \\\"fieldName\\\":null,\\n    \\\"fieldLabel\\\":null,\\n    \\\"dataType\\\":null,\\n    \\\"length\\\":null,\\n    \\\"precisionVal\\\":null,\\n    \\\"partitionKey\\\":null,\\n    \\\"sensLvl\\\":null,\\n    \\\"fieldDescr\\\":null,\\n    \\\"isnullable\\\":\\\"1\\\",\\n    \\\"isDatatimeField\\\":null,\\n    \\\"defValue\\\":null,\\n    \\\"primaryKey\\\":null,\\n    \\\"dateFormat\\\":null,\\n    \\\"selectionType\\\":null,\\n    \\\"primaryKeySeq\\\":null,\\n    \\\"distributedKey\\\":null,\\n    \\\"sensType\\\":null,\\n    \\\"sensTypeArr\\\":[],\\n    \\\"maskRule\\\":null,\\n    \\\"maskType\\\":null,\\n    \\\"isKey\\\":null,\\n    \\\"stdName\\\":null,\\n    \\\"watermarkExpress\\\":null,\\n    \\\"preMerge\\\":null,\\n    \\\"columnFamily\\\":null\\n}\"},{\"name\":\"currRowIndex\",\"descr\":null,\"value\":\"0\"},{\"name\":\"columnFamilyOptions\",\"descr\":null,\"value\":\"[]\"}],\"models\":[],\"services\":[{\"name\":\"recommend\",\"stateName\":\"\",\"descr\":\"标准字段推荐\",\"autoLoad\":false,\"serviceId\":\"179197626464129024\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    debugger;\\r\\n    const fixField = function (recData, field) {\\r\\n        const temp = _.extend({}, field);\\r\\n        if (!temp.fieldName) {\\r\\n            temp.fieldName = data.data[0].recName;\\r\\n        }\\r\\n        if (!temp.fieldLabel) {\\r\\n            temp.fieldLabel = data.data[0].recLabel;\\r\\n        }\\r\\n        if (!temp.stdName) {\\r\\n            temp.stdName = data.data[0].stdCode;\\r\\n        }\\r\\n        if (data.data[0].securityRuleId) {\\r\\n            if (!temp.maskType) {\\r\\n                temp.maskType = '3';\\r\\n            }\\r\\n            if (!temp.maskRule) {\\r\\n                temp.maskRule = data.data[0].securityRuleId;\\r\\n            }\\r\\n        }\\r\\n        if (data.data[0].sensClassName) {\\r\\n            if (!temp.sensType) {\\r\\n                temp.sensType = data.data[0].sensClassName;\\r\\n            }\\r\\n        }\\r\\n        if (data.data[0].sensLvlName) {\\r\\n            if (!temp.sensLvl) {\\r\\n                temp.sensLvl = data.data[0].sensLvlName;\\r\\n            }\\r\\n        }\\r\\n        return temp;\\r\\n    }\\r\\n    if (data.data && data.data.length > 0) {\\r\\n        if (data.data[0].nameIsStd && !data.data[0].labelIsStd) {\\r\\n            const target = [];\\r\\n            $this.formData.fields.forEach(field => {\\r\\n                if (field.fieldName && field.fieldName.toLowerCase() == data.data[0].recName.toLowerCase()) {\\r\\n                    target.push(fixField(data.data, field));\\r\\n                } else {\\r\\n                    target.push(_.extend({}, field));\\r\\n                }\\r\\n            });\\r\\n            $this.setFormData({ fields: target });\\r\\n            $this.datasourceMap.updateTabSensLvl(target);\\r\\n        } else if (!data.data[0].nameIsStd && data.data[0].labelIsStd) {\\r\\n            const target = [];\\r\\n            $this.formData.fields.forEach(field => {\\r\\n                const temp = _.extend({}, field);\\r\\n                if (temp.fieldLabel && temp.fieldLabel.toLowerCase() == data.data[0].recLabel.toLowerCase()) {\\r\\n                    target.push(fixField(data.data, field));\\r\\n                } else {\\r\\n                    target.push(_.extend({}, field));\\r\\n                }\\r\\n            });\\r\\n            $this.setFormData({ fields: target });\\r\\n            $this.datasourceMap.updateTabSensLvl(target);\\r\\n        } else if (data.data[0].nameIsStd && data.data[0].labelIsStd) {\\r\\n            const target = [];\\r\\n            $this.formData.fields.forEach(field => {\\r\\n                const temp = _.extend({}, field);\\r\\n                if (temp.fieldLabel && temp.fieldLabel.toLowerCase() == data.data[0].recLabel.toLowerCase() && temp.fieldName && temp.fieldName.toLowerCase() == data.data[0].recName.toLowerCase()) {\\r\\n                    target.push(fixField(data.data, field));\\r\\n                } else {\\r\\n                    target.push(_.extend({}, field));\\r\\n                }\\r\\n            });\\r\\n            $this.setFormData({ fields: target });\\r\\n            $this.datasourceMap.updateTabSensLvl(target);\\r\\n        }\\r\\n    }\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error) {\\r\\n    if (error.data.devMsg) {\\r\\n        $utils.notification.error({\\r\\n            title: '失败',\\r\\n            content: error.data.devMsg\\r\\n        });\\r\\n    } else {\\r\\n        $utils.notification.error({\\r\\n            title: '失败',\\r\\n            content: '标准推荐失败！'\\r\\n        });\\r\\n    }\\r\\n}\",\"callback\":\"\"},{\"name\":\"updateTabSensLvl\",\"stateName\":\"\",\"descr\":\"\",\"autoLoad\":false,\"serviceId\":null,\"method\":\"get\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    // 通过 vars.params 可以更改查询参数\\r\\n    // 通过 vars.data 可以更改requestdata\\r\\n    // 通过 config.header 可以更改 header\\r\\n    // 通过 config.url 可以更改  url\\r\\n    /* vars.data = {\\r\\n    } */\\r\\n    // console.log(vars, config);\\r\\n    // 可以查看还有哪些参数可以修改。\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"function callback(e, fields) {\\r\\n    let targetFields = [];\\r\\n    if (fields) {\\r\\n        targetFields = fields;\\r\\n    } else {\\r\\n        targetFields = $this.formData.fields;\\r\\n    }\\r\\n    const lvlMap = {};\\r\\n    $this.parent.sensLvlOptions.forEach(item => {\\r\\n        lvlMap[item.itemName] = Number(item.itemLvl || '0');\\r\\n    });\\r\\n    if (targetFields.length > 0) {\\r\\n        let maxSens = '';\\r\\n        targetFields.forEach(field => {\\r\\n            if (!maxSens) {\\r\\n                maxSens = field.sensLvl;\\r\\n            } else if (lvlMap[field.sensLvl] && lvlMap[maxSens] < lvlMap[field.sensLvl]) {\\r\\n                maxSens = field.sensLvl;\\r\\n            }