ateDt'][0] + ' 00:00:00').getTime();\\n        vars.data['createDt.lte'] = new Date(vars.data['createDt'][1] + ' 00:00:00').getTime() + (24 * 60 * 60 * 1000);\\n        delete vars.data['createDt'];\\n    }\\n    delete vars.data.dirNodeId;\\n    const expandChildrenTag = function (node, arr, prop) {\\n        if (prop) {\\n            arr.push(node[prop]);\\n        } else {\\n            arr.push(node);\\n        }\\n        if (node.childrenData) {\\n            node.childrenData.forEach(subNode => {\\n                expandChildrenTag(subNode, arr, prop);\\n            });\\n        } else if (node.children) {\\n            node.children.forEach(subNode => {\\n                expandChildrenTag(subNode, arr, prop);\\n            });\\n        }\\n    };\\n    if ($this.currNode) {\\n        vars.data.archNodeId = $this.currNode.id;\\n        vars.data.workspaceId = $this.currNode.workspaceId;\\n        if ($this.currNode) {\\n            const tagArr = [];\\n            expandChildrenTag($this.currNode, tagArr, 'id');\\n            vars.data.archTags = tagArr.join(',');\\n            const targetNodes = [];\\n            expandChildrenTag($this.currNode, targetNodes);\\n            const targetLvls = [];\\n            targetNodes.forEach(item => {\\n                if (item.type == 'lvl') {\\n                    targetLvls.push(item.name);\\n                }\\n            });\\n            vars.data.lvls = targetLvls.join(',');\\n        }\\n    }\\n    vars.data.searchSubNode = true;\\n    vars.data.limit = $this.pageSize;\\n    vars.data.offset = ($this.pageNum - 1) * $this.pageSize;\\n    if ($this.workspaceFormData.workspaceId) {\\n        vars.data.workspaceId = $this.workspaceFormData.workspaceId;\\n    }\\n    $this.setSearching(true);\\n}\",\"success\":\"function successCallback(data) {\\n    $this.setSearching(false);\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\n    var content = data.data.content;\\n\\n    for (let item of content) {\\n        if (ite