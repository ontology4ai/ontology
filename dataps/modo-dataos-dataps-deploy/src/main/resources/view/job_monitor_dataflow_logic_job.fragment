队没有操作权限...');\\n            return;\\n        }\\n    }\\n\\n    for (var i = 0; i < forceExecuteList.length; i++) {\\n        if (forceExecuteList[i].state === '-1' && forceExecuteList[i].message == '失败自动重做') {\\n            $utils.message.warning(forceExecuteList[i].jobLabel + '不允许重做当前...');\\n            return;\\n        }\\n    }\\n\\n    $this.setRecoverIsSpin(true);\\n    $this.setIsSpin(true);\\n    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/operPermit/checkOperPermit',\\n        {\\n            params:\\n                { \\\"oper\\\": val, \\\"teamName\\\": $identity.teamName }\\n        }).then(response => {\\n\\n            if (response.data.success) {\\n                $this.sCheckAuthorityFroRedoCurrent = true;\\n            } else {\\n                $this.sCheckAuthorityFroRedoCurrent = false;\\n            }\\n        }).catch(function (error) {\\n            $this.setRecoverIsSpin(false);\\n            $this.setIsSpin(false);\\n            $this.sCheckAuthorityFroRedoCurrent = false;\\n            console.log(error);\\n        });\\n\\n\\n\\n    // -----sCheckOnly()-start-----\\n\\n    var _arr = [];\\n    var invalidJobCode = '';\\n    var sCheckOnlyCou = 0;\\n    for (let redoJobTrigger of forceExecuteList) {\\n        var option = _arr.find(function (item) {\\n            return (item.jobCode === redoJobTrigger.jobCode && item.batchNo === redoJobTrigger.batchNo)\\n        });\\n        if (!option) {\\n            $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/getTriggerData', {\\n                params: {\\n                    jobTrigId: redoJobTrigger.jobTrigId\\n                }\\n            }).then(response => {\\n                var judge = true;\\n                var data = response.data;\\n                if (data) {\\n                    if (data.isValid === 0) {\\n                        _arr.push(redoJobTrigger);\\n                    }\\n                }\\n                if (forceExecuteList.length == _arr.length) {\\n                    for (var i = 0; i < forceExecuteList.length; i++) {\\n                        var jobCode = forceExecuteList[i].jobCode;\\n                        var option2 = _arr.find(function (item) {\\n                            return (item.jobCode === jobCode && item.batchNo === forceExecuteList[i].batchNo)\\n                        });\\n                        if (!option2 && invalidJobCode.indexOf(jobCode) === -1) {\\n                            invalidJobCode += jobCode + ',';\\n                        }\\n                    }\\n                }\\n\\n                if (_arr.length == 0) {\\n                    judge = false;\\n                    return;\\n                    // this.$refs.multipleTable.clearSelection();\\n                }\\n\\n                if (invalidJobCode.length != 0) {\\n                    $utils.message.warning(invalidJobCode + \\\"为无效的任务！\\\");\\n                    $this.setRecoverIsSpin(false);\\n                    $this.setIsSpin(false);\\n                    return;\\n                }\\n                sCheckOnlyCou++;\\n\\n                if (sCheckOnlyCou == forceExecuteList.length) {\\n                    // -----sCheckState()-start-----------------------------------------------------------------------\\n\\n                    var sCheckState_arr = [];\\n\\n                    _.map(forceExecuteList, function (val) {\\n                        sCheckState_arr.push(val.jobCode);\\n                    });\\n                    var jobCode = encodeURI(sCheckState_arr);\\n\\n                    $utils.axios.get('/oneplusn-federation/open/dataflow/findJobByCodeList', {\\n                        params: {\\n                            \\\"jobCode\\\": jobCode,\\n                            \\\"production\\\": true\\n                        }\\n                    }).then(response => {\\n                        {\\n                            var data = response.data;\\n                            if (data) {\\n                                var judge = true;\\n                                for (var i = 0; i < forceExecuteList.length; i++) {\\n                                    var option = data.find(function (item) {\\n                                        return (item.jobCode === forceExecuteList[i].jobCode)\\n                                    });\\n                                    if (!option) {\\n                                        judge = false;\\n                                        $utils.message.warning(forceExecuteList[i].jobCode + \\\"未找到相对应的任务配置数据！\\\");\\n                                        $this.setRecoverIsSpin(false);\\n                                        $this.setIsSpin(false);\\n                                        return\\n                                    } else {\\n\\n                                        if ((val == '4' || val == '5') && option.jobType == 'datastash') {\\n                                            judge = false;\\n                                            $utils.message.warning(forceExecuteList[i].jobCode + \\\"为采集程序，无法进行暂停/恢复操作\\\");\\n                                            $this.setRecoverIsSpin(false);\\n                                            $this.setIsSpin(false);\\n                                            return\\n                                        }\\n                                    }\\n                                }\\n                                for (var i = 0; i < data.length; i++) {\\n                                    if (data[i].state != '1') {\\n                                        judge = false;\\n                                        $utils.message.warning(data[i].jobCode + \\\"任务未生效，无法进行操作\\\");\\n                                        $this.setRecoverIsSpin(false);\\n                                        $this.setIsSpin(false);\\n                                        return\\n\\n                                    }\\n                                    // var nowDate = moment(moment().subtract(0, 'days').toDate()).format(\\\"YYYYMMDD\\\");\\n                                    var nowDate = $utils.moment(new Date()).format(\\\"YYYYMMDD\\\");\\n\\n                                    if (data[i].effDt > nowDate || data[i].expDt < nowDate) {\\n                                        judge = false;\\n                                        $utils.message.warning(\\\"该任务已过期\\\");\\n                                        $this.setRecoverIsSpin(false);\\n                                        $this.setIsSpin(false);\\n                                        return\\n\\n                                    }\\n                                }\\n\\n\\n\\n                                // next();\\n                                // -----sCheck()-start-----------------------------------------------------------------------\\n                                // var self = this;\\n                                var val = '5';\\n                                var _obj = {\\n                                    '0': ['0', '-3', '5'],\\n                                    '1': ['0', '-1', '-2', '5', '-3'],\\n                                    '2': ['4', '-1', '-2'],\\n                                    '3': ['3'],\\n                                    '4': ['0', '3', '5', '-3'],\\n                                    '5': ['2'],\\n                                    '6': ['0', '-3', '5']\\n                                }\\n\\n                                if ($this.sCheckAuthorityFroRedoCurrent) {\\n                                    _obj = {\\n                                        '0': ['0', '-3', '5'],\\n                                        '1': ['0', '-1', '-2', '5', '-3'],\\n                                        '2': ['1', '4', '-1', '-2'],\\n                                        '3': ['3'],\\n                                        '4': ['0', '3', '5', '-3'],\\n                                        '5': ['2'],\\n                                        '6': ['0', '-3', '5']\\n                                    }\\n                                }\\n                                var stateArr = _obj[val];\\n\\n\\n\\n                                var label = '';\\n                                var tempArr = [];\\n                                var jobTrigIdList = [];\\n                                _.map(forceExecuteList, function (val) {\\n                                    jobTrigIdList.push(encodeURI(val.jobTrigId));\\n                                });\\n                                // var param = JSON.stringify({ jobTrigId: jobTrigIdList });\\n                                $utils.axios.post('/oneplusn-federation/open/dataflow/monitor/getTriggerDataList', { jobTrigId: jobTrigIdList }).then(response => {\\n                                    var data = response.data;\\n                                    var judge = true;\\n                                    if (data) {\\n                                        var val = '5';\\n                                        tempArr = data;\\n                                        for (var i in tempArr) {\\n                                            var _state = tempArr[i].state;\\n\\n                                            if (!_.contains(stateArr, _state)) {\\n                                                judge = false;\\n                                                label = tempArr[i].jobLabel;\\n                                                break;\\n                                            }\\n                                        }\\n\\n                                        if (!judge) {\\n                                            var state = \\\"\\\";\\n                                            for (var i = 0; i < stateArr.length; i++) {\\n                                                for (var j = 0; j < stateEnum.length; j++) {\\n                                                    if (stateEnum[j].value === stateArr[i])\\n                                                        state += stateEnum[j].label + \\\",\\\";\\n                                                }\\n                                            }\\n                                            state = state.substring(0, state.length - 1);\\n                                            var oper = ['强制执行', '强制通过', '重做', '取消', '暂停', '恢复', '调整优先级'];\\n                                            var message = label + '不符合要求；状态为“' + state + '”才能进行“' + oper[val] + '”操作';\\n                                            if (val === '2') {\\n                                                message += \\\";“成功”状态重做需要授权！\\\"\\n                                            }\\n                                            $utils.message.warning(message);\\n                                            $this.setRecoverIsSpin(false);\\n                                            $this.setIsSpin(false);\\n                                            return\\n                                        }\\n\\n                                        // next();\\n\\n                                        var val = '5';\\n                                        var judge = true;\\n                                        var oper = ['强制执行', '强制通过', '重做', '取消', '暂停', '恢复', '手工任务', '调整优先级'];\\n                                        for (var i = 0; i < forceExecuteList.length; i++) {\\n                                            var data = forceExecuteList[i];\\n                                            var index = _.findIndex(operCheckTime[val], function (item) {\\n                                                return item.label === data.jobTrigId\\n                                            });\\n                                            if (index > -1) {\\n                                                var nowDate = new Date();\\n                                                //大于1分钟\\n                                                if (nowDate.getTime() - operCheckTime[val][index].time.getTime() > 60000) {\\n                                                    operCheckTime[val][index].time = nowDate;\\n                                                    judge = true;\\n                                                } else {\\n                                                    $utils.message.warning(data.jobLabel + '，操作与上次操作时间需要间隔1分钟');\\n                                                    $this.setRecoverIsSpin(false);\\n                                                    $this.setIsSpin(false);\\n                                                    return;\\n                                                }\\n                                            } else {\\n                                                $this.operCheckTime[val].push({ \\\"label\\\": data.jobTrigId, \\\"time\\\": new Date() });\\n                                            }\\n                                        }\\n                                        $this.setRecoverIsSpin(false);\\n                                        $this.setIsSpin(false);\\n                                        $utils.modal.confirm({\\n                                            title: '确定执行恢复操作？',\\n                                            content:\\n                                                '',\\n                                            okButtonProps: {\\n                                                status: 'warning',\\n                                            },\\n                                            onOk: () => {\\n                                                var selectedRows = $this.$refs.job_trigger_tab.selectedRows;\\n                                                var dataArr = [];\\n                                                for (let data of selectedRows) {\\n                                                    dataArr.push({\\n   