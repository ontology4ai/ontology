                                            $this.setIsSpin(false);\\n                                                    console.log(error);\\n                                                });\\n                                            },\\n                                        });\\n\\n                                    }\\n\\n\\n                                }).catch(function (error) {\\n                                    $this.setPauseIsSpin(false);\\n                                    $this.setIsSpin(false);\\n                                    console.log(error);\\n                                });\\n\\n                            }\\n                        }\\n                    })\\n                    // return judge;\\n                }\\n\\n            }).catch(function (error) {\\n                $this.setPauseIsSpin(false);\\n                $this.setIsSpin(false);\\n                console.log(error);\\n            });\\n\\n\\n        }\\n    }\\n\\n    // -----sCheckOnly()-end--------------------------------------\\n\\n}\\n\\n\\n\\n\\nfunction writeTeamContain(teamName) {\\n    var index = _.findIndex($this.writeTeamNames, function (item) {\\n        return item === teamName\\n    });\\n    return index > -1 ? true : false;\\n}\"}},\"type\":\"text\",\"icon\":\"IconPauseAll\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]},{\"id\":\"be1424afb8103fe5\",\"name\":\"be1424afb8103fe5\",\"label\":\"恢复\",\"type\":\"button\",\"options\":{\"hidden\":false,\"hiddenBindVar\":\"$this.showMore1 == false\",\"isLoading\":true,\"loading\":false,\"loadingBindVar\":\"$this.recoverIsSpin == true\",\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,