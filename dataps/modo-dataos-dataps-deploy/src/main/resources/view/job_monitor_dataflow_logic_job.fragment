ons\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":true,\"loading\":false,\"loadingBindVar\":\"$this.exportIsSpin == true\",\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onClick\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\n    var selectedRows = $this.$refs.job_trigger_tab.selectedRows;\\n    if (selectedRows == undefined || selectedRows.length == 0) {\\n        $utils.message.warning('未选择任何任务，请先选择..');\\n        return;\\n    }\\n    $this.setExportIsSpin(true);\\n    $this.setIsSpin(true);\\n    $utils.axios.post('/oneplusn-federation/open/dataflow/monitor/get/export/data', selectedRows).then(response => {\\n\\n        $this.setExportIsSpin(false);\\n        $this.setIsSpin(false);\\n        exportData(\\\"selected\\\", response.data);\\n    }).catch(function (error) {\\n        $this.setExportIsSpin(false);\\n        $this.setIsSpin(false);\\n        console.log(error);\\n    });\\n\\n\\n}\\nfunction exportData(command, data) {\\n\\n    //列标题，逗号隔开，每一个逗号就是隔开一个单元格\\n    var tableColumnChineseName = [], tableColumnName = [];\\n    _.map($this.allTableAttribute, function (a_item) {\\n        tableColumnChineseName.push(a_item.label);\\n        tableColumnName.push(a_item.value);\\n    });\\n    tableColumnName.push(\\\"state\\\");\\n    tableColumnChineseName.push(\\\"状态\\\");\\n    var str = tableColumnChineseName.join(\\\",\\\") + \\\"\\\\n\\\";\\n    // var str = `${tableColumnChineseName.join(\\\",\\\")}\\\\n`;\\n    var len = tableColumnName.length;\\n    //增加\\\\t为了不让表格显示科学计数法或者其他格式\\n\\n    if (data.length > 0) {\\n        _.map(data, function (item) {\\n            for (var i = 0; i < len; i++) {\\n\\n                switch (tableColumnName[i]) {\\n                    case \\\"batchType\\\":\\n                        str = str + \\\"\\\\t\\\" + batchTypeFormatter(item[tableColumnName[i]]) + \\\"\\\\t\\\" + \\\",\\\";\\n\\n                        break;\\n                    case \\\"memberName\\\":\\n                        str = str + \\\"\\\\t\\\" + formatMemberName(item) + \\\"\\\\t\\\" + \\\",\\\";\\n\\n                        break;\\n                    case \\\"duration\\\":\\n                        str = str + \\\"\\\\t\\\" + durationFormatter(item) + \\\"\\\\t\\\" + \\\",\\\";\\n\\n                        break;\\n                    case \\\"avgDuration\\\":\\n                        str = str + \\\"\\\\t\\\" + avgDurationFormatter(item) + \\\"\\\\t\\\" + \\\",\\\";\\n\\n                        break;\\n                    case \\\"isValid\\\":\\n                        str = str + \\\"\\\\t\\\" + isValidFormatter(item) + \\\"\\\\t\\\" + \\\",\\\";\\n\\n                        break;\\n                    case \\\"state\\\":\\n                        str = str + \\\"\\\\t\\\" + stateFormatter(item) + \\\"\\\\t\\\" + \\\",\\\";\\n\\n                        break;\\n                    default:\\n                        var val = '';\\n                        if (tableColumnName[i] == 'actualRedoNum' && item[tableColumnName[i]] == 0) {\\n                            val = '0';\\n                        } else {\\n                            val = item[tableColumnName[i]] ? item[tableColumnName[i]].toString() : \\\"\\\";\\n                        }\\n                        if (val.indexOf(\\\",\\\") > -1) {\\n                            str = str + '\\\"' + val + '\\\"' + ',';\\n                            // str+=`${'\\\"' + val + '\\\"'},`;\\n                        } else {\\n                            str = str + '\\\\t' + val + '\\\\t' + ',';\\n                            // str+=`${'\\\\t'+ val + '\\\\t'},`;\\n                        }\\n                        break;\\n                }\\n            }\\n            str += '\\\\n';\\n        });\\n    }\\n    var title = command === \\\"all\\\" ? \\\"全部数据\\\" : command === \\\"selected\\\" ? \\\"选中数据\\\" : \\\"本页数据\\\";\\n    var browser = getBrowser();\\n    if (browser == 'FF' || browser == 'Chrome') {\\n        var file = new File([\\\"\\\\ufeff\\\" + str], title + '_' + formatDate(new Date(), 'yyyy-MM-dd-hh-mm-ss') + '.csv', { type: 'text/csv;charset=utf-8' });\\n    } else {\\n        var file = new Blob([\\\"\\\\ufeff\\\" + str], { type: 'text/csv;charset=utf-8' });\\n    }\\n\\n    var saveAs = saveAs || (function () {\\n        \\\"use strict\\\";\\n\\n        var view = window;\\n        // IE <10 is explicitly unsupported\\n        if (typeof view === \\\"undefined\\\" || typeof navigator !== \\\"undefined\\\" && /MSIE [1-9]\\\\./.test(navigator.userAgent)) {\\n            return;\\n        }\\n        var\\n            doc = view.document\\n            // only get URL when necessary in case Blob.js hasn't overridden it yet\\n            , get_URL = function () {\\n                return view.URL || view.webkitURL || view;\\n            }\\n            , save_link = doc.createElementNS(\\\"http://www.w3.org/1999/xhtml\\\", \\\"a\\\")\\n            , can_use_save_link = \\\"download\\\" in save_link\\n            , click = function (node) {\\n                var event = new MouseEvent(\\\"click\\\");\\n                node.dispatchEvent(event);\\n            }\\n            , is_safari = /constructor/i.test(view.HTMLElement) || view.safari\\n            , is_chrome_ios = /CriOS\\\\/[\\\\d]+/.test(navigator.userAgent)\\n            , throw_outside = function (ex) {\\n                (view.setImmediate || view.setTimeout)(function () {\\n                    throw ex;\\n                }, 0);\\n            }\\n            , force_saveable_type = \\\"application/octet-stream\\\"\\n            // the Blob API is fundamentally broken as there is no \\\"downloadfinished\\\" event to subscribe to\\n            , arbitrary_revoke_timeout = 1000 * 40 // in ms\\n            , revoke = function (file) {\\n                var revoker = function () {\\n                    if (typeof file === \\\"string\\\") { // file is an object URL\\n                        get_URL().revokeObjectURL(file);\\n                    } else { // file is a File\\n                        file.remove();\\n                    }\\n                };\\n                setTimeout(revoker, arbitrary_revoke_timeout);\\n            }\\n            , dispatch = function (filesaver, event_types, event) {\\n                event_types = [].concat(event_types);\\n                var i = event_types.length;\\n                while (i--) {\\n                    var listener = filesaver[\\\"on\\\" + event_types[i]];\\n                    if (typeof listener === \\\"function\\\") {\\n                        try {\\n                            listener.call(filesaver, event || filesaver);\\n                        } catch (ex) {\\n                            throw_outside(ex);\\n                        }\\n                    }\\n                }\\n            }\\n            , auto_bom = function (blob) {\\n                // prepend BOM for UTF-8 XML and text/* types (including HTML)\\n                // note: your browser will automatically convert UTF-16 U+FEFF to EF BB BF\\n                if (/^\\\\s*(?:text\\\\/\\\\S*|application\\\\/xml|\\\\S*\\\\/\\\\S*\\\\+xml)\\\\s*;.*charset\\\\s*=\\\\s*utf-8/i.test(blob.type)) {\\n                    return new Blob([String.fromCharCode(0xFEFF), blob], { type: blob.type });\\n                }\\n                return blob;\\n            }\\n            , FileSaver = function (blob, name, no_auto_bom) {\\n                if (!no_auto_bom) {\\n                    blob = auto_bom(blob);\\n                }\\n                // First try a.download, then web filesystem, then object URLs\\n                var\\n                    filesaver = this\\n                    , type = blob.type\\n                    , force = type === force_saveable_type\\n                    , object_url\\n                    , dispatch_all = function () {\\n                        dispatch(filesaver, \\\"writestart progress write writeend\\\".split(\\\" \\\"));\\n                    }\\n                    // on any filesys errors revert to saving with object URLs\\n                    , fs_error = function () {\\n                        if ((is_chrome_ios || (force && is_safari)) && view.FileReader) {\\n                            // Safari doesn't allow downloading of blob urls\\n                            var reader = new FileReader();\\n                            reader.onloadend = function () {\\n                                var url = is_chrome_ios ? reader.result : reader.result.replace(/^data:[^;]*;/, 'data:attachment/file;');\\n                                var popup = view.open(url, '_blank');\\n                                if (!popup) view.location.href = url;\\n                                url = undefined; // release reference before dispatching\\n                                filesaver.readyState = filesaver.DONE;\\n                                dispatch_all();\\n                            };\\n                            reader.readAsDataURL(blob);\\n                            filesaver.readyState = filesaver.INIT;\\n                            return;\\n                        }\\n                        // don't create more object URLs than needed\\n                        if (!object_url) {\\n                            object_url = get_URL().createObjectURL(blob);\\n                        }\\n                        if (force) {\\n                            view.location.href = object_url;\\n                        } else {\\n                            var opened = view.open(object_url, \\\"_blank\\\");\\n                            if (!opened) {\\n                                // Apple does not allow window.open, see https://developer.apple.com/library/safari/documentation/Tools/Conceptual/SafariExtensionGuide/WorkingwithWindowsandTabs/WorkingwithWindowsandTabs.html\\n                                view.location.href = object_url;\\n                            }\\n                        }\\n                        filesaver.readyState = filesaver.DONE;\\n                        dispatch_all();\\n                        revoke(object_url);\\n                    }\\n                    ;\\n                filesaver.readyState = filesaver.INIT;\\n\\n                if (can_use_save_link) {\\n                    object_url = get_URL().createObjectURL(blob);\\n                    setTimeout(function () {\\n                        save_link.href = object_url;\\n                        save_link.download = name;\\n                        click(save_link);\\n                        dispatch_all();\\n                        revoke(object_url);\\n                        filesaver.readyState = filesaver.DONE;\\n                    });\\n                    return;\\n                }\\n\\n                fs_error();\\n            }\\n            , FS_proto = FileSaver.prototype\\n            , saveAs = function (blob, name, no_auto_bom) {\\n                return new FileSaver(blob, name || blob.name || \\\"download\\\", no_auto_bom);\\n            }\\n            ;\\n        // IE 10+ (native saveAs)\\n        if (typeof navigator !== \\\"undefined\\\" && navigator.msSaveOrOpenBlob) {\\n            return function (blob, name, no_auto_bom) {\\n                name = name || blob.name || \\\"download\\\";\\n\\n                if (!no_auto_bom) {\\n                    blob = auto_bom(blob);\\n                }\\n                return navigator.msSaveOrOpenBlob(blob, name);\\n            };\\n        }\\n\\n        FS_proto.abort = function () { };\\n        FS_proto.readyState = FS_proto.INIT = 0;\\n        FS_proto.WRITING = 1;\\n        FS_proto.DONE = 2;\\n\\n        FS_proto.error =\\n            FS_proto.onwritestart =\\n            FS_proto.onprogress =\\n            FS_proto.onwrite =\\n            FS_proto.onabort =\\n            FS_proto.onerror =\\n            FS_proto.onwriteend =\\n            null;\\n\\n        return saveAs;\\n    }())\\n    // saveAs(file, title + '_' + (new Date()).getTime() + '.csv');\\n    saveAs(file, title + '_' + formatDate(new Date(), 'yyyy-MM-dd-hh-mm-ss') + '.csv');\\n\\n}\\n\\nfunction batchTypeFormatter(val) {\\n\\n    for (var i in $this.batchTypeOptions) {\\n        if ($this.batchTypeOptions[i].value == val) {\\n            return $this.batchTypeOptions[i].label;\\n        }\\n    }\\n    return '无';\\n}\\n\\nfunction formatMemberName(row) {\\n\\n    var option = _.filter($this.memberNameFormatOptions, function (item) {\\n        if (item.name == row.memberName) {\\n            return item;\\n        }\\n    });\\n    if (option.length > 0) {\\n        return option[0].userName;\\n    } else {\\n        return row.memberName;\\n    }\\n}\\n\\nfunction durationFormatter(val) {\\n\\n    if (val.duration == 0)\\n        return '';\\n    var oTime = \\\"\\\";\\n    oTime = millisecondToStr(val.duration);\\n\\n    return oTime;\\n}\\n\\nfunction avgDurationFormatter(val) {\\n\\n    var timeDifference = 0;\\n    var timeStr = \\\"\\\";\\n    //只统计成功,运行中状态\\n    if (val.state !== \\\"1\\\" && val.state !== \\\"3\\\") {\\n        return \\\"\\\";\\n    }\\n    if (val.avgDuration == 0 || val.avgDuration == null || val.avgDuration == undefined || val.duration == 0) {\\n        return \\\"\\\";\\n    } else {\\n\\n        if (val.state === \\\"3\\\") {\\n            //运行时长 小于 平均运行时长\\n            if (val.avgDuration >= val.duration) {\\n                timeDifference = val.avgDuration - val.duration;\\n                timeStr = millisecondToStr(timeDifference);\\n                var today = new Date();\\n                today.setSeconds(today.getSeconds() + timeDifference / 1000);\\n                var defaultShowDate = formatDate(today);\\n                return \\\"预计在\\\" + defaultShowDate + \\\"执行完成\\\";\\n            } else {\\n                timeDifference = val.duration - val.avgDuration;\\n                timeStr = millisecondToStr(timeDifference);\\n                return \\\"已超过平均运行时长\\\" + timeStr;\\n            }\\n        }\\n        if (val.state === \\\"1\\\") {\\n\\n            //运行时长 小于 平均运行时长\\n            if (Math.abs(val.avgDuration - val.duration) < 60000) {\\n                return \\\"在预计时间内完成\\\";\\n            } else {\\n                if (val.avgDuration >= val.duration) {\\n\\n                    return \\\"比预计时间早完成\\\";\\n                } else {\\n\\n                    timeDifference = val.duration - val.avgDuration;\\n                    var oTime = \\\"\\\";\\n                    oTime = millisecondToStr(timeDifference);\\n                    return \\\"比预计时间晚\\\" + oTime + \\\"完成\\\";\\n                }\\n            }\\n        }\\n    }\\n}\\n\\nfunction formatDate(date) {\\n    var year = date.getFullYear()\\n    var month = date.getMonth() + 1\\n    var day = date.getDate()\\n    var hour = date.getHours()\\n    var minute = date.getMinutes()\\n    var second = date.getSeconds()\\n    return [hour, minute, second].map(function (n) {\\n        n = n.toString()\\n        return n.length > 1 ? n : '0' + n\\n    }).join(':');\\n}\\n\\nfunction millisecondToStr(val) {\\n\\n    var temp = 0;\\n    var oDay = Math.trunc(val / (1000 * 60 * 60 * 24));\\n    temp = val % (1000 * 60 * 60 * 24);\\n    var oHour = Math.trunc(temp / (1000 * 60 * 60));\\n    temp = temp % (1000 * 60 * 60);\\n    var oMin = Math.trunc(temp / (1000 * 60));\\n    temp = temp % (1000 * 60);\\n    var oSen = Math.trunc(temp / 1000);\\n    var oTime = getzf(oDay) + ' ' + getzf(oHour) + ':' + getzf(oMin) + ':' + getzf(oSen);\\n\\n    return oTime;\\n}\\n\\nfunction isValidFormatter(val) {\\n    return val.isValid == 0 ? '有效' : '无效';\\n}\\n\\nfunction stateFormatter(val) {\\n\\n    for (var i in $this.stateEnum) {\\n        if ($this.stateEnum[i].value == val.state) {\\n            return $this.stateEnum[i].label;\\n        }\\n    }\\n    return '未运行';\\n}\\n\\n/*\\n * 获取浏览器类型\\n * */\\nfunction getBrowser() {\\n    var userAgent = navigator.userAgent;\\n    var isOpera = userAgent.indexOf('Opera') > -1;\\n    if (isOpera) {\\n        return 'Opera';\\n    };\\n    if (userAgent.indexOf('Firefox') > -1) {\\n        return 'FF';\\n    }\\n    if (userAgent.indexOf('Chrome') > -1) {\\n        return 'Chrome';\\n    }\\n    if (userAgent.indexOf('Safari') > -1) {\\n        return 'Safari';\\n    }\\n    if ((userAgent.indexOf('compatible') > -1 && userAgent.indexOf('MSIE') > -1 && !isOpera) || (window.ActiveXObject || \\\"ActiveXObject\\\" in window)) {\\n        this.isIE = true;\\n        return 'IE';\\n    };\\n}\\n\\nfunction getzf(num) {\\n    if (parseInt(num) < 10) {\\n        num = '0' + num;\\n    }\\n    return num;\\n}\\n\\n/**\\n * 格式化函数 ， 给日期格式化\\n * date为 new Date()对象， fmt为 'yyyy-MM-dd hh:mm:ss'的格式\\n */\\nfunction formatDate(date, fmt) {\\n    //获取年份\\n    if (/(y+)/.test(fmt)) {\\n        // 把数字变成字符串\\n        let dateY = date.getFullYear() + \\\"\\\";\\n        //RegExp.$1 在判断中出现过，且是括号括起来的，所以 RegExp.$1 就是 \\\"yyyy\\\"\\n        fmt = fmt.replace(RegExp.$1, dateY.substr(4 - RegExp.$1.length));\\n    }\\n\\n    //获取其他\\n    let o = {\\n        \\\"M+\\\": date.getMonth() + 1,\\n        \\\"d+\\\": date.getDate(),\\n        \\\"h+\\\": date.getHours(),\\n        \\\"m+\\\": date.getMinutes(),\\n        \\\"s+\\\": date.getSeconds(),\\n    };\\n    for (const k in o) {\\n        if (new RegExp(`(${k})`).test(fmt)) {\\n            let str = o[k] + \\\"\\\";\\n            fmt = fmt.replace(\\n                RegExp.$1,\\n                RegExp.$1.length == 1 ? str : padLeftZero(str)\\n            );\\n        }\\n    }\\n    return fmt;\\n}\\n\\nfunction padLeftZero(str) {\\n    return (\\\"00\\\" + str).substr(str.length);\\n}\\n\\n\\n\"}},\"type\":\"text\",\"icon\":\"IconImport\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]},{\"id\":\"6a6e6563b5d4ca89\",\"name\":\"6a6e6563b5d4ca89\",\"label\":\"手工任务\",\"type\":\"button\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":true,\"loading\":false,\"loadingBindVar\":\"$this.manualTaskIsSpin == true\",\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onClick\":{\"builtIn\":{\"type\":\"view\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":\"manualTask_tab\",\"before\":\"function beforeCallback(next) {\\n\\n    var manualTaskList = $this.$refs.job_trigger_tab.selectedRows;\\n    if (manualTaskList == undefined || manualTaskList.length == 0) {\\n        $utils.message.warning('未选择任何任务，请先选择..');\\n        return;\\n    }\\n\\n    if (manualTaskList.len != 0) {\\n        var batchType = manualTaskList[0].batchType;\\n        for (let item of manualTaskList) {\\n            if (batchType != item.batchType) {\\n                $utils.message.warning('所选的任务周期不一致！');\\n                return;\\n            }\\n        }\\n        $this.setManualTaskIsSpin(true);\\n        $this.setIsSpin(true);\\n        var manualTaskForm = [];\\n        for (let item of manualTaskList) {\\n            $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/getMinDateArgsByJobCode',\\n                {\\n                    params:\\n                        { \\\"jobCode\\\": item.jobCode }\\n                }).then(response => {\\n                    var data = response.data;\\n                    if (data) {\\n                        var minDateArgs = response;\\n                        var temp = {\\n                            jobCode: item.jobCode,\\n                            beginDateArgs: '',\\n                            endDateArgs: minDateArgs,\\n                            priority: item.priority,\\n                            batchType: item.batchType,\\n                            isSkipDepend: 'false',\\n                            teamName: item.teamName\\n                        };\\n                        manualTaskForm.push(temp);\\n                        if (manualTaskForm.length == manualTaskList.length) {\\n                            $this.setManualTaskIsSpin(false);\\n                            $this.setIsSpin(false);\\n                            next({\\n                                manualTaskList: manualTaskList\\n                            });\\n                        }\\n                    }\\n\\n                }).catch(function (error) {\\n                    console.log(error);\\n                });\\n        }\\n    }\\n\\n\\n}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\",\"params\":\"{\\n    manualTaskList: $this.$refs.job_trigger_tab.selectedRows\\n}\",\"title\":\"手工任务选择界面\"}],\"actions\":[]},\"callback\":\"function callback() { }\"}},\"type\":\"text\",\"icon\":\"IconPlanning\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]}]},{\"id\":\"00017d9050d193b0\",\"name\":\"00017d9050d193b0\",\"label\":\"flex布局\",\"type\":\"flexLayout\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root{}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"s