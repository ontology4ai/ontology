open($this.oneplusnContextPath + \\\"/open/dataflow/monitor/monitorDialog?brokerId=\\\" + row.brokerId\\n                            const newWindow = window.open(\\\"/dataos/task-log?brokerId=\\\" + row.brokerId\\n                                + \\\"&&jobTrigId=\\\" + row.jobTrigId\\n                                + \\\"&&jobCode=\\\" + row.jobCode\\n                                + \\\"&&jobLabel=\\\" + encodeURI(row.jobLabel)\\n                                + \\\"&&startDate=\\\" + row.startDate\\n                                + \\\"&&batchNo=\\\" + row.batchNo\\n                                + \\\"&&message=\\\" + encodeURI(message));\\n                            newWindow.addEventListener('load', () => { newWindow.document.title = '调度日志信息'; });\\n                        }\\n                    } else {\\n                        $utils.message.warning('无对应的任务信息数据！');\\n                        $this.setLogIsSpin(false);\\n\\n\\n                    }\\n\\n                }).catch(function (error) {\\n                    console.log(error);\\n                });\\n        }\\n\\n    }\\n}\"}},\"type\":\"text\",\"icon\":\"IconDataAllocation\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]},{\"id\":\"b4ac043b43a10758\",\"name\":\"b4ac043b43a10758\",\"label\":\"传输日志\",\"type\":\"button\",\"options\":{\"hidden\":false,\"hiddenBindVar\":\"$this.metaProcType != 'udt'\",\"isLoading\":true,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"si