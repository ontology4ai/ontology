dden\":false,\"hiddenBindVar\":null,\"isLoading\":true,\"loading\":false,\"loadingBindVar\":\"$this.redoCurrentIsSpin == true\",\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onClick\":{\"builtIn\":{\"type\":\"view\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":\"redoCurrent_tab\",\"before\":\"function beforeCallback(next) {\\n\\n\\n    const stateEnum = [\\n        { value: '0', label: '新建' },\\n        { value: '1', label: '成功' },\\n        { value: '2', label: '暂停' },\\n        { value: '3', label: '运行中' },\\n        // \\n        { value: '5', label: '排队' },\\n        { value: '-1', label: '失败' },\\n        { value: '-2', label: '中止' },\\n        { value: '-3', label: '重做' }\\n    ]\\n\\n    var redoJobTriggerList = $this.$refs.job_trigger_tab.selectedRows;\\n    if (redoJobTriggerList == undefined || redoJobTriggerList.length == 0) {\\n        $utils.message.warning('未选择任何任务，请先选择..');\\n        return;\\n    }\\n\\n\\n    for (var i = 0; i < redoJobTriggerList.length; i++) {\\n        if (!writeTeamContain(redoJobTriggerList[i].teamName)) {\\n            $utils.message.warning(redoJobTriggerList[i].jobLabel + '所在的团队没有操作权限...');\\n            return;\\n        }\\n    }\\n\\n    for (var i = 0; i < redoJobTriggerList.length; i++) {\\n        if (redoJobTriggerList[i].state === '-1' && redoJobTriggerList[i].message == '失败自动重做') {\\n            $utils.message.warning(redoJobTriggerList[i].jobLabel + '不允许重做当前...');\\n            return;\\n        }\\n    }\\n    for (let row of redoJobTriggerList) {\\n        $utils.axios.get('/oneplusn-federation/open/dataflow/findByJobCode',\\n            {\\n                params:\\n                    { \\\"jobCode\\\": row.jobCode, \\\"production\\\": true }\\n            }).then(response => {\\n                var data = response.data\\n                row.failedContinue = data.jobType === 'dp' ? '0' : '-1';\\n            }).catch(function (error) {\\n                $this.setRedoCurrentIsSpin(false);\\n                $this.setIsSpin(false);\\n                $this.sCheckAuthorityFroRedoCurrent = false;\\n                console.log(error);\\n            });\\n    }\\n\\n    $this.setRedoCurrentIsSpin(true);\\n    $this.setIsSpin(true);\\n    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/operPermit/checkOperPermit',\\n        {\\n            params:\\n                { \\\"oper\\\": '2', \\\"teamName\\\": $identity.teamName }\\n        }).then(response => {\\n\\n            if (response.data.success) {\\n                $this.sCheckAuthorityFroRedoCurrent = true;\\n            } else {\\n                $this.sCheckAuthorityFroRedoCurrent = false;\\n            }\\n        }).catch(function (error) {\\n            $this.setRedoCurrentIsSpin(false);\\n            $this.setIsSpin(false);\\n            $this.sCheckAuthorityFroRedoCurrent = false;\\n            console.log(error);\\n        });\\n\\n\\n    // -----sCheckOnly()-start-----\\n\\n    var _arr = [];\\n    var invalidJobCode = '';\\n    var judge = true;\\n    var sCheckOnlyCou = 0;\\n    for (let redoJobTrigger of redoJobTriggerList) {\\n        var option = _arr.find(function (item) {\\n            return (item.jobCode === redoJobTrigger.jobCode && item.batchNo === redoJobTrigger.batchNo)\\n        });\\n        if (!option) {\\n            $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/getTriggerData', {\\n                params: {\\n                    jobTrigId: redoJobTrigger.jobTrigId\\n                }\\n            }).then(response => {\\n                var data = response.data;\\n                if (data) {\\n                    if (data.isValid === 0) {\\n                        _arr.push(redoJobTrigger);\\n                    }\\n                }\\n                if (redoJobTriggerList.length == _arr.length) {\\n                    for (var i = 0; i < redoJobTriggerList.length; i++) {\\n                        var jobCode = redoJobTriggerList[i].jobCode;\\n                        var option2 = _arr.find(function (item) {\\n                            return (item.jobCode === jobCode && item.batchNo === redoJobTriggerList[i].batchNo)\\n                        });\\n                        if (!option2 && invalidJobCode.indexOf(jobCode) === -1) {\\n                            invalidJobCode += jobCode + ',';\\n                        }\\n                    }\\n                }\\n                // debugger\\n                // return;\\n\\n                if (_arr.length == 0) {\\n                    judge = false;\\n                    return;\\n\\n                }\\n\\n                if (invalidJobCode.length != 0) {\\n                    $utils.message.warning(invalidJobCode + \\\"为无效的任务！\\\");\\n                    $this.setRedoCurrentIsSpin(false);\\n                    $this.setIsSpin(false);\\n                    return;\\n                }\\n                sCheckOnlyCou++;\\n\\n                if (sCheckOnlyCou == redoJobTriggerList.length) {\\n                    // next()\\n                    // -----sCheckState()-start-----------------------------------------------------------------------\\n\\n                    var sCheckState_arr = [];\\n                    var judge = true;\\n                    var sCheckStateCou = 0;\\n                    _.map(redoJobTriggerList, function (val) {\\n                        sCheckState_arr.push(val.jobCode);\\n                    });\\n                    var jobCode = encodeURI(sCheckState_arr);\\n\\n                    $utils.axios.get('/oneplusn-federation/open/dataflow/findJobByCodeList', {\\n                        params: {\\n                            \\\"jobCode\\\": jobCode,\\n                            \\\"production\\\": true\\n                        }\\n                    }).then(response => {\\n                        {\\n\\n                            var data = response.data;\\n                            if (data) {\\n                                for (var i = 0; i < redoJobTriggerList.length; i++) {\\n                                    var option = data.find(function (item) {\\n                                        return (item.jobCode === redoJobTriggerList[i].jobCode)\\n                                    });\\n                                    if (!option) {\\n                                        judge = false;\\n                                        $utils.message.warning(redoJobTriggerList[i].jobCode + \\\"未找到相对应的任务配置数据！\\\");\\n                                        $this.setRedoCurrentIsSpin(false); $this.setIsSpin(false);\\n                                        return\\n                                    } else {\\n                                        if ((\\\"2\\\" == '4' || 2 == '5') && option.jobType == 'datastash') {\\n                                            judge = false;\\n                                            $utils.message.warning(redoJobTriggerList[i].jobCode + \\\"为采集程序，无法进行暂停/恢复操作\\\");\\n                                            $this.setRedoCurrentIsSpin(false); $this.setIsSpin(false);\\n                                            return\\n                                        }\\n                                    }\\n                                }\\n                                for (var i = 0; i < data.length; i++) {\\n                                    if (data[i].state != '1') {\\n                                        judge = false;\\n                                        $utils.message.warning(data[i].jobCode + \\\"任务未生效，无法进行操作\\\");\\n                                        $this.setRedoCurrentIsSpin(false); $this.setIsSpin(false);\\n                                        return\\n\\n                                    }\\n                                    // var nowDate = moment(moment().subtract(0, 'days').toDate()).format(\\\"YYYYMMDD\\\");\\n                                    var nowDate = $utils.moment(new Date()).format(\\\"YYYYMMDD\\\");\\n\\n                                    if (data[i].effDt > nowDate || data[i].expDt < nowDate) {\\n                                        judge = false;\\n                                        $utils.message.warning(\\\"该任务已过期\\\");\\n                                        $this.setRedoCurrentIsSpin(false); $this.setIsSpin(false);\\n                                        return\\n\\n                                    }\\n                                }\\n\\n\\n\\n                                // next();\\n                                // -----sCheck()-start-----------------------------------------------------------------------\\n                                // var self = this;\\n                                var val = '2';\\n                                var _obj = {\\n                                    '0': ['0', '-3', '5'],\\n                                    '1': ['0', '-1', '-2', '5', '-3'],\\n                                    '2': ['4', '-1', '-2'],\\n                                    '3': ['3'],\\n                                    '4': ['0', '3', '5', '-3'],\\n                                    '5': ['2'],\\n                                    '6': ['0', '-3', '5']\\n                                }\\n\\n                                if ($this.sCheckAuthorityFroRedoCurrent) {\\n                                    _obj = {\\n                                        '0': ['0', '-3', '5'],\\n                                        '1': ['0', '-1', '-2', '5', '-3'],\\n                                        '2': ['1', '4', '-1', '-2'],\\n                                        '3': ['3'],\\n                                        '4': ['0', '3', '5', '-3'],\\n                                        '5': ['2'],\\n                                        '6': ['0', '-3', '5']\\n                                    }\\n                                }\\n                                var stateArr = _obj[val];\\n                                var oper = ['强制启动', '强制通过', '重做', '取消', '暂停', '恢复', '调整优先级'];\\n\\n                                var judge = true;\\n                                var label = '';\\n                                var tempArr = [];\\n                                var jobTrigIdList = [];\\n                                _.map(redoJobTriggerList, function (val) {\\n                                    jobTrigIdList.push(encodeURI(val.jobTrigId));\\n                                });\\n                                // var param = JSON.stringify({ jobTrigId: jobTrigIdList });\\n                                $utils.axios.post('/oneplusn-federation/open/dataflow/monitor/getTriggerDataList', { jobTrigId: jobTrigIdList }).then(response => {\\n                                    var data = response.data;\\n                                    if (data) {\\n                                        tempArr = data;\\n                                        for (var i in tempArr) {\\n                                            var _state = tempArr[i].state;\\n                                            if (!_.contains(stateArr, _state)) {\\n                                                judge = false;\\n                                                label = tempArr[i].jobLabel;\\n                                                break;\\n                                            }\\n                                        }\\n\\n                                        if (!judge) {\\n                                            var state = \\\"\\\";\\n                                            for (var i = 0; i < stateArr.length; i++) {\\n                                                for (var j = 0; j < stateEnum.length; j++) {\\n                                                    if (stateEnum[j].value === stateArr[i])\\n                                                        state += stateEnum[j].label + \\\",\\\";\\n                                                }\\n                                            }\\n                                            state = state.substring(0, state.length - 1);\\n                                            var message = label + '不符合要求；状态为“' + state + '”才能进行“' + oper[val] + '”操作';\\n                                            if (val === '2') {\\n                                                message += \\\";“成功”状态重做需要授权！\\\"\\n                                            }\\n                                            $utils.message.warning(message);\\n                                            $this.setRedoCurrentIsSpin(false); $this.setIsSpin(false);\\n                                            return\\n                                        }\\n                                        $this.setRedoCurrentIsSpin(false); $this.setIsSpin(false);\\n\\n                                        next({\\n                                            redoJobTriggerList:\\n                                                redoJobTriggerList\\n                                        });\\n\\n\\n                                    }\\n\\n\\n                                }).catch(function (error) {\\n                                    $this.setRedoCurrentIsSpin(false);\\n                                    $this.setIsSpin(false);\\n                                    console.log(error);\\n                                });\\n\\n                            }\\n                        }\\n                    })\\n                }\\n\\n            }).catch(function (error) {\\n                $this.setRedoCurrentIsSpin(false);\\n                $this.setIsSpin(false);\\n                console.log(error);\\n            });\\n\\n\\n        }\\n    }\\n\\n    // -----sCheckOnly()-end--------------------------------------\\n\\n}\\n\\n\\nfunction writeTeamContain(teamName) {\\n    var index = _.findIndex($this.writeTeamNames, function (item) {\\n        return item === teamName\\n    });\\n    return index > -1 ? true : false;\\n}\\n\\nfunction sCheckOnly() {\\n\\n}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\",\"title\":\"重做当前选项\",\"params\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\n\\n\\n\\n\\n}\"}},\"type\":\"text\",\"icon\":\"IconReCurrent\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]},{\"id\":\"e940129b3ff143e1\",\"name\":\"e940129b3ff143e1\",\"label\":\"重做后续\",\"type\":\"button\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":true,\"loading\":false,\"loadingBindVar\":\"$this.redoFollowIsSpin == true\",\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null