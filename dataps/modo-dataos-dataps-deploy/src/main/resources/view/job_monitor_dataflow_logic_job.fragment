{"id":"dataps-139382522042880012","module":"139693883158589440","moduleLabel":null,"name":"job_monitor_dataflow_logic_job","label":"实例任务调度监控","descr":"","type":"fragment","state":"1","parameters":"[{\"id\":\"0\",\"name\":\"0\",\"label\":\"页面\",\"type\":\"view\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onMount\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\r\\n\\r\\n\\r\\n    if ($this.parentCode != '') {\\r\\n        $this.setSearching(true)\\r\\n        // let param = {\\r\\n        //     parent_code: $this.curCode,\\r\\n        //     batch_no: $this.batchNo\\r\\n        // }\\r\\n        // $this.dacpDataflowJobTriggerViewRepo.search(param);\\r\\n\\r\\n        const filters = $this.filters;\\r\\n\\r\\n        var jobLabel = '';\\r\\n        var batchTypes = '';\\r\\n        var batchNo = '';\\r\\n        var memberName = '';\\r\\n        var runState = '';\\r\\n        var jobType = '';\\r\\n        var priority = '';\\r\\n        var runStateNum = 1;\\r\\n        var tag = '';\\r\\n        var brokerWorkgroup = '';\\r\\n\\r\\n        var batchNoZone = '';\\r\\n\\r\\n        for (var f in filters) {\\r\\n            if (f == 'jobLabel' && filters[f]) {\\r\\n                jobLabel = filters[f];\\r\\n            }\\r\\n            if (f == 'batchTypes' && filters[f]) {\\r\\n\\r\\n                batchTypes = filters[f].join(',');\\r\\n            }\\r\\n            if (f == 'batchNoZone' && filters[f]) {\\r\\n                batchNo = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\r\\n                batchNoZone = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\r\\n            }\\r\\n            if (f == 'batchNo' && filters[f] && batchNoZone == '') {\\r\\n                batchNo = filters[f].replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\");\\r\\n            }\\r\\n            if (f == 'dUser' && filters[f]) {\\r\\n                memberName = filters[f];\\r\\n            }\\r\\n            if (f == 'runState' && filters[f]) {\\r\\n                runState = filters[f];\\r\\n            }\\r\\n            if (f == 'jobType' && filters[f]) {\\r\\n                jobType = filters[f];\\r\\n            }\\r\\n            if (f == 'priority' && filters[f]) {\\r\\n                priority = filters[f];\\r\\n            }\\r\\n\\r\\n            if (f == 'runStateNum' && filters[f]) {\\r\\n                if (filters[f] == true) {\\r\\n                    runStateNum = 0;\\r\\n                    $this.setRunStateNum(0)\\r\\n                } else if (filters[f] == false) {\\r\\n                    runStateNum = 1;\\r\\n                }\\r\\n\\r\\n            }\\r\\n\\r\\n            if (f == 'tag' && filters[f]) {\\r\\n                tag = filters[f];\\r\\n            }\\r\\n            if (f == 'brokerWorkgroup' && filters[f]) {\\r\\n                brokerWorkgroup = filters[f];\\r\\n            }\\r\\n            // if (f == 'cycle' && filters[f]) {\\r\\n            //     vars.params.cycle = '~%' + filters[f] + '%'\\r\\n            // }\\r\\n        }\\r\\n        $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/getTableData',\\r\\n            {\\r\\n                params:\\r\\n                {\\r\\n                    pageNum: 0,\\r\\n                    pageSize: 20,\\r\\n                    parentCode: $this.parentCode,\\r\\n                    batchTypes: $this.batchType,\\r\\n                    batchNo: $this.batchNo,\\r\\n                    teamName: $identity.teamName,\\r\\n                    // taskType: 'all',\\r\\n                    // desc: 'desc',\\r\\n                    // sortColumn: 'jobCode',\\r\\n                    readTeamNames: $identity.teamName,\\r\\n                    runStateNum: $this.runStateNum,\\r\\n                    brokerWorkgroup: brokerWorkgroup,\\r\\n                    priority: priority,\\r\\n                    runState: runState,\\r\\n                    tag: tag\\r\\n                }\\r\\n            }).then(res => {\\r\\n                var data = res.data.data;\\r\\n                $this.setJobTriggerListData(data);\\r\\n                $this.setSearching(false)\\r\\n            }).catch(function (error) {\\r\\n                console.log(error);\\r\\n            });\\r\\n\\r\\n        //获取dp任务子类型udt or dp    \\r\\n        $utils.axios.get('/api/get/meta/proc/type',\\r\\n            {\\r\\n                params:\\r\\n                {\\r\\n                    procName: $this.parentCode\\r\\n                }\\r\\n            }).then(res => {\\r\\n                var procType = res.data.data.procType;\\r\\n                console.log(procType);\\r\\n                $this.setMetaProcType(procType);\\r\\n            }).catch(function (error) {\\r\\n                console.log(error);\\r\\n            });\\r\\n\\r\\n\\r\\n        $utils.axios.get('/oneplusn-federation/open/dataflow/getMemberNameOptions', {\\r\\n            params: {\\r\\n                teamName: $identity.teamName\\r\\n            }\\r\\n        })\\r\\n            .then(function (response) {\\r\\n                var data = response.data;\\r\\n                if (data) {\\r\\n                    $this.setMemberNameFormatOptions(data);\\r\\n                    _.map(data, function (val) {\\r\\n                        var temp = {\\r\\n                            userName: val.userName + \\\"(\\\" + val.name + \\\")\\\",\\r\\n                            userId: val.userId,\\r\\n                            name: val.name\\r\\n                        }\\r\\n                        $this.memberNameOptions.push(temp);\\r\\n                    });\\r\\n                }\\r\\n            }).catch(function (error) {\\r\\n                console.log(error);\\r\\n            })\\r\\n\\r\\n    }\\r\\n\\r\\n}\"}},\"type\":\"one-screen-layout\",\"titleVisible\":false,\"vars\":[{\"name\":\"jobListData\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"curCode\",\"descr\":null,\"value\":\"''\"},{\"name\":\"batchNo\",\"descr\":null,\"value\":\"''\"},{\"name\":\"jobTriggerListData\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"sCheckAuthorityFroRedoCurrent\",\"descr\":null,\"value\":\"false\"},{\"name\":\"operCheckTime\",\"descr\":null,\"value\":\"{\\n    '0': [],\\n        '1': [],\\n            '2': [],\\n       