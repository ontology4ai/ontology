s\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onClick\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\n    console.log($this);\\n    if ($this.operType == 'create') {\\n        var wsId = $utils.guid();\\n        var baseInfo = $this.getChildren('baseInfo').$refs.baseInfo_from.getFieldsValue();\\n        var wsTypeInfo = $this.getChildren('baseInfo').$refs.wsTypeFrom.getFieldsValue();\\n\\n        // 安全设置\\n        var wsSecurityFrom = $this.getChildren('security').$refs.wsSecurityFrom.getFieldsValue();\\n\\n        var wsDirInfo1 = {};\\n        var wsDirInfo2 = {};\\n        // var wsDirInfo3 = {};\\n        let dirList = [];\\n        if (wsTypeInfo.devState == 1 || wsTypeInfo.type == 2) {\\n            wsDirInfo1 = $this.getChildren('wsDir').$refs.wsDirFrom1.getFieldsValue();\\n            wsDirInfo2 = $this.getChildren('wsDir').workspaceDirData;\\n            dirList = treeToArr(wsDirInfo2);\\n            // wsDirInfo3 = $this.getChildren('wsDir').$refs.wsDirFrom3.getFieldsValue();\\n        }\\n\\n        for (let dir of dirList) {\\n            dir.dirType = 'proc';\\n        }\\n\\n\\n        // var wsDirInfo1 = $this.getChildren('wsDir').$refs.wsDirFrom1.getFieldsValue();\\n        // var wsDirInfo2 = $this.getChildren('wsDir').workspaceDirData;\\n        // let dirList = treeToArr(wsDirInfo2);\\n\\n        // var wsDirInfo3 = $this.getChildren('wsDir').$refs.wsDirFrom3.getFieldsValue();\\n\\n        //数据建模空间\\n        // if (wsTypeInfo.type == 1) {\\n        //     wsObj.wsTypeInfo = wsTypeInfo.modelType;\\n        //     // delete wsTypeInfo.dataDevMode;\\n        //     delete wsTypeInfo.modelWsName;\\n        //     //数据开发空间\\n        // } else if (wsTypeInfo.type == 2) {\\n        //     delete wsTypeInfo.dataWarehouse;\\n        //     delete wsTypeInfo.devState;\\n        // }\\n        var wsObj = Object.assign(baseInfo, wsTypeInfo);\\n        wsObj.dirBound = wsDirInfo1.dirBound;\\n        wsObj.id = wsId;\\n\\n        //数据建模空间\\n        if (wsObj.type == 1) {\\n\\n            wsObj.dataDevMode = wsTypeInfo.modelType;\\n            // delete wsTypeInfo.dataDevMode;\\n            delete wsObj.modelWsName;\\n            //数据开发空间\\n        } else if (wsObj.type == 2) {\\n            delete wsObj.dataWarehouse;\\n            delete wsObj.devState;\\n        }\\n\\n\\n\\n\\n        if (wsObj.devState == 1 || wsObj.type == 2) {\\n\\n\\n            var dpAndStreamFrom = {};\\n            var projec = {};\\n            if (wsTypeInfo.devState == 1 || wsTypeInfo.type == 2) {\\n\\n                dpAndStreamFrom = $this.getChildren('ide').$refs.dpAndStreamFrom.getFieldsValue();\\n                projec = $this.getChildren('ide').$refs.dpAndStreamFrom.getFieldsValue();\\n            }\\n\\n            // 开发工具\\n            var modelWorkspaceDevCategoryList = [];\\n            // 组件\\n            var modelWorkspaceDevCompList = [];\\n            if (dpAndStreamFrom.dp == true) {\\n                var workspaceDevCategory = {};\\n                workspaceDevCategory.categoryName = '离线编排';\\n                modelWorkspaceDevCategoryList.push(workspaceDevCategory);\\n                var dpDevCompList = $this.getChildren('ide').getChildren('dpDevCompList').$refs.dpDevCompList.state.selectedRows;\\n                if (dpDevCompList != undefined) {\\n                    for (let dpDevComp of dpDevCompList) {\\n                        var modelWorkspaceDevComp = {};\\n                        modelWorkspaceDevComp.name = dpDevComp.stepInst;\\n                        modelWorkspaceDevComp.label = dpDevComp.stepInstLabel;\\n                        modelWorkspaceDevComp.categoryName = '离线编排';\\n                        modelWorkspaceDevComp.authDate = $utils.moment();\\n                        modelWorkspaceDevCompList.push(modelWorkspaceDevComp);\\n                    }\\n                }\\n            }\\n            if (dpAndStreamFrom.stream == true) {\\n                var workspaceDevCategory = {};\\n                workspaceDevCategory.categoryName = '实时编排';\\n                modelWorkspaceDevCategoryList.push(workspaceDevCategory);\\n                var streamDevCompList = $this.getChildren('ide').getChildren('streamDevCompList').$refs.streamDevCompList.state.selectedRows;\\n                if (streamDevCompList != undefined) {\\n                    for (let streamDevComp of streamDevCompList) {\\n                        var modelWorkspaceDevComp = {};\\n                        modelWorkspaceDevComp.name = streamDevComp.stepInst;\\n                        modelWorkspaceDevComp.label = streamDevComp.stepInstLabel;\\n                        modelWorkspaceDevComp.categoryName = '实时编排';\\n                        modelWorkspaceDevComp.authDate = $utils.moment();\\n                        modelWorkspaceDevCompList.push(modelWorkspaceDevComp);\\n                    }\\n                }\\n            }\\n\\n            if (projec.project == true) {\\n                var workspaceDevCategory = {};\\n                workspaceDevCategory.categoryName = '工程';\\n                modelWorkspaceDevCategoryList.push(workspaceDevCategory);\\n                // var projectDevCompList = projec.projectDevComp;\\n                var projectDevCompList = $this.getChildren('ide').getChildren('projectDevCompList').$refs.projectDevCompList.state.selectedRows;\\n                if (projectDevCompList != undefined) {\\n                    for (let projectDevComp of projectDevCompList) {\\n                        var modelWorkspaceDevComp = {};\\n                        modelWorkspaceDevComp.name = projectDevComp.projectDevComp;\\n                        modelWorkspaceDevComp.label = projectDevComp.projectDevComp;\\n                        modelWorkspaceDevComp.categoryName = '工程';\\n                        modelWorkspaceDevComp.authDate = $utils.moment();\\n                        modelWorkspaceDevCompList.push(modelWorkspaceDevComp);\\n                    }\\n                }\\n            }\\n\\n            wsObj.modelWorkspaceDevCategoryList = modelWorkspaceDevCategoryList;\\n            wsObj.modelWorkspaceDevCompList = modelWorkspaceDevCompList;\\n            wsObj.modelWorkspaceDirList = dirList;\\n        }\\n\\n\\n        // 工作空间权限\\n        var modelWorkspacePrivList = [];\\n        var dirPriv = {};\\n        dirPriv.objectType = 'dir';\\n        dirPriv.responsible = wsSecurityFrom.dir;\\n        dirPriv.workspaceId = wsObj.id;\\n        var devContentPriv = {};\\n        devContentPriv.objectType = 'devContent';\\n        devContentPriv.responsible = wsSecurityFrom.devContent;\\n        devContentPriv.workspaceId = wsObj.id;\\n\\n        var numOfDataQuery = {};\\n        numOfDataQuery.objectType = 'numOfDataQuery';\\n        numOfDataQuery.responsible = wsSecurityFrom.numOfDataQuery == undefined ? '0' : wsSecurityFrom.numOfDataQuery.toString();\\n        numOfDataQuery.workspaceId = wsObj.id;\\n\\n\\n        var dsProfileList = wsSecurityFrom.dsProfile;\\n        for (let ondDsProfile of dsProfileList) {\\n            var dsProfile = {};\\n            dsProfile.objectType = 'dsProfile';\\n            dsProfile.responsible = ondDsProfile;\\n            dsProfile.workspaceId = wsObj.id;\\n            modelWorkspacePrivList.push(dsProfile);\\n        }\\n        var orderOfDataQueryList = wsSecurityFrom.orderOfDataQuery;\\n        for (let ondOrderOfDataQuery of orderOfDataQueryList) {\\n            var orderOfDataQuery = {};\\n            orderOfDataQuery.objectType = 'orderOfDataQuery';\\n            orderOfDataQuery.responsible = ondOrderOfDataQuery;\\n            orderOfDataQuery.workspaceId = wsObj.id;\\n            modelWorkspacePrivList.push(orderOfDataQuery);\\n        }\\n\\n        modelWorkspacePrivList.push(dirPriv);\\n        modelWorkspacePrivList.push(devContentPriv);\\n        modelWorkspacePrivList.push(numOfDataQuery);\\n\\n\\n        wsObj.modelWorkspacePrivList = modelWorkspacePrivList;\\n\\n\\n        wsObj.principal = $identity.userName;\\n        wsObj.createUser = $identity.userName;\\n        wsObj.updateUser = $identity.userName;\\n\\n        // 自建团队\\n        var modelTeamWorkspaceList = []\\n\\n        if ($identity.teamName != null && $identity.teamName != undefined) {\\n            var modelTeamWorkspace = {};\\n            modelTeamWorkspace.teamName = $identity.teamName;\\n            // 自建\\n            modelTeamWorkspace.type = '1';\\n            modelTeamWorkspace.workspaceId = wsObj.id;\\n            modelTeamWorkspace.workspaceName = wsObj.name;\\n            modelTeamWorkspace.workspaceLabel = wsObj.label;\\n            modelTeamWorkspaceList.push(modelTeamWorkspace);\\n\\n        }\\n        wsObj.modelTeamWorkspaceList = modelTeamWorkspaceList;\\n        wsObj.privilege = '0';\\n        $this.modelWorkspaceRepo.createCascade(wsObj);\\n        $this.setSaveLoading(true);\\n    }\\n\\n\\n\\n}\\nfunction treeToArr(data) {\\n    const result = [];\\n    data.forEach(item => {\\n        const loop = data => {\\n            result.push({\\n                name: data.key,\\n                label: data.title,\\n                parentName: data.parentName\\n            });\\n            let child = data.children\\n            if (child) {\\n                for (let i = 0; i < child.length; i++) {\\n                    loop(child[i])\\n                }\\n            }\\n        }\\n        loop(item);\\n    })\\n    return result;\\n}\"}},\"type\":\"primary\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"stateVars\":[\"devState\",\"devState\"],\"innerVars\":[\"$refs[\",\"$refs[\"],\"children\":[]}]}]}]}]}]","inputVars":null,"viewPlugins":null,"version":352,"createUser":"xiacj3","createDt":null,"lastupd":null,"updateUser":null,"digest":null,"versionInfo":"","appName":"dataps","createUserName":null}