t.templateArchTree);\\n            }else{\\n                $this.parent.treeData.push($this.subjectData);\\n               $this.parent.$refs.treeDef.treeChartRef.current.loadData($this.parent.treeData);\\n            }\\n   \\n            //$this.datasourceMap.saveSubjectData();\\n        } else {\\n\\n        }\\n    }\\n\\n    $this.close();\\n    //window.parent.location.reload();\\n}\"}},\"type\":\"primary\",\"size\":\"default\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]}]}]}]}]","inputVars":null,"viewPlugins":null,"version":74,"createUser":"xiacj3","createDt":null,"lastupd":null,"updateUser":null,"digest":null,"versionInfo":null,"appName":"dataps","createUserName":null}