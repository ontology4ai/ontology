ems);\\r\\n    } else {\\r\\n        data.data.extendItems = {};\\r\\n    }\\r\\n    $this.setFormData(data.data);\\r\\n    $this.getChildren('fields').$refs.fieldsForm.formRef.current.clearFields();\\r\\n    $this.getChildren('fields').setFormData({ fields: data.data.datapsLogicModelFieldDraftList });\\r\\n    $utils.notification.success({\\r\\n        title: '成功',\\r\\n        content: '模型保存成功！',\\r\\n    });\\r\\n    if (!$this.modelId) {\\r\\n        //回填模型ID供二次编辑使用\\r\\n        $this.setModelId(data.data.id);\\r\\n        setTimeout(() => {\\r\\n            window.parent.closeIdeTab('addLogicModel');\\r\\n        }, 1000)\\r\\n    } else {\\r\\n        setTimeout(() => {\\r\\n            window.parent.closeIdeTab($this.modelId);\\r\\n        }, 1000)\\r\\n    }\\r\\n    if ($this.getParent()) {\\r\\n        $this.close();\\r\\n        if ($this.getParent().datasourceMap && $this.getParent().datasourceMap.getModelPage) {\\r\\n            $this.getParent().datasourceMap.getModelPage();\\r\\n        }\\r\\n        if ($this.getParent().datasourceMap && $this.getParent().datasourceMap.getArchTree) {\\r\\n            $this.getParent().datasourceMap.getArchTree();\\r\\n        }\\r\\n    }\\r\\n    $this.datasourceMap.getSrcData(checkData => {\\r\\n        $this.datasourceMap.devCheck(checkData);\\r\\n    });\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n    $utils.notification.error({\\r\\n        title: '解析失败',\\r\\n        content: '模型保存失败！',\\r\\n    });\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"loadLvlOptions\",\"stateName\":\"\",\"descr\":\"载入层次选项信息\",\"autoLoad\":false,\"serviceId\":\"182165573441130496\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.params.subjectName='lvl';\\r\\n}\",\"success