is.formData[key].join('_');\\r\\n            } else {\\r\\n                targetVal.value = $this.formData[key];\\r\\n            }\\r\\n            target.push(targetVal);\\r\\n        }\\r\\n    }\\r\\n    $this.setLastNamingVals(target);\\r\\n\\r\\n    if(!$this.formData.id&&$this.formData.lvlArr&&$this.formData.lvlArr.length>0){\\r\\n        const targetLvl = $this.formData.lvlArr[$this.formData.lvlArr.length-1];\\r\\n        if(namingComs.fields.some(item=>{return item.field=='lvl'})){\\r\\n            const abbrMap = {};\\r\\n            $this.lvlOptions.forEach(item=>{\\r\\n                abbrMap[item.name] = item.abbr||item.name;\\r\\n            });\\r\\n            if(abbrMap[targetLvl]){\\r\\n                $this.setFormData({namingItems:{lvl:abbrMap[targetLvl]}});\\r\\n            }\\r\\n        }\\r\\n    }\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"loadSensLvlOptions\",\"stateName\":\"sensLvlOptions\",\"descr\":\"载入敏感级别选项信息\",\"autoLoad\":true,\"serviceId\":\"194850029540528128\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.params.subjectName = 'SENS_LVL';\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"loadCycleTypeOptions\",\"stateName\":\"cycleTypeOptions\",\"descr\":\"载入周期选项信息\",\"autoLoad\":true,\"serviceId\":\"121952148195086336\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.params.subjectName='cycleType';\\r\\n}\",\"success\":\"function successCal