中的 b 字段为1\\n    return data.data; // 重要，需返回 data\\n}\",\"fail\":\"function failCallback(error){\\n    // console.log(error);\\n    // 可以在这里做弹框提示等操作\\n}\",\"methodType\":\"POST\",\"description\":\"逻辑模型草稿更新指定的一对多对象\",\"methodName\":\"updateCascadeSpecific\",\"type\":\"model\",\"url\":\"/_api/datapsLogicModelDraft/update/cascade/{modelNames}\"},{\"name\":\"createCascade\",\"stateName\":\"\",\"label\":\"逻辑模型草稿\",\"descr\":\"保存一对多的对象\",\"method\":\"POST\",\"autoLoad\":true,\"loadType\":\"1\",\"fields\":[],\"serviceId\":\"/_api/datapsLogicModelDraft/create/cascade\",\"condition\":true,\"conditionBindVar\":\"\",\"data\":\"{}\",\"dataBindVar\":\"\",\"placeholders\":[],\"before\":\"function beforeCallback(vars, config) {\\n    // 通过 vars.params 可以更改查询参数\\n    // 通过 vars.data 可以更改requestdata\\n    // 通过 config.header 可以更改 header\\n    // 通过 config.url 可以更改  url\\n    /* vars.data = {\\n    } */\\n    // console.log(vars, config);\\n    // 可以查看还有哪些参数可以修改。\\n}\",\"success\":\"function successCallback(data) {\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\n    return data.data; // 重要，需返回 data\\n}\",\"fail\":\"function failCallback(error){\\n    // console.log(error);\\n    // 可以在这里做弹框提示等操作\\n}\",\"methodType\":\"POST\",\"description\":\"逻辑模型草稿保存一对多的对象\",\"methodName\":\"createCascade\",\"type\":\"model\",\"url\":\"/_api/datapsLogicModelDraft/create/cascade\"}]}],\"services\":[{\"name\":\"getTeamDsOptions\",\"stateName\":\"dsOptions\",\"descr\":\"获取团队数据源\",\"autoLoad\":false,\"serviceId\":\"245587372905156608\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.params.workspaceId = $this.workspaceId;\\r\\n    vars.params.dsCategory = 'analytic,message,sequential,mostuse,itai,bigdata,rdb,nosql,storage';\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    const dsMap = {};\\r\\n    data.data.forEach(item => {\\r\\n        dsMap[item.name] = item;\\r\\n    });\\r\\n    $this.setDsMap(dsMap);\\r\\n    if ($this.formData.dsName && dsMap[$this.formData.dsName] && dsMap[$this.formData.dsName].dsSchema) {\\r\\n        const schemas = dsMap[$this.formData.dsName].dsSchema.split(',');\\r\\n        const schemaOptions = [];\\r\\n        schemas.forEach(sch => {\\r\\n            schemaOptions.push({\\r\\n                label: sch,\\r\\n                value: sch\\r\\n            });\\r\\n        });\\r\\n        $this.setSchemaOptions(schemaOptions);\\r\\n        if(!$this.formData.tabSchema&&schemas.length==1) {\\r\\n            $this.setFormData({ tabSchema: schemas[0] });\\r\\n        }\\r\\n    }\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"getDsDetail\",\"stateName\":\"\",\"descr\":\"查询数据源详情，确认数据源类型\",\"autoLoad\":false,\"serviceId\":\"187264398031306752\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    if (data.data) {\\r\\n        $this.setDsType(data.data.dsType);\\r\\n        if (['kafka', 'redis', 'hbase', 'es', 'hdfs', 'hudi', 'pulsar'].indexOf(data.data.dsType) > -1) {\\r\\n            $this.setSchemaOptions([{\\r\\n                label: 'default',\\r\\n                value: 'default'\\r\\n            }]);\\r\\n            $this.setFormData({ tabSchema: 'default' });\\r\\n        }\\r\\n        if ($this.getChildren('strategyCfg') && $this.getChildren('strategyCfg').strategyOptionMap) {\\r\\n            if ($this.getChildren('strategyCfg').strategyOptionMap[data.data.dsType]) {\\r\\n                $this.getChildren('strategyCfg').setStrategyOptions($this.getChildren('strategyCfg').strategyOptionMap[data.data.dsType]);\\r\\n            } else {\\r\\n                $this.getChildren('strategyCfg').setStrategyOptions($this.getChildren('strategyCfg').strategyOptionMap['default']);\\r\\n            }\\r\\n        }\\r\\n        $this.datasourceMap.loadFieldDataTypes();\\r\\n        $this.datasourceMap.getFieldLenPresicionLimit();\\r\\n        $this.datasourceMap.getReservedWordData();\\r\\n        if (data.data.dsConf) {\\r\\n            $this.setDsConf(JSON.parse(data.data.dsConf));\\r\\n        }\\r\\n        setTimeout(() => {\\r\\n            if ($this.getChildren(data.data.dsType + 'Physic') && $this.getChildren(data.data.dsType + 'Physic').formData) {\\r\\n                let location = JSON.parse(data.data.dsConf).location || JSON.parse(data.data.dsConf).filePath || '';\\r\\n                if (!location.endsWith('/')) {\\r\\n                    location += '/';\\r\\n                }\\r\\n                if (['hive', 'hdfs'].indexOf($this.dsType) > -1) {\\r\\n                    $this.getChildren(data.data.dsType + 'Physic').setFormData({ storage_path: location + ($this.formData.modelName || '').toLowerCase() });\\r\\n                }\\r\\n            }\\r\\n        }, 1000);\\r\\n        // if ($this.formData.modelName && data.data.dsType == 'redis' && ($this.formData.preRowKeyRule)) {\\r\\n        //     $this.setFormData({ preRowKeyRule: { prefix: $this.formData.modelName } });\\r\\n        // }\\r\\n    } else {\\r\\n        $this.utils.modal.error({\\r\\n            title: '错误',\\r\\n            content:\\r\\n                '未查询到数据源信息！',\\r\\n        });\\r\\n    }\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $this.utils.modal.error({\\r\\n            title: '错误',\\r\\n            content:\\r\\n                '获取数据源信息失败！',\\r\\n        });\\r\\n}\",\"callback\":\"\"},{\"name\":\"loadModelArch\",\"stateName\":\"\",\"descr\":\"载入模型目录树\",\"autoLoad\":false,\"serviceId\":\"175950744414765056\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.params.workspaceId = $this.workspaceId;\\r\\n    vars.params.teamName = $identity.teamName;\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    const typeMap = {};\\r\\n    if (data.data.length === 0) {\\r\\n        return data.data;\\r\\n    }\\r\\n    const getDirArr = function (arr, map, dirId) {\\r\\n        if (map[dirId]) {\\r\\n            arr.unshift(dirId);\\r\\n        }\\r\\n        if (map[dirId] && map[dirId].parentId) {\\r\\n            getDirArr(arr, map, map[dirId].parentId);\\r\\n        }\\r\\n    }\\r\\n    const findLvl = function (key, map) {\\r\\n        if (map[key]) {\\r\\n            if (map[key].type == 'lvl') {\\r\\n                $this.setArchLvl(map[key].name);\\r\\n                if (!$this.modelId) {\\r\\n                    $this.setFormData({ lvl: map[key].name });\\r\\n                    $this.datasourceMap.resolveNamingRule();\\r\\n                }\\r\\n            } else if (map[key].parentId) {\\r\\n                findLvl(map[key].parentId, map);\\r\\n            }\\r\\n        }\\r\\n    }\\r\\n    const findTopic = function (key, map) {\\r\\n        if (map[key]) {\\r\\n            if (map[key].type == 'topic') {\\r\\n                $this.setArchTopic(map[key].name);\\r\\n                if (!$this.modelId) {\\r\\n                    $this.setFormData({ topic: map[key].name });\\r\\n                }\\r\\n            } else if (map[key].parentId) {\\r\\n                findTopic(map[key].parentId, map);\\r\\n            }\\r\\n        }\\r\\n    }\\r\\n    const keyMap = {};\\r\\n    const roots = [];\\r\\n    data.data.forEach(item => {\\r\\n        keyMap[item.id] = item;\\r\\n        item.key = item.id;\\r\\n        if (!item.parentId) {\\r\\n            roots.push(item);\\r\\n        }\\r\\n    });\\r\\n    $this.setArchMap(keyMap);\\r\\n    $this.setModelTree(roots.filter(item => {\\r\\n        return item.key != '_un_category_node_';\\r\\n    }));\\r\\n    const expandTypeMap = function (type, nodes, typeMap) {\\r\\n        if (nodes.length > 0) {\\r\\n            nodes.forEach(node => {\\r\\n                typeMap[node.id] = type;\\r\\n                if (node.children) {\\r\\n                    expandTypeMap(type, node.children, typeMap);\\r\\n                }\\r\\n            });\\r\\n        }\\r\\n    }\\r\\n    roots.forEach(root => {\\r\\n        typeMap[root.id] = root;\\r\\n        if (root.children) {\\r\\n            expandTypeMap(root, root.children, typeMap);\\r\\n        }\\r\\n    });\\r\\n\\r\\n    $this.setArchTypeMap(typeMap);\\r\\n    $this.setFilteredModelTree(roots.filter(item => {\\r\\n        return item.type !== 'lvl' && item.key != '_un_category_node_';\\r\\n    }));\\r\\n    const curArr = [];\\r\\n    getDirArr(curArr, keyMap, $this.dirId);\\r\\n    if ($this.useArchAsTag) {\\r\\n        if ($this.formData.id) {\\r\\n            $this.setFormData({\\r\\n                busiProps: $this.busiProps.filter(tempArr => {\\r\\n                    let busiPropMatched = true;\\r\\n                    tempArr.forEach(targetK => {\\r\\n                        if (!keyMap[targetK]) {\\r\\n                            busiPropMatched = false;\\r\\n                        }\\r\\n                    });\\r\\n                    return busiPropMatched;\\r\\n                })\\r\\n            });\\r\\n        } else if ($this.dirId && keyMap[$this.dirId]) {\\r\\n            if (curArr && curArr.length > 0 && typeMap[curArr[0]] && typeMap[curArr[0]].type != 'lvl') {\\r\\n                let busiPropMatched = true;\\r\\n                curArr.forEach(targetK => {\\r\\n                    if (!keyMap[targetK]) {\\r\\n                        busiPropMatched = false;\\r\\n                    }\\r\\n                });\\r\\n                if(busiPropMatched) {\\r\\n                    $this.setFormData({ busiProps: [curArr] });\\r\\n                }\\r\\n            }\\r\\n        }\\r\\n        const idNameMap = {};\\r\\n        const nameIdMap = {};\\r\\n        data.data.forEach(item => {\\r\\n            idNameMap[item.id] = item.name;\\r\\n            nameIdMap[item.name] = item.id;\\r\\n        });\\r\\n        const lvlTemp = roots.filter(item => {\\r\\n            return item.type == 'lvl';\\r\\n        });\\r\\n        if (lvlTemp.length > 0 && lvlTemp[0].children) {\\r\\n            $this.setLvlOptions(lvlTemp[0].children);\\r\\n        }\\r\\n        if ($this.formData.lvl) {\\r\\n            const getSubjectArr = function (arr, map, id, idNameMap) {\\r\\n                if (map[id] && idNameMap[id] != 'lvl') {\\r\\n                    arr.unshift(idNameMap[id]);\\r\\n                }\\r\\n                if (map[id] && map[id].parentId) {\\r\\n                    getSubjectArr(arr, map, map[id].parentId, idNameMap);\\r\\n                }\\r\\n            }\\r\\n            const curArr = [];\\r\\n            getSubjectArr(curArr, keyMap, nameIdMap[$this.formData.lvl], idNameMap);\\r\\n            $this.setFormData({ lvlArr: curArr });\\r\\n        }\\r\\n\\r\\n    } else {\\r\\n        $this.setFormData({ dirIdArr: curArr });\\r\\n        if ($this.dirId && !$this.formData.id) {\\r\\n            if (!keyMap[$this.dirId]) {\\r\\n                $this.setDirId('');\\r\\n                $this.utils.modal.warning({\\r\\n                    title: '警告',\\r\\n                    content:\\r\\n                        '模型归属目录ID“' + $this.dirId + '”错误，请重新选择！',\\r\\n                });\\r\\n            } else {\\r\\n                findLvl($this.dirId, keyMap);\\r\\n                findTopic($this.dirId, keyMap);\\r\\n            }\\r\\n        }\\r\\n        $this.datasourceMap.loadTopicOptions();\\r\\n        $this.datasourceMap.loadLvlOptions();\\r\\n    }\\r\\n    return data.data[0].children; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    console.error(error);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"getModel\",\"stateName\":\"\",\"descr\":\"获取模型数据\",\"autoLoad\":false,\"serviceId\":\"/_api/datapsLogicModelDraft/{id}\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    config.url=config.url.replace('{id}',$this.modelId);\\r\\n    $this.setLoading(true);\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    $this.setLoading(false);\\r\\n    if (data.data.memberName != ($identity.teamName + '-' + $identity.userId)) {\\r\\n        $this.setDisable(true);\\r\\n        $this.utils.modal.info({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '当前登录用户非模型责任人，只允许查看模型信息。',\\r\\n        });\\r\\n    }\\r\\n    const targetData = { ...data.data };\\r\\n\\r\\n    if (targetData.extendItems) {\\r\\n        targetData.extendItems = JSON.parse(targetData.extendItems);\\r\\n    } else {\\r\\n        targetData.extendItems = {};\\r\\n    }\\r\\n    if (targetData.extendItems.structureType) {\\r\\n        targetData.structureType = targetData.extendItems.structureType;\\r\\n    }\\r\\n    if (targetData.extendItems.preRowKeyRule) {\\r\\n        targetData.preRowKeyRule = targetData.extendItems.preRowKeyRule;\\r\\n    }\\r\\n    if (targetData.extendItems.rowKeyRule) {\\r\\n        targetData.rowKeyRule = targetData.extendItems.rowKeyRule;\\r\\n    }\\r\\n    targetData.namingItems = targetData.extendItems;\\r\\n    const sortArr = function (arr) {\\r\\n        for (var i = 0; i <= arr.length - 1; i++) {  // 外层循环管趟数\\r\\n            for (var j = 0; j < arr.length - i - 1; j++) { // 内层循环管每一趟的交换次数\\r\\n                // 内部交换2个变量的值  前一个和后面一个数组元素相比较\\r\\n                if (arr[j].fieldPosi > arr[j + 1].fieldPosi) {\\r\\n                    var temp = arr[j];\\r\\n                    arr[j] = arr[j + 1];\\r\\n                    arr[j + 1] = temp;\\r\\n                }\\r\\n            }\\r\\n        }\\r\\n    }\\r\\n\\r\\n    if (targetData.datapsLogicModelFieldDraftList) {\\r\\n        sortArr(targetData.datapsLogicModelFieldDraftList);\\r\\n        targetData.datapsLogicModelFieldDraftList.forEach(field => {\\r\\n            if (field.extendItems) {\\r\\n                const tempFieldEt = JSON.parse(field.extendItems);\\r\\n                for (var fk in tempFieldEt) {\\r\\n                    field[fk] = tempFieldEt[fk];\\r\\n                }\\r\\n            }\\r\\n        });\\r\\n    }\\r\\n    const busiProps = [];\\r\\n    targetData.datapsModelBusiPropDraftList.forEach(item => {\\r\\n        busiProps.push(JSON.parse(item.propRemark));\\r\\n    });\\r\\n    $this.setBusiProps(busiProps);\\r\\n    $this.setFormData(targetData);\\r\\n    $this.setFieldsLoaded(true);\\r\\n    $this.datasourceMap.getDsDetail({ dsName: targetData.dsName });\\r\\n    $this.setDirId(targetData.dirId);\\r\\n    $this.setWorkspaceId(targetData.workspaceId);\\r\\n    $this.datasourceMap.getTeamDsOptions();\\r\\n    $this.datasourceMap.loadModelArch();\\r\\n    $this.datasourceMap.resolveNamingRule();\\r\\n    //模型类型回显\\r\\n    const expandFunc = function (arr, map) {\\r\\n        arr.forEach(item => {\\r\\n            map[item.value] = item;\\r\\n            if (item.children) {\\r\\n                expandFunc(item.children, map);\\r\\n            }\\r\\n        });\\r\\n    }\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"saveModel\",\"stateName\":\"\",\"descr\":\"保存模型\",\"autoLoad\":false,\"serviceId\":\"74864532203474944\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    //从父页面表单取数据\\r\\n    const saveData = { ...$this.formData };\\r\\n\\r\\n    saveData.updateUser = $identity.userId;\\r\\n    if (!$this.modelId) {\\r\\n        saveData.createUser = $identity.userId;\\r\\n        saveData.teamName = $identity.teamName;\\r\\n        saveData.memberName = $identity.teamName + '-' + $identity.userId;\\r\\n    }\\r\\n\\r\\n    //二次编辑需要带上模型ID\\r\\n    if ($this.modelId) {\\r\\n        saveData.id = $this.modelId;\\r\\n    }\\r\\n    if ($this.workspaceId) {\\r\\n        saveData.workspaceId = $this.workspaceId;\\r\\n    }\\r\\n    //从目录级联框取模型归属目录ID\\r\\n    if (saveData.dirIdArr && saveData.dirIdArr.length > 0) {\\r\\n        saveData.dirId = saveData.dirIdArr[saveData.dirIdArr.length - 1];\\r\\n    }\\r\\n    //从层次级联框取模型层次编码\\r\\n    if (saveData.lvlArr && saveData.lvlArr.length > 0) {\\r\\n        saveData.lvl = saveData.lvlArr[saveData.lvlArr.length - 1];\\r\\n    }\\r\\n    //从主题级联框取模型主题编码\\r\\n    if (saveData.topicArr && saveData.topicArr.length > 0) {\\r\\n        saveData.topic = saveData.topicArr[saveData.topicArr.length - 1];\\r\\n    }\\r\\n    saveData.datapsModelBusiPropDraftList = [];\\r\\n    if (saveData.busiProps) {\\r\\n        saveData.busiProps.forEach(item => {\\r\\n            const tempProp = {\\r\\n                propValue: item[item.length - 1],\\r\\n                propRemark: JSON.stringify(item)\\r\\n            };\\r\\n            if ($this.archTypeMap[item[item.length - 1]]) {\\r\\n                tempProp.propName = $this.archTypeMap[item[item.length - 1]].name;\\r\\n            }\\r\\n            if ($this.archMap[item[item.length - 1]]) {\\r\\n                tempProp.propLabel = $this.archMap[item[item.length - 1]].label;\\r\\n            }\\r\\n            saveData.datapsModelBusiPropDraftList.push(tempProp);\\r\\n        });\\r\\n    }\\r\\n\\r\\n    //去掉多余的属性\\r\\n    delete saveData.dirIdArr;\\r\\n    delete saveData.lvlArr;\\r\\n    delete saveData.topicArr;\\r\\n    delete saveData.busiProps;\\r\\n\\r\\n    if ($this.$refs.cfgTabs.state.activeTab == 'fields') {\\r\\n        saveData.datapsLogicModelFieldDraftList = $this.getChildren('fields').formData.fields;\\r\\n    } else if ($this.$refs.cfgTabs.state.activeTab == ($this.dsType + 'Physic')) {\\r\\n        if ($this.getChildren($this.dsType + 'Physic')) {\\r\\n            saveData.extendItems = $this.getChildren($this.dsType + 'Physic').formData;\\r\\n        }\\r\\n    } else if ($this.$refs.cfgTabs.state.activeTab == ('strategyCfg')) {\\r\\n        saveData.datapsTabStorageRuleDraftList = $this.getChildren('strategyCfg').formData.strategys;\\r\\n    }\\r\\n\\r\\n    if (!saveData.extendItems) {\\r\\n        saveData.extendItems = {};\\r\\n    }\\r\\n\\r\\n    if (['redis'].indexOf($this.dsType) && saveData.extendItems.dataTypeArr && saveData.extendItems.dataTypeArr.length > 0) {\\r\\n        saveData.extendItems.dataType = saveData.extendItems.dataTypeArr[saveData.extendItems.dataTypeArr.length - 1];\\r\\n    }\\r\\n\\r\\n    const fieldNames = [];\\r\\n    $this.namingComs.fields.forEach(item => {\\r\\n        fieldNames.push(item.field);\\r\\n    });\\r\\n    for (var k in saveData.namingItems) {\\r\\n        if (fieldNames.indexOf(k) > -1) {\\r\\n            saveData.extendItems[k] = saveData.namingItems[k];\\r\\n        }\\r\\n    }\\r\\n\\r\\n    const tempFields = saveData.datapsLogicModelFieldDraftList;\\r\\n    saveData.datapsLogicModelFieldDraftList = [];\\r\\n    tempFields.forEach(field => {\\r\\n        if ($this.lowerUpperCase == 'lower') {\\r\\n            field.fieldName = field.fieldName.toLowerCase();\\r\\n        } else if ($this.lowerUpperCase == 'upper') {\\r\\n            field.fieldName = field.fieldName.toUpperCase();\\r\\n        }\\r\\n        saveData.datapsLogicModelFieldDraftList.push(_.extend({}, field));\\r\\n    })\\r\\n\\r\\n    if (['kafka', 'redis', 'pulsar', 'hbase', 'elasticsearch'].indexOf($this.dsType) > -1 && saveData.structureType) {\\r\\n        saveData.extendItems.structureType = saveData.structureType;\\r\\n    }\\r\\n\\r\\n    if (['redis'].indexOf($this.dsType) > -1 && saveData.preRowKeyRule) {\\r\\n        saveData.extendItems.preRowKeyRule = saveData.preRowKeyRule;\\r\\n        saveData.extendItems.keyValue = saveData.preRowKeyRule.prefix + ':' + saveData.preRowKeyRule.rowKeyRule;\\r\\n        delete saveData.preRowKeyRule;\\r\\n    }\\r\\n\\r\\n    if (['hbase'].indexOf($this.dsType) > -1 && saveData.rowKeyRule) {\\r\\n        saveData.extendItems.rowKeyRule = saveData.rowKeyRule;\\r\\n        delete saveData.rowKeyRule;\\r\\n    }\\r\\n\\r\\n    //取扩展参数\\r\\n    saveData.extendItems = JSON.stringify(saveData.extendItems);\\r\\n    if ($this.lowerUpperCase == 'lower') {\\r\\n        saveData.modelName = saveData.modelName.toLowerCase();\\r\\n    } else if ($this.lowerUpperCase == 'upper') {\\r\\n        saveData.modelName = saveData.modelName.toUpperCase();\\r\\n    }\\r\\n\\r\\n    for (var i in saveData.datapsLogicModelFieldDraftList) {\\r\\n        var field = saveData.datapsLogicModelFieldDraftList[i];\\r\\n        field.fieldPosi = (Number(i) + 1);\\r\\n        if (field.length) {\\r\\n            field.length = field.length + '';\\r\\n        }\\r\\n        if (field.length == '') {\\r\\n            field.length = null;\\r\\n        }\\r\\n        if (field.precisionVal) {\\r\\n            field.precisionVal = field.precisionVal + '';\\r\\n        }\\r\\n        if (field.precisionVal == '') {\\r\\n            field.precisionVal = null;\\r\\n        }\\r\\n        const tempFieldEt = {};\\r\\n        if ($this.dsType == 'kafka') {\\r\\n            tempFieldEt.dateFormat = field.dateFormat;\\r\\n            delete field.dateFormat;\\r\\n            tempFieldEt.selectionType = field.selectionType;\\r\\n            delete field.selectionType;\\r\\n            tempFieldEt.primaryKeySeq = field.primaryKeySeq;\\r\\n            delete field.primaryKeySeq;\\r\\n        } else if ($this.dsType == 'redis') {\\r\\n            tempFieldEt.isKey = field.isKey;\\r\\n            delete field.isKey;\