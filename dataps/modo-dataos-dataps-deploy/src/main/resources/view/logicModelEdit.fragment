ntent:\\r\\n                        '请至少选择一个字段名为主键！',\\r\\n                });\\r\\n                return;\\r\\n            }\\r\\n\\r\\n            let flagDate;\\r\\n            for (let i in cmshFields) {\\r\\n                if (cmshFields[i].isDatatimeField === '1') {\\r\\n                    flagDate = 1;\\r\\n                    break;\\r\\n                }\\r\\n            }\\r\\n            if ((['hive', 'inceptor'].indexOf($this.dsType) != -1) && flagDate != 1) {\\r\\n                $this.utils.modal.error({\\r\\n                    title: '错误',\\r\\n                    content:\\r\\n                        '请至少选择一个字段作为时间标志！',\\r\\n                });\\r\\n                return;\\r\\n            }\\r\\n\\r\\n            let isName = 'dsjzx_taskid';\\r\\n            let isEx;\\r\\n            for (let i in cmshFields) {\\r\\n                if (cmshFields[i].fieldName.toLowerCase() === isName) {\\r\\n                    isEx = 1\\r\\n                    break;\\r\\n                }\\r\\n            }\\r\\n            if (!$this.formData.lvlArr.includes(\\\"ODS\\\") && isEx != 1) {\\r\\n                $this.utils.modal.error({\\r\\n                    title: '错误',\\r\\n                    content:\\r\\n                        '字段dsjzx_taskid不存在，请增加该字段！',\\r\\n                });\\r\\n                return;\\r\\n            }\\r\\n        }\\r\\n    }\\r\\n    $this.$refs.baseForm.validate(valid => {\\r\\n        if (valid) {\\r\\n            if ($this.getChildren('fields') && $this.getChildren('fields').formData && $this.getChildren('fields').formData.fields) {\\r\\n                $this.getChildren('fields').$refs.fieldsForm.validate(valid2 => {\\r\\n                    if (valid2) {\\r\\n                        if ($this.getChildren($this.dsType + 'Physic') && $this.getChildren($this.dsType + 'Physic').formData && $this.getChildren($this.dsType + 'Physic').$refs.physicForm) {\\r\\n                            $this.getChildren($this.dsType + 'Physic').$refs.physicForm.validate(valid3 => {\\r\\n                                if (valid3) {\\r\\n                                    if ($this.getChildren('strategyCfg') && $this.getChildren('strategyCfg').formData) {\\r\\n\\r\\n                                        $this.getChildren('strategyCfg').$refs.strategysForm.validate(valid4 => {\\r\\n                                            if (valid4) {\\r\\n                                                $this.datasourceMap.saveModel();\\r\\n                                            } else {\\r\\n                                                if ($this.$refs.cfgTabs.state.activeTab == 'strategyCfg') {\\r\\n                                                    $this.setFormData({ datapsTabStorageRuleDraftList: $this.getChildren('strategyCfg').formData.strategys });\\r\\n                                                }\\r\\n                                                $this.$refs.cfgTabs.setActive('strategyCfg');\\r\\n                                            }\\r\\n                                        });\\r\\n                                    } else {\\r\\n                                        $this.datasourceMap.saveModel();\\r\\n                                    }\\r\\n\\r\\n                                } else {\\r\\n                                    if ($this.$refs.cfgTabs.state.activeTab == 'fields') {\\r\\n                                        $this.setFormData({ datapsLogicModelFieldDraftList: $this.getChildren('fields').formData.fields });\\r\\n                                    }\\r\\n                                    $this.$refs.cfgTabs.setActive($this.dsType + 'Physic');\\r\\n                                }\\r\\n                            });\\r\\n                        } else {\\r\\n                            $this.datasourceMap.saveModel();\\r\\n                        }\\r\\n                    } else {\\r\\n                        if ($this.$refs.cfgTabs.state.activeTab == ($this.dsType + 'Physic')) {\\r\\n                            $this.setFormData({ extendItems: $this.getChildren($this.dsType + 'Physic').formData });\\r\\n                        }\\r\\n                        $this.$refs.cfgTabs.setActive('fields');\\r\\n                    }\\r\\n                });\\r\\n            } else {\\r\\n                if ($this.getChildren($this.dsType + 'Physic') && $this.getChildren($this.dsType + 'Physic').formData && $this.getChildren($this.dsType + 'Physic').$refs.physicForm) {\\r\\n                    $this.getChildren($this.dsType + 'Physic').$refs.physicForm.validate(valid3 => {\\r\\n                        if (valid3) {\\r\\n                            $this.datasourceMap.saveModel();\\r\\n                        } else {\\r\\n                            if ($this.$refs.cfgTabs.state.activeTab == 'fields') {\\r\\n                                $this.setFormData({ datapsLogicModelFieldDraftList: $this.getChildren('fields').formData.fields });\\r\\n                            }\\r\\n                            $this.$refs.cfgTabs.setActive($this.dsType + 'Physic');\\r\\n                        }\\r\\n                    });\\r\\n                }\\r\\n            }\\r\\n        }\\r\\n    })\\r\\n}\"}},\"type\":\"primary\",\"disabledBindVar\":\"\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]}]}]}]}]}]","inputVars":null,"viewPlugins":null,"version":1041,"createUser":"chengkai3","createDt":null,"lastupd":null,"updateUser":null,"digest":null,"versionInfo":"","appName":"dataps","createUserName":null}