       \"showConfirm\": false,\n                                                                    \"fail\": \"\",\n                                                                    \"data\": \"{}\",\n                                                                    \"before\": \"\",\n                                                                    \"successActions\": [],\n                                                                    \"success\": \"\",\n                                                                    \"placeholders\": [],\n                                                                    \"confirmText\": \"\",\n                                                                    \"successMsg\": \"\",\n                                                                    \"errorMsg\": \"\"\n                                                                },\n                                                                \"type\": \"view\",\n                                                                \"actions\": []\n                                                            },\n                                                            \"callback\": \"\"\n                                                        }\n                                                    },\n                                                    \"hidden\": false,\n                                                    \"successActions\": [],\n                                                    \"icon\": \"IconDelete\",\n                                                    \"showTooltip\": false,\n                                                    \"id\": \"action699567223292af61\",\n                                                    \"label\": \"\",\n                                                    \"services\": [],\n                                                    \"type\": \"text\",\n                                                    \"fragmentRef\": \"5f1089c19a2a0642\",\n                                                    \"showIcon\": false,\n                                                    \"event\": {\n                                                        \"builtIn\": {\n                                                            \"type\": \"view\",\n                                                            \"isSingleService\": true,\n                                                            \"urlAction\": {\n                                                                \"url\": null,\n                                                                \"blank\": true\n                                                            },\n                                                            \"viewActions\": [],\n                                                            \"actions\": []\n                                                        },\n                                                        \"callback\": \"function callback(row) {\\n    $utils.modal.confirm({\\n        title: '是否确定删除程序？',\\n        content:\\n            '',\\n        okButtonProps: {\\n            status: 'danger',\\n        },\\n        onOk: () => {\\n            deleteDefine(row.stepInst);\\n        },\\n    });\\n    var deleteDefine = function (stepInst) {\\n        $this.setLoading(true);\\n        $utils.axios.post('/_api/_/dp-proc/step/define/delete/' + row.stepInst).then(res => {\\n            var data = res.data;\\n            $this.setLoading(false);\\n            if (data.success) {\\n                $utils.message.success(data.message);\\n            } else {\\n                $utils.message.success(data.message);\\n            };\\n            $this.datasourceMap.getTable(0, 30);\\n        }).catch(function (error) {\\n            console.log(error);\\n            $this.setLoading(false);\\n        });\\n    }\\n\\n\\n\\n}\"\n                                                    },\n                       