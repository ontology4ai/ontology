                                                    \"condition\": \"true\",\n                                                                \"showType\": \"modal\",\n                                                                \"viewName\": null,\n                                                                \"before\": \"function beforeCallback() {}\",\n                                                                \"width\": \"50%\",\n                                                                \"top\": \"15vh\",\n                                                                \"fullscreen\": false,\n                                                                \"size\": \"50%\",\n                                                                \"tabViewName\": null,\n                                                                \"tabParams\": \"\",\n                                                                \"tabKey\": \"\",\n                                                                \"tabLabel\": \"\"\n                                                            }\n                                                        ],\n                                                        \"actions\": []\n                                                    },\n                                                    \"callback\": \"function callback(current) {\\n    let pageNum = current.pageSize * (current.current - 1);\\n    let pageSize = current.pageSize;\\n    $this.setPageNum(pageNum);\\n    $this.setPageSize(pageSize);\\n    $this.datasourceMap.getTable('');\\n}\"\n                                                }\n                                            },\n                                            \"service\": {\n                                                \"data\": \"{}\",\n                                                \"before\": \"function beforeCallback(params, service) {\\n    if ($this.filterForm.model.lastupdDateGte) {\\n        params['lastupdDate.gte'] = $this.filterForm.model.lastupdDateGte\\n    }\\n   if ($this.filterForm.model.lastupdDateLte) {\\n       \\n        params['lastupdDate.lte'] = $this.filterForm.model.lastupdDateLte\\n    }\\n    delete params.lastupdDate;\\n    if (params.operState == '0') {\\n        delete params.operState;\\n        params['operState.ne'] = '0';\\n    }\\n  \\tif ($this.filterForm.model.memberLabel) {\\n        params.memberLabel = '~%' + $this.filterForm.model.memberLabel + '%';\\n    }\\n  \\tif ($this.filterForm.model.keyWord) {\\n        params._orGroup_ = 'assetLabel,assetCode,assetDescr=~%' + $this.filterForm.model.keyWord + '%'\\n    }\\n    params.userId = $identity.userId;\\n    params.teamName = $identity.teamName;\\n    params.collectType = 'asset_table';\\n    params.offset = ($this.metaModel_list.pageNum - 1) * $this.metaModel_list.pageSize;\\n    params.limit = $this.metaModel_list.pageSize;\\n    return params;\\n}\",\n                                                \"successActions\": [],\n                                                \"placeholders\": [],\n                                                \"confirmText\": \"\",\n                                                \"label\": \"服务\",\n                                                \"url\": \"22683116535779328\",\n                                                \"errorMsg\": \"\",\n                                                \"showConfirm\": false,\n                                                \"fail\": \"\",\n                                                \"condition\": \"\",\n                                                \"success\": \"\",\n                                                \"successMsg\": \"\",\n                                                \"fields\": []\n                                            },\n                                            \"actions\": [\n                                                {\n                                                    \"eventMap\": {\n                                                        \"click\": {\n                                                            \"builtIn\": {\n                                                                \"urlAction\": {\n                                                                    \"blank\": true\n                                                                },\n                                                                \"viewAction\": {\n                                                                    \"viewId\": \"032cfcb824f3a399\",\n                                                                    \"tabLabel\": \"\",\n                                                                    \"top\": \"15vh\",\n                                                                    \"fullscreen\": false,\n                                                                    \"size\": \"50%\",\n                                                                    \"viewName\": \"exchange_online\",\n                                                                    \"before\": \"function beforeCallback(row, ref, callback) {\\n    $this.state.onlineServs.splice(0);\\n    $this.state.onlineServs.push(row);\\n    callback();\\n}\",\n                                                                    \"width\": \"50%\",\n                                                                    \"showType\": \"dialog\",\n                                                                    \"tabKey\": \"\",\n                                                                    \"tabParams\": \"\"\n                                                                },\n                                                                \"serviceActions\": [],\n                                                                \"isSingleService\": true,\n                                                                \"serviceAction\": {\n                                                                    \"showConfirm\": false,\n                                                                    \"fail\": \"\",\n                                                                    \"data\": \"{}\",\n                                                                    \"before\": \"\",\n                                                                    \"successActions\": [],\n                                                                    \"success\": \"\",\n                                                                    \"placeholders\": [],\n                                                                    \"confirmText\": \"\",\n                                                                    \"successMsg\": \"\",\n                                                                    \"errorMsg\": \"\"\n                                                                },\n                                                                \"type\": \"url\",\n                                                                \"actions\": []\n                                                            },\n                                                            \"callback\": \"function callback(row, ref) {\\n    /**\\n     * @param {Object} row - 行数据\\n     * @param {Object} ref - 表格实例\\n     */\\n    $this.state.onlineServs.splice(0);\\n    $this.state.onlineServs.push(row);\\n    $http.get(`/_api/goCatalogSafeFlow/find?applyType=4&tabId=${row.assetId}`).then(resp => {\\n        let length = resp.data.data.length\\n        let data = resp.data.data\\n        console.log(length)\\n        if (data && length > 0) {\\n            data.sort((a, b) => {\\n                return new Date(a.updateTime).getTime() - new Date(b.updateTime).getTime()\\n            })\\n\\n            if (data[length - 1].flowState == '1') {\\n                $this.modelListTabs.addTab(\\n                    $utils.guid(),\\n                    row.assetLabel,\\n                    null,\\n                    'view',\\n                    'exchange_online', {\\n                        tabId: row.assetId,\\n                        applyId: '',\\n                        applyType: '4'\\n                    }\\n                );\\n            } else {\\n                console.log($app)\\n                $app.$notify({\\n                    title: '警告',\\n                    type: 'warning',\\n                    showClose: true,\\n                    message: '市场经营工单尚未完成审核'\\n                })\\n            }\\n        } else {\\n            $app.$confirm('本服务未提交安全审核，安全审核通过后方可操作上架', '提示', {\\n                confirmButtonText: '安全审核',\\n                cancelButtonText: '取消',\\n                type: 'warning'\\n            }).then(() => {\\n              exchangeOnlineSafety()\\n            }).catch(() => {\\n                $app.$notify({\\n                    type: 'warning',\\n                    showClose: true,\\n                    message: '已取消审核'\\n                });\\n            });\\n        }\\n    })\\n\\n    function exchangeOnlineSafety() {\\n        $http.post('/api/exchangeOnlineSafety', {\\n            applyId: '',\\n            tabId: row.assetId,\\n            checkView: '',\\n            checkState: '0',\\n            applyType: '4',\\n            createUser: $identity.userId\\n        }).then(res => {\\n            if (res.data.code == 200) {\\n                $app.$notify({\\n                    type: 'success',\\n                    showClose: true,\\n                    message: '审核提交成功'\\n                });\\n            } else {\\n                $app.$notify({\\n                    type: 'error',\\n                    showClose: true,\\n                    message: '审核提交失败'\\n                });\\n            }\\n        })\\n    }\\n\\n    return row;\\n}\"\n                                                        }\n                                       