Data(listToTree(data.data));\\n    return data.data; // 重要，需返回 data\\n}\\n\\nfunction listToTree(data, idName, parentIdName) {\\n    if (!idName) {\\n        idName = 'name';\\n    }\\n    if (!parentIdName) {\\n        parentIdName = 'parentName';\\n    }\\n\\n    // * 先生成parent建立父子关系\\n    const obj = {};\\n    data.forEach((item) => {\\n        obj[item[idName]] = item;\\n    });\\n    const parentList = [];\\n    data.forEach((item) => {\\n        // item.hasChildren = false;\\n        item.key = item.name;\\n        item.title = item.label;\\n        const parent = obj[item[parentIdName]];\\n        if (parent) {\\n            // * 当前项有父节点\\n            parent.children = parent.children || [];\\n            parent.children.push(item);\\n            // parent.hasChildren = true;\\n        } else {\\n            // * 当前项没有父节点 -> 顶层\\n            parentList.push(item);\\n        }\\n    });\\n    return parentList;\\n}\",\"fail\":\"function failCallback(error){\\n    // console.log(error);\\n    // 可以在这里做弹框提示等操作\\n}\",\"methodType\":\"GET\",\"description\":\"工作空间目录表通过参数查询对象\",\"methodName\":\"find\",\"type\":\"model\",\"url\":\"/_api/modelWorkspaceDir/find\"},{\"name\":\"deleteBatch\",\"stateName\":\"\",\"label\":\"工作空间目录表\",\"descr\":\"批量删除对象信息\",\"method\":\"POST\",\"autoLoad\":true,\"loadType\":\"1\",\"fields\":[],\"serviceId\":\"/_api/modelWorkspaceDir/deleteBatch\",\"condition\":true,\"conditionBindVar\":\"\",\"data\":\"{}\",\"dataBindVar\":\"\",\"placeholders\":[],\"before\":\"function beforeCallback(vars, config) {\\n    // 通过 vars.params 可以更改查询参数\\n    // 通过 vars.data 可以更改requestdata\\n    // 通过 config.header 可以更改 header\\n    // 通过 config.url 可以更改  url\\n    /* vars.data = {\\n    } */\\n    // console.log(vars, config);\\n    // 可以查看还有哪些参数可以修改。\\n}\",\"success\":\"function successCallback(data) {\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\n    return data.data; // 重要，需返回 data\\n}\",\"fail\":\"function failCallback(error){\\n    // console.log(error);\\