indVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onClick\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\r\\n\\r\\n  debugger;\\r\\n  console.log($this.getParent());\\r\\n  let tree = $this.getParent().workspaceDirData;\\r\\n  let pNode =\\r\\n  {\\r\\n    key: $this.getParent().currentNode.name,\\r\\n    title: $this.getParent().currentNode.label,\\r\\n    parentName: $this.getParent().currentNode.parentName\\r\\n  };\\r\\n  if ($this.editType == 'add') {\\r\\n    //遍历父级的树结构，在指定节点插入\\r\\n    let newNode = {\\r\\n      key: $this.curNode.name,\\r\\n      title: $this.curNode.label,\\r\\n      parentName: $this.getParent().currentNode.name\\r\\n    };\\r\\n    //校验节点key是否已存在\\r\\n    let exist = checkNodeInTree(tree, newNode.key, false);\\r\\n    if (exist) {\\r\\n      $utils.modal.warning({\\r\\n        title: '提示',\\r\\n        content:\\r\\n          '节点英文名已存在，请检查后输入！'\\r\\n      });\\r\\n\\r\\n      return;\\r\\n    }\\r\\n\\r\\n    let newTree = insertNode(tree, pNode, newNode);\\r\\n    $this.getParent().setWorkspaceDirData(newTree);\\r\\n  } else {\\r\\n    //遍历父级的树结构，修改指定节点\\r\\n    let newNode = {\\r\\n      key: $this.curNode.name,\\r\\n      title: $this.curNode.label,\\r\\n      parentName: $this.getParent().currentNode.parentName\\r\\n    };\\r\\n    //校验节点key是否已存在\\r\\n\\r\\n    let newTree = updateNode(tree, pNode, newNode);\\r\\n    $this.getParent().setWorkspaceDirData(newTree);\\r\\n  }\\r\\n\\r\\n  $this.close();\\r\\n  $this.curNode = {};\\r\\n\\r\\n}\\r\\n\\r\\nfunction insertNode(tree, pNode, newNode) {\\r\\n  return appendNodeInTree(pNode.key, tree, newNode);\\r\\n}\\r\\n\\r\\nfunction appendNodeInTree(key, tree, obj) {\\r\\n  tree.forEach(ele => {\\r\\n    if (ele.key === key) {\\r\\n      ele.children ? ele.children.push(obj) : ele.children = [obj]\\r\\n    } else {\\r\\n      if (ele.children) {\\r\\n        appendNodeInTree(key, ele.children, obj)\\r\\n      }\\r\\n    }\\r\\n  })\\r\\n  return tree;\\r\\n}\\r\\n\\r\\nfunction updateNode(tree, node, newNode) {\\r\\n  return updateNodeInTree(tree, node.key, newNode);\\r\\n\\r\\n}\\r\\nfunction updateNodeInTree(treeList, key, obj) {\\r\\n  if (!treeList || !treeList.length) {\\r\\n    return;\\r\\n  }\\r\\n  for (let i = 0; i < treeList.length; i++) {\\r\\n    if (treeList[i].key == key) {\\r\\n      treeList[i] = obj;\\r\\n      break;\\r\\n    }\\r\\n    updateNodeInTree(treeList[i].children, key, obj);\\r\\n  }\\r\\n  return treeList;\\r\\n\\r\\n}\\r\\n\\r\\nfunction checkNodeInTree(treeList, key, exixt) {\\r\\n  if (!treeList || !treeList.length) {\\r\\n    return exixt;\\r\\n  }\\r\\n  for (let i = 0; i < treeList.length; i++) {\\r\\n    if (treeList[i].key == key) {\\r\\n      exixt = true;\\r\\n      return exixt;\\r\\n    }\\r\\n    return checkNodeInTree(treeList[i].children, key);\\r\\n  }\\r\\n  return exixt;\\r\\n}\"}},\"type\":\"primary\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]}]}]}]}]}]","inputVars":null,"viewPlugins":null,"version":47,"createUser":"xiacj3","createDt":null,"lastupd":null,"updateUser":null,"digest":null,"versionInfo":"","appName":"dataps","createUserName":null}