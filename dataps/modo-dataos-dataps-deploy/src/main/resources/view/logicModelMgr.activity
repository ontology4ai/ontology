isable(true);\\r\\n    }\\r\\n    $this.datasourceMap.getSystemProperty({ name: 'customAppSign' });//获取系统标识\\r\\n    //获取是否展示局方责任人开关\\r\\n    $this.datasourceMap.getProperty();\\r\\n}\"\n                }\n            },\n            \"type\": \"one-screen-layout\",\n            \"titleVisible\": false,\n            \"vars\": [\n                {\n                    \"name\": \"filterFormData\",\n                    \"descr\": \"表单数据\",\n                    \"value\": \"{}\"\n                },\n                {\n                    \"name\": \"pageNum\",\n                    \"descr\": \"页码\",\n                    \"value\": \"1\"\n                },\n                {\n                    \"name\": \"pageSize\",\n                    \"descr\": \"一页大小\",\n                    \"value\": \"20\"\n                },\n                {\n                    \"name\": \"searching\",\n                    \"descr\": \"查询loading\",\n                    \"value\": \"false\"\n                },\n                {\n                    \"name\": \"modelTreeSelectedKeys\",\n                    \"descr\": \"模型目录树选中节点的key\",\n                    \"value\": \"[]\"\n                },\n                {\n                    \"name\": \"currNode\",\n                    \"descr\": \"当前选中结点\",\n                    \"value\": \"null\"\n                },\n                {\n                    \"name\": \"editSupport\",\n                    \"descr\": \"是否支持编辑（暂时没考虑好哪些场景需要编辑，先默认为可编辑）\",\n                    \"value\": \"true\"\n                },\n                {\n                    \"name\": \"batchOperRows\",\n                    \"descr\": \"批量操作时选中的行（校验用）\",\n                    \"value\": \"[]\"\n                },\n                {\n                    \"name\": \"teamMemberOptions\",\n                    \"descr\": null,\n                    \"value\": \"[]\"\n                },\n                {\n                    \"name\": \"disable\",\n                    \"descr\": null,\n                    \"value\": \"false\"\n                },\n                {\n                    \"name\": \"userWorkspaceOptions\",\n                    \"descr\": null,\n                    \"value\": \"[]\"\n                },\n                {\n                    \"name\": \"workspaceFormData\",\n                    \"descr\": null,\n                    \"value\": \"{\\r\\n}\"\n                },\n                {\n                    \"name\": \"isMgrRole\",\n                    \"descr\": null,\n                    \"value\": \"false\"\n                },\n                {\n                    \"name\": \"customAppSign\",\n                    \"descr\": \"应用定制标识cmsh\",\n                    \"value\": \"''\"\n                },\n                {\n                    \"name\": \"useArchAsTag\",\n                    \"descr\": null,\n                    \"value\": \"'false'\"\n                },\n                {\n                    \"name\": \"showOfficialMember\",\n                    \"descr\": \"是否展示局方责任人true展示 false不展示\",\n                    \"value\": \"false\"\n                }\n            ],\n            \"models\": [],\n            \"services\": [\n                {\n                    \"name\": \"getModelPage\",\n                    \"stateName\": \"modelPage\",\n                    \"descr\": \"分页查询逻辑模型\",\n                    \"autoLoad\": true,\n                    \"loadType\": \"1\",\n                    \"serviceId\": \"192960566994395136\",\n                    \"method\": \"GET\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": [],\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    vars.data = _.extend({}, $this.$refs.filterForm.getFieldsValue());\\r\\n    vars.data.teamName = $identity.teamName;\\r\\n    if (vars.data['lastupd'] && vars.data['lastupd'].length > 0) {\\r\\n        vars.data['lastupd.gte'] = new Date(vars.data['lastupd'][0]+' 00:00:00').getTime();\\r\\n        vars.data['lastupd.lte'] = new Date(vars.data['lastupd'][1]+' 00:00:00').getTime()+(24*60*60*1000);\\r\\n        delete vars.data['lastupd'];\\r\\n    }\\r\\n    if (vars.data['createDt'] && vars.data['createDt'].length > 0) {\\r\\n        vars.data['createDt.gte'] = new Date(vars.data['createDt'][0]+' 00:00:00').getTime();\\r\\n        vars.data['createDt.lte'] = new Date(vars.data['createDt'][1]+' 00:00:00').getTime()+(24*60*60*1000);\\r\\n        delete vars.data['createDt'];\\r\\n    }\\r\\n    delete vars.data.dirNodeId;\\r\\n    const expandChildrenTag = function(node, arr, prop){\\r\\n        if(prop){\\r\\n            arr.push(node[prop]);\\r\\n        }else{\\r\\n            arr.push(node);\\r\\n        }\\r\\n        if(node.childrenData){\\r\\n            node.childrenData.forEach(subNode=>{\\r\\n                expandChildrenTag(subNode, arr, prop);\\r\\n            });\\r\\n        }else if(node.children){\\r\\n            node.children.forEach(subNode=>{\\r\\n                expandChildrenTag(subNode, arr, prop);\\r\\n            });\\r\\n        }\\r\\n    };\\r\\n    if ($this.currNode) {\\r\\n        vars.data.archNodeId = $this.currNode.id;\\r\\n        vars.data.workspaceId = $this.currNode.workspaceId;\\r\\n        if($this.currNode){\\r\\n            const tagArr = [];\\r\\n            expandChildrenTag($this.currNode, tagArr, 'id');\\r\\n            vars.data.archTags = tagArr.join(',');\\r\\n            const targetNodes = [];\\r\\n            expandChildrenTag($this.currNode, targetNodes);\\r\\n            const targetLvls = [];\\r\\n            targetNodes.forEach(item=>{\\r\\n                if(item.type=='lvl'){\\r\\n                    targetLvls.push(item.name);\\r\\n                }\\r\\n            });\\r\\n            vars.data.lvls = targetLvls.join(',');\\r\\n        }\\r\\n    }\\r\\n    vars.data.searchSubNode = true;\\r\\n    vars.data.limit = $this.pageSize;\\r\\n    vars.data.offset = ($this.pageNum - 1) * $this.pageSize;\\r\\n    if($this.workspaceFormData.workspaceId){\\r\\n        vars.data.workspaceId = $this.workspaceFormData.workspaceId;\\r\\n    }\\r\\n    vars.data.isMgr = '1';\\r\\n    $this.setSearching(true);\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    \\r\\n    for(var i = 0;i<data.data.content.length;i++){\\r\\n        data.data.content[i].index = i+1;\\r\\n        data.data.content[i].stateName = $i18n(data.data.content[i].stateName);\\r\\n        data.data.content[i].onlineResState = $i18n(data.data.content[i].onlineResState);\\r\\n        let extendItems = {};\\r\\n        try{\\r\\n            extendItems = JSON.parse(data.data.content[i].extendItems);\\r\\n        }catch(e){\\r\\n            console.error(e);\\r\\n        }\\r\\n        if(extendItems!=null&&extendItems.hasOwnProperty('official_member_name')) {\\r\\n            data.data.content[i].officialMemberName = extendItems.official_member_name;\\r\\n        }else{\\r\\n            data.data.content[i].officialMemberName = \\\"\\\";\\r\\n        }\\r\\n    }\\r\\n    $this.setSearching(false);\\r\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    $this.setSearching(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\n                    \"callback\": \"\"\n                },\n                {\n                    \"name\": \"getArchTree\",\n                    \"stateName\": \"archTree\",\n                    \"descr\": \"获取逻辑模型树\",\n                    \"autoLoad\": true,\n                    \"loadType\": \"1\",\n                    \"serviceId\": \"177879512999989248\",\n                    \"method\": \"GET\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": [],\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    vars.params.withCount = false;\\r\\n    vars.params.teamName = $identity.teamName;\\r\\n    return vars;\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    data.data.push({\\r\\n        id:'_un_category_node_',\\r\\n        key:'_un_category_node_',\\r\\n        archLabel:'未归类',\\r\\n        label:'未归类'\\r\\n    });\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\n                    \"callback\": \"\"\n                },\n                {\n                    \"name\": \"getTeamMembers\",\n                    \"stateName\": \"teamMemberOptions\",\n                    \"descr\": \"获取团队成员信息\",\n                    \"autoLoad\": true,\n                    \"serviceId\": \"/_api/_/teamMember/listMemberByTeamName\",\n                    \"method\": \"GET\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    vars.params.teamName = $identity.teamName||'';\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\r\\n    data.data.forEach(item=>{\\r\\n        item.memberName = $identity.teamName+'-'+item.userId;\\r\\n    });\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\"\n                },\n                {\n                    \"name\": \"modelOnline\",\n                    \"stateName\": \"\",\n                    \"descr\": \"逻辑模型上架\",\n   