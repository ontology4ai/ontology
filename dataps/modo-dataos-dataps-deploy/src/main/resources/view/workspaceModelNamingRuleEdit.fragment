llback(vars, config) {\\r\\n    vars.params.workspaceId=$this.parent.workspaceId;\\r\\n    vars.params.subjectName='lvl';\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    $this.setLvlOptions(data.data);\\r\\n    const idMap = {};\\r\\n    const nameMap = {};\\r\\n    var loadMapFunc = function (arr, map, nameMap) {\\r\\n        arr.forEach(item => {\\r\\n            map[item.value] = item;\\r\\n            nameMap[item.value] = item.value;\\r\\n            if (item.children) {\\r\\n                loadMapFunc(arr, map);\\r\\n            }\\r\\n        });\\r\\n    }\\r\\n    loadMapFunc(data.data, idMap, nameMap);\\r\\n    var resolveArr = function (id, arr, map) {\\r\\n        arr.push(map[id].value);\\r\\n        if (map[id] && map[id].parentId && map[map[id].parentId]) {\\r\\n            resolveArr(map[map[id].parentId].id, arr, map);\\r\\n        }\\r\\n    }\\r\\n    const targetArr = [];\\r\\n    if ($this.formData.lvl) {\\r\\n        resolveArr(nameMap[$this.formData.lvl], targetArr, idMap);\\r\\n        $this.setFormData({targetArr:targetArr});\\r\\n    }\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"resolveRule\",\"stateName\":\"\",\"descr\":\"\",\"autoLoad\":false,\"serviceId\":\"dataps-139382593555763200\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.params.workspaceId = $this.parent.workspaceId;\\r\\n    vars.params.rule = encodeURI($this.formData.namingRule);\\r\\n    $this.setLoading(true);\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    $this.setLoading(false);\\r\\n    $this.setActiveStep($this.activeStep + 1);\\r\\n    $this.$refs.steps.setCurrent($this.activeStep + 1);\\r\\n    const namingComs = { layout: 'inline', fields: [] };\\r\\n    data.data.forEach(item => {\\r\\n        let com = {};\\r\\n        if (item.defValue) {\\r\\n            com = { label: item.defValue };\\r\\n        } else if (item.recComponent == 'select') {\\r\\n            com = { field: item.field, label: item.recRule, noStyle: true };\\r\\n            com.type = 'select';\\r\\n            com.options = {\\r\\n                placeholder: item.recRule,\\r\\n                options: item.options,\\r\\n                type: 'button',\\r\\n                style: {\\r\\n                    width: '100px'\\r\\n                }\\r\\n            }\\r\\n        } else if (item.recComponent == 'cascader') {\\r\\n            com = { field: item.field, label: item.recRule, noStyle: true };\\r\\n            com.type = 'cascader';\\r\\n            com.options = {\\r\\n                placeholder: item.recRule,\\r\\n                options: item.options,\\r\\n                style: {\\r\\n                    width: '100px'\\r\\n                }\\r\\n            }\\r\\n        } else if (item.recComponent == 'input') {\\r\\n            com = { field: item.field, label: item.recRule, noStyle: true };\\r\\n            com.type = 'input';\\r\\n            com.options = {\\r\\n                placeholder: item.recRule,\\r\\n                style: {\\r\\n                    width: '100px'\\r\\n                }\\r\\n            }\\r\\n        }\\r\\n        namingComs.fields.push(com);\\r\\n    });\\r\\n    $this.setNamingComs(namingComs);\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error) {\\r\\n    $this.setLoading(false);\\r\\n    let msg = '命名规则解析失败!';\\r\\n    if (error.data.devMsg && error.data.devMsg.indexOf('java.lang.RuntimeException: ') > -1) {\\r\\n        msg = error.data.devMsg.substr(error.data.devMsg.indexOf('java.lang.RuntimeException: ') + 28);\\r\\n    }\\r\\n    $utils.notification.error({\\r\\n        title: '失败',\\r\\n        content: msg\\r\\n    });\\r\\n}\",\"callback\":\"\"},{\"name\":\