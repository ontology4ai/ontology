stStr.replace(/\\\\s+/g, \\\" \\\")\\n\\t\\treturn resultStr;\\n\\t};\\n\\tvar jsonToString = function (json) {\\n\\t\\tjson = JSON.stringify(json, function (key, val) {\\n\\t\\t\\tif (typeof val === 'function') {\\n\\t\\t\\t\\treturn val + '';\\n\\t\\t\\t}\\n\\t\\t\\treturn val;\\n\\t\\t});\\n\\t\\treturn json;\\n\\t};\\n\\t// console.log('this', $this)\\n\\t$this.$refs.refForm.validate(valid => {\\n\\t\\tif (valid) {\\n\\t\\t\\tvar formData = {};\\n\\t\\t\\tformData = $this.$refs.refForm.getFieldsValue();\\n\\t\\t\\tconsole.log('projectBaseInfo', formData);\\n\\t\\t\\tlet extConf = '';\\n\\n\\t\\t\\tif ($this.oper == 'edit' && ($this.stepInst == 'sql' || $this.stepInst == 'sql-index')) {\\n\\t\\t\\t\\tvar regexp;\\n\\t\\t\\t\\tif (formData.allowCrtTab != '1') {\\n\\t\\t\\t\\t\\tvar errorInfo = formData.allowCrtTab == '3' ? formData.errorInfo : '不允许创建表';\\n\\t\\t\\t\\t\\tregexp = \\\"if (value) { var resultStr = value.replace(/[\\\\\\\\r\\\\\\\\n]/g, ' ');resultStr = resultStr.replace(/\\\\\\\\s+/g, ' ');var regexp = \\\" + formData.regexp + \\\"; if (regexp.test(resultStr)) { callback(new Error('\\\" + errorInfo + \\\"')); } }\\\"\\n\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\tregexp = '';\\n\\t\\t\\t\\t};\\n\\t\\t\\t\\t//更改表单里面的验证函数，暂时不支持\\n\\n\\t\\t\\t};\\n\\t\\t\\tlet defaultExtConf = {\\n\\t\\t\\t\\tallowCrtTab: formData.allowCrtTab ? formData.allowCrtTab : '1',\\n\\t\\t\\t\\tregexp: formData.regexp ? formData.regexp : '/n*/gi',\\n\\t\\t\\t\\terrorInfo: formData.errorInfo ? formData.errorInfo : '',\\n\\t\\t\\t\\tnotify: formData.notify ? formData.notify : ''\\n\\t\\t\\t};\\n\\t\\t\\textConf = JSON.stringify(defaultExtConf);\\n\\t\\t\\tformData.extConf = extConf;\\n\\t\\t\\tif ($this.oper == 'edit') {\\n\\t\\t\\t\\tformData = Object.assign({}, $this.rowData, formData);\\n\\t\\t\\t};\\n\\t\\t\\tif (formData.stepCfg != null && formData.stepCfg != \\\"\\\") {\\n\\t\\t\\t\\ttry {\\n\\t\\t\\t\\t\\tvar jsonStr = null;\\n\\t\\t\\t\\t\\teval('jsonStr = ' + iGetInnerText(formData.stepCfg));\\n\\t\\t\\t\\t\\tformData.stepCfg = jsonToString(jsonStr);\\n\\t\\t\\t\\t\\thandleSave(formData);\\n\\t\\t\\t\\t} catch (e) {\\n\\t\\t\\t\\t\\tconsole.log('组件配置输入内容格式错误')\\n\\t\\t\\t\\t\\t$utils.message.error('组件配置输入内容格式错误!');\\n\\t\\t\\t\\t\\t// _self.$notify({type: 'error', message: '组件配置输入内容格式错误'});\\n\\t\\t\\t\\t\\treturn false;\\n\\t\\t\\t\\t}\\n\\t\\t\\t} else {\\n\\t\\t\\t\\thandleSave(formData);\\n\\t\\t\\t}\\n\\n\\n\\t\\t}\\n\\t});\\n\\tvar handleSave = function (datas) {\\n\\t\\t$utils.axios.post('/_api/_/dp-proc/step/define', datas).then(res => {\\n\\t\\t\\tvar resp = res.data;\\n\\t\\t\\tif (resp.success) {\\n\\t\\t\\t\\t$utils.message.success(resp.message);\\n\\t\\t\\t\\t$this.parent.datasourceMap.getTable();\\n\\t\\t\\t\\t$this.close();\\n\\t\\t\\t} else {\\n\\t\\t\\t\\t$utils.message.error(resp.message);\\n\\t\\t\\t}\\n\\t\\t}).catch(function (error) {\\n\\t\\t\\tconsole.log(error);\\n\\t\\t})\\n\\t};\\n\\n}\"}},\"type\":\"primary\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]}]}]}]}]","inputVars":null,"viewPlugins":null,"version":100,"createUser":"xiacj3","createDt":null,"lastupd":null,"updateUser":null,"digest":null,"versionInfo":"","appName":"dataps","createUserName":null}