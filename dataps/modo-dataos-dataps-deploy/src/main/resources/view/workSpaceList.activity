                                     \"callback\": \"function callback() {\\n    $item.state = '0'\\n\\n    $this.modelWorkspaceRepo.update($item);\\n}\"\n                                                                                                    },\n                                                                                                    \"hiddenBindVar\": \"$item.state == '0' ||$item.state == '禁用'\\n\\n\\n\\n\\n\",\n                                                                                                    \"hidden\": false\n                                                                                                },\n                                                                                                {\n                                                                                                    \"label\": \"启用\",\n                                                                                                    \"__ORIGIN_DATA\": {\n                                                                                                        \"label\": \"\"\n                                                                                                    },\n                                                                                                    \"event\": {\n                                                                                                        \"builtIn\": {\n                                                                                                            \"type\": \"url\",\n                                                                                                            \"isSingleService\": true,\n                                                                                                            \"urlAction\": {\n                                                                                                                \"url\": null,\n                       