                                                               \"pageSizeChangeResetCurrent\": true,\n                                                                                                    \"sizeCanChange\": true,\n                                                                                                    \"total\": 0,\n                                                                                                    \"pageSize\": 20,\n                                                                                                    \"current\": 1\n                                                                                                },\n                                                                                                \"event\": {\n                                                                                                    \"builtIn\": {\n                                                                                                        \"type\": \"url\",\n                                                                                                        \"isSingleService\": true,\n                                                                                                        \"urlAction\": {\n                                                                                                            \"url\": null,\n                                                                                                            \"blank\": true\n                                                                                                        },\n                                                                                                        \"viewActions\": [\n                                                                                                            {\n                                                                                                                \"condition\": \"true\",\n                                                                                                                \"showType\": \"modal\",\n                                                                                                                \"viewName\": null,\n                                                                                                                \"before\": \"function beforeCallback() {}\",\n                                                                                                                \"width\": \"50%\",\n                                                                                                                \"top\": \"15vh\",\n                                                                                                                \"fullscreen\": false,\n                                                                                                                \"size\": \"50%\",\n                                                                                                                \"tabViewName\": null,\n                                                                                                                \"tabParams\": \"\",\n                                                                                                                \"tabKey\": \"\",\n                                                                                                                \"tabLabel\": \"\"\n                                                                                                            }\n                                                                                                        ],\n                                                                                                        \"actions\": []\n                                                                                                    },\n                                                