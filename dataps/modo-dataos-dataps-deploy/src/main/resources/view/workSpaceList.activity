                      \"css\": \":root {\\n    background-color: var(--color-white); \\n    border-radius: 4px;\\n    height: 138px;\\n    /* height: auto; */\\n    border: 1px solid rgba(229, 230, 235, 1);\\n    width: calc((100% - 64px)/3);\\n    margin: 12px 0 0 12px;\\n    display:inline-block;\\n    transition: all 0.2s ease 0s;\\n    /* cursor: pointer; */\\n\\n}\\n\\n:root:hover {\\n    box-shadow: rgb(211, 211, 211) 0px 0px 5px;\\n}\\n\\n\\n/* :root.no-drag {\\n    margin-left: 12px;\\n} */\",\n                                                            \"loop\": {\n                                                                \"isLoading\": false,\n                                                                \"loading\": false,\n                                                                \"loadingBindVar\": null,\n                                                                \"data\": null,\n                                                                \"dataBindVar\": \"$this.workSpace_listData\",\n                                                                \"item\": \"item\",\n                                                                \"index\": \"index\",\n                                                                \"key\": \"index\",\n                                                                \"paginationVisible\": true,\n                                                                \"disabled\": false,\n                                                                \"pagination\": {\n                                                                    \"style\": {\n                                                                        \"display\": \"block\"\n                                                                    },\n                                                                    \"sizeOptions\": [\n                                                                        10,\n                                                                        20,\n                                                                        30,\n                                                                        40,\n                                                                        50\n                                                                    ],\n                                                                    \"show\": true,\n                                                                    \"showTotal\": true,\n                                                                    \"pageSizeChangeResetCurrent\": true,\n                                                                    \"sizeCanChange\": true,\n                                                                    \"total\": 0,\n                                                                    \"pageSize\": 20,\n                                                                    \"current\": 1\n                                                                },\n                                                                \"event\": {\n                                                                    \"builtIn\": {\n                                                                        \"type\": \"url\",\n                                                                        \"isSingleService\": true,\n                                                                        \"urlAction\": {\n                                                                            \"url\": null,\n                                                                            \"blank\": true\n                                                                        },\n                                                                        \"viewActions\": [\n                                                                            {\n                                                                                \"condition\": \"true\",\n                                                                                \"showType\": \"modal\",\n                                                                                \"viewName\": null,\n                                                                                \"before\": \"function beforeCallback() {}\",\n                                                                                \"width\": \"50%\",\n                                                                                \"top\": \"15vh\",\n                                                                                \"fullscreen\": false,\n                                                                                \"size\": \"50%\",\n                                                                                \"tabViewName\": null,\n                                                                                \"tabParams\": \"\",\n                                                                                \"tabKey\": \"\",\n                                                                                \"tabLabel\": \"\"\n                                                                            }\n                                                                        ],\n                                                                        \"actions\": []\n                                                                    },\n                                                                    \"callback\": \"function callback(current, pageSize) {\\r\\n    // $this.setPageSize(pageSize);\\r\\n    // $this.setPageNum(current);\\r\\n    // $this.modelWorkspaceRepo.searchCascade({\\r\\n    //     offset: pageSize * (current - 1),\\r\\n    //     limit: pageSize\\r\\n    // });\\r\\n\\r\\n\\r\\n\\r\\n    const filters = $this.$refs.filterForm.getFieldsValue();\\r\\n    var beginDate = '';\\r\\n    var endDate = '';\\r\\n    // var url = 'http://10.19.28.145/datamodel/_api/modelWorkspace/search/cascade?offset=0&limit=10&sort=-updateDate';\\r\\n\\r\\n    $this.setSearching(true)\\r\\n    var url = '/_api/modelWorkspace/search/cascade?offset=' + pageSize * (current - 1) + '&limit=' + pageSize + '&sort=-updateDate';\\r\\n    for (var f in filters) {\\r\\n        if (f == 'label' && filters[f]) {\\r\\n            url += '&_orGroup_=name%2Clabel%3D~%25' + filters[f] + '%25';\\r\\n        }\\r\\n        if (f == 'type' && filters[f]) {\\r\\n            url += '&type=' + filters[f];\\r\\n        }\\r\\n        if (f == 'updateDate' && filters[f]) {\\r\\n            beginDate = filters[f][0];\\r\\n            endDate = filters[f][1];\\r\\n            url += '&updateDate>=' + beginDate + '&updateDate<' + endDate;\\r\\n        }\\r\\n\\r\\n    }\\r\\n\\r\\n    $utils.axios.get(url).then(res => {\\r\\n\\r\\n        var content = res.data.data.content;\\r\\n\\r\\n        var wsNames = '';\\r\\n        for (let row of content) {\\r\\n            wsNames += row.name + ',';\\r\\n        }\\r\\n\\r\\n        wsNames.substring(0, wsNames.lastIndexOf(\\\",\\\") - 1);\\r\\n\\r\\n\\r\\n        // 获取程序数量\\r\\n        $utils.axios.get('/_api/_/modoProc/find?workspaceName=' + wsNames).then(result => {\\r\\n\\r\\n            console.log(result.data.data)\\r\\n            for (let row of content) {\\r\\n                var count = 0;\\r\\n                for (let proc of result.data.data) {\\r\\n                    if (row.name == proc.workspaceName) {\\r\\n                        count++;\\r\\n                    }\\r\\n                }\\r\\n                row.numOfProc = count;\\r\\n            }\\r\\n\\r\\n            $this.setProc_listData(result.data.data);\\r\\n\\r\\n            $this.modelWorkspaceRepo.searchCascade({\\r\\n                offset: pageSize * (current - 1),\\r\\n                limit: pageSize,\\r\\n                sort: '-updateDate'\\r\\n            });\\r\\n        }).catch(function (error) {\\r\\n            console.log(error);\\r\\n        });\\r\\n\\r\\n    }).catch(function (error) {\\r\\n        console.log(error);\\r\\n    });\\r\\n}\"\n                                                                }\n                                                            },\n                                                            \"eventMap\": {}\n                                                        },\n                                                        \"defaultOptions\": {\n                                                            \"css\": \":root {\\nheight: 200px;\\n}\"\n                                                        },\n                                                        \"stateVars\": [\n                                                            \"workSpace_listData\"\n                                                        ],\n                                                        \"innerVars\": [],\n                                                        \"children\": [\n                                                            {\n                                                                \"id\": \"35c07830581cb032\",\n                                                                \"name\": \"cardList\",\n                                                                \"label\": \"卡片\",\n                                                                \"type\": \"container\",\n                                                                \"options\": {\n                                                                    \"hidden\": false,\n                                                                    \"hiddenBindVar\": null,\n                                                                    \"isLoading\": false,\n                                                                    \"loading\": false,\n                                                                    \"loadingBindVar\": null,\n                                                                    \"loadingText\": null,\n                                                                    \"loadingTextBindVar\": null,\n                                                                    \"showTooltip\": false,\n                                                                    \"tooltip\": null,\n                                                                    \"tooltipBindVar\": null,\n                                                                    \"className\": \"\",\n                                                                    \"css\": \":root {\\n    /* height: calc(100% - 30px); */\\n    flex: 1 1 0%;\\n    /* overflow: hidden; */\\n    /* flex-direction: column; */\\n    /* padding:20px 10px 0px 15px; */\\n    /* padding:20px 20px 0px 24px; */\\n}\",\n                                                                    \"loop\": {\n                                                                        \"isLoading\": false,\n                                                                        \"loading\": false,\n                                                                        \"loadingBindVar\": null,\n                                                                        \"data\": null,\n                                                                        \"dataBindVar\": \"\",\n                                                                        \"item\": \"item\",\n                                                                        \"index\": \"index\",\n                                                                        \"key\": \"index\",\n                                                                        \"paginationVisible\": true,\n                                                                        \"disabled\": false,\n                                                                        \"pagination\": {\n                                                                            \"style\": {\n                                                                                \"display\": \"block\"\n                                                                            },\n                                                                            \"sizeOptions\": [\n                                                                                10,\n                                                                                20,\n                                                                                30,\n                                                                                40,\n                                                                                50\n                                                                            ],\n                                                                            \"show\": true,\n                                                                            \"showTotal\": true,\n                                                                            \"pageSizeChangeResetCurrent\": true,\n                                                                            \"sizeCanChange\": true,\n                                                                            \"total\": 0,\n                                                                            \"pageSize\": 20,\n                                                                            \"current\": 1\n                                                                        },\n                                                                        \"event\": {\n                                                                            \"builtIn\": {\n                                                                                \"type\": \"url\",\n                                                                                \"isSingleService\": true,\n                                                                                \"urlAction\": {\n                                                                                    \"url\": null,\n                                                                                    \"blank\": true\n                                                                                },\n                                                                                \"viewActions\": [\n                                                                                    {\n                                                                                        \"condition\": \"true\",\n                                                                                        \"showType\": \"modal\",\n                                                                                        \"viewName\": null,\n                                                                                        \"before\": \"function beforeCallback() {}\",\n                                                                                        \"width\": \"50%\",\n                                                                                        \"top\": \"15vh\",\n                                                                                        \"fullscreen\": false,\n                                                                                        \"size\": \"50%\",\n                                                                                        \"tabViewName\": null,\n                                                                                        \"tabParams\": \"\",\n                                                                                        \"tabKey\": \"\",\n                                                                                        \"tabLabel\": \"\"\n                                                                                    }\n                                                                                ],\n                                                                                \"actions\": []\n                                                                            },\n                                                                            \"callback\": \"function callback() {}\"\n                                                                        }\n                                                                    },\n                                                                    \"eventMap\": {\n                                                                        \"onDoubleClick\": {\n                                                                            \"builtIn\": {\n                                                                                \"type\": \"view\",\n                                                                                \"isSingleService\": true,\n                                                                                \"urlAction\": {\n                                                                                    \"url\": null,\n                                                                                    \"blank\": true\n                                                                                },\n                                                                                \"viewActions\": [\n                                                                                    {\n                                                                                        \"condition\": \"true\",\n                                                                                        \"showType\": \"tab\",\n                                                                                        \"viewName\": \"workspaceTab\",\n                                                                                        \"before\": \"function beforeCallback() { }\",\n                                                                                        \"width\": \"50%\",\n                                                                                        \"top\": \"15vh\",\n                                                                                        \"fullscreen\": false,\n                                                                                        \"size\": \"50%\",\n                                                                                        \"tabViewName\": null,\n                                                                                        \"tabParams\": \"\",\n                                                                                        \"tabKey\": \"\",\n                                                                                        \"tabLabel\": \"\",\n                                                                                        \"tabKeyBindVar\": \"$item.name + '-detail'\",\n                                                                                        \"tabNodeName\": \"workspaceHomeTab\",\n                                                                                        \"titleBindVar\": \"$item.label + '-详情'\",\n                                                                                        \"params\": \"{\\n    currRow: $this.currRow,\\n        priv: $this.currRow,\\n            operType: 'update',\\n                dpDevCompList: $this.dpDevCompList,\\n                    streamDevCompList: $this.streamDevCompList,\\n                        devState: $this.devState\\n}\\n\\n\"\n                                                                                    }\n                                                                                ],\n                                                                                \"actions\": []\n                                                                            },\n                                                                            \"callback\": \"function callback() {\\n\\n    // 目录权限回显处理\\n    var modelWorkspacePrivList = $item.modelWorkspacePrivList;\\n    if (modelWorkspacePrivList.length > 0) {\\n        var dsProfileArr = [];\\n        var orderOfDataQueryArr = [];\\n        for (let modelWorkspacePriv of modelWorkspacePrivList) {\\n            if (modelWorkspacePriv.objectType == 'dir') {\\n                $item.dir = modelWorkspacePriv.responsible;\\n            }\\n            if (modelWorkspacePriv.objectType == 'devContent') {\\n                $item.devContent = modelWorkspacePriv.responsible;\\n            }\\n            if (modelWorkspacePriv.objectType == 'numOfDataQuery') {\\n                $item.numOfDataQuery = modelWorkspacePriv.responsible;\\n            }\\n\\n            if (modelWorkspacePriv.objectType == 'dsProfile') {\\n                dsProfileArr.push(modelWorkspacePriv.responsible);\\n                // $item.dsProfile = modelWorkspacePriv.responsible;\\n            }\\n            if (modelWorkspacePriv.objectType == 'orderOfDataQuery') {\\n                orderOfDataQueryArr.push(modelWorkspacePriv.responsible);\\n                // $item.orderOfDataQuery = modelWorkspacePriv.responsible;\\n            }\\n        }\\n\\n        $item.dsProfile = dsProfileArr;\\n        $item.orderOfDataQuery = orderOfDataQueryArr;\\n    }\\n\\n\\n    // 开发工具开关回显处理\\n    var modelWorkspaceDevCategoryList = $item.modelWorkspaceDevCategoryList;\\n    if (modelWorkspaceDevCategoryList.length > 0) {\\n        for (let modelWorkspaceDevCategor of modelWorkspaceDevCategoryList) {\\n            if (modelWorkspaceDevCategor.categoryName == '离线编排') {\\n                $item.dp = true;\\n            }\\n            if (modelWorkspaceDevCategor.categoryName == '实时编排') {\\n                $item.stream = true;\\n            }\\n\\n            if (modelWorkspaceDevCategor.categoryName == '工程') {\\n                $item.project = true;\\n            }\\n\\n        }\\n    }\\n\\n\\n    var modelWorkspaceDevCompList = $item.modelWorkspaceDevCompList;\\n    var projectDevComp = [];\\n    for (let modelWorkspaceDevComp of modelWorkspaceDevCompList) {\\n        if (modelWorkspaceDevComp.categoryName == '工程') {\\n            projectDevComp.push(modelWorkspaceDevComp.name);\\n        }\\n\\n    }\\n    $item.projectDevComp = projectDevComp;\\n    if ($item.devState == 0) {\\n        $this.setDevState(false);\\n        $item.dirBound = '1';\\n        $item.dir = 'mgr';\\n        $item.procAndModel = 'mgr';\\n        $item.dp = true;\\n        $item.stream = true;\\n        $item.sqlJdbc = true;\\n        $item.sqlSubmit = true;\\n        $item.project = true;\\n        $item.projectDevComp = ['Python', 'PySpark', 'PyFlink', 'Shell'];\\n\\n        $item.modelWorkspaceDevCompList = undefined;\\n    }\\n    $item.dpDevCompList = $this.dpDevCompList;\\n    $item.streamDevCompList = $this.streamDevCompList;\\n\\n\\n    if ($item.state == '0') {\\n        $item.state = '禁用'\\n    } else if ($item.state == '1') {\\n        $item.state = '启用'\\n    }\\n\\n    if ($item.devState == '0') {\\n        $item.devState = '否'\\n    } else if ($item.devState == '1') {\\n        $item.devState = '是'\\n    }\\n\\n    if ($item.type == '1') {\\n        $item.type = '数据建模空间'\\n    } else if ($item.type == '2') {\\n        $item.type = '数据开发空间'\\n    }\\n\\n    if ($item.dataDevMode == '1') {\\n        $item.dataDevMode = '绑定建模空间'\\n    } else if ($item.dataDevMode == '2') {\\n        $item.dataDevMode = '敏捷数据开发'\\n    } else if ($item.dataDevMode == '3') {\\n        $item.dataDevMode = '数仓规划'\\n    } else if ($item.dataDevMode == '4') {\\n        $item.dataDevMode = 'ER建模'\\n    }\\n\\n\\n    $this.setCurrRow($item);\\n    if ($this.getCurrRow() == null || $this.getCurrRow() == undefined) {\\n        $this.currRow = $item;\\n    }\\n    // $this.modelWsDevCompDefineRepo.list();\\n    // $this.modelWsDevCompDefineRepo.find();\\n}\"\n                                                                        }\n                                                                    }\n                                                                },\n                                                                \"defaultOptions\": {\n                                                                    \"css\": \":root {\\nheight: 200px;\\n}\"\n                                                                },\n                                                                \"stateVars\": [],\n                                                                \"innerVars\": [],\n                                                                \"children\": [\n                                                                    {\n                                                                        \"id\": \"4bea329e52490d39\",\n                                                                        \"name\": \"4bea329e52490d39\",\n                                                                        \"label\": \"卡片头\",\n                                                                        \"type\": \"container\",\n                                                                        \"options\": {\n                                                                            \"hidden\": false,\n                                                                            \"hiddenBindVar\": null,\n                                                                            \"isLoading\": false,\n                                                                            \"loading\": false,\n                                                                            \"loadingBindVar\": null,\n                                                                            \"loadingText\": null,\n                                 