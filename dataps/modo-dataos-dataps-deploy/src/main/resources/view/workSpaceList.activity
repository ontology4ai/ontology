                                                                                     {\n                                                                                                    \"label\": \"禁用\",\n                                                                                                    \"__ORIGIN_DATA\": {\n                                                                                                        \"label\": \"\"\n                                                                                                    },\n                                                                                                    \"event\": {\n                                                                                                        \"builtIn\": {\n                                                                                                            \"type\": \"url\",\n                                                                                                            \"isSingleService\": true,\n                                                                                                            \"urlAction\": {\n                                                                                                                \"url\": null,\n                                                                                                                \"blank\": true\n                                                                                                            },\n                                                                                                            \"viewActions\": [\n                                                                                                                {\n                                                                                                                    \"condition\": \"true\",\n                                                                   