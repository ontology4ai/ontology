me\": \"workSpace_listData\",\n                            \"label\": \"工作空间表\",\n                            \"descr\": \"通过参数分页查询一对多对象\",\n                            \"method\": \"GET\",\n                            \"autoLoad\": true,\n                            \"loadType\": \"1\",\n                            \"fields\": [],\n                            \"serviceId\": \"/_api/modelWorkspace/search/cascade\",\n                            \"condition\": true,\n                            \"conditionBindVar\": \"\",\n                            \"data\": \"{}\",\n                            \"dataBindVar\": \"{\\n    offset: 0,\\n        limit: 10,\\n            sort: '-updateDate'\\n}\",\n                            \"placeholders\": \"[]\",\n                            \"before\": \"function beforeCallback(vars, config) {\\n    // 通过 vars.params 可以更改查询参数\\n    // 通过 vars.data 可以更改requestdata\\n    // 通过 config.header 可以更改 header\\n    // 通过 config.url 可以更改  url\\n    /* vars.data = {\\n    } */\\n    // console.log(vars, config);\\n    // 可以查看还有哪些参数可以修改。\\n\\n\\n\\n    const filters = $this.$refs.filterForm.getFieldsValue();\\n    var beginDate = '';\\n    var endDate = '';\\n    for (var f in filters) {\\n        if (f == 'label' && filters[f]) {\\n            //name%2Clabel%3D~%25data_model%25\\n            vars.params._orGroup_ = 'name,label=~%' + filters[f] + '%'\\n        }\\n        if (f == 'type' && filters[f]) {\\n            vars.params.type = filters[f];\\n        }\\n        if (f == 'updateDate' && filters[f]) {\\n            beginDate = filters[f][0];\\n            endDate = filters[f][1];\\n            config.url = config.url + '?' + 'updateDate>=' + beginDate + '&updateDate<' + endDate;\\n        }\\n\\n    }\\n\\n\\n    // vars.data.limit = $this.pageSize;\\n    // vars.data.offset = ($this.pageNum - 1) * $this.pageSize;\\n\\n\\n}\",\n                            \"success\": \"function successCallback(data) {\\n    // data.data.b = 1; 修改返回数据结构