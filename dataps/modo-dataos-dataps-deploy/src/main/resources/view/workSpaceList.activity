\"\",\n                                                                                                                    \"tabLabel\": \"\"\n                                                                                                                }\n                                                                                                            ],\n                                                                                                            \"actions\": []\n                                                                                                        },\n                                                                                                        \"callback\": \"function callback() {\\n    $item.state = '1'\\n\\n    $this.modelWorkspaceRepo.update($item);\\n}\"\n                                                                                                    },\n                                                                                                    \"hidden\": false,\n                                                                                                    \"hiddenBindVar\": \"$item.state == '1' || $item.state == '启用'\"\n                                                                                                },\n                                                                                                {\n                                                                                                    \"label\": \"删除\",\n                                                                                                    \"__ORIGIN_DATA\": {\n                                                                                                        \"label\": \"\"\n                                                                                                    },\n                                                                                                    \"event\": {\n                                                                                                        \"builtIn\": {\n                                                                                                            \"type\": \"url\",\n                                                                                                            \"isSingleService\": true,\n                                                                                                            \"urlAction\": {\n                                                                                                                \"url\": null,\n                                                                                                                \"blank\": true\n                                                                                                            },\n                                                                                                            \"viewActions\": [\n                                                                                                                {\n                                                                                                                    \"condition\": \"true\",\n                                                                                                                    \"showType\": \"modal\",\n                                                                                                                    \"viewName\": null,\n                                                                                                                    \"before\": \"function beforeCallback() {}\",\n                                                                                                                    \"width\": \"50%\",\n                                                                                                                    \"top\": \"15vh\",\n                                                                                                                    \"fullscreen\": false,\n                                                                                                                    \"size\": \"50%\",\n                                                                                                                    \"tabViewName\": null,\n                                                                                                                    \"tabParams\": \"\",\n                                                                                                                    \"tabKey\": \"\",\n                                                                                                                    \"tabLabel\": \"\"\n                                                                                                                }\n                                                                                                            ],\n                                                                                                            \"actions\": []\n                                                                                                        },\n                                                                                                        \"callback\": \"function callback() {\\n    var item = $item;\\n    $utils.axios.get('/_api/_/modoProc/find?workspaceName=' + item.name)\\n        .then(function (response) {\\n            if (response.data.data.length > 0) {\\n                $utils.message.warning('当前空间存在开发任务,不允许删除!');\\n            } else {\\n\\n                $utils.modal.confirm({\\n                    title: '是否确定删除该工作空间？',\\n                    content:\\n                        '',\\n                    okButtonProps: {\\n                        status: 'danger',\\n                    },\\n                    onOk: () => {\\n                        $this.modelWorkspaceRepo.deleteById(null, { id: $item.id });\\n                    },\\n                });\\n\\n            }\\n\\n        }).catch(function (err) { console.log(err); });\\n    // $this.modelWorkspaceRepo.deleteById(null, { id: $item.id });\\n}\"\n                                                                                                    }\n                                                                                                },\n                                                                                                {\n                                                                                                    \"label\": \"测试\",\n                                                                                                    \"__ORIGIN_DATA\": {\n                                                                                                        \"label\": \"\"\n                                                                                                    },\n                                                                                                    \"event\": {\n                                                                                                        \"builtIn\": {\n                                                                                                            \"type\": \"view\",\n                                                                                                            \"isSingleService\": true,\n                                                                                                            \"urlAction\": {\n                                                                                                                \"url\": null,\n                                                                                                                \"blank\": true\n                                                                                                            },\n                                                                                                            \"viewActions\": [\n                                                                                                                {\n                                                                                                                    \"condition\": \"true\",\n                                                                                                                    \"showType\": \"tab\",\n                                                                                                                    \"viewName\": \"workspaceTab\",\n                                                                                                                    \"before\": \"function beforeCallback() {}\",\n                                                                                                                    \"width\": \"50%\",\n                                                                                                                    \"top\": \"15vh\",\n                                                                                                                    \"fullscreen\": false,\n                                                                                                                    \"size\": \"50%\",\n                                                                                                                    \"tabViewName\": null,\n                                                                                                                    \"tabParams\": \"\",\n                                                                                                                    \"tabKey\": \"\",\n                                                                                                                    \"tabLabel\": \"\",\n                                                                                                                    \"params\": \"{\\n    currRow: $this.currRow,\\n        priv: $this.currRow,\\n            operType: 'update',\\n                dpDevCompList: $this.dpDevCompList,\\n                    streamDevCompList: $this.streamDevCompList,\\n                        devState: $this.devState\\n}\\n\\n\",\n                                                                                                                    \"tabNodeName\": \"workspaceHomeTab\",\n                                                                                                                    \"titleBindVar\": \"$item.label\"\n                                                                                                                }\n                                                                                                            ],\n                                                                                                            \"actions\": []\n                                                                                                        },\n                                                                                                        \"callback\": \"function callback() {\\n    // 目录权限回显处理\\n    var modelWorkspacePrivList = $item.modelWorkspacePrivList;\\n    if (modelWorkspacePrivList.length > 0) {\\n        var dsProfileArr = [];\\n        var orderOfDataQueryArr = [];\\n        for (let modelWorkspacePriv of modelWorkspacePrivList) {\\n            if (modelWorkspacePriv.objectType == 'dir') {\\n                $item.dir = modelWorkspacePriv.responsible;\\n            }\\n            if (modelWorkspacePriv.objectType == 'devContent') {\\n                $item.devContent = modelWorkspacePriv.responsible;\\n            }\\n            if (modelWorkspacePriv.objectType == 'numOfDataQuery') {\\n                $item.numOfDataQuery = modelWorkspacePriv.responsible;\\n            }\\n\\n            if (modelWorkspacePriv.objectType == 'dsProfile') {\\n                dsProfileArr.push(modelWorkspacePriv.responsible);\\n                // $item.dsProfile = modelWorkspacePriv.responsible;\\n            }\\n            if (modelWorkspacePriv.objectType == 'orderOfDataQuery') {\\n                orderOfDataQueryArr.push(modelWorkspacePriv.responsible);\\n                // $item.orderOfDataQuery = modelWorkspacePriv.responsible;\\n            }\\n        }\\n\\n        $item.dsProfile = dsProfileArr;\\n        $item.orderOfDataQuery = orderOfDataQueryArr;\\n    }\\n\\n\\n    // 开发工具开关回显处理\\n    var modelWorkspaceDevCategoryList = $item.modelWorkspaceDevCategoryList;\\n    if (modelWorkspaceDevCategoryList.length > 0) {\\n        for (let modelWorkspaceDevCategor of modelWorkspaceDevCategoryList) {\\n            if (modelWorkspaceDevCategor.categoryName == '离线编排') {\\n                $item.dp = true;\\n            }\\n            if (modelWorkspaceDevCategor.categoryName == '实时编排') {\\n                $item.stream = true;\\n            }\\n\\n            if (modelWorkspaceDevCategor.categoryName == '工程') {\\n                $item.project = true;\\n            }\\n\\n        }\\n    }\\n\\n\\n    var modelWorkspaceDevCompList = $item.modelWorkspaceDevCompList;\\n    var projectDevComp = [];\\n    for (let modelWorkspaceDevComp of modelWorkspaceDevCompList) {\\n        if (modelWorkspaceDevComp.categoryName == '工程') {\\n            projectDevComp.push(modelWorkspaceDevComp.name);\\n        }\\n\\n    }\\n    $item.projectDevComp = projectDevComp;\\n    if ($item.devState == 0) {\\n        $this.setDevState(false);\\n        $item.dirBound = '1';\\n        $item.dir = 'mgr';\\n        $item.procAndModel = 'mgr';\\n        $item.dp = true;\\n        $item.stream = true;\\n        $item.sqlJdbc = true;\\n        $item.sqlSubmit = true;\\n        $item.project = true;\\n        $item.projectDevComp = ['Python', 'PySpark', 'PyFlink', 'Shell'];\\n\\n        $item.modelWorkspaceDevCompList = undefined;\\n    }\\n    $item.dpDevCompList = $this.dpDevCompList;\\n    $item.streamDevCompList = $this.streamDevCompList;\\n\\n\\n    if ($item.state == '0') {\\n        $item.state = '禁用'\\n    } else if ($item.state == '1') {\\n        $item.state = '启用'\\n    }\\n\\n    if ($item.devState == '0') {\\n        $item.devState = '否'\\n    } else if ($item.devState == '1') {\\n        $item.devState = '是'\\n    }\\n\\n    if ($item.type == '1') {\\n        $item.type = '数据建模空间'\\n    } else if ($item.type == '2') {\\n        $item.type = '数据开发空间'\\n    }\\n\\n    if ($item.dataDevMode == '1') {\\n        $item.dataDevMode = '绑定建模空间'\\n    } else if ($item.dataDevMode == '2') {\\n        $item.dataDevMode = '敏捷数据开发'\\n    } else if ($item.dataDevMode == '3') {\\n        $item.dataDevMode = '数仓规划'\\n    } else if ($item.dataDevMode == '4') {\\n        $item.dataDevMode = 'ER建模'\\n    }\\n    $this.setCurrRow($item);\\n}\"\n                                                                                                    },\n                                                                                                    \"hiddenBindVar\": \"\",\n                                                                                                    \"hidden\": true\n                                                                                                }\n                                                                                            ],\n                                                                                            \"isSkeleton\": false,\n                                                                                            \"size\": \"mini\"\n                                                                                        },\n                                                                                        \"stateVars\": [],\n                                                         