screen\": false,\n                                \"size\": \"50%\",\n                                \"tabViewName\": null,\n                                \"tabParams\": \"\",\n                                \"tabKey\": \"\",\n                                \"tabLabel\": \"\"\n                            }\n                        ],\n                        \"actions\": []\n                    },\n                    \"callback\": \"function callback() {\\n    $this.datasourceMap.searchMember();\\n}\"\n                }\n            },\n            \"type\": \"one-screen-layout\",\n            \"titleVisible\": false,\n            \"vars\": [\n                {\n                    \"name\": \"loading\",\n                    \"descr\": null,\n                    \"value\": \"false\"\n                },\n                {\n                    \"name\": \"formData\",\n                    \"descr\": \"仅用于绑定表格数据\",\n                    \"value\": \"{\\n    memberTransfer: []\\n}\"\n                },\n                {\n                    \"name\": \"pageNum\",\n                    \"descr\": \"分页页码，默认1\",\n                    \"value\": \"1\"\n                },\n                {\n                    \"name\": \"pageSize\",\n                    \"descr\": \"分页条数，默认10\",\n                    \"value\": \"10\"\n                },\n                {\n                    \"name\": \"sourceListData777\",\n                    \"descr\": \"表格数据源，默认空数组\",\n                    \"value\": \"[]\"\n                },\n                {\n                    \"name\": \"idList\",\n                    \"descr\": \"选中行的id数组\",\n                    \"value\": \"[]\"\n                },\n                {\n                    \"name\": \"cmshGovUrl\",\n                    \"descr\": \"cmshGovUrl\",\n                    \"value\": \"`${window.location.protocol}//${window.location.host}/cmsh_gov_deploy`\"\n                }\n            ],\n            \"models\": [],\n            \"services\": [\n                {\n                    \"name\": \"searchMember\",\n                    \"stateName\": \"\",\n                    \"descr\": \"\",\n                    \"autoLoad\": false,\n                    \"method\": \"GET\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\n    // 通过 vars.params 可以更改查询参数\\n    // 通过 vars.data 可以更改requestdata\\n    // 通过 config.header 可以更改 header\\n    // 通过 config.url 可以更改  url\\n    /* vars.data = {\\n    } */\\n    // console.log(vars, config);\\n    // 可以查看还有哪些参数可以修改。\\n    const filters = {};\\n    vars.params.limit = $this.pageSize;\\n    vars.params.offset = ($this.pageNum - 1) * $this.pageSize;\\n    // 设置查询参数\\n    const filterVars = $this.$refs.filterForm.getFieldsValue();\\n    if (filterVars.name) {\\n        // vars.params.keyWord = 'name,label=~%'+filterVars.name+'%';\\n        vars.params.userName = '~%' + filterVars.name.trim() + '%';\\n    }\\n    \\n    //定义的展开函数\\n    const expandChildrenTag = function (node, arr, prop) {\\n        if (prop) {\\n            arr.push(node[prop]);\\n        } else {\\n            arr.push(node);\\n        }\\n        if (node.childrenData) {\\n            node.childrenData.forEach(subNode => {\\n                expandChildrenTag(subNode, arr, prop);\\n            });\\n        } else if (node.children) {\\n            node.children.forEach(subNode => {\\n                expandChildrenTag(subNode, arr, prop);\\n            });\\n        }\\n    };\\n\\n    //设置父级参数\\n    //vars.params.teamName = $identity.teamName;//暂时屏蔽\\n    if ($this.parent.currNode) {\\n        vars.params.workspaceId = $this.parent.currNode.workspaceId;\\n        if ($this.parent.currNode) {\\n            const tagArr = [];\\n            expandChildrenTag($this.parent.currNode, tagArr, 'id');\\n            vars.params.archTags = tagArr.join(',');\\n            const targetNodes = [];\\n            expandChildrenTag($this.parent.currNode, targetNodes);\\n            const targetLvls = [];\\n            targetNodes.forEach(item => {\\n                if (item.type == 'lvl') {\\n                    targetLvls.push(item.name);\\n                }\\n            });\\n            vars.params.lvls = targetLvls.join(',');\\n        }\\n    }\\n    if ($this.parent.workspaceFormData.workspaceId) {\\n        vars.params.workspaceId = $this.parent.workspaceFormData.workspaceId;\\n    }\\n}\",\n                    \"success\": \"function successCallback(data) {\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\n    data.data.content.forEach(item => {\\n        item.key = item.id;\\n        item.name = item.userName;\\n        item.dsName = item.phone;\\n        item.tabSchema = item.modoAppUserId;\\n        item.createDate = item.email;\\n    })\\n    //更新数据\\n    //$this.setSourceListData([].concat(data));\\n    $this.setLoading(false);\\n    return data.data; // 重要，需返回 data\\n}\",\n                    \"fail\": \"function failCallback(error){\\n    // console.log(error);\\n    // 可以在这里做弹框提示等操作\\n}\",\n                    \"callback\": \"function searchMember(next, data) {\\n    $this.setSourceListData777([]);\\n    $this.setLoading(true);\\n\\n    const filters = $this.$refs.filterForm.getFieldsValue();\\n    const param = {};\\n    if (filters.name) {\\n        param.search = filters.name;\\n    }\\n    // 分页参数的set是异步操作，所以需要传参\\n    if (data) {\\n        param.pageSize = data.pageSize;\\n        param.pageNum = data.pageNum - 1;\\n    } else {\\n        param.pageSize = $this.pageSize;\\n        param.pageNum = $this.pageNum - 1;\\n    }\\n    //param.teamName = $identity.teamName;\\n    const url = $this.cmshGovUrl + '/_api/_/cmsh/sync/getAllPyModelData';\\n\\n    $utils.axios.get(url,\\n        {\\n            params: param\\n        }).then(res => {\\n            if (res.data.success) {\\n                const data = res.data.data;\\n                $this.setSourceListData777(data);\\n            }\\n        }).catch(function (error) {\\n            console.log(error);\\n            $this.setLoading(false);\\n        });\\n}\",\n                    \"serviceId\": null\n                },\n                {\n                    \"name\": \"modelClean\",\n                    \"stateName\": \"\",\n                    \"descr\": \"\",\n                    \"autoLoad\": false,\n                    \"serviceId\": null,\n                    \"method\": \"POST\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\n    // 通过 vars.params 可以更改查询参数\\n    // 通过 vars.data 可以更改requestdata\\n    // 通过 config.header 可以更改 header\\n    // 通过 config.url 可以更改  url\\n    /* vars.data = {\\n    } */\\n    // console.log(vars, config);\\n    // 可以查看还有哪些参数可以修改。\\n}\",\n                    \"success\": \"function successCallback(data) {\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\n    return data.data; // 重要，需返回 data\\n}\",\n                    \"fail\": \"function failCallback(error){\\n    // console.log(error);\\n    // 可以在这里做弹框提示等操作\\n}\",\n                    \"callback\": \"function searchMember(next, thisData) {\\n    const param = {};\\n    param.teamName = $identity.teamName;\\n    param.memberName = $identity.teamName + '-' + $identity.userId;\\n    const url = $this.cmshGovUrl + '/_api/_/cmsh/sync/copyPyModel2Yx';\\n\\n    //定义的展开函数,暂时不支持lvl\\n    /**const expandChildrenTag = function (node, arr, prop) {\\n        if (prop) {\\n            arr.push(node[prop]);\\n        } else {\\n            arr.push(node);\\n        }\\n        if (node.childrenData) {\\n            node.childrenData.forEach(subNode => {\\n                expandChildrenTag(subNode, arr, prop);\\n            });\\n        } else if (node.children) {\\n            node.children.forEach(subNode => {\\n                expandChildrenTag(subNode, arr, prop);\\n            });\\n        }\\n    };\\n\\n    //设置父级参数\\n    if ($this.parent.currNode) {\\n        param.workspaceId = $this.parent.currNode.workspaceId;\\n        if ($this.parent.currNode) {\\n            const tagArr = [];\\n            expandChildrenTag($this.parent.currNode, tagArr, 'id');\\n            param.archTags = tagArr.join(',');\\n            const targetNodes = [];\\n            expandChildrenTag($this.parent.currNode, targetNodes);\\n            const targetLvls = [];\\n            targetNodes.forEach(item => {\\n                if (item.type == 'lvl') {\\n                    targetLvls.push(item.name);\\n                }\\n            });\\n            param.lvls = targetLvls.join(',');\\n        }\\n    }**/\\n    if ($this.parent.workspaceFormData.workspaceId) {\\n        param.workspaceId = $this.parent.workspaceFormData.workspaceId;\\n    }\\n    param.tabIdList = (thisData.idList ? thisData.idList : $this.idList).join(',');//组装字符串\\n\\n    $utils.axios.get(url,\\n        {\\n            params: param\\n        }).then(res => {\\n            if (res.data.success) {\\n                $this.utils.modal.success({\\n                    title: '提示',\\n                    content:\\n                        '清洗成功',\\n                });\\n                // 刷新表格\\n                $this.parent.datasourceMap.getModelPage();\\n            } else {\\n                $this.utils.modal.error({\\n                    title: '提示',\\n                    content:\\n                        '清洗失败' + res.data.message,\\n                });\\n                console.log(res.data.data[0]);\\n            }\\n\\n        }).catch(function (error) {\\n            console.log(error);\\n            $this.setLoading(false)\\n        });\\n}\"\n                }\n            ]