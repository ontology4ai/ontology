{"id":"847a9f47bff9e96e","module":"236063466669670400","moduleLabel":null,"name":"ddlModelFieldImport","label":"模型字段DDL导入","descr":"模型字段DDL导入","type":"fragment","state":"1","parameters":"[{\"id\":\"0\",\"name\":\"0\",\"label\":\"页面\",\"type\":\"view\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltipText\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"data\":null,\"dataBindVar\":null,\"var\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{},\"type\":\"one-screen-layout\",\"titleVisible\":false,\"vars\":[{\"name\":\"formData\",\"descr\":null,\"value\":\"{\\r\\n    ddl: ''\\r\\n}\"}],\"models\":[],\"services\":[{\"name\":\"ddlResolveFields\",\"stateName\":\"\",\"descr\":\"\",\"autoLoad\":false,\"serviceId\":\"186852960548438016\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.data.dsType = $this.dsType;\\r\\n    vars.data.ddl = $this.formData.ddl;\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    const target = [];\\r\\n    if ($this.parent.formData.fields) {\\r\\n        $this.parent.formData.fields.forEach(item => {\\r\\n            if (item.fieldName || item.fieldLabel || item.dataType) {\\r\\n                target.push(item);\\r\\n            }\\r\\n        });\\r\\n    }\\r\\n    data.data.data.forEach(item => {\\r\\n        const temp = {};\\r\\n        for (var k in $this.parent.srcField) {\\r\\n            temp[k] = item[k];\\r\\n        }\\r\\n        temp.fieldName = item.name;\\r\\n        temp.fieldLabel = item.label;\\r\\n        temp.fieldDescr = item.descr;\\r\\n        temp.partitionKey = item.partitionKey+'';\\r\\n        target.push(temp);\\r\\n    });\\r\\n    $this.parent.$refs.fieldsForm.formRef.current.clearFields();\\r\\n    $this.parent.setFormData({ fields: target });\\r\\n    if (data.data.tableName) {\\r\\n        if (!$this.parent.parent.formData.modelName) {\\r\\n            $this.parent.parent.$refs.baseForm.setFieldsValue({ \\\"modelName\\\": data.data.tableName });\\r\\n        } else if ($this.parent.parent.formData.modelName != data.data.tableName && !($this.parent.parent.disable || ['CHANGE', 'PUBLISHED'].indexOf($this.parent.parent.formData.state) > -1)) {\\r\\n            $utils.modal.confirm({\\r\\n                title: '警告',\\r\\n                content: '是否使用DDL中的表名？',\\r\\n                okButtonProps: {\\r\\n                    status: 'danger',\\r\\n                },\\r\\n                onOk: () => {\\r\\n                    $this.parent.parent.$refs.baseForm.setFieldsValue({ \\\"modelName\\\": data.data.tableName });\\r\\n                },\\r\\n                cancelText: '取消',\\r\\n                okText: '继续'\\r\\n            });\\r\\n        }\\r\\n    }\\r\\n    $this.close();\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"}],\"i18n\":{}},\"children\":[{\"id\":\"bb4e9e893e2ace2f\",\"name\":\"bb4e9e893e2ace2f\",\"label\":\"页面布局\",\"type\":\"flexLayout\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltipText\":null,\"