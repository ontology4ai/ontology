{"id":"ff98ed2aea8da71d","module":"8a7494bd8f51c770018f51cab8ac0001","moduleLabel":null,"name":"hu_dataps_test","label":"hu_dataps_test","descr":"hu_dataps_test","type":"activity","state":"1","parameters":"[\n    {\n        \"id\": \"0\",\n        \"name\": \"0\",\n        \"label\": \"页面\",\n        \"type\": \"view\",\n        \"options\": {\n            \"hidden\": false,\n            \"hiddenBindVar\": null,\n            \"isLoading\": false,\n            \"loading\": false,\n            \"loadingBindVar\": null,\n            \"loadingText\": null,\n            \"loadingTextBindVar\": null,\n            \"showTooltip\": false,\n            \"tooltip\": null,\n            \"tooltipBindVar\": null,\n            \"className\": \"\",\n            \"css\": \":root {\\n}\",\n            \"loop\": {\n                \"isLoading\": false,\n                \"loading\": false,\n                \"loadingBindVar\": null,\n                \"data\": null,\n                \"dataBindVar\": null,\n                \"item\": \"item\",\n                \"index\": \"index\",\n                \"key\": \"index\",\n                \"paginationVisible\": true,\n                \"disabled\": false,\n                \"pagination\": {\n                    \"style\": {\n                        \"display\": \"block\"\n                    },\n                    \"sizeOptions\": [\n                        10,\n                        20,\n                        30,\n                        40,\n                        50\n                    ],\n                    \"show\": true,\n                    \"showTotal\": true,\n                    \"pageSizeChangeResetCurrent\": true,\n                    \"sizeCanChange\": true,\n                    \"total\": 0,\n                    \"pageSize\": 20,\n                    \"current\": 1\n                },\n                \"event\": {\n                    \"builtIn\": {\n                        \"type\": \"url\",\n                        \"isSingleService\": true,\n                        \"urlAction\": {\n                            \"url\": null,\n                            \"blank\": true\n                        },\n                        \"viewActions\": [\n                            {\n                                \"condition\": \"true\",\n                                \"showType\": \"modal\",\n                                \"viewName\": null,\n                                \"before\": \"function beforeCallback() {}\",\n                                \"width\": \"50%\",\n                                \"top\": \"15vh\",\n                                \"fullscreen\": false,\n                                \"size\": \"50%\",\n                                \"tabViewName\": null,\n                                \"tabParams\": \"\",\n                                \"tabKey\": \"\",\n                                \"tabLabel\": \"\"\n                            }\n                        ],\n                        \"actions\": []\n                    },\n                    \"callback\": \"function callback() {}\"\n                }\n            },\n            \"eventMap\": {\n                \"onMount\": {\n                    \"builtIn\": {\n                        \"type\": \"url\",\n                        \"isSingleService\": true,\n                        \"urlAction\": {\n                            \"url\": null,\n                            \"blank\": true\n                        },\n                        \"viewActions\": [\n                            {\n                                \"condition\": \"true\",\n                                \"showType\": \"modal\",\n                                \"viewName\": null,\n                                \"before\": \"function beforeCallback() {}\",\n                                \"width\": \"50%\",\n                                \"top\": \"15vh\",\n                                \"fullscreen\": false,\n                                \"size\": \"50%\",\n                                \"tabViewName\": null,\n                                \"tabParams\": \"\",\n                                \"tabKey\": \"\",\n                                \"tabLabel\": \"\"\n                            }\n                        ],\n                        \"actions\": []\n                    },\n                    \"callback\": \"function callback() {\\r\\n    var taskId = new Date().getTime();\\r\\n    startEventSource(taskId);\\r\\n    function startEventSource(taskId) {\\r\\n        // 创建一个新的EventSource对象，指向服务器的SSE endpoint\\r\\n        var source = new EventSource('/dataps/_api/sse/connect/' + taskId);\\r\\n\\r\\n        // 当接收到服务器发来的message事件时触发此回调函数\\r\\n        source.addEventListener('message', function (event) {\\r\\n            // event.data 包含服务器发送过来的数据\\r\\n            var sseData = JSON.parse(event.data);\\r\\n            console.log('Received message: ', event.data);\\r\\n            //source.close();\\r\\n            if (sseData.isEnd) {\\r\\n                source.close();\\r\\n            }\\r\\n        });\\r\\n\\r\\n        // 处理连接错误\\r\\n        source.onerror = function (event) {\\r\\n            console.error('EventSource error:', event);\\r\\n            source.close();\\r\\n            $this.setEventSource(startEventSource(taskId));\\r\\n        };\\r\\n\\r\\n        // 如果需要在关闭连接时执行清理操作，可以监听close事件\\r\\n        source.addEventListener('close', function (event) {\\r\\n            console.log('EventSource closed');\\r\\n        });\\r\\n        return source;\\r\\n    }\\r\\n\\r\\n    var objBody = new Object();\\r\\n    objBody.taskId = taskId;\\r\\n    objBody.demandInfo = '';\\r\\n    objBody.message = '生成\\\"51小长假分析\\\"模型的开发任务';\\r\\n    $utils.axios.post('/api/getGptInputTabName', objBody).then(function (res) {\\r\\n        var result = res.data.data;\\r\\n\\r\\n\\r\\n    }).catch(function (e) { });\\r\\n}\\r\\n\\r\\n\"\n                }\n            },\n            \"type\": \"one-screen-layout\",\n            \"titleVisible\": false,\n            \"vars\": [],\n            \"models\": [],\n            \"services\": [],\n            \"i18n\": {}\n        },\n        \"children\": []\n    }\n]","inputVars":null,"viewPlugins":null,"version":null,"createUser":null,"createDt":null,"lastupd":null,"updateUser":null,"digest":null,"versionInfo":"","appName":"dataps","createUserName":null}