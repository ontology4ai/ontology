,\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\r\\n    if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.priv != '1') {\\r\\n        $this.utils.modal.warning({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '无编辑权限！',\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n    if (!$this.$refs.treeDef.treeChartRef.current.getSelection().data.parent) {\\r\\n        $this.utils.modal.warning({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '根结点不允许删除！',\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n    if (['lvl'].indexOf($this.$refs.treeDef.treeChartRef.current.getSelection().data.name) > -1) {\\r\\n        $this.utils.modal.warning({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '层级不允许删除！',\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n    if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.hasChildren) {\\r\\n        $utils.modal.confirm({\\r\\n            title: '警告',\\r\\n            content: '确认删除该结点及其下属结点吗？',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            onOk: () => {\\r\\n                const keyMap = {};\\r\\n                $this.treeData.forEach(item => {\\r\\n                    item.children = [];\\r\\n                    keyMap[item.key] = item;\\r\\n                });\\r\\n                $this.treeData.forEach(item => {\\r\\n                    if (item.parent && keyMap[item.parent]) {\\r\\n                        keyMap[item.parent].children.push(item);\\r\\n                    }\\r\\n                });\\r\\n                const toRemove = [$this.$refs.treeDef.treeChartRef.current.getSelection().data.key];\\r\\n                const getChildren = function (children, keyList) {\\r\\n                    children.forEach(item => {\\r\\n                        keyList.push(item.key);\\r\\n                        if (item.children && item.children.length > 0) {\\r\\n                            getChildren(item.children, keyList);\\r\\n                        }\\r\\n                    });\\r\\n                }\\r\\n                getChildren(keyMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children, toRemove);\\r\\n                $this.treeData.forEach(item => {\\r\\n                    if (toRemove.indexOf(item.key) > -1) {\\r\\n                        item.changeState = 'delete';\\r\\n                    }\\r\\n                });\\r\\n                $this.$refs.treeDef.treeChartRef.current.loadData($this.treeData);\\r\\n            }\\r\\n        });\\r\\n    } else {\\r\\n        $utils.modal.confirm({\\r\\n            title: '警告',\\r\\n            content: '确认删除该结点吗？',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            onOk: () => {\\r\\n                $this.treeData.forEach(item => {\\r\\n                    if (item.key == $this.$refs.treeDef.treeChartRef.current.getSelection().data.key) {\\r\\n                        item.changeState = 'delete';\\r\\n                    }\\r\\n                });\\r\\n                $this.$refs.treeDef.treeChartRef.current.loadData($this.treeData);\\r\\n            }\\r\\n        });\\r\\n    }\\r\\n}\"},\"hiddenBindVar\":\"\"}],\"fieldNames\":{\"key\":\"key\",\"parent\":\"parent\",\"label\":\"label\"},\"bgFormatterBindVar\":\"function render(node) {\\r\\n    if (node.name == 'root' || node.parent == 'root') {\\r\\n        return '#3491FA';\\r\\n    } else {\\r\\n        return '#E5E6EB';\\r\\n    }\\r\\n}\",\"strokeFormatterBindVar\":\"function render(node) {\\r\\n    if (node.priv == '1') {\\r\\n        return 'gold';\\r\\n    } else {\\r\\n        return 'gray';\\r\\n    }\\r\\n}\",\"colorFormatterBindVar\":\"function render(node) {\\r\\n    if (node.changeState == 'add') {\\r\\n        return '#00B42A';\\r\\n    } else if (node.changeState == 'change') {\\r\\n        return '#A26D0A';\\r\\n    } else if (node.changeState == 'delete') {\\r\\n        return '#CB272D';\\r\\n    } else {\\r\\n        return '#1D2129';\\r\\n    }\\r\\n}\"},\"children\":[]}]}]},{\"id\":\"ae9ce4468dd1bab2\",\"name\":\"ae9ce4468dd1bab2\",\"label\":\"flex布局\",\"type\":\"flexLayout\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root{\\r\\n    padding:8px;\\r\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{},\"width\":\"100%\",\"height\":\"auto\",\"gutter\":\"5px\",\"flexDirection\":\"row\",\"flex\":\"auto\",\"flexGrow\":false,\"justifyContent\":\"flex-end\"},\"defaultOptions\":{\"gutter\":\"5px\",\"width\":\"100%\",\"height\":\"200px\",\"flexDirection\":\"row\",\"flex\":\"auto\",\"flexGrow\":true},\"children\":[{\"id\":\"e39bf75d28ab9aa1\",\"name\":\"e39bf75d28ab9aa1\",\"label\":\"保存\",\"