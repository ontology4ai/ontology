\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onSelect\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback(selection, { event, node }) {\\r\\n    //二次点击同一节点，取消选中，并保证指发起一次查询请求\\r\\n    if (node && $this.modelTreeSelectedKeys.indexOf(node.key) > -1) {\\r\\n        $this.modelTreeSelectedKeys.splice($this.modelTreeSelectedKeys.indexOf(node.key), 1);\\r\\n        $this.$refs.modelTree.setSelectedKeys($this.modelTreeSelectedKeys, node);\\r\\n    } else {\\r\\n        if (node) {\\r\\n            $this.setCurrNode(node.props);\\r\\n            $this.setFilterFormData(_.extend({}, $this.filterFormData, { dirNodeId: node.props.archLabel }));\\r\\n        } else {\\r\\n            $this.setCurrNode(null);\\r\\n            $this.setFilterFormData(_.extend({}, $this.filterFormData, { dirNodeId: '' }));\\r\\n        }\\r\\n        $this.setModelTreeSelectedKeys(selection);\\r\\n        $this.datasourceMap.getModelPage();\\r\\n    }\\r\\n}\"}},\"data\":[{\"title\":\"Trunk 0-0\",\"key\":\"0-0\",\"children\":[{\"title\":\"Leaf 0-0-1\",\"key\":\"0-0-1\"},{\"title\":\"Branch 0-0-2\",\"key\":\"0-0-2\",\"children\":[{\"title\":\"Leaf 0-0-2-1\",\"key\":\"0-0-2-1\"}]}]},{\"title\":\"Trunk 0-1\",\"key\":\"0-1\",\"children\":[{\"title\":\"Leaf 0-1-1\",\"