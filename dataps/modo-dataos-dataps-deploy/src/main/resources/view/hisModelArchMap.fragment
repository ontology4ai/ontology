{"id":"6e3cbdd9b689d781","module":"236138945695121408","moduleLabel":null,"name":"hisModelArchMap","label":"历史模型编目映射","descr":"历史模型编目映射","type":"fragment","state":"1","parameters":"[{\"id\":\"0\",\"name\":\"0\",\"label\":\"页面\",\"type\":\"view\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltipText\":null,\"className\":\"\",\"css\":\":root {\\n}\\n\",\"loop\":{\"data\":null,\"dataBindVar\":null,\"var\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{},\"type\":\"one-screen-layout\",\"titleVisible\":false,\"vars\":[{\"name\":\"filterFormData\",\"descr\":\"表单数据\",\"value\":\"{}\"},{\"name\":\"pageNum\",\"descr\":\"页码\",\"value\":\"1\"},{\"name\":\"pageSize\",\"descr\":\"一页大小\",\"value\":\"20\"},{\"name\":\"searching\",\"descr\":\"查询loading\",\"value\":\"false\"},{\"name\":\"modelTreeSelectedKeys\",\"descr\":\"模型目录树选中节点的key\",\"value\":\"[]\"},{\"name\":\"currNode\",\"descr\":\"当前选中结点\",\"value\":\"null\"},{\"name\":\"editSupport\",\"descr\":\"是否支持编辑（暂时没考虑好哪些场景需要编辑，先默认为可编辑）\",\"value\":\"true\"},{\"name\":\"batchOperRows\",\"descr\":\"批量操作时选中的行（校验用）\",\"value\":\"[]\"},{\"name\":\"teamMemberOptions\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"disable\",\"descr\":null,\"value\":\"false\"}],\"models\":[],\"services\":[{\"name\":\"getModelPage\",\"stateName\":\"modelPage\",\"descr\":\"分页查询逻辑模型\",\"autoLoad\":true,\"loadType\":\"1\",\"serviceId\":\"189887279207424000\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":[],\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.data = _.extend({}, $this.$refs.filterForm.getFieldsValue());\\r\\n    vars.data.version = $this.version;\\r\\n    if (vars.data['lastupd'] && vars.data['lastupd'].length > 0) {\\r\\n        vars.data['lastupd.gte'] = new Date(vars.data['lastupd'][0]).getTime();\\r\\n        vars.data['lastupd.lte'] = new Date(vars.data['lastupd'][1]).getTime();\\r\\n        delete vars.data['lastupd'];\\r\\n    }\\r\\n    if (vars.data['createDt'] && vars.data['createDt'].length > 0) {\\r\\n        vars.data['createDt.gte'] = new Date(vars.data['createDt'][0]).getTime();\\r\\n        vars.data['createDt.lte'] = new Date(vars.data['createDt'][1]).getTime();\\r\\n        delete vars.data['createDt'];\\r\\n    }\\r\\n    delete vars.data.dirNodeId;\\r\\n    const expandChildrenTag = function(node, arr, prop){\\r\\n        if(prop){\\r\\n            arr.push(node[prop]);\\r\\n        }else{\\r\\n            arr.push(node);\\r\\n        }\\r\\n        if(node.childrenData){\\r\\n            node.childrenData.forEach(subNode=>{\\r\\n                expandChildrenTag(subNode, arr, prop);\\r\\n            });\\r\\n        }else if(node.children){\\r\\n            node.children.forEach(subNode=>{\\r\\n                expandChildrenTag(subNode, arr, prop);\\r\\n            });\\r\\n        }\\r\\n    };\\r\\n    if ($this.currNode) {\\r\\n        // vars.data.archNodeId = $this.currNode.id;\\r\\n        vars.data.workspaceId = $this.currNode.workspaceId;\\r\\n        if($this.currNode){\\r\\n            const tagArr = [];\\r\\n            expandChildrenTag($this.currNode, tagArr, 'id');\\r\\n            vars.data.archTags = tagArr.join(',');\\r\\n            const targetNodes = [];\\r\\n            expandChildrenTag($this.currNode, targetNodes);\\r\\n            const targetLvls = [];\\r\\n            targetNodes.forEach(item=>{\\r\\n                if(item.type=='lvl'){\\r\\n                    targetLvls.push(item.name);\\r\\n                }\\r\\n            });\\r\\n            vars.data.lvls = targetLvls.join(',');\\r\\n        }\\r\\n    }\\r\\n    vars.data.searchSubNode = true;\\r\\n    vars.data.limit = $this.pageSize;\\r\\n    vars.data.offset = ($this.pageNum - 1) * $this.pageSize;\\r\\n    $this.setSearching(true);\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    $this.setSearching(false);\\r\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $this.setSearching(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"getArchTree\",\"stateName\":\"archTree\",\"descr\":\"获取逻辑模型树\",\"autoLoad\":true,\"loadType\":\"1\",\"serviceId\":\"176464680436285440\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":[],\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.params.version = $this.version;\\r\\n    return vars;\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    const roots = [];\\r\\n    const map = {};\\r\\n    const targetNodes = [];\\r\\n    data.data.forEach(item => {\\r\\n        if (item.parent) {\\r\\n            item.parent_id = item.parent;\\r\\n        }\\r\\n        item.num = 0;\\r\\n        item.archCode = item.name;\\r\\n        item.archLabel = item.label;\\r\\n        map[item.key] = item;\\r\\n        if(item.changeState!='delete'){\\r\\n            targetNodes.push(item);\\r\\n        }\\r\\n    });\\r\\n    targetNodes.forEach(item => {\\r\\n        if (item.parent && map[item.parent]) {\\r\\n            if (!map[item.parent].children) {\\r\\n                map[item.parent].children = [];\\r\\n            }\\r\\n            map[item.parent].children.push(item);\\r\\n        }\\r\\n        if (item.parent == 'root') {\\r\\n            delete item.parent;\\r\\n            delete item.parent_id;\\r\\n            roots.push(item);\\r\\n        }\\r\\n    });\\r\\n    roots.push({\\r\\n        id:'_un_category_node_',\\r\\n        key:'_un_category_node_',\\r\\n        archLabel:'未归类',\\r\\n        label:'未归类'\\r\\n    });\\r\\n    return roots; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"getTeamMembers\",\"stateName\":\"teamMemberOptions\",\"descr\":\"获取团队成员信息\",\"autoLoad\":true,\"serviceId\":\"/_api/_/teamMember/listMemberByTeamName\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.params.teamName = $identity.teamName||'';\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\r\\n    data.data.forEach(item=>{\\r\\n        item.memberName = $identity.teamName+'-'+item.userId;\\r\\n    });\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\"},{\"name\":\"deleteById\",\"stateName\":\"\",\"descr\":\"\",\"autoLoad\":false,\"serviceId\":\"/_api/datapsLogicModelDraft/delete/{id}\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    config.url = config.url.replace('{id}', $this.$refs.table.currentRow.id);\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    $this.datasourceMap.getModelPage();\\r\\n    $this.datasourceMap.getArchTree();\\r\\n    $utils.notification.success({\\r\\n        title: '成功',\\r\\n        content: '模型删除成功！',\\r\\n    });\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(err