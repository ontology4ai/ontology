{"id":"f427c396198e8320","module":"8a74995c91d46b990191d46e2f8c0000","moduleLabel":null,"name":"dataIDEBlank","label":"IDE空白跳转页面","descr":"IDE空白跳转页面","type":"activity","state":"1","parameters":"[\n    {\n        \"id\": \"0\",\n        \"name\": \"0\",\n        \"label\": \"页面\",\n        \"type\": \"view\",\n        \"options\": {\n            \"hidden\": false,\n            \"hiddenBindVar\": null,\n            \"isLoading\": false,\n            \"loading\": false,\n            \"loadingBindVar\": null,\n            \"loadingText\": null,\n            \"loadingTextBindVar\": null,\n            \"showTooltip\": false,\n            \"tooltip\": null,\n            \"tooltipBindVar\": null,\n            \"className\": \"\",\n            \"css\": \":root {\\n}\",\n            \"loop\": {\n                \"isLoading\": false,\n                \"loading\": false,\n                \"loadingBindVar\": null,\n                \"data\": null,\n                \"dataBindVar\": null,\n                \"item\": \"item\",\n                \"index\": \"index\",\n                \"key\": \"index\",\n                \"paginationVisible\": true,\n                \"disabled\": false,\n                \"pagination\": {\n                    \"style\": {\n                        \"display\": \"block\"\n                    },\n                    \"sizeOptions\": [\n                        10,\n                        20,\n                        30,\n                        40,\n                        50\n                    ],\n                    \"show\": true,\n                    \"showTotal\": true,\n                    \"pageSizeChangeResetCurrent\": true,\n                    \"sizeCanChange\": true,\n                    \"total\": 0,\n                    \"pageSize\": 20,\n                    \"current\": 1\n                },\n                \"event\": {\n                    \"builtIn\": {\n                        \"type\": \"url\",\n                        \"isSingleService\": true,\n                        \"urlAction\": {\n                            \"url\": null,\n                            \"blank\": true\n                        },\n                        \"viewActions\": [\n                            {\n                                \"condition\": \"true\",\n                                \"showType\": \"modal\",\n                                \"viewName\": null,\n                                \"before\": \"function beforeCallback() {}\",\n                                \"width\": \"50%\",\n                                \"top\": \"15vh\",\n                                \"fullscreen\": false,\n                                \"size\": \"50%\",\n                                \"tabViewName\": null,\n                                \"tabParams\": \"\",\n                                \"tabKey\": \"\",\n                                \"tabLabel\": \"\"\n                            }\n                        ],\n                        \"actions\": []\n                    },\n                    \"callback\": \"function callback() {}\"\n                }\n            },\n            \"eventMap\": {},\n            \"type\": \"one-screen-layout\",\n            \"titleVisible\": false,\n            \"vars\": [\n                {\n                    \"name\": \"commonUrl\",\n                    \"descr\": null,\n                    \"value\": \"`${window.location.protocol}//${window.location.host}/_common_`\"\n                },\n                {\n                    \"name\": \"searching\",\n                    \"descr\": null,\n                    \"value\": \"false\"\n                }\n            ],\n            \"models\": [],\n            \"services\": [\n                {\n                    \"name\": \"getWorkspace\",\n                    \"stateName\": \"\",\n                    \"descr\": \"\",\n                    \"autoLoad\": true,\n                    \"serviceId\": null,\n                    \"method\": \"get\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\n    // 通过 vars.params 可以更改查询参数\\n    // 通过 vars.data 可以更改requestdata\\n    // 通过 config.header 可以更改 header\\n    // 通过 config.url 可以更改  url\\n    /* vars.data = {\\n    } */\\n    // console.log(vars, config);\\n    // 可以查看还有哪些参数可以修改。\\n}\",\n                    \"success\": \"function successCallback(data) {\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\n    return data.data; // 重要，需返回 data\\n}\",\n                    \"fail\": \"function failCallback(error){\\n    // console.log(error);\\n    // 可以在这里做弹框提示等操作\\n}\",\n                    \"callback\": \"function getWorkspace() {\\n    // _api/_/workspace/search/page?offset=0&limit=20&userId=admin\\n\\n    $this.setSearching(true);\\n    $utils.axios.get(`${$this.commonUrl}/_api/_/workspace/search/page`, {\\n        params:\\n        {\\n            offset: 0,\\n            limit: 1,\\n            userId: $identity.userId\\n        }\\n    }).then(res => {\\n        $this.setSearching(false);\\n        if (res.data && res.data.success) {\\n            const data = res.data.data;\\n            if (data.content && data.content.length > 0) {\\n                const ws = data.content[0];\\n                const domain = location.href.includes('/datastash') ? 'datastash' : location.href.includes('/develop') ? 'develop' : ''\\n                let url = `${$this.commonUrl}/datadev_ide/${ws.id}?domain=${domain}`;\\n                console.log(url);\\n                window.location.href = url;\\n            } else {\\n                $utils.message.info('当前团队，当前用户未配置可用工作空间');\\n            }\\n\\n        } else {\\n            $utils.message.error('查询工作空间失败' + res.data.message);\\n        }\\n    }).catch(function (error) {\\n        $this.setSearching(false);\\n        console.log(error);\\n        $utils.message.error('查询失败');\\n    });\\n}\"\n                }\n            ],\n            \"i18n\": {\n                \"zh-CN\": \"{}\"\n            }\n        },\n        \"children\": []\n    }\n]","inputVars":null,"viewPlugins":null,"version":null,"createUser":null,"createDt":null,"lastupd":null,"updateUser":null,"digest":null,"versionInfo":"","appName":"dataps","createUserName":null}