ent\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onClick\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() { \\n    $this.close();\\n}\"}}},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]},{\"id\":\"859f5e6e71c74e9f\",\"name\":\"859f5e6e71c74e9f\",\"label\":\"确定\",\"type\":\"button\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":true,\"loading\":false,\"loadingBindVar\":\"$this.isSpin == true\",\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onClick\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\n\\n\\n    $this.setIsSpin(true)\\n    var adjustmentPriorityTriggerList = $this.adjustmentPriorityTriggerList;\\n    var adjustmentPriorityFrom = $this.$refs.adjustmentPriorityFrom.getFieldsValue();\\n    var priority = adjustmentPriorityFrom.priority;\\n    var prePriorityState = adjustmentPriorityFrom.prePriorityState;\\n\\n    if (prePriorityState === false || prePriorityState === undefined) {\\n        prePriorityState = '0';\\n    } else if (prePriorityState === true) {\\n        prePriorityState = '1';\\n    }\\n\\n    var dataArr = [];\\n    for (let data of adjustmentPriorityTriggerList) {\\n        dataArr.push({\\n            jobTrigId: data.jobTrigId,\\n            teamName: $identity.teamName,\\n            userId: $identity.userId,\\n            priority: priority,\\n            prePriorityState: prePriorityState\\n        })\\n    }\\n\\n    $utils.axios.defaults.timeout = 600000;\\n    $utils.axios.post('/oneplusn-federation/open/dataflow/monitor/adjustPriority', dataArr).then(res => {\\n        $this.setIsSpin(false);\\n        $this.close();\\n        if (res.data.success === true) {\\n            $utils.message.success('调整优先级成功！');\\n\\n            if ($this.operType === 'logic') {\\n                const filters = $this.parent.$refs.jobMonitorFilterForm.getFieldsValue();\\n                var current = $this.parent.$refs.logicJobMonitorTab.state.current;\\n                var pageSize = $this.parent.$refs.logicJobMonitorTab.state.pageSize;\\n\\n                var jobLabel = '';\\n                var batchTypes = 'daily';\\n                var batchNo = '';\\n                var memberName = '';\\n                var runState = '';\\n                var jobType = '';\\n                var priority = '';\\n                var runStateNum = 1;\\n                var tag = '';\\n                var brokerWorkgroup = '';\\n                var batchNoZone = '';\\n\\n                for (var f in filters) {\\n                    if (f == 'jobLabel' && filters[f]) {\\n                        jobLabel = filters[f];\\n                    }\\n                    if (f == 'batchTypes' && filters[f]) {\\n\\n                        batchTypes = filters[f].join(',');\\n                    }\\n                    if (f == 'batchNoZone' && filters[f]) {\\n                        batchNo = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n                        batchNoZone = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n                    }\\n                    if (f == 'batchNo' && filters[f] && batchNoZone == '') {\\n                        batchNo = filters[f].replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\");\\n                    }\\n                    if (f == 'dUser' && filters[f]) {\\n                        memberName = filters[f];\\n                    }\\n                    if (f == 'runState' && filters[f]) {\\n                        runState = filters[f];\\n                    }\\n                    if (f == 'jobType' && filters[f]) {\\n                        jobType = filters[f];\\n                    }\\n                    if (f == 'priority' && filters[f]) {\\n                        priority = filters[f];\\n                    }\\n                    //runStateNum: true\\n                    if (f == 'runStateNum' && filters[f]) {\\n                        if (filters[f] == true) {\\n                            runStateNum = 0;\\n\\n                        } else if (filters[f] == false) {\\n                            runStateNum = 1;\\n                        }\\n\\n                    }\\n                    if (f == 'tag' && filters[f]) {\\n                        tag = filters[f];\\n                    }\\n                    if (f == 'brokerWorkgroup' && filters[f]) {\\n                        brokerWorkgroup = filters[f];\\n                    }\\n                    // if (f == 'cycle' && filters[f]) {\\n                    //     vars.params.cycle = '~%' + filters[f] + '%'\\n                    // }\\n                }\\n\\n                let state = '';\\n                let queryType = '0';\\n                if ($this.parent.jobState2.length == 0) {\\n                    if ($this.parent.jobState.indexOf('ALL') == -1) {\\n                        state = $this.parent.jobState.join(',');\\n                        queryType = '0';\\n\\n                    }\\n                } else {\\n                    if ($this.parent.jobState2.indexOf('ALL') == -1) {\\n                        state = $this.parent.jobState2.join(',');\\n                        queryType = '1';\\n                    }\\n                }\\n\\n\\n                $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/getStatisticsCollectData',\\n                    {\\n                        params:\\n                        {\\n                            jobLabel: jobLabel,\\n                            batchTypes: batchTypes,\\n                            batchNo: batchNo,\\n                            teamName: $identity.teamName,\\n                            memberName: memberName,\\n                            runState: runState,\\n                            jobType: jobType,\\n                            priority: priority,\\n                            runStateNum: runStateNum,\\n                            tag: tag,\\n                            brokerWorkgroup: brokerWorkgroup\\n                        }\\n                    }).then(res => {\\n                        $this.setJobS(res.data.data);\\n                        if (res.data.data.jtFinish != null && res.data.data.jtSum != null) {\\n                            $this.parent.setJobSuccessRate(Math.round((res.data.data.jtFinish / res.data.data.jtSum) * 100))\\n                        } else {\\n                            $this.parent.setJobSuccessRate(0);\\n                        }\\n\\n\\n                    }).catch(function (error) {\\n                        $this.setIsSpin(false)\\n                        console.log(error);\\n                    });\\n\\n\\n                $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/v2/getStatisticsTableData',\\n                    {\\n                        params:\\n                        {\\n                            pageNum: current - 1,\\n                            pageSize: pageSize,\\n                            jobLabel: jobLabel,\\n                            batchTypes: batchTypes,\\n                            batchNo: batchNo,\\n                            teamName: $identity.teamName,\\n                            taskType: 'all',\\n                            desc: 'desc',\\n                            sortColumn: 'jobCode',\\n                            memberName: memberName,\\n                            runState: runState,\\n                            jobType: jobType,\\n                            priority: priority,\\n                            readTeamNames: $identity.teamName,\\n                            jobState: state,\\n                            queryType: queryType,\\n                            runStateNum: runStateNum,\\n                            tag: tag,\\n                            brokerWorkgroup: brokerWorkgroup\\n                        }\\n                    }).then(res => {\\n                        var data = res.data.data;\\n                        $this.parent.setLogicJobTriggerListData(data);\\n\\n                    }).catch(function (error) {\\n                        $this.setIsSpin(false)\\n                        console.log(error);\\n                    });\\n            } else {\\n                if ($this.parent.parentCode != '') {\\n                    var current = $this.parent.$refs.job_trigger_tab.state.current;\\n                    var pageSize = $this.parent.$refs.job_trigger_tab.state.pageSize;\\n                    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/getTableData',\\n                        {\\n                            params:\\n                            {\\n                                pageNum: current - 1,\\n                                pageSize: pageSize,\\n                                parentCode: $this.parent.parentCode,\\n                                batchTypes: $this.parent.batchType,\\n                                batchNo: $this.parent.batchNo,\\n                                teamName: $identity.teamName,\\n                                taskType: 'all',\\n                                desc: 'desc',\\n                                sortColumn: 'jobCode',\\n                                readTeamNames: $identity.teamName,\\n                                runStateNum: $this.parent.runStateNum\\n                            }\\n                        }).then(res => {\\n                            var data = res.data.data;\\n\\n                            $this.parent.setJobTriggerListData(data);\\n\\n                        }).catch(function (error) {\\n                            $this.setIsSpin(false)\\n                            console.log(error);\\n                        });\\n                }\\n            }\\n\\n        } else {\\n            $utils.message.error('调整优先级失败！' + res.data.msg)\\n        }\\n    }).catch(function (error) {\\n        $this.setIsSpin(false)\\n        console.log(error);\\n    });\\n\\n}\\n\"}},\"type\":\"primary\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]}]}]}]}]","inputVars":null,"viewPlugins":null,"version":34,"createUser":"xiacj3","createDt":null,"lastupd":null,"updateUser":null,"digest":null,"versionInfo":"","appName":"dataps","createUserName":null}