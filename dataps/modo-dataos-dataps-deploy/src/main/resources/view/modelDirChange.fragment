{"id":"e17d90ba93d72b2f","module":"236150763746426880","moduleLabel":null,"name":"modelDirChange","label":"模型目录移动","descr":"模型目录移动","type":"fragment","state":"1","parameters":"[{\"id\":\"0\",\"name\":\"0\",\"label\":\"页面\",\"type\":\"view\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltipText\":null,\"className\":\"\",\"css\":\":root {\\n    padding:20px;\\n}\",\"loop\":{\"data\":null,\"dataBindVar\":null,\"var\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false},\"eventMap\":{},\"type\":\"one-screen-layout\",\"titleVisible\":false,\"vars\":[{\"name\":\"teamMemberOptions\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"toTransfer\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"modelTree\",\"descr\":null,\"value\":\"[]\"}],\"models\":[],\"services\":[{\"name\":\"loadModelArch\",\"stateName\":\"\",\"descr\":\"载入模型目录树\",\"autoLoad\":true,\"serviceId\":\"180004040250462208\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.params.teamName = $this.teamName;\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    const typeMap = {};\\r\\n    if (data.data.length === 0) {\\r\\n        return data.data;\\r\\n    }\\r\\n    const keyMap = {};\\r\\n    const roots = [];\\r\\n    data.data.forEach(item=>{\\r\\n        keyMap[item.id] = item;\\r\\n        item.key = item.id;\\r\\n        if(!item.parentId){\\r\\n            roots.push(item);\\r\\n        }\\r\\n    });\\r\\n     const expandTypeMap = function(type, nodes, typeMap){\\r\\n        if(nodes.length>0){\\r\\n            nodes.forEach(node=>{\\r\\n                typeMap[node.id] = type;\\r\\n                if(node.children){\\r\\n                    expandTypeMap(type, node.children, typeMap);\\r\\n                }\\r\\n            });\\r\\n        }\\r\\n    }\\r\\n    roots.forEach(root=>{\\r\\n        typeMap[root.id] = root;\\r\\n        if(root.children){\\r\\n            expandTypeMap(root, root.children, typeMap);\\r\\n        }\\r\\n    });\\r\\n    $this.setModelTree(roots);\\r\\n    return data.data[0].children; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    console.error(error);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"changeModelDir\",\"stateName\":\"\",\"descr\":\"模型目录修改\",\"autoLoad\":false,\"serviceId\":\"192243506573230080\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.data.dirId = $this.$refs.memberForm.getFieldsValue().dirIdArr[$this.$refs.memberForm.getFieldsValue().dirIdArr.length-1];\\r\\n    vars.data.modelIds = $this.modelIds; \\r\\n    vars.data.userId = $identity.userId;\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\r\\n    $utils.notification.success({\\r\\n        title: '成功',\\r\\n        content: '模型目录修改成功！',\\r\\n    });\\r\\n    $this.getParent().datasourceMap.getModelPage();\\r\\n    if($this.getParent()&&$this.getParent().getParent()&&$this.getParent().getParent().datasourceMap.getDataArchDefTree){\\r\\n        $this.getParent().getParent().datasourceMap.getDataArchDefTree();\\r\\n    }\\r\\n    $this.close();\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $utils.notification.error({\\r\\n        title: '失败',\\r\\n        content: '模型目录修改失败！',\\r\\n    });\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"}],\"i18n\":{\"zh-CN\":\"{}\",\"en-US\":\"{}\"}},\"children\":[{\"id\":\"bb4e9e893e2ace2f\",\"name\":\"bb4e9e893e2ace2f\",\"label\":\"页面布局\",\"type\":\"flexLayout\",\"op