     }\\r\\n    });\\r\\n    const loadChildrenPriv = function (arr) {\\r\\n        arr.forEach(item => {\\r\\n            item.priv = '1';\\r\\n            if (item.children && item.children.length > 0) {\\r\\n                loadChildrenPriv(item.children);\\r\\n            }\\r\\n        })\\r\\n    }\\r\\n    parentPrivs.forEach(item => {\\r\\n        if (item.children && item.children.length > 0) {\\r\\n            loadChildrenPriv(item.children);\\r\\n        }\\r\\n    });\\r\\n    $this.setLoading(false);\\r\\n    $this.setCascaderOptions(data.data.filter(item=>{\\r\\n        return item.parent&&item.parent==rootKey;\\r\\n    }));\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"saveDataArch\",\"stateName\":\"\",\"descr\":\"\",\"autoLoad\":false,\"serviceId\":\"176353616549822464\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.data.archData = $this.treeData.filter(item=>{\\r\\n        return item.changeState!='notChange';\\r\\n    });\\r\\n    vars.data.workspaceId = $this.workspaceId;\\r\\n    $this.setLoading(true);\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\r\\n    $this.setLoading(false);\\r\\n    $utils.notification.success({\\r\\n        title: '成功',\\r\\n        content: '数据架构保存成功！',\\r\\n    });\\r\\n    $this.datasourceMap.getDataArchDefTree();\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n     $this.setLoading(false);\\r\\n     $utils.notification.error({\\r\\n        title: '失败',\\r\\n        content: '数据架构保存失败！',\\r\\n    });\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"checkSysDataAr