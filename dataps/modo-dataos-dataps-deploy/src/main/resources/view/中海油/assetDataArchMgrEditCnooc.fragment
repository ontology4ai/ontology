":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"dblclick\":{\"builtIn\":{\"type\":\"view\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"$this.$refs.treeDef.treeChartRef.current.getSelection().data.name!=$this.rootKey\",\"showType\":\"drawer\",\"viewName\":\"assetDataArchNodeEditCnooc\",\"before\":\"function beforeCallback() { }\",\"width\":\"75%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\",\"title\":\"架构结点编辑\",\"params\":\"{\\r\\n    archType: $this.archType,\\r\\n        impl: $this.impl,\\r\\n            rootKey: $this.rootKey,\\r\\n    isMgr: '1', formData: _.extend({ parentNode: $this.srcArchMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.parent] }, $this.$refs.treeDef.treeChartRef.current.getSelection().data)\\r\\n}\"}],\"actions\":[]},\"callback\":\"function callback() {\\r\\n    $this.setEditNode($this.$refs.treeDef.treeChartRef.current.getSelection().data);\\r\\n}\"},\"nodeDrag\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback(e, node) {\\r\\n    debugger;\\r\\n}\"},\"nodeDrop\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback(e, node, cb) {\\r\\n    const loadChildrens = function (target, arr) {\\r\\n        if (target.children) {\\r\\n            target.children.forEach(item => {\\r\\n                arr.push(item);\\r\\n                loadChildrens(item, arr);\\r\\n            });\\r\\n        }\\r\\n    }\\r\\n    const childrens = [];\\r\\n    loadChildrens($this.$refs.treeDef.treeChartRef.current.getSelection().data, childrens);\\r\\n    if (childrens.some(item => {\\r\\n        return item.id === node.data.key;\\r\\n    })) {\\r\\n        $utils.message.warning(\\\"不允许挂载到自己的下属节点！\\\");\\r\\n        return;\\r\\n    }\\r\\n    if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.priv != '1' || node.data.priv != '1') {\\r\\n        $this.utils.modal.warning({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '无编辑权限！',\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n    if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.parent == node.data.key) {\\r\\n        cb();\\r\\n        return;\\r\\n    } else {\\r\\n        const target = [];\\r\\n        $this.treeData.forEach(item => {\\r\\n            target.push(item);\\r\\n            if (item.key == $this.$refs.treeDef.treeChartRef.current.getSelection().data.key) {\\r\\n                debugger;\\r\\n                item.parent = node.data.key;\\r\\n                if (item.changeState != 'add') {\\r\\n                    item.changeState = 'change';\\r\\n                } else {\\r\\n                    item.changeState = 'add';\\r\\n                }\\r\\n                if (node.data.key == $this.rootKey) {\\r\\n                    item.busiType = '1';\\r\\n                } else if (node.data.busiType == '1') {\\r\\n                    item.busiType = '2';\\r\\n                }\\r\\n            }\\r\\n        });\\r\\n        $this.setTreeData(target);\\r\\n        cb();\\r\\n    }\\r\\n}\"}},\"data\":[{\"key\":\"root\",\"name\":\"root\",\"label\":\"数据架构定义\",\"descr\":\"数据架构定义描述\"},{\"key\":\"topic\",\"name\":\"topic\",\"label\":\"主题\",\"descr\":\"主题描述\",\"parent\":\"root\"},{\"key\":\"lvl\",\"name\":\"lvl\",\"label\":\"层次\",\"descr\":\"层次描述\",\"parent\":\"root\"},{\"key\":\"sys\",\"name\":\"sys\",\"label\":\"系统\",\"descr\":\"系统描述\",\"parent\":\"root\"},{\"key\":\"db\",\"name\":\"db\",\"label\":\"数据库\",\"descr\":\"数据库描述\",\"parent\":\"root\"}],\"dataBindVar\":\"$this.treeData\",\"contextMenus\":[{\"label\":\"添加下级\",\"__ORIGIN_DATA\":{\"label\":\"\"},\"event\":{\"builtIn\":{\"type\":\"view\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"drawer\",\"viewName\":\"assetDataArchNodeEditCnooc\",\"before\":\"function beforeCallback() { }\",\"width\":\"75%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\",\"params\":\"{\\r\\n    archType: $this.archType,\\r\\n        impl: $this.impl,\\r\\n            rootKey: $this.rootKey,\\r\\n    isMgr: '1', formData: { parentNode: $this.$refs.treeDef.treeChartRef.current.getSelection().data, parent: $this.$refs.treeDef.treeChartRef.current.getSelection().data.key, parentLabel: $this.$refs.treeDef.treeChartRef.current.getSelection().data.label, priv: '1', type: $this.$refs.treeDef.treeChartRef.current.getSelection().data.parent == $this.rootKey ? $this.$refs.treeDef.treeChartRef.current.get