oadChildrenPriv = function (arr) {\\r\\n        arr.forEach(item => {\\r\\n            item.priv = '1';\\r\\n            if (item.children && item.children.length > 0) {\\r\\n                loadChildrenPriv(item.children);\\r\\n            }\\r\\n        })\\r\\n    }\\r\\n    parentPrivs.forEach(item => {\\r\\n        if (item.children && item.children.length > 0) {\\r\\n            loadChildrenPriv(item.children);\\r\\n        }\\r\\n    });\\r\\n    $this.setLoading(false);\\r\\n    if (data.data.length == 0) {\\r\\n        data.data.push({\\r\\n            \\\"key\\\": \\\"root\\\",\\r\\n            \\\"priv\\\": \\\"1\\\",\\r\\n            \\\"label\\\": \\\"编目\\\",\\r\\n            \\\"name\\\": \\\"root\\\",\\r\\n            \\\"type\\\": \\\"root\\\",\\r\\n            \\\"descr\\\": \\\"编目\\\",\\r\\n            \\\"changeState\\\": \\\"notChange\\\"\\r\\n        });\\r\\n    }\\r\\n    $this.setCascaderOptions(data.data.filter(item => {\\r\\n        return item.parent && item.parent == rootKey;\\r\\n    }));\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"saveDataArch\",\"stateName\":\"\",\"descr\":\"\",\"autoLoad\":false,\"serviceId\":\"225548456596156416\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.data.archData = $this.treeData.filter(item=>{\\r\\n        item.archType = $this.archType;\\r\\n        return item.changeState!='delete';\\r\\n    });\\r\\n    vars.data.updateUser = $identity.userId;\\r\\n    vars.data.archType = $this.archType||null;\\r\\n    vars.data.impl = $this.impl||null;\\r\\n    $this.setLoading(true);\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    $this.setLoading(false);\\r\\n    $utils.notification.success({\\