Type\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\r\\n    const catalogMap = {};\\r\\n    $this.treeData.forEach(item => {\\r\\n        catalogMap[item.key] = item;\\r\\n    });\\r\\n    $this.treeData.forEach(item => {\\r\\n        if (item.parent && catalogMap[item.parent]) {\\r\\n            if (!catalogMap[item.parent].children) {\\r\\n                catalogMap[item.parent].children = [];\\r\\n            }\\r\\n            catalogMap[item.parent].children.push(item);\\r\\n        }\\r\\n    });\\r\\n    if (!$this.$refs.treeDef.treeChartRef.current.getSelection().data.parent) {\\r\\n        $this.utils.modal.warning({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '根结点不允许删除！',\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n    if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.archModelNum && $this.$refs.treeDef.treeChartRef.current.getSelection().data.archModelNum > 0) {\\r\\n        $this.utils.modal.confirm({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '节点下存在模型，请先修改模型编目！',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            onOk: () => {\\r\\n                $this.parent.$refs.sysDataArch.addTab('changeModelArch', '模型编目修改', '', 'logicModelArchMove', {\\r\\n                    dirIds: [$this.$refs.treeDef.treeChartRef.current.getSelection().data.key]\\r\\n                })\\r\\n            }\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n    const filterModelDirs = function (nodes, dirs, dirIds, filterProp) {\\r\\n        nodes.forEach(item => {\\r\\n            if (item[filterProp] && item[filterProp] > 0) {\\r\\n                dirs.push(item.label);\\r\\n                dirIds.push(item.key);\\r\\n            }\\r\\n            if (item.children) {\\r\\n                filterModelDirs(item.children, dirs, dirIds, filterProp);\\r\\n            }\\r\\n        });\\r\\n    }\\r\\n    if (catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children) {\\r\\n        let modelDirs = [];\\r\\n        let modelDirIds = [];\\r\\n        filterModelDirs(catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children, modelDirs, modelDirIds, 'archModelNum');\\r\\n        if (modelDirs.length > 0) {\\r\\n            $this.utils.modal.confirm({\\r\\n                title: '提示',\\r\\n                content:\\r\\n                    '子节点“' + modelDirs.join(',') + '”下存在模型，请先修改模型编目！',\\r\\n                okButtonProps: {\\r\\n                    status: 'danger',\\r\\n                },\\r\\n                onOk: () => {\\r\\n                    $this.parent.$refs.sysDataArch.addTab('changeModelArch', '模型编目修改', '', 'logicModelArchMove', {\\r\\n                        dirIds: modelDirIds\\r\\n                    })\\r\\n                }\\r\\n            });\\r\\n            return;\\r\\n        }\\r\\n    }\\r\\n\\r\\n    const target = [];\\r\\n    if (catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key] && catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children && catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children.length > 0) {\\r\\n        $utils.modal.confirm({\\r\\n            title: '警告',\\r\\n            content: '确认删除该结点及其下属结点吗？',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            onOk: () => {\\r\\n                const toRemove = [$this.$refs.treeDef.treeChartRef.current.getSelection().data.key];\\r\\n                const getChildren = function (children, keyList) {\\r\\n                    children.forEach(item => {\\r\\n                        keyList.push(item.key);\\r\\n                        if (item.children && item.children.length > 0) {\\r\\n                            getChildren(item.children, keyList);\\r\\n                        }\\r\\n                    });\\r\\n                }\\r\\n                getChildren(catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children, toRemove);\\r\\n                $this.treeData.forEach(item => {\\r\\n                    if (toRemove.indexOf(item.key) > -1) {\\r\\n                        if (item.changeState != 'add') {\\r\\n                            item.changeState = 'delete';\\r\\n                            target.push(item);\\r\\n                        }\\r\\n                    } else {\\r\\n                        target.push(item);\\r\\n                    }\\r\\n                });\\r\\n                target.forEach(item => {\\r\\n                    delete item.children;\\r\\n                })\\r\\n                $this.setTreeData(target);\\r\\n                $this.$refs.treeDef.treeChartRef.current.loadData(target);\\r\\n            }\\r\\n        });\\r\\n    } else {\\r\\n        $utils.modal.confirm({\\r\\n            title: '警告',\\r\\n            content: '确认删除该结点吗？',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            onOk: () => {\\r\\n                $this.treeData.forEach(item => {\\r\\n                    if (item.key == $this.$refs.treeDef.treeChartRef.current.getSelection().data.key) {\\r\\n                        if (item.changeState != 'add') {\\r\\n                            item.changeState = 'delete';\\r\\n                            target.push(item);\\r\\n                        }\\r\\n                    } else {\\r\\n                        target.push(item);\\r\\n                    }\\r\\n                });\\r\\n                target.forEach(item => {\\r\\n                    delete item.children;\\r\\n                })\\r\\n          