bel\":\"\",\"params\":\"{ editType: 'add' }\",\"title\":\"新增空间目录节点\"}],\"actions\":[]},\"callback\":\"function callback(props) {\\r\\n    let c = {\\r\\n        name: props._key,\\r\\n        label: props.title\\r\\n\\r\\n    }\\r\\n    $this.setCurrentNode(c);\\r\\n\\r\\n}\"}}}},{\"label\":\"编辑\",\"icon\":\"IconEdit\",\"event\":{\"builtIn\":{\"type\":\"view\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":\"workSpaceDirEditPage\",\"before\":\"function beforeCallback() {}\",\"width\":\"30%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\",\"params\":\"{ curNode: $this.currentNode, editType: 'edit' }\",\"title\":\"编辑空间目录节点\"}],\"actions\":[]},\"callback\":\"function callback(props) {\\r\\n    let c = {\\r\\n        name: props._key,\\r\\n        label: props.title\\r\\n\\r\\n    }\\r\\n    $this.setCurrentNode(c);\\r\\n\\r\\n}\"}},{\"label\":\"删除\",\"icon\":\"IconDelete\",\"event\":{\"builtIn\":{\"type\":\"view\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() { }\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback(props) {\\r\\n    \\r\\n    if (props._key == 'topDir') {\\r\\n        $utils.message.warning('根节点不可删除！');\\r\\n        return;\\r\\n    }\\r\\n\\r\\n    // _api/_/modoProc/find?workspaceName=data_dev&dirId=node1\\r\\n\\r\\n    $utils.axios.get('/_api/_/modoProc/find?workspaceName=' + $this.currRow.name + '&dirId=' + props.name).then(data => {\\r\\n        if (data.data.data.length > 0) {\\r\\n            $utils.message.warning('该节点下有程序，不可删除！');\\r\\n            return;\\r\\n        } else {\\r\\n            $utils.modal.confirm({\\r\\n                title: '删除节点确认',\\r\\n                content:\\r\\n                    '是否确认删除该节点[' + props.title + ']?',\\r\\n                okButtonProps: {\\r\\n                    status: 'danger',\\r\\n                },\\r\\n                onOk: () => {\\r\\n                    debugger;\\r\\n                    let tree = $this.workspaceDirData;\\r\\n                    let newTree = removeNode(tree, props._key);\\r\\n                    $this.setWorkspaceDirData(newTree);\\r\\n\\r\\n                }\\r\\n            });\\r\\n        }\\r\\n\\r\\n\\r\\n\\r\\n    }).catch(function (error) {\\r\\n        console.log(error);\\r\\n    });\\r\\n\\r\\n\\r\\n}\\r\\n\\r\\nfunction removeNode(tree, key) {\\r\\n\\r\\n    const removeNodeInTree = (treeList, key) => { // 通过id从数组（树结构）中移除元素\\r\\n        if (!treeList || !treeList.length) {\\r\\n            return\\r\\n        }\\r\\n        for (let i = 0; i < treeList.length; i++) {\\r\\n            if (treeList[i].key === key) {\\r\\n                treeList.splice(i, 1);\\r\\n                break;\\r\\n            }\\r\\n            removeNodeInTree(treeList[i].children, key)\\r\\n        }\\r\\n        return treeList;\\r\\n    }\\r\\n\\r\\n    return removeNodeInTree(tree, key);\\r\\n\\r\\n}\"}}]},\"stateVars\":[\"workspaceDirData\"],\"innerVars\":[],\"children\":[]}]}]}]}]},{\"id\":\"3b4f5a4b777eb5ec\",\"name\":\"3b4f5a4b777eb5ec\",\"label\":\"flex布局\",\"type\":\"flexLayout\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root{\\n        /* display: flex;\\n    align-items: center; */\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVi