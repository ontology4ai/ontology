{"id":"dataps-139382522042880002","module":"53562681944412160","moduleLabel":null,"name":"workSpaceEditPage","label":"工作空间编辑页面","descr":"","type":"fragment","state":"1","parameters":"[{\"id\":\"0\",\"name\":\"0\",\"label\":\"页面\",\"type\":\"view\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltipText\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"data\":null,\"dataBindVar\":null,\"var\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onMount\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\n\\n\\n\\n    const allTabsConst = JSON.parse(JSON.stringify($this.$refs.dpAndStreamTab.state.tabs));\\n    $this.currRow.tabs = allTabsConst;\\n\\n    var allTabs = $this.$refs.dpAndStreamTab.state.tabs;\\n    if ($this.currRow.dp == true && $this.currRow.stream == true && $this.currRow.project == true) {\\n        $this.$refs.dpAndStreamTab.setActive('projectDevCompList');\\n        $this.$refs.dpAndStreamTab.setActive('streamDevCompList');\\n        $this.$refs.dpAndStreamTab.setActive('dpDevCompList');\\n    } else if ($this.currRow.dp == true && $this.currRow.stream == true) {\\n        arrDelete(allTabs, (item) => item.title == '工程');\\n        $this.$refs.dpAndStreamTab.setActive('streamDevCompList');\\n        $this.$refs.dpAndStreamTab.setActive('dpDevCompList');\\n    } else if ($this.currRow.dp == true && $this.currRow.project == true) {\\n        arrDelete(allTabs, (item) => item.title == '实时编排');\\n        $this.$refs.dpAndStreamTab.setActive('projectDevCompList');\\n        $this.$refs.dpAndStreamTab.setActive('dpDevCompList');\\n    } else if ($this.currRow.stream == true && $this.currRow.project == true) {\\n        arrDelete(allTabs, (item) => item.title == '离线编排');\\n        $this.$refs.dpAndStreamTab.setActive('projectDevCompList');\\n        $this.$refs.dpAndStreamTab.setActive('streamDevCompList');\\n    } else if ($this.currRow.dp == true) {\\n        arrDelete(allTabs, (item) => item.title == '实时编排');\\n        arrDelete(allTabs, (item) => item.title == '工程');\\n        $this.$refs.dpAndStreamTab.setActive('dpDevCompList');\\n    } else if ($this.currRow.stream == true) {\\n        arrDelete(allTabs, (item) => item.title == '离线编排');\\n        arrDelete(allTabs, (item) => item.title == '工程');\\n        $this.$refs.dpAndStreamTab.setActive('streamDevCompList');\\n    } else if ($this.currRow.project == true) {\\n        arrDelete(allTabs, (item) => item.title == '离线编排');\\n        arrDelete(allTabs, (item) => item.title == '实时编排');\\n        $this.$refs.dpAndStreamTab.setActive('projectDevCompList');\\n    }\\n\\n\\n    $this.$refs.dpAndStreamTab.setTabs(allTabs);\\n\\n    let modelWorkspaceDirList = $this.currRow.modelWorkspaceDirList;\\n    if (modelWorkspaceDirList != undefined && modelWorkspaceDirList.length > 0) {\\n        const procDirs = modelWorkspaceDirList.filter(item => item.dirType == 'proc');\\n        $this.setWorkspaceDirData(listToTree(procDirs));\\n    }\\n    $this.$refs['treeData'].setExpandedKeys(['topDir']);\\n\\n}\\n\\n\\nfunction listToTree(data, idName, parentIdName) {\\n    if (!idName) {\\n        idName = 'name';\\n    }\\n    if (!parentIdName) {\\n        parentIdName = 'parentName';\\n    }\\n\\n    // * 先生成parent建立父子关系\\n    const obj = {};\\n    data.forEach((item) => {\\n        obj[item[idName]] = item;\\n    });\\n    const parentList = [];\\n    data.forEach((item) => {\\n        // item.hasChildren = false;\\n        item.key = item.name;\\n        item.title = item.label;\\n        const parent = obj[item[parentIdName]];\\n        if (parent) {\\n            // * 当前项有父节点\\n            parent.children = parent.children || [];\\n            parent.children.push(item);\\n            // parent.hasChildren = true;\\n        } else {\\n            // * 当前项没有父节点 -> 顶层\\n            parentList.push(item);\\n        }\\n    });\\n    return parentList;\\n}\\n\\n/**\\n         * 删除数组中指定对象\\n         * @param {OBject} arr \\n         * @param {function} func 返回ture或false\\n         */\\nfunction arrDelete(arr, func) {\\n    // 遍历取到每个对象和对应下标，通过自定义的函数判断该对象是否删除，\\n    arr.forEach((item, i) => {\\n        if (func(item)) {\\n            arr.splice(i, 1)\\n        }\\n    })\\n}\"}},\"type\":\"one-screen-layout\",\"titleVisible\":false,\"vars\":[{\"name\":\"workspaceDirData\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"currentNode\",\"descr\":null,\"value\":\"{}\"},{\"name\":\"showLabelFrom\",\"descr\":\"显示中文名编辑表单\",\"value\":\"false\"},{\"name\":\"showDescrFrom\",\"descr\":\"显示描述表单\",\"value\":\"false\"},{\"name\":\"saveLoading\",\"descr\":null,\"value\":\"false\"}],\"models\":[{\"id\":\"54952326569627648\",\"modelId\":null,\"namespace\":\"io.github.suanchou.driver.domain\",\"doc\":\"工作空间表\",\"topic\":\"54562042241323008\",\"loc\":\"601.4285714285716 -38.5714285714285\",\"appName\":\"datamodel\",\"language\":\"zh-cn\",\"expand\":false,\"type\":\"record\",\"name\":\"ModelWorkspace\",\"modelType\":\"domain\",\"modelSubType\":\"\",\"