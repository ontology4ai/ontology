uiltIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\n\\n\\n    var wsObj = $this.currRow;\\n    var label = $this.$refs.label_from.getFieldsValue().label;\\n    var descr = $this.$refs.descr_from.getFieldsValue().descr;\\n\\n    // 是否修改中文名和描述\\n\\n    if ($this.showLabelFrom === true && label !== undefined && label !== null && label !== '') {\\n        wsObj.label = label;\\n    }\\n    if ($this.showDescrFrom === true && descr !== undefined && descr !== null && descr !== '') {\\n        wsObj.descr = descr;\\n    }\\n\\n\\n    if (wsObj.state == '禁用') {\\n        wsObj.state = '0'\\n    } else if (wsObj.state == '启用') {\\n        wsObj.state = '1'\\n    }\\n\\n    if (wsObj.devState == '否') {\\n        wsObj.devState = '0'\\n    } else if (wsObj.devState == '是') {\\n        wsObj.devState = '1'\\n    }\\n\\n    if (wsObj.type == '数据建模空间') {\\n        wsObj.type = '1'\\n    } else if (wsObj.type == '数据开发空间') {\\n        wsObj.type = '2'\\n    }\\n\\n    if (wsObj.dataDevMode == '绑定建模空间') {\\n        wsObj.dataDevMode = '1'\\n    } else if (wsObj.dataDevMode == '敏捷数据开发') {\\n        wsObj.dataDevMode = '2'\\n    } else if (wsObj.dataDevMode == '数仓规划') {\\n        wsObj.dataDevMode = '3'\\n    } else if (wsObj.dataDevMode == 'ER建模') {\\n        wsObj.dataDevMode = '4'\\n    }\\n\\n\\n\\n    // 是开发才配置开发工具\\n    let dirList = [];\\n    if (wsObj.devState == '1' || wsObj.type == '2') {\\n\\n        // 树\\n\\n        wsDirInfo2 = $this.workspaceDirData;\\n        dirList = treeToArr(wsDirInfo2);\\n        dirList = dirList.concat($this.currRow.modelWorkspaceDirList.filter(item => item.dirType != 'proc'));\\n\\n        var dpAndStreamFrom = $this.$refs.dpAndStreamFrom.getFieldsValue();\\n        // 开发工具\\n        var modelWorkspaceDevCategoryList = [];\\n        // 组件\\n        var modelWorkspaceDevCompList = [];\\n        if (dpAndStreamFrom.dp == true) {\\n            var workspaceDevCategory = {};\\n            workspaceDevCategory.categoryName = '离线编排';\\n            modelWorkspaceDevCategoryList.push(workspaceDevCategory);\\n\\n            var dpDevCompList = $this.getChildren('dpDevCompList').$refs.dpDevCompList.state.selectedRows;\\n\\n            if (dpDevCompList != undefined) {\\n                for (let dpDevComp of dpDevCompList) {\\n                    var modelWorkspaceDevComp = {};\\n                    modelWorkspaceDevComp.name = dpDevComp.stepInst;\\n                    modelWorkspaceDevComp.label = dpDevComp.stepInstLabel;\\n                    modelWorkspaceDevComp.categoryName = '离线编排';\\n                    modelWorkspaceDevComp.authDate = $utils.moment();\\n                    modelWorkspaceDevCompList.push(modelWorkspaceDevComp);\\n                }\\n            }\\n        }\\n        if (dpAndStreamFrom.stream == true) {\\n            var workspaceDevCategory = {};\\n            workspaceDevCategory.categoryName = '实时编排';\\n            modelWorkspaceDevCategoryList.push(workspaceDevCategory);\\n\\n            var streamDevCompList = $this.getChildren('streamDevCompList').$refs.streamDevCompList.state.selectedRows;\\n            if (streamDevCompList != undefined) {\\n                for (let streamDevComp of streamDevCompList) {\\n                    var modelWorkspaceDevComp = {};\\n                    modelWorkspaceDevComp.name = streamDevComp.stepInst;\\n                    modelWorkspaceDevComp.label = streamDevComp.stepInstLabel;\\n                    modelWorkspaceDevComp.categoryName = '实时编排';\\n                    modelWorkspaceDevComp.authDate = $utils.moment();\\n                    modelWorkspaceDevCompList.push(modelWorkspaceDevComp);\\n                }\\n            }\\n        }\\n\\n        if (dpAndStreamFrom.project == true) {\\n            var workspaceDevCategory = {};\\n            workspaceDevCategory.categoryName = '工程';\\n            modelWorkspaceDevCategoryList.push(workspaceDevCategory);\\n            var projectDevCompList = $this.getChildren('projectDevCompList').$refs.projectDevCompList.state.selectedRows;\\n            // var projectDevCompList = projec.projectDevComp;\\n\\n            if (projectDevCompList != undefined) {\\n                for (let projectDevComp of projectDevCompList) {\\n                    var modelWorkspaceDevComp = {};\\n                    modelWorkspaceDevComp.name = projectDevComp.projectDevComp;\\n                    modelWorkspaceDevComp.label = projectDevComp.projectDevComp;\\n                    modelWorkspaceDevComp.categoryName = '工程';\\n                    modelWorkspaceDevComp.authDate = $utils.moment();\\n                    modelWorkspaceDevCompList.push(modelWorkspaceDevComp);\\n                }\\n            }\\n        }\\n        wsObj.modelWorkspaceDevCompList = modelWorkspaceDevCompList;\\n        wsObj.modelWorkspaceDevCategoryList = modelWorkspaceDevCategoryList;\\n\\n    } else {\\n        wsObj.modelWorkspaceDevCompList = undefined;\\n        wsObj.modelWorkspaceDevCategoryList = undefined;\\n    }\\n\\n    var workspacePrivFrom0 = $this.$refs.workspacePrivFrom0.getFieldsValue();\\n    var workspacePrivFrom1 = $this.$refs.workspacePrivFrom1.getFieldsValue();\\n    var workspacePrivFrom2 = $this.$refs.workspacePrivFrom2.getFieldsValue();\\n    // 工作空间权限\\n    var modelWorkspacePrivList = [];\\n    var dirPriv = {};\\n    dirPriv.objectType = 'dir';\\n    dirPriv.responsible = workspacePrivFrom0.dir;\\n    dirPriv.workspaceId = wsObj.id;\\n    var devContentPriv = {};\\n    devContentPriv.objectType = 'devContent';\\n    devContentPriv.responsible = workspacePrivFrom0.devContent;\\n    devContentPriv.workspaceId = wsObj.id;\\n    var numOfDataQuery = {};\\n    numOfDataQuery.objectType = 'numOfDataQuery';\\n    numOfDataQuery.responsible = workspacePrivFrom2.numOfDataQuery == undefined ? '0' : workspacePrivFrom2.numOfDataQuery.toString();\\n    numOfDataQuery.workspaceId = wsObj.id;\\n\\n\\n\\n    var dsProfileList = workspacePrivFrom1.dsProfile;\\n    for (let ondDsProfile of dsProfileList) {\\n        var dsProfile = {};\\n        dsProfile.objectType = 'dsProfile';\\n        dsProfile.responsible = ondDsProfile;\\n        dsProfile.workspaceId = wsObj.id;\\n        modelWorkspacePrivList.push(dsProfile);\\n    }\\n    var orderOfDataQueryList = workspacePrivFrom1.orderOfDataQuery;\\n    for (let ondOrderOfDataQuery of orderOfDataQueryList) {\\n        var orderOfDataQuery = {};\\n        orderOfDataQuery.objectType = 'orderOfDataQuery';\\n        orderOfDataQuery.responsible = ondOrderOfDataQuery;\\n        orderOfDataQuery.workspaceId = wsObj.id;\\n        modelWorkspacePrivList.push(orderOfDataQuery);\\n    }\\n\\n\\n\\n    modelWorkspacePrivList.push(dirPriv);\\n    modelWorkspacePrivList.push(devContentPriv);\\n    modelWorkspacePrivList.push(numOfDataQuery);\\n\\n\\n\\n    wsObj.modelWorkspacePrivList = modelWorkspacePrivList;\\n\\n\\n\\n    wsObj.modelWorkspaceDirList = dirList;\\n    wsObj.updateUser = $identity.userName;\\n    $this.modelWorkspaceRepo.updateCascade(wsObj);\\n    $this.setSaveLoading(true);\\n\\n\\n}\\n\\nfunction treeToArr(data) {\\n    const result = [];\\n    data.forEach(item => {\\n        const loop = data => {\\n            result.push({\\n                name: data.key,\\n                label: data.title,\\n                parentName: data.parentName,\\n                dirType: 'proc'\\n            });\\n            let child = data.children\\n            if (child) {\\n                for (let i = 0; i < child.length; i++) {\\n                    loop(child[i])\\n                }\\n            }\\n        }\\n        loop(item);\\n    })\\n    return result;\\n}\"}},\"type\":\"primary\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"stateVars\":[],\"innerVars\":[],\"children\":[]},{\"id\":\"2b0321d299fb87a1\",\"name\":\"2b0321d299fb87a1\",\"label\":\"容器\",\"type\":\"container\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\nheight: 200px;\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1}},\"eventMap\":{}},\"defaultOptions\":{\"css\":\":root {\\nheight: 200px;\\n}\"},\"stateVars\":[],\"innerVars\":[],\"children\":[]}]}]}]}]","inputVars":null,"viewPlugins":null,"version":714,"createUser":"xiacj3","createDt":null,"lastupd":null,"updateUser":null,"digest":null,"versionInfo":"","appName":"dataps","createUserName":null}