\"name\":\"searching\",\"descr\":null,\"value\":\"false\"},{\"name\":\"lvlOptions\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"lvlMap\",\"descr\":null,\"value\":\"{}\"}],\"models\":[],\"services\":[{\"name\":\"getPage\",\"stateName\":\"\",\"descr\":\"\",\"autoLoad\":false,\"loadType\":\"1\",\"serviceId\":\"/_api/datapsModelNamingRule/search\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":[],\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    const filters = $this.$refs.searchForm.getFieldsValue();\\r\\n    for (var f in filters) {\\r\\n        if (f == 'keyWord' && filters[f]) {\\r\\n            vars.params._orGroup_ = 'namingRule=~%' + filters[f] + '%'\\r\\n        }else if(f=='targetArr' && filters[f] && filters[f].length>0){\\r\\n            vars.params.targetLvl = filters[f][filters[f].length-1];\\r\\n        }else if(filters[f]){\\r\\n            vars.params[f] = filters[f];\\r\\n        }\\r\\n        \\r\\n    }\\r\\n    if (vars.params.pageSize == undefined) {\\r\\n        vars.params.limit = 10;\\r\\n    } else {\\r\\n        vars.params.limit = vars.params.pageSize;\\r\\n        delete vars.params.pageSize;\\r\\n    }\\r\\n    if (vars.params.pageNum == undefined) {\\r\\n        vars.params.offset = 0;\\r\\n    } else {\\r\\n        vars.params.offset = (vars.params.pageNum - 1) * vars.params.limit;\\r\\n        delete vars.params.pageNum;\\r\\n    }\\r\\n    $this.setSearching(true);\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    $this.setSearching(false);\\r\\n    data.data.content.forEach(item => {\\r\\n        if (item.targetType == 'lvl') {\\r\\n            item.targetTypeLabel = '层级';\\r\\n        } else if (item.targetType == 'workspaceDir') {\\r\\n            item.targetTypeLabel = '工作空间目录';\\r\\n        }\\r\\n\\r\\n        if (item.ruleLevel == '1') {\\r\\n            item.ruleLevelLabel = '红色(阻断后续操作)';\\r\\n        } else if (item.ruleLevel == '2') {\\r\\n            item.ruleLevelLabel = '黄色(不阻断仅提示)';\\r\\n        }\\r\\n        item.targetLabel = item.targetLvlLabel || item.targetDirLabel;\\r\\n\\r\\n        if(item.ruleType) {\\r\\n            const tempTypes = item.ruleType.split(',');\\r\\n            const targetRuleTypeLabels = [];\\r\\n            tempTypes.forEach(item=>{\\r\\n                targetRuleTypeLabels.push($this.ruleTypeMap[item]||item);\\r\\n            });\\r\\n            item.ruleTypeLabel = targetRuleTypeLabels.join(',');\\r\\n        }else{\\r\\n            item.ruleTypeLabel = '';\\r\\n        }\\r\\n    });\\r\\n    data.data.content.forEach(item => {\\r\\n        item.lvlLabel = $this.lvlMap[item.lvl];\\r\\n    });\\r\\n    $this.setTableData(data.data);\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $this.setSearching(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"deleteById\",\"stateName\":\"\",\"descr\":\"根据ID删除参考数据\",\"autoLoad\":false,\"loadType\":\"1\",\"serviceId\":\"/_api/datapsModelNamingRule/delete/{id}\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":[],\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    var url = config.url;\\r\\n    config.url = url.replace('{id}', $this.$refs.stdPubDimTable.currentRow.id);\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    $utils.notification.success({\\r\\n        title: '成功',\\r\\n        content: '命名规则删除成功！',\\r\\n    });\\r\\n    $this.datasourceMap.getPage();\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $utils.notification.error({\\r\\n        title: '失败',\\r\\n        content: '命名规则删除失败！',\\r\\n    });\\r\\n}\",\"callback\":\"\"},{\"name\":\"getLvlOptions\",\"stateName\":\"lvlOptions\",\"descr\":\"获取层次\",\"autoLoad\":false,\"serviceId\":\"173799105170919424\",\"method\":\"GET\",\"dataBindVar\":\