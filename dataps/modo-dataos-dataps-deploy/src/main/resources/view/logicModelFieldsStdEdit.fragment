d && !data.data[0].labelIsStd) {\\r\\n            const target = [];\\r\\n            $this.formData.fields.forEach(field => {\\r\\n                const temp = _.extend({}, field);\\r\\n                if (temp.fieldName&&temp.fieldName.toLowerCase() == data.data[0].recName.toLowerCase()) {\\r\\n                    temp.fieldLabel = data.data[0].recLabel;\\r\\n                }\\r\\n                temp.stdName = data.data[0].stdCode;\\r\\n                target.push(temp);\\r\\n            });\\r\\n            $this.setFormData({ fields: target });\\r\\n        } else if (!data.data[0].nameIsStd && data.data[0].labelIsStd) {\\r\\n            const target = [];\\r\\n            $this.formData.fields.forEach(field => {\\r\\n                const temp = _.extend({}, field);\\r\\n                if (temp.fieldLabel&&temp.fieldLabel.toLowerCase() == data.data[0].recLabel.toLowerCase()) {\\r\\n                    temp.fieldName = data.data[0].recName;\\r\\n                }\\r\\n                temp.stdName = data.data[0].stdCode;\\r\\n                target.push(temp);\\r\\n            });\\r\\n            $this.setFormData({ fields: target });\\r\\n        } else if (data.data[0].nameIsStd && data.data[0].labelIsStd) {\\r\\n            const target = [];\\r\\n            $this.formData.fields.forEach(field => {\\r\\n                const temp = _.extend({}, field);\\r\\n                if (temp.fieldLabel&&temp.fieldLabel.toLowerCase() == data.data[0].recLabel.toLowerCase()&&temp.fieldName&&temp.fieldName.toLowerCase() == data.data[0].recName.toLowerCase()) {\\r\\n                    temp.stdName = data.data[0].stdCode;\\r\\n                }\\r\\n                target.push(temp);\\r\\n            });\\r\\n            $this.setFormData({ fields: target });\\r\\n        }\\r\\n    }\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error) {\\r\\n    if (error.data.devMsg) {\\r\\n        $utils.notification.error({\\r\\n            tit