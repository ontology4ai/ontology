                                \"viewName\": null,\n                                                        \"before\": \"function beforeCallback() {}\",\n                                                        \"width\": \"50%\",\n                                                        \"top\": \"15vh\",\n                                                        \"fullscreen\": false,\n                                                        \"size\": \"50%\",\n                                                        \"tabViewName\": null,\n                                                        \"tabParams\": \"\",\n                                                        \"tabKey\": \"\",\n                                                        \"tabLabel\": \"\"\n                                                    }\n                                                ],\n                                                \"actions\": []\n                                            },\n                                            \"callback\": \"function callback() {\\n\\n    $this.close();\\n }\"\n                                        }\n                                    }\n                                },\n                                \"defaultOptions\": {\n                                    \"css\": \":root {\\n\\n}\"\n                                },\n                                \"children\": []\n                            },\n                            {\n                                \"id\": \"41cf2c1066f07eec\",\n                                \"name\": \"41cf2c1066f07eec\",\n                                \"label\": \"确定\",\n                                \"type\": \"button\",\n                                \"options\": {\n                                    \"hidden\": false,\n                                    \"hiddenBindVar\": null,\n                                    \"isLoading\": false,\n                                    \"loading\": false,\n                                    \"loadingBindVar\": null,\n                                    \"loadingText\": null,\n                                    \"loadingTextBindVar\": null,\n                                    \"showTooltip\": false,\n                                    \"tooltip\": null,\n                                    \"tooltipBindVar\": null,\n                                    \"className\": \"\",\n                                    \"css\": \":root {\\nmargin-right: 10px\\n}\",\n                                    \"loop\": {\n                                        \"dataBindVar\": null,\n                                        \"key\": \"index\",\n                                        \"item\": \"item\",\n                                        \"index\": \"index\",\n                                        \"pagination\": {\n                                            \"show\": true,\n                                            \"pageSize\": 20\n                                        },\n                                        \"isLoading\": false,\n                                        \"event\": {\n                                            \"builtIn\": {\n                                                \"type\": \"url\",\n                                                \"isSingleService\": true,\n                                                \"urlAction\": {\n                                                    \"url\": null,\n                                                    \"blank\": true\n                                                },\n                                                \"viewActions\": [\n                                                    {\n                                                        \"condition\": \"true\",\n                                                        \"showType\": \"modal\",\n                                                        \"viewName\": null,\n                                                        \"before\": \"function beforeCallback() {}\",\n                                                        \"width\": \"50%\",\n                                                        \"top\": \"15vh\",\n                                                        \"fullscreen\": false,\n                                                        \"size\": \"50%\",\n                                                        \"tabViewName\": null,\n                                                        \"tabParams\": \"\",\n                                                        \"tabKey\": \"\",\n                                                        \"tabLabel\": \"\"\n                                                    }\n                                                ],\n                                                \"actions\": []\n                                            },\n                                            \"callback\": \"function callback() {}\"\n                                        }\n                                    },\n                                    \"eventMap\": {\n                                        \"onClick\": {\n                                            \"builtIn\": {\n                                                \"type\": \"url\",\n                                                \"isSingleService\": true,\n                                                \"urlAction\": {\n                                                    \"url\": null,\n                                                    \"blank\": true\n                                                },\n                                                \"viewActions\": [\n                                                    {\n                                                        \"condition\": \"true\",\n                                                        \"showType\": \"modal\",\n                                                        \"viewName\": null,\n                                                        \"before\": \"function beforeCallback() {}\",\n                                                        \"width\": \"50%\",\n                                                        \"top\": \"15vh\",\n                                                        \"fullscreen\": false,\n                                                        \"size\": \"50%\",\n                                                        \"tabViewName\": null,\n                                                        \"tabParams\": \"\",\n                                                        \"tabKey\": \"\",\n                                                        \"tabLabel\": \"\"\n                                                    }\n                                                ],\n                                                \"actions\": []\n                                            },\n                                            \"callback\": \"function callback() {\\n    var modelTransferBetweenTeamsForm = $this.$refs.modelTransferBetweenTeamsForm.getFieldsValue();\\n    console.log(\\\"modelTransferBetweenTeamsForm\\\", modelTransferBetweenTeamsForm);\\n    var selectedRows = $this.toTransfer;\\n    $this.$refs.modelTransferBetweenTeamsForm.validate((valid) => {\\n        if (valid) {\\n            //额外的数据源授权情况校验\\n            $this.datasourceMap.getModelDevDsOptions({ workspaceId: $this.workspaceId }).then(res => {\\n                if (res.data.code == '200') {\\n                    let data = res.data.data;\\n                    if (data && data.length > 0) {\\n                        let dsNames = [];\\n                        data.forEach(item => {\\n                            dsNames.push(item.name);\\n                        });\\n                        let unTransModels = [];\\n                        selectedRows.forEach(row => {\\n                            if (!dsNames.includes(row.dsName)) {\\n                                unTransModels.push(row.modelLabel);\\n                            }\\n                        });\\n                        if (unTransModels.length > 0) {\\n                            $utils.notification.error({\\n                                title: $i18n('失败'),\\n                                content: $i18n('模型：' + unTransModels.join(',') + ' 所属目标团队对应的数据源为空！不可移交'),\\n                            });\\n                        } else {\\n                            let updateDatas = [];\\n                            for (let row of selectedRows) {\\n                                let update = {};\\n                                update.id = row.id;\\n                                update.workspaceId = $this.workspaceId;\\n                                update.memberName = modelTransferBetweenTeamsForm.createUser;\\n                                update.dirId = modelTransferBetweenTeamsForm.dir;\\n                                update.teamName = modelTransferBetweenTeamsForm.teamName;\\n                                update.lastupd = $this.utils.moment(new Date()).format('YYYY-MM-DD HH:mm:ss');\\n                                updateDatas.push(update);\\n                            }\\n                            $this.datasourceMap.modelTransBatch(updateDatas).then(resp => {\\n                                if (resp.data.code == '200') {\\n                                    $utils.notification.success({\\n                                        title: $i18n('成功'),\\n                                        content: $i18n('模型移交成功！'),\\n                                    });\\n                                    $this.parent.datasourceMap.getModelPage();\\n                                    $this.close();\\n                                } else {\\n                                    $utils.notification.error({\\n                                        title: $i18n('失败'),\\n                                        content: $i18n('模型移交失败！'),\\n                                    });\\n                                }\\n\\n                            });\\n                        }\\n                    } else {\\n                        $utils.notification.error({\\n                            title: $i18n('失败'),\\n                            content: $i18n('目标团队对应的数据源为空！不可移交'),\\n                        });\\n                    }\\n                }\\n            })\\n\\n\\n        } else {\\n            console.log(\\\"校验不通过\\\");\\n        }\\n    })\\n\\n}\"\n                                        }\n                                    },\n                                    \"type\": \"primary\"\n                                },\n                                \"defaultOptions\": {\n                                    \"css\": \":root {\\n\\n}\"\n                                },\n                                \"children\": []\n                            }\n                        ]\n                    }\n                ]\n            }\n        ]\n    }\n]","inputVars":null,"viewPlugins":null,"version":46,"createUser":"xiacj3","createDt":null,"lastupd":null,"updateUser":null,"digest":null,"versionInfo":"","appName":"dataps","createUserName":null}