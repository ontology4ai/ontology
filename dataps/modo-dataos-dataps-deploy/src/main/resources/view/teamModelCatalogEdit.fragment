        if (!itemMap[item.parent].children) {\\r\\n                itemMap[item.parent].children = [];\\r\\n            }\\r\\n            itemMap[item.parent].children.push(item);\\r\\n        }\\r\\n    });\\r\\n    const getChildren = function (node, arr) {\\r\\n        arr.push(node.key);\\r\\n        if (node.children) {\\r\\n            node.children.forEach(child => {\\r\\n                getChildren(child, arr);\\r\\n            });\\r\\n        }\\r\\n    }\\r\\n    const getParents = function (node, map, arr) {\\r\\n        arr.push(node.key);\\r\\n        if (node.parent && map[node.parent]) {\\r\\n            getParents(map[node.parent], map, arr);\\r\\n        }\\r\\n    }\\r\\n    const ids = [];\\r\\n    if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.priv == '0') {\\r\\n        getParents($this.$refs.treeDef.treeChartRef.current.getSelection().data, itemMap, ids);\\r\\n    } else {\\r\\n        getChildren($this.$refs.treeDef.treeChartRef.current.getSelection().data, ids);\\r\\n    }\\r\\n    const target = [];\\r\\n    const targetMap = {};\\r\\n    $this.treeData.forEach(node => {\\r\\n        const item = _.extend({}, node);\\r\\n        if (ids.indexOf(item.key) > -1) {\\r\\n            if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.priv == '1') {\\r\\n                if ($this.catalogIdMap[item.key] && $this.catalogIdMap[item.key].priv == '1') {\\r\\n                    item.changeState = 'delete';\\r\\n                } else {\\r\\n                    item.changeState = '';\\r\\n                }\\r\\n                item.priv = '0';\\r\\n                isDelete = true;\\r\\n            } else {\\r\\n                if ($this.catalogIdMap[item.key] && $this.catalogIdMap[item.key].priv == '0') {\\r\\n                    item.changeState = 'add';\\r\\n                } else {\\r\\n                    item.changeState = '';\\r\\n                }\\r\\n                item.priv = '1';\\r\\n            }\\r\\n    