\n                },\\r\\n                onOk: () => {\\r\\n                    $this.parent.$refs.tabs.addTab('changeModelDir', '模型目录修改', '', 'logicModelArchMove', {\\r\\n                        dirIds: [$this.$refs.treeDef.treeChartRef.current.getSelection().data.key]\\r\\n                    })\\r\\n                }\\r\\n            });\\r\\n            return;\\r\\n        }\\r\\n        if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.archModelNum && $this.$refs.treeDef.treeChartRef.current.getSelection().data.archModelNum > 0) {\\r\\n            $this.utils.modal.confirm({\\r\\n                title: '提示',\\r\\n                content:\\r\\n                    '节点下存在模型，请先修改模型编目！',\\r\\n                okButtonProps: {\\r\\n                    status: 'danger',\\r\\n                },\\r\\n                onOk: () => {\\r\\n                    $this.parent.$refs.tabs.addTab('changeModelArch', '模型编目修改', '', 'logicModelArchMove', {\\r\\n                        dirIds: [$this.$refs.treeDef.treeChartRef.current.getSelection().data.key]\\r\\n                    })\\r\\n                }\\r\\n            });\\r\\n            return;\\r\\n        }\\r\\n        const filterModelDirs = function (nodes, dirs, dirIds, filterProp) {\\r\\n            nodes.forEach(item => {\\r\\n                if (item[filterProp] && item[filterProp] > 0) {\\r\\n                    dirs.push(item.label);\\r\\n                    dirIds.push(item.id);\\r\\n                }\\r\\n                if (item.children) {\\r\\n                    filterModelDirs(item.children, dirs, dirIds, filterProp);\\r\\n                }\\r\\n            });\\r\\n        }\\r\\n        if ($this.archMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key] && $this.archMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children) {\\r\\n            let modelDirs = [];\\r\\n            let modelDirIds = [];\\r\\n            filterModelDirs($this.archMap[$this.$r