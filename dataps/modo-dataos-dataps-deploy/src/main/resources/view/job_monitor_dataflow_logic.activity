":\"text\",\"status\":\"default\",\"icon\":\"IconMoreRow\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]},{\"id\":\"30c729f8f60787a9\",\"name\":\"30c729f8f60787a9\",\"label\":\"取消\",\"type\":\"button\",\"options\":{\"hidden\":false,\"hiddenBindVar\":\"$this.showMore1 == false\",\"isLoading\":true,\"loading\":false,\"loadingBindVar\":\"$this.cancelIsSpin == true\",\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onClick\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\n\\n    var selectedRows = $this.$refs.logicJobMonitorTab.selectedRows;\\n\\n    if (selectedRows == undefined || selectedRows.length == 0) {\\n        $utils.message.warning('未选择任何任务，请先选择..');\\n        return;\\n    }\\n    var dataArr = [];\\n    for (let row of selectedRows) {\\n        dataArr.push({ \\\"jobCode\\\": row.parentCode, \\\"batchNo\\\": row.batchNo });\\n    }\\n    $this.setCancelIsSpin(true);\\n    $this.setIsSpin(true);\\n    $utils.axios.post('/oneplusn-federation/open/dataflow/monitor/modo/getJobTriggerData', dataArr).then(response => {\\n        var forceExecuteList = response.data;\\n\\n        var val = '3';// 取消\\n        const stateEnum = [\\n            { value: '0', label: '新建' },\\n            { value: '1', label: '成功' },\\n            { value: '2', label: '暂停' },\\n            { value: '3', label: '运行中' },\\n\\n            { value: '5', label: '排队' },\\n            { value: '-1', label: '失败' },\\n            { value: '-2', label: '中止' },\\n            { value: '-3', label: '重做' }\\n        ]\\n        var operCheckTime = $this.operCheckTime;\\n\\n        if (forceExecuteList == undefined || forceExecuteList.length == 0) {\\n            $utils.message.warning('未选择任何任务，请先选择..');\\n            $this.setCancelIsSpin(false);\\n            $this.setIsSpin(false);\\n            return;\\n        }\\n\\n\\n        for (var i = 0; i < forceExecuteList.length; i++) {\\n            if (!writeTeamContain(forceExecuteList[i].teamName)) {\\n                $utils.message.warning(forceExecuteList[i].jobLabel + '所在的团队没有操作权限...');\\n                $this.setCancelIsSpin(false);\\n                $this.setIsSpin(false);\\n                return;\\n            }\\n        }\\n\\n        for (var i = 0; i < forceExecuteList.length; i++) {\\n            if (forceExecuteList[i].state === '-1' && forceExecuteList[i].message == '失败自动重做') {\\n                $utils.message.warning(forceExecuteList[i].jobLabel + '不允许重做当前...');\\n                $this.setCancelIsSpin(false);\\n                $this.setIsSpin(false);\\n                return;\\n            }\\n        }\\n\\n\\n        $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/operPermit/checkOperPermit',\\n            {\\n                params:\\n                    { \\\"oper\\\": val, \\\"teamName\\\": $identity.teamName }\\n            }).then(response => {\\n\\n                if (response.data.success) {\\n                    $this.sCheckAuthorityFroRedoCurrent = true;\\n                } else {\\n                    $this.sCheckAuthorityFroRedoCurrent = false;\\n                }\\n            }).catch(function (error) {\\n                $this.setCancelIsSpin(false);\\n                $this.setIsSpin(false);\\n                $this.sCheckAuthorityFroRedoCurrent = false;\\n                console.log(error);\\n            });\\n\\n\\n\\n        // -----sCheckOnly()-start-----\\n\\n        var _arr = [];\\n        var invalidJobCode = '';\\n        var sCheckOnlyCou = 0;\\n        for (let redoJobTrigger of forceExecuteList) {\\n            var option = _arr.find(function (item) {\\n                return (item.jobCode === redoJobTrigger.jobCode && item.batchNo === redoJobTrigger.batchNo)\\n            });\\n            if (!option) {\\n                $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/getTriggerData', {\\n                    params: {\\n                        jobTrigId: redoJobTrigger.jobTrigId\\n                    }\\n                }).then(response => {\\n                    var judge = true;\\n                    var data = response.data;\\n                    if (data) {\\n                        if (data.isValid === 0) {\\n                            _arr.push(redoJobTrigger);\\n                        }\\n                    }\\n                    if (forceExecuteList.length == _arr.length) {\\n                        for (var i = 0; i < forceExecuteList.length; i++) {\\n                            var jobCode = forceExecuteList[i].jobCode;\\n                            var option2 = _arr.find(function (item) {\\n                                return (item.jobCode === jobCode && item.batchNo === forceExecuteList[i].batchNo)\\n                            });\\n                            if (!option2 && invalidJobCode.indexOf(jobCode) === -1) {\\n                                invalidJobCode += jobCode + ',';\\n                            }\\n                        }\\n                    }\\n\\n                    if (_arr.length == 0) {\\n                        judge = false;\\n                        return;\\n                        // this.$refs.multipleTable.clearSelection();\\n                    }\\n\\n                    if (invalidJobCode.length != 0) {\\n                        $utils.message.warning(invalidJobCode + \\\"为无效的任务！\\\");\\n                        $this.setCancelIsSpin(false);\\n                        $this.setIsSpin(false);\\n                        return;\\n                    }\\n                    sCheckOnlyCou++;\\n\\n                    if (sCheckOnlyCou == forceExecuteList.length) {\\n                        // -----sCheckState()-start-----------------------------------------------------------------------\\n\\n                        var sCheckState_arr = [];\\n\\n                        _.map(forceExecuteList, function (val) {\\n                            sCheckState_arr.push(val.jobCode);\\n                        });\\n                        var jobCode = encodeURI(sCheckState_arr);\\n\\n                        $utils.axios.get('/oneplusn-federation/open/dataflow/findJobByCodeList', {\\n                            params: {\\n                                \\\"jobCode\\\": jobCode,\\n                                \\\"production\\\": true\\n                            }\\n                        }).then(response => {\\n                            {\\n                                var data = response.data;\\n                                if (data) {\\n                                    var judge = true;\\n                                    for (var i = 0; i < forceExecuteList.length; i++) {\\n                                        var option = data.find(function (item) {\\n                                            return (item.jobCode === forceExecuteList[i].jobCode)\\n                                        });\\n                                        if (!option) {\\n                                            judge = false;\\n                                            $utils.message.warning(forceExecuteList[i].jobCode + \\\"未找到相对应的任务配置数据！\\\");\\n                                            $this.setCancelIsSpin(false);\\n                                            $this.setIsSpin(false);\\n                                            return\\n                                        } else {\\n\\n                                            if ((val == '4' || val == '5') && option.jobType == 'datastash') {\\n                                                judge = false;\\n                                                $utils.message.warning(forceExecuteList[i].jobCode + \\\"为采集程序，无法进行暂停/恢复操作\\\");\\n                                                $this.setCancelIsSpin(false);\\n                                                $this.setIsSpin(false);\\n                                                return\\n                                            }\\n                                        }\\n                                    }\\n                                    for (var i = 0; i < data.length; i++) {\\n                                        if (data[i].state != '1') {\\n                                            judge = false;\\n                                            $utils.message.warning(data[i].jobCode + \\\"任务未生效，无法进行操作\\\");\\n                                            $this.setCancelIsSpin(false);\\n                                            $this.setIsSpin(false);\\n                                            return\\n\\n                                        }\\n                                        // var nowDate = moment(moment().subtract(0, 'days').toDate()).format(\\\"YYYYMMDD\\\");\\n                                        var nowDate = $utils.moment(new Date()).format(\\\"YYYYMMDD\\\");\\n\\n                                        if (data[i].effDt > nowDate || data[i].expDt < nowDate) {\\n                                            judge = false;\\n                                            $utils.message.warning(\\\"该任务已过期\\\");\\n                                            $this.setCancelIsSpin(false);\\n                                            $this.setIsSpin(false);\\n                                            return\\n\\n                                        }\\n                                    }\\n\\n\\n\\n                                    // next();\\n                                    // -----sCheck()-start-----------------------------------------------------------------------\\n                                    // var self = this;\\n                                    var val = '3';\\n                                    var _obj = {\\n                                        '0': ['0', '-3', '5'],\\n                                        '1': ['0', '-1', '-2', '5', '-3'],\\n                                        '2': ['4', '-1', '-2'],\\n                                        '3': ['0', '2', '3', '4', '5', '-3'],\\n                                        '4': ['0', '3', '5', '-3'],\\n                                        '5': ['2'],\\n                                        '6': ['0', '-3', '5']\\n                                    }\\n\\n                                    if ($this.sCheckAuthorityFroRedoCurrent) {\\n                                        _obj = {\\n                                            '0': ['0', '-3', '5'],\\n                                            '1': ['0', '-1', '-2', '5', '-3'],\\n                                            '2': ['1', '4', '-1', '-2'],\\n                                            '3': ['0', '2', '3', '4', '5', '-3'],\\n                                            '4': ['0', '3', '5', '-3'],\\n                                            '5': ['2'],\\n                                            '6': ['0', '-3', '5']\\n                                        }\\n                                    }\\n                                    var stateArr = _obj[val];\\n\\n\\n\\n                                    var label = '';\\n                                    var tempArr = [];\\n                                    var jobTrigIdList = [];\\n                                    _.map(forceExecuteList, function (val) {\\n                                        jobTrigIdList.push(encodeURI(val.jobTrigId));\\n                                    });\\n                                    // var param = JSON.stringify({ jobTrigId: jobTrigIdList });\\n                                    $utils.axios.post('/oneplusn-federation/open/dataflow/monitor/getTriggerDataList', { jobTrigId: jobTrigIdList }).then(response => {\\n                                        var data = response.data;\\n                                        var judge = true;\\n                                        if (data) {\\n                                            var val = '3';\\n                                            tempArr = data;\\n                                            for (var i in tempArr) {\\n                                                var _state = tempArr[i].state;\\n\\n                                                if (!_.contains(stateArr, _state)) {\\n                                                    judge = false;\\n                                                    label = tempArr[i].jobLabel;\\n                                                    break;\\n                                                }\\n                                            }\\n\\n                                            if (!judge) {\\n                                                var state = \\\"\\\";\\n                                                for (var i = 0; i < stateArr.length; i++) {\\n                                                    for (var j = 0; j < stateEnum.length; j++) {\\n                                                        if (stateEnum[j].value === stateArr[i])\\n                                                            state += stateEnum[j].label + \\\",\\\";\\n                                                    }\\n                                                }\\n                                                state = state.substring(0, state.length - 1);\\n                                                var oper = ['强制执行', '强制通过', '重做', '取消', '暂停', '恢复', '调整优先级'];\\n                                                var message = label + '不符合要求；状态为“' + state + '”才能进行“' + oper[val] + '”操作';\\n                                                if (val === '2') {\\n                                                    message += \\\";“成功”状态重做需要授权！\\\"\\n                                                }\\n                                                $utils.message.warning(message);\\n                                                $this.setCancelIsSpin(false);\\n                                                $this.setIsSpin(false);\\n                                                return\\n                                            }\\n\\n                                            // next();\\n\\n                                            var val = '3';\\n                                            var judge = true;\\n                                            var oper = ['强制执行', '强制通过', '重做', '取消', '暂停', '恢复', '手工任务', '调整优先级'];\\n                                            for (var i = 0; i < forceExecuteList.length; i++) {\\n                                                var data = forceExecuteList[i];\\n                                                var index = _.findIndex(operCheckTime[val], function (item) {\\n                                                    return item.label === data.jobTrigId\\n                                                });\\n                                                if (index > -1) {\\n                                                    var nowDate = new Date();\\n                                                    //大于1分钟\\n                                                    if (nowDate.getTime() - operCheckTime[val][index].time.getTime() > 60000) {\\n                                                        operCheckTime[val][index].time = nowDate;\\n                                                        judge = true;\\n                                                    } else {\\n                                                        $utils.message.warning(data.jobLabel + '，操作与上次操作时间需要间隔1分钟');\\n                                                        $this.setCancelIsSpin(false);\\n                                                        $this.setIsSpin(false);\\n                                                        return;\\n\\n                                                    }\\n                                                } else {\\n                                                    $this.operCheckTime[val].push({ \\\"label\\\": data.jobTrigId, \\\"time\\\": new Date() });\\n                                                }\\n                                            }\\n                                            $this.setCancelIsSpin(false);\\n                                            $this.setIsSpin(false);\\n                                            $utils.modal.confirm({\\n                                                title: '确定执行取消操作？',\\n                                                content:\\n                                                    '',\\n                                                okButtonProps: {\\n                                                    status: 'warning',\\n                                                },\\n                                                onOk: () => {\\n\\n                                                    var dataArr = [];\\n                                                    for (let data of forceExecuteList) {\\n                                                        dataArr.push({\\n                                                            jobTrigId: data.jobTrigId,\\n                                                            teamName: $identity.teamName,\\n                                                            userId: $identity.userId\\n                                                        })\\n                                                    }\\n                                                    $utils.axios.defaults.timeout = 600000;\\n                                                    $utils.axios.post('/oneplusn-federation/open/dataflow/monitor/cancel', dataArr).then(res => {\\n\\n                                                        if (res.data.success === true) {\\n                                                            $utils.message.success('取消成功！');\\n\\n\\n                                                            const filters = $this.$refs.jobMonitorFilterForm.getFieldsValue();\\n                                                            var current = $this.$refs.logicJobMonitorTab.state.current;\\n                                                            var pageSize = $this.$refs.logicJobMonitorTab.state.pageSize;\\n\\n                                                            var jobLabel = '';\\n                                                            var batchTypes = 'daily';\\n                                                            var batchNo = '';\\n                                                            var memberName = '';\\n                                                            var runState = '';\\n                                                            var jobType = '';\\n                                                            var priority = '';\\n                                                            var runStateNum = 1;\\n                                                            var tag = '';\\n                                                            var brokerWorkgroup = '';\\n                                                            var batchNoZone = '';\\n\\n                                                            for (var f in filters) {\\n                                                                if (f == 'jobLabel' && filters[f]) {\\n                                                                    jobLabel = filters[f];\\n                                                                }\\n                                                                if (f == 'batchTypes' && filters[f]) {\\n\\n                                                                    batchTypes = filters[f].join(',');\\n                                                                }\\n                                                                if (f == 'batchNoZone' && filters[f]) {\\n                                                                    batchNo = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n                                                                    batchNoZone = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n                                                                }\\n                                                                if (f == 'batchNo' && filters[f] && batchNoZone == '') {\\n                                                                    batchNo = filters[f].replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\");\\n                                                                }\\n                                                                if (f == 'dUser' && filters[f]) {\\n                                                                    memberName = filters[f];\\n                                                                }\\n                                                                if (f == 'runState' && filters[f]) {\\n                                                                    runState = filters[f];\\n                                                                }\\n                                                                if (f == 'jobType' && filters[f]) {\\n                                                                    jobType = filters[f];\\n                                                                }\\n                                                                if (f == 'priority' && filters[f]) {\\n                                                                    priority = filters[f];\\n                                                                }\\n                                                                //runStateNum: true\\n                                                                if (f == 'runStateNum' && filters[f]) {\\n                                                                    if (filters[f] == true) {\\n                                                                        runStateNum = 0;\\n\\n                                                                    } else if (filters[f] == false) {\\n                                                                        runStateNum = 1;\\n                                                                    }\\n\\n                                                                }\\n                                                                if (f == 'tag' && filters[f]) {\\n                                                                    tag = filters[f];\\n                                                                }\\n                                                                if (f == 'brokerWorkgroup' && filters[f]) {\\n                                                                    brokerWorkgroup = filters[f];\\n                                                                }\\n                                                                // if (f == 'cycle' && filters[f]) {\\n                                                                //     vars.params.cycle = '~%' + filters[f] + '%'\\n                                                                // }\\n                                                            }\\n\\n                                                            let state = '';\\n                                                            let queryType = '0';\\n                                                            if ($this.jobState2.length == 0) {\\n                                                                if ($this.jobState.indexOf('ALL') == -1) {\\n                                                                    state = $this.jobState.join(',');\\n                                                                    queryType = '0';\\n\\n                                                                }\\n                                                            } else {\\n                                                                if ($this.jobState2.indexOf('ALL') == -1) {\\n                                                                    state = $this.jobState2.join(',');\\n                                                                    queryType = '1';\\n                                                                }\\n                                                            }\\n\\n\\n                                                            $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/getStatisticsCollectData',\\n                                                                {\\n                                                                    params:\\n                                                                    {\\n                                                                        jobLabel: jobLabel,\\n                                                                        batchTypes: batchTypes,\\n                                                                        batchNo: batchNo,\\n                                                                        teamName: $identity.teamName,\\n                                                                        memberName: memberName,\\n                                                                        runState: runState,\\n                                                                        jobType: jobType,\\n                                                                        priority: priority,\\n                                                                        runStateNum: runStateNum,\\n                                                                        tag: tag,\\n                                                                        brokerWorkgroup: brokerWorkgroup\\n                                                                    }\\n                                                                }).then(res => {\\n                                                                    $this.setJobS(res.data.data);\\n                                                                    if (res.data.data.jtFinish != null && res.data.data.jtSum != null) {\\n                                                                        $this.setJobSuccessRate(Math.round((res.data.data.jtFinish / res.data.data.jtSum) * 100))\\n                                                                    } else {\\n                                                                        $this.setJobSuccessRate(0);\\n                                                                    }\\n\\n\\n                                                                }).catch(function (error) {\\n                                                                    console.log(error);\\n                                                                });\\n\\n\\n                                                            $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/v2/getStatisticsTableData',\\n                                                                {\\n                                                                    params:\\n                                                                    {\\n                                                                        pageNum: current - 1,\\n                                                                        pageSize: pageSize,\\n                                                                        jobLabel: jobLabel,\\n                                                                        batchTypes: batchTypes,\\n                                                                        batchNo: batchNo,\\n                                                                        teamName: $identity.teamName,\\n                                                                        taskType: 'all',\\n                                                                        desc: 'desc',\\n                                                                        sortColumn: 'jobCode',\\n                                                                        memberName: memberName,\\n                                                                        runState: runState,\\n                                                                        jobType: jobType,\\n                                                                        priority: priority,\\n                                                                        readTeamNames: $identity.teamName,\\n                                                                        jobState: state,\\n                                                                        queryType: queryType,\\n                                                                        runStateNum: runStateNum,\\n                                                                        tag: tag,\\n                                                                        brokerWorkgroup: brokerWorkgroup\\n                                                                    }\\n                                                                }).then(res => {\\n                                                                    var data = res.data.data;\\n                                                                    $this.setLogicJobTriggerListData(data);\\n\\n                                                                }).catch(function (error) {\\n                                                                    console.log(error);\\n                                                                });\\n\\n                                                        } else {\\n                                                            $utils.message.error('取消失败！' + res.data.msg)\\n                                                        }\\n\\n\\n                                                    }).catch(function (error) {\\n                                                        $this.setCancelIsSpin(false);\\n                                                        $this.setIsSpin(false);\\n                                                        console.log(error);\\n                                                    });\\n                                                },\\n                                            });\\n\\n                                        }\\n\\n\\n                                    }).catch(function (error) {\\n                                        $this.setCancelIsSpin(false);\\n                                        $this.setIsSpin(false);\\n                                        console.log(error);\\n                                    });\\n\\n                                }\\n                            }\\n                        })\\n                        // return judge;\\n                    }\\n\\n                }).catch(function (error) {\\n                    $this.setCancelIsSpin(false);\\n                    $this.setIsSpin(false);\\n                    console.log(error);\\n                });\\n\\n\\n            }\\n        }\\n\\n        // -----sCheckOnly()-end--------------------------------------\\n    }).catch(function (error) {\\n        $this.setCancelIsSpin(false);\\n        $this.setIsSpin(false);\\n        console.log(error);\\n    });\\n\\n}\\n\\n\\n\\n\\nfunction writeTeamContain(teamName) {\\n    var index = _.findIndex($this.writeTeamNames, function (item) {\\n        return item === teamName\\n    });\\n    return index > -1 ? true : false;\\n}\"}},\"type\":\"text\",\"icon\":\"IconError\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]},{\"id\":\"fe1c3d71f0d63d51\",\"name\":\"fe1c3d71f0d63d51\",\"label\":\"暂停\",\"type\":\"button\",\"options\":{\"hidden\":false,\"hiddenBindVar\":\"$this.showMore1 == false\",\"isLoading\":true,\"loading\":false,\"loadingBindVar\":\"$this.pauseIsSpin == true\",\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onClick\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\n\\n    var selectedRows = $this.$refs.logicJobMonitorTab.selectedRows;\\n\\n    if (selectedRows == undefined || selectedRows.length == 0) {\\n        $utils.message.warning('未选择任何任务，请先选择..');\\n        return;\\n    }\\n    var dataArr = [];\\n    for (let row of selectedRows) {\\n        dataArr.push({ \\\"jobCode\\\": row.parentCode, \\\"batchNo\\\": row.batchNo });\\n    }\\n    $this.setPauseIsSpin(true);\\n    $this.setIsSpin(true);\\n    $utils.axios.post('/oneplusn-federation/open/dataflow/monitor/modo/getJobTriggerData', dataArr).then(response => {\\n        var forceExecuteList = response.data;\\n\\n        var val = '4';// 暂停执行\\n        const stateEnum = [\\n            { value: '0', label: '新建' },\\n            { value: '1', label: '成功' },\\n            { value: '2', label: '暂停' },\\n            { value: '3', label: '运行中' },\\n\\n            { value: '5', label: '排队' },\\n            { value: '-1', label: '失败' },\\n            { value: '-2', label: '中止' },\\n            { value: '-3', label: '重做' }\\n        ]\\n        var operCheckTime = $this.operCheckTime;\\n\\n        if (forceExecuteList == undefined || forceExecuteList.length == 0) {\\n            $utils.message.warning('未选择任何任务，请先选择..');\\n            $this.setPauseIsSpin(false);\\n            $this.setIsSpin(false);\\n            return;\\n        }\\n\\n\\n        for (var i = 0; i < forceExecuteList.length; i++) {\\n            if (!writeTeamContain(forceExecuteList[i].teamName)) {\\n                $utils.message.warning(forceExecuteList[i].jobLabel + '所在的团队没有操作权限...');\\n                $this.setPauseIsSpin(false);\\n                $this.setIsSpin(false);\\n                return;\\n            }\\n        }\\n\\n        for (var i = 0; i < forceExecuteList.length; i++) {\\n            if (forceExecuteList[i].state === '-1' && forceExecuteList[i].message == '失败自动重做') {\\n                $utils.message.warning(forceExecuteList[i].jobLabel + '不允许重做当前...');\\n                $this.setPauseIsSpin(false);\\n                $this.setIsSpin(false);\\n                return;\\n            }\\n        }\\n\\n\\n        $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/operPermit/checkOperPermit',\\n            {\\n                params:\\n                    { \\\"oper\\\": val, \\\"teamName\\\": $identity.teamName }\\n            }).then(response => {\\n\\n                if (response.data.success) {\\n                    $this.sCheckAuthorityFroRedoCurrent = true;\\n                } else {\\n                    $this.sCheckAuthorityFroRedoCurrent = false;\\n                }\\n            }).catch(function (error) {\\n                $this.setPauseIsSpin(false);\\n                $this.setIsSpin(false);\\n                $this.sCheckAuthorityFroRedoCurrent = false;\\n                console.log(error);\\n            });\\n\\n\\n\\n        // -----sCheckOnly()-start-----\\n\\n        var _arr = [];\\n        var invalidJobCode = '';\\n        var sCheckOnlyCou = 0;\\n        for (let redoJobTrigger of forceExecuteList) {\\n            var option = _arr.find(function (item) {\\n                return (item.jobCode === redoJobTrigger.jobCode && item.batchNo === redoJobTrigger.batchNo)\\n            });\\n            if (!option) {\\n                $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/getTriggerData', {\\n                    params: {\\n                        jobTrigId: redoJobTrigger.jobTrigId\\n                    }\\n                }).then(response => {\\n                    var judge = true;\\n                    var data = response.data;\\n                    if (data) {\\n                        if (data.isValid === 0) {\\n                            _arr.push(redoJobTrigger);\\n                        }\\n                    }\\n                    if (forceExecuteList.length == _arr.length) {\\n                        for (var i = 0; i < forceExecuteList.length; i++) {\\n                            var jobCode = forceExecuteList[i].jobCode;\\n                            var option2 = _arr.find(function (item) {\\n                                return (item.jobCode === jobCode && item.batchNo === forceExecuteList[i].batchNo)\\n                            });\\n                            if (!option2 && invalidJobCode.indexOf(jobCode) === -1) {\\n                                invalidJobCode += jobCode + ',';\\n                            }\\n                        }\\n                    }\\n\\n                    if (_arr.length == 0) {\\n                        judge = false;\\n                        return;\\n                        // this.$refs.multipleTable.clearSelection();\\n                    }\\n\\n                    if (invalidJobCode.length != 0) {\\n                        $utils.message.warning(invalidJobCode + \\\"为无效的任务！\\\");\\n                        $this.setPauseIsSpin(false);\\n                        $this.setIsSpin(false);\\n                        return;\\n                    }\\n                    sCheckOnlyCou++;\\n\\n                    if (sCheckOnlyCou == forceExecuteList.length) {\\n                        // -----sCheckState()-start-----------------------------------------------------------------------\\n\\n                        var sCheckState_arr = [];\\n\\n                        _.map(forceExecuteList, function (val) {\\n                            sCheckState_arr.push(val.jobCode);\\n                        });\\n                        var jobCode = encodeURI(sCheckState_arr);\\n\\n                        $utils.axios.get('/oneplusn-federation/open/dataflow/findJobByCodeList', {\\n                            params: {\\n                                \\\"jobCode\\\": jobCode,\\n                                \\\"production\\\": true\\n                            }\\n                        }).then(response => {\\n                            {\\n                                var data = response.data;\\n                                if (data) {\\n                                    var judge = true;\\n                                    for (var i = 0; i < forceExecuteList.length; i++) {\\n                                        var option = data.find(function (item) {\\n                                            return (item.jobCode === forceExecuteList[i].jobCode)\\n                                        });\\n                                        if (!option) {\\n                                            judge = false;\\n                                            $utils.message.warning(forceExecuteList[i].jobCode + \\\"未找到相对应的任务配置数据！\\\");\\n                                            $this.setPauseIsSpin(false);\\n                                            $this.setIsSpin(false);\\n                                            return\\n                                        } else {\\n\\n                                            if ((val == '4' || val == '5') && option.jobType == 'datastash') {\\n                                                judge = false;\\n                                                $utils.message.warning(forceExecuteList[i].jobCode + \\\"为采集程序，无法进行暂停/恢复操作\\\");\\n                                                $this.setPauseIsSpin(false);\\n                                                $this.setIsSpin(false);\\n                                                return\\n                                            }\\n                                        }\\n                                    }\\n                                    for (var i = 0; i < data.length; i++) {\\n                                        if (data[i].state != '1') {\\n                                            judge = false;\\n                                            $utils.message.warning(data[i].jobCode + \\\"任务未生效，无法进行操作\\\");\\n                                            $this.setPauseIsSpin(false);\\n                                            $this.setIsSpin(false);\\n                                            return\\n\\n                                        }\\n                                        // var nowDate = moment(moment().subtract(0, 'days').toDate()).format(\\\"YYYYMMDD\\\");\\n                                        var nowDate = $utils.moment(new Date()).format(\\\"YYYYMMDD\\\");\\n\\n                                        if (data[i].effDt > nowDate || data[i].expDt < nowDate) {\\n                                            judge = false;\\n                                            $utils.message.warning(\\\"该任务已过期\\\");\\n                                            $this.setPauseIsSpin(false);\\n                                            $this.setIsSpin(false);\\n                                            return\\n                                        }\\n                                    }\\n\\n\\n\\n                                    // next();\\n                                    // -----sCheck()-start-----------------------------------------------------------------------\\n                                    // var self = this;\\n                                    var val = '4';\\n                                    var _obj = {\\n                                        '0': ['0', '-3', '5'],\\n                                        '1': ['0', '-1', '-2', '5', '-3'],\\n                                        '2': ['4', '-1', '-2'],\\n                                        '3': ['3'],\\n                                        '4': ['0', '5', '-3'],\\n                                        '5': ['2'],\\n                                        '6': ['0', '-3', '5']\\n                                    }\\n\\n                                    if ($this.sCheckAuthorityFroRedoCurrent) {\\n                                        _obj = {\\n                                            '0': ['0', '-3', '5'],\\n                                            '1': ['0', '-1', '-2', '5', '-3'],\\n                                            '2': ['1', '4', '-1', '-2'],\\n                                            '3': ['3'],\\n                                            '4': ['0', '5', '-3'],\\n                                            '5': ['2'],\\n                                            '6': ['0', '-3', '5']\\n                                        }\\n                                    }\\n                                    var stateArr = _obj[val];\\n\\n\\n\\n                                    var label = '';\\n                                    var tempArr = [];\\n                                    var jobTrigIdList = [];\\n                                    _.map(forceExecuteList, function (val) {\\n                                        jobTrigIdList.push(encodeURI(val.jobTrigId));\\n                                    });\\n                                    // var param = JSON.stringify({ jobTrigId: jobTrigIdList });\\n                                    $utils.axios.post('/oneplusn-federation/open/dataflow/monitor/getTriggerDataList', { jobTrigId: jobTrigIdList }).then(response => {\\n                                        var data = response.data;\\n                                        var judge = true;\\n                                        if (data) {\\n                                            var val = '4';\\n                                            tempArr = data;\\n                                            for (var i in tempArr) {\\n                                                var _state = tempArr[i].state;\\n\\n                                                if (!_.contains(stateArr, _state)) {\\n                                                    judge = false;\\n                                                    label = tempArr[i].jobLabel;\\n                                                    break;\\n                                                }\\n                                            }\\n\\n                                            if (!judge) {\\n                                                var state = \\\"\\\";\\n                                                for (var i = 0; i < stateArr.length; i++) {\\n                                                    for (var j = 0; j < stateEnum.length; j++) {\\n                                                        if (stateEnum[j].value === stateArr[i])\\n                                                            state += stateEnum[j].label + \\\",\\\";\\n                                                    }\\n                                                }\\n                                                state = state.substring(0, state.length - 1);\\n                                                var oper = ['强制执行', '强制通过', '重做', '取消', '暂停', '恢复', '调整优先级'];\\n                                                var message = label + '不符合要求；状态为“' + state + '”才能进行“' + oper[val] + '”操作';\\n                                                if (val === '2') {\\n                                                    message += \\\";“成功”状态重做需要授权！\\\"\\n                                                }\\n                                                $utils.message.warning(message);\\n                                                $this.setPauseIsSpin(false);\\n                                                $this.setIsSpin(false);\\n                                                return\\n                                            }\\n\\n                                            // next();\\n\\n                                            var val = '4';\\n                                            var judge = true;\\n                                            var oper = ['强制执行', '强制通过', '重做', '取消', '暂停', '恢复', '手工任务', '调整优先级'];\\n                                            for (var i = 0; i < forceExecuteList.length; i++) {\\n                                                var data = forceExecuteList[i];\\n                                                var index = _.findIndex(operCheckTime[val], function (item) {\\n                                                    return item.label === data.jobTrigId\\n                                                });\\n                                                if (index > -1) {\\n                                                    var nowDate = new Date();\\n                                                    //大于1分钟\\n                                                    if (nowDate.getTime() - operCheckTime[val][index].time.getTime() > 60000) {\\n                                                        operCheckTime[val][index].time = nowDate;\\n                                                        judge = true;\\n                                                    } else {\\n                                                        $utils.message.warning(data.jobLabel + '，操作与上次操作时间需要间隔1分钟');\\n                                                        $this.setPauseIsSpin(false);\\n                                                        $this.setIsSpin(false);\\n                                                        return;\\n\\n                                                    }\\n                                                } else {\\n                                                    $this.operCheckTime[val].push({ \\\"label\\\": data.jobTrigId, \\\"time\\\": new Date() });\\n                                                }\\n                                            }\\n                                            $this.setPauseIsSpin(false);\\n                                            $this.setIsSpin(false);\\n                                            $utils.modal.confirm({\\n                                                title: '确定执行暂停操作？',\\n                                                content:\\n                                                    '',\\n                                                okButtonProps: {\\n                                                    status: 'warning',\\n                                                },\\n                                                onOk: () => {\\n\\n                                                    var dataArr = [];\\n                                                    for (let data of forceExecuteList) {\\n                                                        dataArr.push({\\n                                                            jobTrigId: data.jobTrigId,\\n                                                            teamName: $identity.teamName,\\n                                                            userId: $identity.userId\\n                                                        })\\n                                                    }\\n                                                    $utils.axios.defaults.timeout = 600000;\\n                                                    $utils.axios.post('/oneplusn-federation/open/dataflow/monitor/pause', dataArr).then(res => {\\n\\n                                                        if (res.data.success === true) {\\n                                                            $utils.message.success('暂停成功！');\\n\\n                                                            const filters = $this.$refs.jobMonitorFilterForm.getFieldsValue();\\n                                                            var current = $this.$refs.logicJobMonitorTab.state.current;\\n                                                            var pageSize = $this.$refs.logicJobMonitorTab.state.pageSize;\\n\\n                                                            var jobLabel = '';\\n                                                            var batchTypes = 'daily';\\n                                                            var batchNo = '';\\n                                                            var memberName = '';\\n                                                            var runState = '';\\n                                                            var jobType = '';\\n                                                            var priority = '';\\n                                                            var runStateNum = 1;\\n                                                            var tag = '';\\n                                                            var brokerWorkgroup = '';\\n                                                            var batchNoZone = '';\\n\\n                                                            for (var f in filters) {\\n                                                                if (f == 'jobLabel' && filters[f]) {\\n                                                                    jobLabel = filters[f];\\n                                                                }\\n                                                                if (f == 'batchTypes' && filters[f]) {\\n\\n                                                                    batchTypes = filters[f].join(',');\\n                                                                }\\n                                                                if (f == 'batchNoZone' && filters[f]) {\\n                                                                    batchNo = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n                                                                    batchNoZone = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n                                                                }\\n                                                                if (f == 'batchNo' && filters[f] && batchNoZone == '') {\\n                                                                    batchNo = filters[f].replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\");\\n                                                                }\\n                                                                if (f == 'dUser' && filters[f]) {\\n                                                                    memberName = filters[f];\\n                                                                }\\n                                                                if (f == 'runState' && filters[f]) {\\n                                                                    runState = filters[f];\\n                                                                }\\n                                                                if (f == 'jobType' && filters[f]) {\\n                                                                    jobType = filters[f];\\n                                                                }\\n                                                                if (f == 'priority' && filters[f]) {\\n                                                                    priority = filters[f];\\n                                                                }\\n                                                                //runStateNum: true\\n                                                                if (f == 'runStateNum' && filters[f]) {\\n                                                                    if (filters[f] == true) {\\n                                                                        runStateNum = 0;\\n\\n                                                                    } else if (filters[f] == false) {\\n                                                                        runStateNum = 1;\\n                                                                    }\\n\\n                                                                }\\n\\n                                                                if (f == 'tag' && filters[f]) {\\n                                                                    tag = filters[f];\\n                                                                }\\n                                                                if (f == 'brokerWorkgroup' && filters[f]) {\\n                                                                    brokerWorkgroup = filters[f];\\n                                                                }\\n                                                                // if (f == 'cycle' && filters[f]) {\\n                                                                //     vars.params.cycle = '~%' + filters[f] + '%'\\n                                                                // }\\n                                                            }\\n\\n                                                            let state = '';\\n                                                            let queryType = '0';\\n                                                            if ($this.jobState2.length == 0) {\\n                                                                if ($this.jobState.indexOf('ALL') == -1) {\\n                                                                    state = $this.jobState.join(',');\\n                                                                    queryType = '0';\\n\\n                                                                }\\n                                                            } else {\\n                                                                if ($this.jobState2.indexOf('ALL') == -1) {\\n                                                                    state = $this.jobState2.join(',');\\n                                                                    queryType = '1';\\n                                                                }\\n                                                            }\\n\\n\\n                                                            $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/getStatisticsCollectData',\\n                                                                {\\n                                                                    params:\\n                                                                    {\\n                                                                        jobLabel: jobLabel,\\n                                                                        batchTypes: batchTypes,\\n                                                                        batchNo: batchNo,\\n                                                                        teamName: $identity.teamName,\\n                                                                        memberName: memberName,\\n                                                                        runState: runState,\\n                                                                        jobType: jobType,\\n                                                                        priority: priority,\\n                                                                        runStateNum: runStateNum,\\n                                                                        tag: tag,\\n                                                                        brokerWorkgroup: brokerWorkgroup\\n                                                                    }\\n                                                                }).then(res => {\\n                                                                    $this.setJobS(res.data.data);\\n                                                                    if (res.data.data.jtFinish != null && res.data.data.jtSum != null) {\\n                                                                        $this.setJobSuccessRate(Math.round((res.data.data.jtFinish / res.data.data.jtSum) * 100))\\n                                                                    } else {\\n                                                                        $this.setJobSuccessRate(0);\\n                                                                    }\\n\\n\\n                                                                }).catch(function (error) {\\n                                                                    console.log(error);\\n                                                                });\\n\\n\\n                                                            $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/v2/getStatisticsTableData',\\n                                                                {\\n                                                                    params:\\n                                                                    {\\n                                                                        pageNum: current - 1,\\n                                                                        pageSize: pageSize,\\n                                                                        jobLabel: jobLabel,\\n                                                                        batchTypes: batchTypes,\\n                                                                        batchNo: batchNo,\\n                                                                        teamName: $identity.teamName,\\n                                                                        taskType: 'all',\\n                                                                        desc: 'desc',\\n                                                                        sortColumn: 'jobCode',\\n                                                                        memberName: memberName,\\n                                                                        runState: runState,\\n                                                                        jobType: jobType,\\n                                                                        priority: priority,\\n                                                                        readTeamNames: $identity.teamName,\\n                                                                        jobState: state,\\n                                                                        queryType: queryType,\\n                                                                        runStateNum: runStateNum,\\n                                                                        tag: tag,\\n                                                                        brokerWorkgroup: brokerWorkgroup\\n                                                                    }\\n                                                                }).then(res => {\\n                                                                    var data = res.data.data;\\n                                                                    $this.setLogicJobTriggerListData(data);\\n\\n                                                                }).catch(function (error) {\\n                                                                    console.log(error);\\n                                                                });\\n\\n\\n                                                        } else {\\n                                                            $utils.message.error('暂停失败！' + res.data.msg)\\n                                                        }\\n\\n\\n                                                    }).catch(function (error) {\\n                                                        $this.setPauseIsSpin(false);\\n                                                        $this.setIsSpin(false);\\n                                                        console.log(error);\\n                                                    });\\n                                                },\\n                                            });\\n\\n                                        }\\n\\n\\n                                    }).catch(function (error) {\\n                                        $this.setPauseIsSpin(false);\\n                                        $this.setIsSpin(false);\\n                                        console.log(error);\\n                                    });\\n\\n                                }\\n                            }\\n                        })\\n                        // return judge;\\n                    }\\n\\n                }).catch(function (error) {\\n                    $this.setPauseIsSpin(false);\\n                    $this.setIsSpin(false);\\n                    console.log(error);\\n                });\\n\\n\\n            }\\n        }\\n\\n        // -----sCheckOnly()-end--------------------------------------\\n    }).catch(function (error) {\\n        $this.setPauseIsSpin(false);\\n        $this.setIsSpin(false);\\n        console.log(error);\\n    });\\n\\n}\\n\\n\\n\\n\\nfunction writeTeamContain(teamName) {\\n    var index = _.findIndex($this.writeTeamNames, function (item) {\\n        return item === teamName\\n    });\\n    return index > -1 ? true : false;\\n}\"}},\"type\":\"text\",\"icon\":\"IconPauseAll\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]},{\"id\":\"149898661c507caf\",\"name\":\"149898661c507caf\",\"label\":\"恢复\",\"type\":\"button\",\"options\":{\"hidden\":false,\"hiddenBindVar\":\"$this.showMore1 == false\",\"isLoading\":true,\"loading\":false,\"loadingBindVar\":\"$this.recoverIsSpin == true\",\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onClick\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\