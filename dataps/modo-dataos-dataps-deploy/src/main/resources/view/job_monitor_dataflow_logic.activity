},\"callback\":\"function callback(values, sort, select) {\\r\\n    $this.setSortValues(sort);\\r\\n    var desc = 'desc';\\r\\n    var sortColumn = 'jobCode';\\r\\n    if (sort.direction != undefined && sort.field != undefined) {\\r\\n        sortColumn = sort.field;\\r\\n        if (sort.direction == 'descend') {\\r\\n            desc = 'desc';\\r\\n        } else if (sort.direction == 'ascend') {\\r\\n            desc = 'asc';\\r\\n        }\\r\\n    }\\r\\n    var jobLabel = '';\\r\\n    var batchTypes = 'daily';\\r\\n    var batchNo = '';\\r\\n    var memberName = '';\\r\\n    var runState = '';\\r\\n    var jobType = '';\\r\\n    var priority = '';\\r\\n    var runStateNum = 1;\\r\\n    var tag = '';\\r\\n    var brokerWorkgroup = '';\\r\\n\\r\\n    const filters = $this.$refs.jobMonitorFilterForm.getFieldsValue();\\r\\n    for (var f in filters) {\\r\\n        if (f == 'jobLabel' && filters[f]) {\\r\\n            jobLabel = filters[f];\\r\\n        }\\r\\n        if (f == 'batchTypes' && filters[f]) {\\r\\n            if (filters[f] == '') {\\r\\n                $utils.message.warning('请选择周期！');\\r\\n                return;\\r\\n            }\\r\\n            batchTypes = filters[f].join(',');\\r\\n        } if (f == 'batchNoZone' && filters[f]) {\\r\\n            batchNo = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\r\\n        }\\r\\n        if (f == 'batchNo' && filters[f]) {\\r\\n            batchNo = filters[f].replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\");\\r\\n        }\\r\\n        if (f == 'dUser' && filters[f]) {\\r\\n            memberName = filters[f];\\r\\n        }\\r\\n        if (f == 'runState' && filters[f]) {\\r\\n            runState = filters[f];\\r\\n        }\\r\\n        if (f == 'jobType' && filters[f]) {\\r\\n            jobType = filters[f];\\r\\n        }\\r\\n        if (f == 'priority' && filters[f]) {\\r\\n            priority = filters[f];\\r\\n        }\\r\\n        if (f == 'runStateNum' && filters[f]) {\\r\\n            if (filters[f] == true) {\\r\\n                runStateNum = 0;\\r\\n                $this.setRunStateNum(0)\\r\\n            } else if (filters[f] == false) {\\r\\n                runStateNum = 1;\\r\\n            }\\r\\n\\r\\n        }\\r\\n\\r\\n        if (f == 'tag' && filters[f]) {\\r\\n            tag = filters[f];\\r\\n        }\\r\\n        if (f == 'brokerWorkgroup' && filters[f]) {\\r\\n            brokerWorkgroup = filters[f];\\r\\n        }\\r\\n        // if (f == 'cycle' && filters[f]) {\\r\\n        //     vars.params.cycle = '~%' + filters[f] + '%'\\r\\n        // }\\r\\n    }\\r\\n\\r\\n\\r\\n    let state = '';\\r\\n    let queryType = '0';\\r\\n    if ($this.jobState2.length == 0) {\\r\\n        if ($this.jobState.indexOf('ALL') == -1) {\\r\\n            state = $this.jobState.join(',');\\r\\n            queryType = '0';\\r\\n        }\\r\\n    } else {\\r\\n        if ($this.jobState2.indexOf('ALL') == -1) {\\r\\n            state = $this.jobState2.join(',');\\r\\n            queryType = '1';\\r\\n        }\\r\\n    }\\r\\n\\r\\n    $this.setSearching(true)\\r\\n    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/v2/getStatisticsTableData',\\r\\n        {\\r\\n            params:\\r\\n            {\\r\\n                pageNum: values.current - 1,\\r\\n                pageSize: values.pageSize,\\r\\n                jobLabel: jobLabel,\\r\\n                batchTypes: batchTypes,\\r\\n                batchNo: batchNo,\\r\\n                teamName: $identity.teamName,\\r\\n                taskType: 'all',\\r\\n                desc: desc,\\r\\n                sortColumn: sortColumn,\\r\\n                memberName: memberName,\\r\\n                runState: runState,\\r\\n                jobType: jobType,\\r\\n                priority: priority,\\r\\n                readTeamNames: $identity.teamName,\\r\\n                jobState: state,\\r\\n                queryType: queryType,\\r\\n                runStateNum: runStateNum,\\r\\n                tag: tag,\\r\\n                brokerWorkgroup: brokerWorkgroup\\r\\n            }\\r\\n        }).then(res => {\\r\\n            var data = res.data.data;\\r\\n\\r\\n            $this.setLogicJobTriggerListData(data);\\r\\n            $this.setSearching(false)\\r\\n\\r\\n        }).catch(function (error) {\\r\\n            console.log(error);\\r\\n            $this.setSearching(false)\\r\\n        });\\r\\n}\"}},\"modelName\":\"DacpDataflowLogicJobD\",\"showHeader\":true,\"borderCell\":true,\"columns\":[{\"title\":\"任务编号\",\"dataIndex\":\"parentCode\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"jobCode\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"jobode\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"jobcode\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"jocode\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"jcode\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"code\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"ode\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"jode\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"joode\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"jobode\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"jobCode\",\"__ORIGIN_DATA\":{\"title\":\"任务编号\",\"dataIndex\":\"code\",\"__ORIGIN_DATA\":{\"title\":\"任务\",\"dataIndex\":\"code\",\"__ORIGIN_DATA\":{\"title\":\"任务便\",\"dataIndex\":\"code\",\"__ORIGIN_DATA\":{\"title\":\"任务便哈\",\"dataIndex\":\"code\",\"__ORIGIN_DATA\":{\"title\":\"\",\"dataIndex\":\"code\"}}}},\"tagColors\":[],\"align\":\"center\",\"width\":\"180\",\"fixed\":\"left\"},\"tagColors\":[],\"align\":\"center\",\"width\":\"180\",\"fixed\":\"left\"},\"tagColors\":[],\"align\":\"center\",\"width\":\"180\",\"fixed\":\"left\"},\"tagColors\":[],\"align\":\"center\",\"width\":\"18