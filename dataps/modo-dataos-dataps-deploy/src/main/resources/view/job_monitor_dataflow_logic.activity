th\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{}},\"defaultOptions\":{\"css\":\":root {\\nheight: 200px;\\n}\"},\"children\":[{\"id\":\"7fc7fae62b5d4588\",\"name\":\"jobMonitorFilterForm\",\"label\":\"任务调度监控表单\",\"type\":\"form\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root,\\r\\n:root .modo-filter-form-content {\\r\\n    height: auto;\\r\\n}\\r\\n:root .tag-list {\\r\\n    white-space: normal;\\r\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"search\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\n\\n    $this.setSearching(true)\\n    $this.setRunStateNum(1)\\n    // $this.dacpDataflowLogicJobDRepo.search();\\n    const filters = $this.$refs.jobMonitorFilterForm.getFieldsValue();\\n    var current = $this.$refs.logicJobMonitorTab.state.current;\\n    var pageSize = $this.$refs.logicJobMonitorTab.state.pageSize;\\n    if (!ifCompare(filters, $this.filterHistory)) {\\n        current = 1;\\n    }\\n    $this.setFilterHistory(filters);\\n    var jobLabel = '';\\n    var batchTypes = '';\\n    var batchNo = '';\\n    var memberName = '';\\n    var runState = '';\\n    var jobType = '';\\n    var priority = '';\\n    var runStateNum = 1;\\n    var tag = '';\\n    var brokerWorkgroup = '';\\n\\n    var batchNoZone = '';\\n\\n    for (var f in filters) {\\n        if (f == 'jobLabel' && filters[f]) {\\n            jobLabel = filters[f];\\n        }\\n        if (f == 'batchTypes' && filters[f]) {\\n\\n            batchTypes = filters[f].join(',');\\n        }\\n        if (f == 'batchNoZone' && filters[f]) {\\n            batchNo = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n            batchNoZone = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n        }\\n        if (f == 'batchNo' && filters[f] && batchNoZone == '') {\\n            batchNo = filters[f].replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\");\\n        }\\n        if (f == 'dUser' && filters[f]) {\\n            memberName = filters[f];\\n        }\\n        if (f == 'runState' && filters[f]) {\\n            runState = filters[f];\\n        }\\n        if (f == 'jobType' && filters[f]) {\\n            jobType = filters[f];\\n        }\\n        if (f == 'priority' && filters[f]) {\\n            priority = filters[f];\\n        }\\n\\n        if (f == 'runStateNum' && filters[f]) {\\n            if (filters[f] == true) {\\n                runStateNum = 0;\\n                $this.setRunStateNum(0)\\n            } else if (filters[f] == false) {\\n                runStateNum = 1;\\n            }\\n\\n        }\\n\\n        if (f == 'tag' && filters[f]) {\\n            tag = filters[f];\\n        }\\n        if (f == 'brokerWorkgroup' && filters[f]) {\\n            brokerWorkgroup = filters[f];\\n        }\\n        // if (f == 'cycle' && filters[f]) {\\n        //     vars.params.cycle = '~%' + filters[f] + '%'\\n        // }\\n    }\\n\\n    if (batchNo == '' && batchNoZone == '') {\\n        $utils.message.warning('筛选条件必须包含批次或批次区间！');\\n        $this.setSearching(false)\\n        return;\\n    }\\n    if (batchTypes == '') {\\n        $utils.message.warning('请选择周期！');\\n        $this.setSearching(false)\\n        return;\\n    }\\n    var sort = $this.sortValues;\\n    var desc = 'desc';\\n    var sortColumn = 'jobCode';\\n    if (sort.direction != undefined && sort.field != undefined) {\\n        sortColumn = sort.field;\\n        if (sort.direction == 'descend') {\\n            desc = 'desc';\\n        } else if (sort.direction == 'ascend') {\\n            desc = 'asc';\\n        }\\n    }\\n\\n    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/getStatisticsCollectData',\\n        {\\n            params:\\n            {\\n                jobLabel: jobLabel,\\n                batchTypes: batchTypes,\\n                batchNo: batchNo,\\n                teamName: $identity.teamName,\\n                memberName: memberName,\\n                runState: runState,\\n                jobType: jobType,\\n                priority: priority,\\n                runStateNum: runStateNum,\\n                tag: tag,\\n                desc,\\n                sortColumn,\\n                brokerWorkgroup: brokerWorkgroup\\n            }\\n        }).then(res => {\\n            $this.$refs.logicJobMonitorTab.setState({ selectedRowKeys: [], selectedRows: [] });\\n            $this.setJobS(res.data.data);\\n            if (res.data.data.jtFinish != null && res.data.data.jtSum != null) {\\n                $this.setJobSuccessRate(Math.round((res.data.data.jtFinish / res.data.data.jtSum) * 100))\\n            } else {\\n                $this.setJobSuccessRate(0);\\n            }\\n\\n        }).catch(function (error) {\\n            $this.setSearching(false)\\n            console.log(error);\\n        });\\n\\n    let state = '';\\n    let queryType = '0';\\n\\n    if ($this.jobState2.length == 0) {\\n\\n        if ($this.jobState.indexOf('ALL') == -1) {\\n            state = $this.jobState.join(',');\\n            queryType = '0';\\n\\n        }\\n    } else {\\n\\n        if ($this.jobState2.indexOf('ALL') == -1) {\\n            state = $this.jobState2.join(',');\\n            queryType = '1';\\n        }\\n    }\\n\\n\\n    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/v2/getStatisticsTableData',\\n        {\\n            params:\\n            {\\n                pageNum: current - 1,\\n                pageSize: pageSize,\\n                jobLabel: jobLabel,\\n                batchTypes: batchTypes,\\n                batchNo: batchNo,\\n                teamName: $identity.teamName,\\n                taskType: 'all',\\n                desc,\\n                sortColumn,\\n                memberName: memberName,\\n                runState: runState,\\n                jobType: jobType,\\n                priority: priority,\\n                readTeamNames: $identity.teamName,\\n                jobState: state,\\n                queryType: queryType,\\n                runStateNum: runStateNum,\\n                tag: tag,\\n                brokerWorkgroup: brokerWorkgroup\\n            }\\n        }).then(res => {\\n            $this.$refs.logicJobMonitorTab.setState({ selectedRowKeys: [], selectedRows: [] });\\n            var data = res.data.data;\\n            $this.setLogicJobTriggerListData(data);\\n            $this.setSearching(false)\\n        }).catch(function (error) {\\n            console.log(error);\\n            $this.setSearching(false)\\n        });\\n}\\n\\nfunction ifCompare(object1, object2) {\\n    var o1keys = Object.keys(object1);\\n    var o2keys = Object.keys(object2);\\n    if (o2keys.length !== o1keys.length) return false;\\n    for (let i = 0; i <= o1keys.length - 1; i++) {\\n        let key = o1keys[i];\\n        if (!o2keys.includes(key)) return false;\\n        if (object2[key] !== object1[key]) return false;\\n\\n    }\\n    return true;\\n\\n}\"}},\"labelFlex\":\"70px\",\"modelName\":\"DacpDataflowLogicJobD\",\"min\":3,\"layout\":\"inline\",\"valuesBindVar\":\"$this.jobMonitorFilterFormData\",\"initialValuesBindVar\":\"{ batchTypes: ['daily'] }\"},\"children\":[{\"id\":\"f559c4b94603ba07\",\"name\":\"jobLabel\",\"label\":\"任务\",\"type\":\"input\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root{}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\"