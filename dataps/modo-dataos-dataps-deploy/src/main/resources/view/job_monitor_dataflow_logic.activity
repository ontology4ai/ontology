message == null ? \\\"\\\" : row.message;\\n                            if ('datastash' === data.jobType) {\\n                                // window.open($this.oneplusnContextPath + \\\"/datastash/workshop/unit/task/state/\\\" + row.jobTrigId);\\n                                window.open(\\\"/dacp_fed/datastash/workshop/unit/task/state/\\\" + row.jobTrigId);\\n                            } else {\\n                                // window.open($this.oneplusnContextPath + \\\"/open/dataflow/monitor/monitorDialog?brokerId=\\\" + row.brokerId\\n                                const newWindow = window.open(\\\"/dataos/task-log?brokerId=\\\" + row.brokerId\\n                                    + \\\"&&jobTrigId=\\\" + row.jobTrigId\\n                                    + \\\"&&jobCode=\\\" + row.jobCode\\n                                    + \\\"&&jobLabel=\\\" + encodeURI(row.jobLabel)\\n                                    + \\\"&&startDate=\\\" + row.startDate\\n                                    + \\\"&&batchNo=\\\" + row.batchNo\\n                                    + \\\"&&message=\\\" + encodeURI(message));\\n                                newWindow.addEventListener('load', () => { newWindow.document.title = '调度日志信息'; });\\n                            }\\n                        } else {\\n                            $utils.message.warning('无对应的任务信息数据！');\\n                            $this.setLogIsSpin(false);\\n                            $this.setIsSpin(false);\\n\\n                        }\\n\\n                    }).catch(function (error) {\\n                        console.log(error);\\n                    });\\n            }\\n        }\\n    }).catch(function (error) {\\n        console.log(error);\\n    });\\n}\"}},\"type\":\"text\",\"icon\":\"IconDataAllocation\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]},{\"id\":\"2c7c00ad7e2f8e60\",\"name\":\"2c7c00ad7e2f8e44\",\"label\":\"依赖分析\",\"type\":\"button\",\"options\":{\"hidden