                 if (data[i].effDt > nowDate || data[i].expDt < nowDate) {\\n                                            judge = false;\\n                                            $utils.message.warning(\\\"该任务已过期\\\");\\n                                            $this.setAdjustPriorityIsSpin(false);\\n                                            $this.setIsSpin(false);\\n                                            return\\n\\n                                        }\\n                                    }\\n\\n\\n\\n                                    // next();\\n                                    // -----sCheck()-start-----------------------------------------------------------------------\\n                                    // var self = this;\\n                                    var val = '6';\\n                                    var _obj = {\\n                                        '0': ['0', '-3', '5'],\\n                                        '1': ['0', '-1', '-2', '5', '-3'],\\n                                        '2': ['4', '-1', '-2'],\\n                                        '3': ['3'],\\n                                        '4': ['0', '3', '5', '-3'],\\n                                        '5': ['2'],\\n                                        '6': ['0', '-3', '5']\\n                                    }\\n\\n                                    if ($this.sCheckAuthorityFroRedoCurrent) {\\n                                        _obj = {\\n                                            '0': ['0', '-3', '5'],\\n                                            '1': ['0', '-1', '-2', '5', '-3'],\\n                                            '2': ['1', '4', '-1', '-2'],\\n                                            '3': ['3'],\\n                                            '4': ['0', '3', '5', '-3'],\\n                                            '5': ['2'],\\n                                            '6': ['0', '-3', '5']\\n                      