value: \\\"createDate\\\" },\\n    { label: \\\"执行时长\\\", value: \\\"duration\\\" },\\n    { label: \\\"剩余时长\\\", value: \\\"avgDuration\\\" },\\n    { label: \\\"执行信息\\\", value: \\\"message\\\" },\\n    { label: \\\"任务名称\\\", value: \\\"jobLabel\\\" },\\n    { label: \\\"优先级\\\", value: \\\"priority\\\" },\\n    { label: \\\"周期\\\", value: \\\"batchType\\\" },\\n    { label: \\\"BrokerID\\\", value: \\\"brokerId\\\" },\\n    { label: \\\"责任人\\\", value: \\\"memberName\\\" },\\n    { label: \\\"完成时间\\\", value: \\\"completeDate\\\" },\\n    { label: \\\"是否有效\\\", value: \\\"isValid\\\" },\\n    { label: \\\"重做次数\\\", value: \\\"actualRedoNum\\\" },\\n    { label: \\\"第一次开始时间\\\", value: \\\"firstStartDate\\\" },\\n    { label: \\\"第一次完成时间\\\", value: \\\"firstCompleteDate\\\" }\\n]\"},{\"name\":\"memberList\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"tagOptions\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"searching\",\"descr\":null,\"value\":\"false\"},{\"name\":\"brokerWorkgroupOptions\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"sortValues\",\"descr\":\"表格排序的值\",\"value\":\"{}\"}],\"models\":[],\"services\":[{\"name\":\"getListDataByState\",\"stateName\":\"state\",\"descr\":\"\",\"autoLoad\":false,\"serviceId\":null,\"method\":\"get\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":false,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\n    // 通过 vars.params 可以更改查询参数\\n    // 通过 vars.data 可以更改requestdata\\n    // 通过 config.header 可以更改 header\\n    // 通过 config.url 可以更改  url\\n    /* vars.data = {\\n    } */\\n    // console.log(vars, config);\\n    // 可以查看还有哪些参数可以修改。\\n}\",\"success\":\"function successCallback(data) {\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\n    return data.data; // 重要，需返回 data\\n}\",\"fail\":\"function failCallback(error){\\n    // console.log(error);\\n    // 可以在这里做弹框提示等操作\\n}\",\"callback\":\"function getListDataByState(next, state, queryType) {\\n\\n    // $this.dacpDataflowLogicJobDRepo.search();\\n    const filters = $this.$refs.jobMonitorFilterForm.getFieldsValue();\\n    var current = $this.$refs.logicJobMonitorTab.state.current;\\n    var pageSize = $this.$refs.logicJobMonitorTab.state.pageSize;\\n    if (!ifCompare(filters, $this.filterHistory)) {\\n        current = 1;\\n    }\\n    $this.setFilterHistory(filters);\\n    var jobLabel = '';\\n    var batchTypes = 'daily';\\n    var batchNo = '';\\n    var memberName = '';\\n    var runState = '';\\n    var jobType = '';\\n    var priority = '';\\n    var runStateNum = 1;\\n    var tag = '';\\n    for (var f in filters) {\\n        if (f == 'jobLabel' && filters[f]) {\\n            jobLabel = filters[f];\\n        }\\n        if (f == 'batchTypes' && filters[f]) {\\n            batchTypes = filters[f].join(',');\\n        } if (f == 'batchNoZone' && filters[f]) {\\n            batchNo = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n        }\\n        if (f == 'batchNo' && filters[f]) {\\n            batchNo = filters[f].replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\");\\n        }\\n        if (f == 'dUser' && filters[f]) {\\n            memberName = filters[f];\\n        }\\n        if (f == 'runState' && filters[f]) {\\n            runState = filters[f];\\n        }\\n        if (f == 'jobType' && filters[f]) {\\n            jobType = filters[f];\\n        }\\n        if (f == 'priority' && filters[f]) {\\n            priority = filters[f];\\n        }\\n         if (f == 'runStateNum' && filters[f]) {\\n            if (filters[f] == true) {\\n                runStateNum = 0;\\n                $this.setRunStateNum(0)\\n            } else if (filters[f] == false) {\\n                runStateNum = 1;\\n            }\\n\\n        }\\n\\n        if (f == 'tag' && filters[f]) {\\n            tag = filters[f];\\n        }\\n        // if (f == 'cycle' && filters[f]) {\\n        //     vars.params.cycle = '~%' + filters[f] + '%'\\n        // }\\n    }\\n    if (state.indexOf('ALL') != -1) {\\n        state = '';\\n    }\\n    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/v2/getStatisticsTableData',\\n        {\\n            params:\\n            {\\n                pageNum: current - 1,\\n                pageSize: pageSize,\\n                jobLabel: jobLabel,\\n                batchTypes: batchTypes,\\n                batchNo: batchNo,\\n                teamName: $identity.teamName,\\n                taskType: 'all',\\n                desc: 'desc',\\n                sortColumn: 'jobCode',\\n                memberName: memberName,\\n                runState: runState,\\n                jobType: jobType,\\n                priority: priority,\\n                readTeamNames: $identity.teamName,\\n                jobState: state,\\n                queryType: queryType,\\n                runStateNum: runStateNum,\\n                tag: tag\\n            }\\n        }).then(res => {\\n            var data = res.data.data;\\n\\n            $this.setLogicJobTriggerListData(data);\\n\\n        }).catch(function (error) {\\n            console.log(error);\\n        });\\n}\\n\\nfunction ifCompare(object1, object2) {\\n    var o1keys = Object.keys(object1);\\n    var o2keys = Object.keys(object2);\\n    if (o2keys.length !== o1keys.length) return false;\\n    for (let i = 0; i <= o1keys.length - 1; i++) {\\n        let key = o1keys[i];\\n        if (!o2keys.includes(key)) return false;\\n        if (object2[key] !== object1[key]) return false;\\n\\n    }\\n    return true;\\n\\n}\"}],\"i18n\":{\"zh-CN\":\"{}\",\"en-US\":\"{}\"}},\"children\":[{\"id\":\"e838b28b3955f1aa\",\"name\":\"logic_job_monitor_tab\",\"label\":\"逻辑调度任务监控\",\"type\":\"tabs\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindV