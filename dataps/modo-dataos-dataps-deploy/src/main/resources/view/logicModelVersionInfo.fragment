$this.versionCount >= 2 && $this.versionCount <= 5\",\n                                                \"showType\": \"modal\",\n                                                \"viewName\": \"catalogAssetVersionCompareBase_grid\",\n                                                \"before\": \"function beforeCallback() {}\",\n                                                \"width\": \"75%\",\n                                                \"top\": \"15vh\",\n                                                \"fullscreen\": false,\n                                                \"size\": \"50%\",\n                                                \"tabViewName\": null,\n                                                \"tabParams\": \"\",\n                                                \"tabKey\": \"\",\n                                                \"tabLabel\": \"\",\n                                                \"title\": \"版本对比\"\n                                            }\n                                        ],\n                                        \"actions\": []\n                                    },\n                                    \"callback\": \"function callback() {\\n    // 给赋值选中的版本\\n    if ($this.versionCount < 2 || $this.versionCount > 5) {\\n        $utils.message.warning('请选择比较的版本，不能少于2个，且不得大于5个');\\n        return false;\\n    }\\n    debugger\\n    var paramObj = {\\n        hisList: $this.hisList,\\n        tabId: $this.id\\n    };\\n    const targetVersions = [];\\n    const targetVersionLabels = [];\\n    $this.hisList.forEach(obj => {\\n        if (obj.check && obj.check.length >= 1 && obj.check[0] === '1') {\\n            targetVersions.push(obj.version);\\n            targetVersionLabels.push('V' + obj.version);\\n        }\\n    });\\n    // 添加页面到父级的父级的选项卡中\\n    $this.getParent().$refs.logic_tabs.addTab('logicModelVerCompare' + targetVersions.join(','), targetVersionLabels.join(',') + '-版本对比', null, 'logicModelVerCompare'