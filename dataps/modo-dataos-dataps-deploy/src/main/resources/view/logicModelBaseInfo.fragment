            \"models\": [],
            \"services\": [
                {
                    \"name\": \"getModelDetail\",
                    \"stateName\": \"tabInfo\",
                    \"descr\": \"获取模型详情\",
                    \"autoLoad\": true,
                    \"serviceId\": \"78502590924689408\",
                    \"method\": \"GET\",
                    \"dataBindVar\": \"\",
                    \"placeholders\": \"[]\",
                    \"condition\": true,
                    \"conditionBindVar\": \"\",
                    \"before\": \"function beforeCallback(vars, config) {\\n    vars.params.tabHisId = $this.parent.tabHisId;\\n    vars.params.id = $this.parent.modelId;\\n    vars.params.workspaceId = $this.parent.workspaceId;\\n    vars.params.dataSrc = $this.parent.dataSrc;\\n}\",
                    \"success\": \"function successCallback(data) {\\n    if(data.data.datasource){\\n        data.data.dsLabel = data.data.datasource.dsLabel;\\n    }\\n    if(data.data.busiProps){\\n        const busiPropLabels = [];\\n        data.data.busiProps.forEach(item=>{\\n            if(item.propLabel){\\n                busiPropLabels.push(item.propLabel);\\n            }\\n        });\\n        data.data.busiPropLabels = busiPropLabels.join(',');\\n    }\\n    // 格式化脱敏规则,add by rl,20240424\\n    for(const obj of data.data.fields){\\n        obj.maskRuleLabel = $this.parent.maskRuleOptionsMap[obj.maskRule];\\n    }\\n    if(data.data.extendItems) {\\n        try{\\n          data.data.extendItems = JSON.parse(data.data.extendItems);\\n        }catch(e){\\n          data.data.extendItems = {};\\n        }\\n    }\\n    console.log(JSON.stringify(data.data));\\n    $this.parent.setTabInfo(data.data);\\n    return data.data; // 重要，需返回 data\\n}\",
                    \"fail\": \"function failCallback(error){\\n    // console.log(error);\\n    // 可以在这里做弹框提示等操作\\n}\",
                    \"callback\": \"\"
                },
                {
                    \"name\": \"getPageCustom\",
                    \"stateName\": \"\",
                    \"descr\": \"获取模型编辑定制\",
                    \"autoLoad\": true,
                    \"serviceId\": null,
                    \"method\": \"get\",
                    \"dataBindVar\": \"\",
                    \"placeholders\": \"[]\",
                    \"condition\": true,
                    \"conditionBindVar\": \"\",
                    \"before\": \"function beforeCallback(vars, config) {\\n    // 通过 vars.params 可以更改查询参数\\n    // 通过 vars.data 可以更改requestdata\\n    // 通过 config.header 可以更改 header\\n    // 通过 config.url 可以更改  url\\n    /* vars.data = {\\n    } */\\n    // console.log(vars, config);\\n    // 可以查看还有哪些参数可以修改。\\n}\",
                    \"success\": \"function successCallback(data) {\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\n    return data.data; // 重要，需返回 data\\n}\",
                    \"fail\": \"function failCallback(error){\\n    // console.log(error);\\n    // 可以在这里做弹框提示等操作\\n}\",
                    \"callback\": \"function callback() {\\n    const mergeArrays = (ary1, ary2, key = 'id') => {\\n        const result = [].concat(ary1); // 创建一个ary1的副本\\n        ary2.forEach(item2 => {\\n            const index = result.findIndex(item1 => item1[key] === item2[key]);\\n\\n            if (index !== -1) {\\n                // 如果在ary1中找到相同key的数据，则替换\\n                result[index] = item2;\\n            } else {\\n                // 如果在ary1中找不到相同key的数据，则添加到最后\\n                result.push(item2);\\n            }\\n        });\\n\\n        return result;\\n    }\\n    $utils.axios.post(window.location.origin + `/_common_/api/search/page/customs`, { offset: 0, limit: 100 }).then((res) => {\\n        if (res?.data?.success) {\\n            const list = res.data.data.content;\\n            // // 口径描述\\n            // const busiCaliber = list.find((item)=> item.itemName === 'busiCaliber' && item.customType === 'customFormItemLabel');\\n            // // 描述\\n            // const modelDescr = list.find((item)=> item.itemName === 'modelDescr' && item.customType === 'customFormItemLabel');\\n            // // 场景描述\\n            // const sceneDescr = list.find((item)=> item.itemName === 'sceneDescr' && item.customType === 'addFormItem');\\n\\n            // $this.setCustomPage({\\n            //     busiCaliber: busiCaliber || false,\\n            //     modelDescr: modelDescr || false,\\n            //     sceneDescr: sceneDescr || false,\\n            // })\\n\\n            const baseFields = list.filter((item) => {\\n                return item.customType === \\\"customFormItemLabel\\\" || item.customType === \\\"addFormItem\\\";\\n            }).map((item) => {\\n                const keyField = [\\\"select\\\", \\\"mul_select\\\", \\\"cascader\\\", \\\"mul_cascader\\\"].includes(item.inputCom) ? item.itemName + 'Label' : null;\\n                const key = item.itemName;\\n                if (!keyField) {\\n                    return {\\n                        text: item.itemLabel,\\n                        key,\\n                        hidden: false,\\n                    }\\n                }\\n                return {\\n                    text: item.itemLabel,\\n                    key,\\n                    hidden: false,\\n                    keyFunc: (dt) => {\\n                        if (dt.hasOwnProperty(keyField) || dt.hasOwnProperty(key)) {\\n                            return dt[keyField] || dt[key] || '--';\\n                        }\\n                        if (dt.extendItems) {\\n                            return dt.extendItems[keyField] || dt.extendItems[key] || '--';\\n                        }\\n                        return '--';\\n                    }\\n                };\\n            });\\n\\n            const baseModelFields = mergeArrays($this.baseFieldsList, baseFields, 'key');\\n            // console.log(baseModelFields);\\n            $this.setBaseFieldsList(baseModelFields);\\n            $this.parent.setCustomModelFields(list);\\n\\n        }\\n    }).catch(() => {\\n        console.log('获取模型编辑定制失败...')\\n    })\\n}\"
                },
                {
                    \"name\": \"getChangeFieldList\",
                    \"stateName\": \"\",
                    \"descr\": \"查询改变的字段\",
                    \"autoLoad\": true,
                    \"serviceId\": null,
                    \"method\": \"get\",
                    \"dataBindVar\": \"\",
                    \"placeholders\": \"[]\",
                    \"condition\": true,
                    \"conditionBindVar\": \"\",
                    \"before\": \"function beforeCallback(vars, config) {\\n    // 通过 vars.params 可以更改查询参数\\n    // 通过 vars.data 可以更改requestdata\\n    // 通过 config.header 可以更改 header\\n    // 通过 config.url 可以更改  url\\n    /* vars.data = {\\n    } */\\n    // console.log(vars, config);\\n    // 可以查看还有哪些参数可以修改。\\n}\",
                    \"success\": \"function successCallback(data) {\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\n    return data.data; // 重要，需返回 data\\n}\",
                    \"fail\": \"function failCallback(error){\\n    // console.log(error);\\n    // 可以在这里做弹框提示等操作\\n}\",
                    \"callback\": \"function callback() {\\n    $utils.axios.get(window.location.origin + `/dataps/_api/_/modoTabTag/getModelDifferent`, { params: { tabId: $this.parent.modelId } }).then((res) => {\\n        if (res?.data?.success) {\\n            const { base, extend, fieldDifferent } = res.data.data || { base: [], extend: [], fieldDifferent: {} };\\n            const fields = [].concat(base).concat(extend);\\n            $this.setChangeFields(fields);\\n            $this.parent.setChangeFieldList(fieldDifferent || {});\\n        }\\n    }).catch(() => {\\n\\n    })\\n}\"
                }
            ],
            \"i18n\": {
                \"zh-CN\": \"{}\",
                \"en-US\": \"{}\"
            }
