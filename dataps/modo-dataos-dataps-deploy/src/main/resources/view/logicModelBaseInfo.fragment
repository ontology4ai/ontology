                    \"descr\": \"基本信息显示字段\",
                    \"value\": \"[\\n    { text: '表名', key: 'modelName', hidden: false },\\n    { text: '中文名', key: 'modelLabel', hidden: false },\\n    { text: '数据源', key: 'dsLabel', hidden: false },\\n    { text: 'schema', key: 'tabSchema', hidden: false },\\n    { text: '敏感级别', key: 'sensLvlLabel', hidden: true },\\n    { text: '周期', key: 'updateCycleLabel', hidden: false },\\n    { text: '归属目录', key: 'archLabel', hidden: true },\\n    { text: '状态', key: 'stateName', hidden: false },\\n    { text: '描述', key: 'modelDescr', hidden: false },\\n    { text: '真实表名', key: 'realModelName', hidden: true },\\n]\"
