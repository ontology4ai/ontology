            \"css\": \":root {\\n    padding:10px;\\n}\\n\\n:root .grey-header {\\n    height: 40px;\\n    background: #F2F3F5;\\n    border-radius: 2px;\\n}\\n\\n:root .grey-header-title {\\n    height: 14px;\\n    font-size: 14px;\\n    font-family: SourceHanSansCN-Medium, SourceHanSansCN;\\n    font-weight: 500;\\n    color: #1D2129;\\n    line-height: 40px;\\n    margin-left:25px;\\n}\\n:root .flex-content{\\n    display: flex;\\n    flex-direction: column;\\n\\n}\\n:root .item-info {\\n    margin-left:30px;\\n    margin-top:15px;\\n    display: block;\\n}\\n:root .item-info:last-of-type {\\n    margin-bottom:15px;\\n}\\n:root .item-info>span:first-of-type{\\n    width: 85px;\\n    text-align: right;\\n    flex-shrink: 0;\\n}\\n:root .item-label {\\n    font-size: 12px;\\n    font-family: SourceHanSansCN-Regular, SourceHanSansCN;\\n    font-weight: 400;\\n    color: #86909C;\\n    line-height: 18px;\\n}\\n\\n:root .item-value {\\n    font-size: 12px;\\n    font-family: SourceHanSansCN-Regular, SourceHanSansCN;\\n    font-weight: 400;\\n    color: #1D2129;\\n    line-height: 18px;\\n}\",
