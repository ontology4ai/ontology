{"id":"bf03867288655dce","module":"236137972616593408","moduleLabel":null,"name":"workspaceDataArchNodeEdit","label":"数据架构节点编辑","descr":"数据架构结点编辑","type":"fragment","state":"1","parameters":"[\n    {\n        \"id\": \"0\",\n        \"name\": \"0\",\n        \"label\": \"页面\",\n        \"type\": \"view\",\n        \"options\": {\n            \"hidden\": false,\n            \"hiddenBindVar\": null,\n            \"isLoading\": false,\n            \"loading\": false,\n            \"loadingBindVar\": null,\n            \"loadingText\": null,\n            \"loadingTextBindVar\": null,\n            \"showTooltip\": false,\n            \"tooltipText\": null,\n            \"className\": \"\",\n            \"css\": \":root {\\n}\",\n            \"loop\": {\n                \"data\": null,\n                \"dataBindVar\": null,\n                \"var\": \"item\",\n                \"index\": \"index\",\n                \"key\": \"index\",\n                \"paginationVisible\": true,\n                \"disabled\": false,\n                \"event\": {\n                    \"builtIn\": {\n                        \"type\": \"url\",\n                        \"isSingleService\": true,\n                        \"urlAction\": {\n                            \"url\": null,\n                            \"blank\": true\n                        },\n                        \"viewActions\": [\n                            {\n                                \"condition\": \"true\",\n                                \"showType\": \"modal\",\n                                \"viewName\": null,\n                                \"before\": \"function beforeCallback() {}\",\n                                \"width\": \"50%\",\n                                \"top\": \"15vh\",\n                                \"fullscreen\": false,\n                                \"size\": \"50%\",\n                                \"tabViewName\": null,\n                                \"tabParams\": \"\",\n                                \"tabKey\": \"\",\n                                \"tabLabel\": \"\"\n                            }\n                        ],\n                        \"actions\": []\n                    },\n                    \"callback\": \"function callback() {}\"\n                }\n            },\n            \"eventMap\": {\n                \"onMount\": {\n                    \"builtIn\": {\n                        \"type\": \"url\",\n                        \"isSingleService\": true,\n                        \"urlAction\": {\n                            \"url\": null,\n                            \"blank\": true\n                        },\n                        \"viewActions\": [\n                            {\n                                \"condition\": \"true\",\n                                \"showType\": \"modal\",\n                                \"viewName\": null,\n                                \"before\": \"function beforeCallback() {}\",\n                                \"width\": \"50%\",\n                                \"top\": \"15vh\",\n                                \"fullscreen\": false,\n                                \"size\": \"50%\",\n                                \"tabViewName\": null,\n                                \"tabParams\": \"\",\n                                \"tabKey\": \"\",\n                                \"tabLabel\": \"\"\n                            }\n                        ],\n                        \"actions\": []\n                    },\n                    \"callback\": \"function callback() {\\r\\n\\r\\n    const target = {};\\r\\n    for (var k in $this.srcFormData) {\\r\\n        target[k] = $this.formData[k] || $this.srcFormData[k];\\r\\n    }\\r\\n    $this.setFormData(target);\\r\\n    /*\\r\\n    var parentTreeData = $this.parent.treeDataForEdit;\\r\\n    var result = findNodeInTree(parentTreeData, 'huqiang');\\r\\n    function findNodeInTree(tree, nameAlias) {\\r\\n        // 递归函数用于查找具有给定ID的节点\\r\\n        function recursiveFind(nodes, nameAlias) {\\r\\n            for (let i = 0; i < nodes.length; i++) {\\r\\n                if (nodes[i].nameAlias === nameAlias) {\\r\\n                    return nodes[i]; // 找到节点，返回该节点\\r\\n                }\\r\\n                if (nodes[i].children && nodes[i].children.length > 0) {\\r\\n                    const foundNode = recursiveFind(nodes[i].children, nameAlias);\\r\\n                    if (foundNode) {\\r\\n                        return foundNode; // 在子节点中找到，返回该节点\\r\\n                    }\\r\\n                }\\r\\n            }\\r\\n            return null; // 未找到节点，返回null\\r\\n        }\\r\\n\\r\\n        return recursiveFind(tree, nameAlias); // 开始递归搜索\\r\\n    }\\r\\n    */\\r\\n}\"\n                }\n            },\n            \"type\": \"one-screen-layout\",\n            \"titleVisible\": false,\n            \"vars\": [\n                {\n                    \"name\": \"formData\",\n                    \"descr\": null,\n                    \"value\": \"{}\"\n                },\n                {\n                    \"name\": \"srcFormData\",\n                    \"descr\": null,\n                    \"value\": \"{\\r\\n    id:'',\\r\\n    name:'',\\r\\n    nameAlias:'',\\r\\n    label:'',\\r\\n    abbr:'',\\r\\n    seq:0,\\r\\n    descr:'',\\r\\n    parent:'',\\r\\n    parentLabel:'',\\r\\n    isRoot:'',\\r\\n    namingRule:''\\r\\n}\"\n                },\n                {\n                    \"name\": \"isMgr\",\n                    \"descr\": null,\n                    \"value\": \"0\"\n                },\n                {\n                    \"name\": \"loading\",\n                    \"descr\": null,\n                    \"value\": \"false\"\n                },\n                {\n                    \"name\": \"archType\",\n                    \"descr\": null,\n                    \"value\": \"''\"\n                },\n                {\n                    \"name\": \"impl\",\n                    \"descr\": null,\n                    \"value\": \"''\"\n                },\n                {\n                    \"name\": \"rootKey\",\n                    \"descr\": null,\n                    \"value\": \"''\"\n                }\n            ],\n            \"models\": [],\n            \"services\": [\n                {\n                    \"name\": \"getLatestSysDataArchNode\",\n                    \"stateName\": \"\",\n                    \"descr\": \"\",\n                    \"autoLoad\": false,\n                    \"serviceId\": \"237982688712650752\",\n                    \"method\": \"POST\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    vars.data.privUser = $identity.userId;\\r\\n    vars.data.isMgr = $this.isMgr;\\r\\n    vars.data.archData = $this.formData;\\r\\n    vars.data.archType = $this.archType||null;\\r\\n    vars.data.impl = $this.impl||null;\\r\\n    $this.setLoading(true);\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    $this.setLoading(false);\\r\\n    const target = [];\\r\\n    let nodeData = {};\\r\\n    let isAdd = false;\\r\\n    if ($this.formData.id) {\\r\\n        $this.parent.treeDataForEdit.forEach(node => {\\r\\n            const targetNode = _.extend({}, node);\\r\\n            if (targetNode.id == $this.formData.id) {\\r\\n                for (var k in $this.formData) {\\r\\n                    targetNode[k] = $this.formData[k] || '';\\r\\n                }\\r\\n                targetNode.changeState = data.data;\\r\\n                targetNode.updateUser = $identity.userId;\\r\\n                nodeData = { ...targetNode };\\r\\n            }\\r\\n            target.push(targetNode);\\r\\n        });\\r\\n    } else {//新增节点\\r\\n        isAdd = true;\\r\\n        const id = $this.utils.guid();\\r\\n        const toAdd = _.extend({}, $this.formData, { id: id, key: id, changeState: 'add', updateUser: $identity.userId, priv: '1' });\\r\\n        if (!toAdd.type) {\\r\\n            toAdd.type = toAdd.name;\\r\\n        }\\r\\n        for (var k in $this.srcFormData) {\\r\\n            if (!toAdd[k]) {\\r\\n                toAdd[k] = $this.srcFormData[k];\\r\\n            }\\r\\n        }\\r\\n        $this.parent.treeDataForEdit.forEach(node => {\\r\\n            target.push(_.extend({}, node));\\r\\n        });\\r\\n        nodeData = toAdd;\\r\\n        target.push(toAdd);\\r\\n    }\\r\\n    \\r\\n    if(!isAdd) {\\r\\n        $this.parent.$refs.treeDef.treeChartRef.current.updateNodeData(nodeData, nodeData.id);\\r\\n    }else {\\r\\n        $this.parent.$refs.treeDef.treeChartRef.current.addNode(nodeData);\\r\\n    }\\r\\n    console.log('------setTreeData', target, $this.parent.$refs.treeDef.treeChartRef.current.getData());\\r\\n    $this.parent.setTreeDataForEdit(target);\\r\\n    const keyMap = {};\\r\\n    target.forEach(item => {\\r\\n        item.children = [];\\r\\n        keyMap[item.key] = item;\\r\\n    });\\r\\n    target.forEach(item => {\\r\\n        if (item.parent && keyMap[item.parent]) {\\r\\n            keyMap[item.parent].children.push(item);\\r\\n        }\\r\\n    });\\r\\n    $this.parent.setArchMap(keyMap);\\r\\n    $this.close();\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\n                    \"callback\": \"\"\n                },\n                {\n                    \"name\": \"checkCodeUniq\",\n                    \"stateName\": \"\",\n                    \"descr\": \"\",\n                    \"autoLoad\": false,\n                    \"serviceId\": \"212900060840615936\",\n                    \"method\": \"get\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    $this.setLoading(true);\\r\\n    vars.params.code = $this.formData.name;\\r\\n    vars.params.id = $this.formData.id;\\r\\n    vars.params.targetKey = 'name';\\r\\n    vars.params.parent = $this.formData.parent;\\r\\n    vars.params.archType = $this.archType||null;\\r\\n    vars.params.impl = $this.impl||null;\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    $this.setLoading(false);\\r\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\n                    \"callback\": \"\"\n                },\n                {\n                    \"name\": \"checkCodeAliasUniq\",\n                    \"stateName\": \"\",\n                    \"descr\": \"\",\n                    \"autoLoad\": false,\n                    \"serviceId\": \"212900060840615936\",\n                    \"method\": \"get\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    $this.setLoading(true);\\r\\n    vars.params.code = $this.formData.nameAlias;\\r\\n    vars.params.id = $this.formData.id;\\r\\n    vars.params.targetKey = 'nameAlias';\\r\\n    vars.params.parent = $this.formData.parent;\\r\\n    vars.params.archType = $this.archType||null;\\r\\n    vars.params.impl = $this.impl||null;\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    $this.setLoading(false);\\r\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\n                    \"callback\": \"\"\n                }\n            ],\n            \"i18n\": {\n                \"zh-CN\": \"{\\r\\n    \\\"英文名\\\":\\\"英文名\\\",\\r\\n    \\\"中文名\\\":\\\"中文名\\\",\\r\\n    \\\"顺序号\\\":\\\"顺序号\\\",\\r\\n    \\\"缩写\\\":\\\"缩写\\\",\\r\\n    \\\"描述\\\":\\\"描述\\\"\\r\\n}\",\n                \"en-US\": \"{\\r\\n    \\\"英文名\\\":\\\"Name\\\",\\r\\n    \\\"中文名\\\":\\\"Label\\\",\\r\\n    \\\"顺序号\\\":\\\"Sort\\\",\\r\\n    \\\"缩写\\\":\\\"Abbr\\\",\\r\\n    \\\"描述\\\":\\\"Descr\\\"\\r\\n}\"\n            }\n        },\n        \"children\": [\n            {\n                \"id\": \"bb4e9e893e2ace2f\",\n                \"name\": \"bb4e9e893e2ace2f\",\n                \"label\": \"页面布局\",\n                \"type\": \"flexLayout\",\n                \"options\": {\n                    \"hidden\": false,\n                    \"hiddenBindVar\": null,\n                    \"isLoading\": true,\n                    \"loading\": false,\n                    \"loadingBindVar\": \"$this.loading\",\n                    \"loadingText\": null,\n                    \"loadingTextBindVar\": null,\n                    \"showTooltip\": false,\n                    \"tooltipText\": null,\n                    \"className\": \"\",\n                    \"css\": \":root{\\r\\n    padding:20px;\\r\\n}\",\n                    \"loop\": {\n                        \"data\": null,\n                        \"dataBindVar\": null,\n                        \"var\": \"item\",\n                        \"index\": \"index\",\n                        \"key\": \"index\",\n                        \"paginationVisible\": true,\n                        \"disabled\": false,\n                        \"e