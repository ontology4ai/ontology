\": \"50%\",\n                                                        \"top\": \"15vh\",\n                                                        \"fullscreen\": false,\n                                                        \"size\": \"50%\",\n                                                        \"tabViewName\": null,\n                                                        \"tabParams\": \"\",\n                                                        \"tabKey\": \"\",\n                                                        \"tabLabel\": \"\"\n                                                    }\n                                                ],\n                                                \"actions\": []\n                                            },\n                                            \"callback\": \"function callback() {}\"\n                                        }\n                                    },\n                                    \"eventMap\": {},\n                                    \"labelFlex\": \"80px\",\n                                    \"modelName\": null,\n                                    \"min\": 3,\n                                    \"valuesBindVar\": \"$this.formData\"\n                                },\n                                \"children\": [\n                                    {\n                                        \"id\": \"8aa3e51d7f06b708\",\n                                        \"name\": \"name\",\n                                        \"label\": \"英文名\",\n                                        \"type\": \"input\",\n                                        \"options\": {\n                                            \"hidden\": false,\n                                            \"hiddenBindVar\": \"$this.formData.id == $this.rootKey || ($this.formData.parent != $this.rootKey)\",\n                                            \"isLoading\": false,\n                                            \"loading\": false,\n                                            \"loadingBindVar\": null,\n                                            \"loadingText\": null,\n                                            \"loadingTextBindVar\": null,\n                                            \"showTooltip\": false,\n                                            \"tooltip\": null,\n                                            \"tooltipBindVar\": null,\n                                            \"className\": \"\",\n                                            \"css\": \":root{}\",\n                                            \"loop\": {\n                                                \"dataBindVar\": null,\n                                                \"key\": \"index\",\n                                                \"item\": \"item\",\n                                                \"index\": \"index\",\n                                                \"pagination\": {\n                                                    \"show\": true,\n                                                    \"pageSize\": 20\n                                                },\n                                                \"isLoading\": false,\n                                                \"event\": {\n                                                    \"builtIn\": {\n                                                        \"type\": \"url\",\n                                                        \"isSingleService\": true,\n                                                        \"urlAction\": {\n                                                            \"url\": null,\n                                                            \"blank\": true\n                                                        },\n                                                        \"viewActions\": [\n                                                            {\n                                                                \"condition\": \"true\",\n                                                                \"showType\": \"modal\",\n                                                                \"viewName\": null,\n                                                                \"before\": \"function beforeCallback() {}\",\n                                                                \"width\": \"50%\",\n                                                                \"top\": \"15vh\",\n                                                                \"fullscreen\": false,\n                                                                \"size\": \"50%\",\n                                                                \"tabViewName\": null,\n                                                                \"tabParams\": \"\",\n                                                                \"tabKey\": \"\",\n                                                                \"tabLabel\": \"\"\n                                                            }\n                                                        ],\n                                                        \"actions\": []\n                                                    },\n                                                    \"callback\": \"function callback() {}\"\n                                                }\n                                            },\n                                            \"eventMap\": {},\n                                            \"span\": \"24\",\n                                            \"labelFlex\": \"\",\n                                            \"rules\": [\n                                                {\n                                                    \"type\": \"required\",\n                                                    \"message\": \"英文名不能为空\"\n                                                },\n                                                {\n                                                    \"validatorBindVar\": \"function callback(value, callback) {\\r\\n    var _nameRegExp = new RegExp(\\\"^[a-zA-Z][a-zA-Z0-9_${}]*$\\\");\\r\\n    if (!_nameRegExp.test(value)) {\\r\\n        callback('只包含数字、字母、下划线、$、{、}, 只能以字母开头!');\\r\\n    }\\r\\n}\"\n                                                },\n                                                {\n                                                    \"validatorBindVar\": \"function callback(value, callback) {\\r\\n    return $this.datasourceMap.checkCodeUniq().then(resp => {\\r\\n        if (resp.data.data.result) {\\r\\n        } else {\\r\\n            callback(resp.data.data.msg);\\r\\n        }\\r\\n    }).catch(err => {\\r\\n        console.error(err);\\r\\n        callback('节点英文名唯一性校验失败!');\\r\\n    });\\r\\n}\"\n                                                },\n                                                {}\n                                            ],\n                                            \"maxLength\": \"60\",\n                                            \"showWordLimit\": true,\n                                            \"disabledBindVar\": \"$this.formData.namingRule\"\n                                        },\n                                        \"labelBindVar\": \"$i18n('英文名')\",\n                                        \"children\": []\n                                    },\n                                    {\n                                        \"id\": \"a9c3c47f1648b4f8\",\n                                        \"name\": \"nameAlias\",\n                                        \"label\": \"英文名\",\n                                        \"type\": \"input\",\n                                        \"options\": {\n                                            \"hidden\": false,\n                                            \"hiddenBindVar\": \"$this.formData.id == $this.rootKey || $this.formData.parent == $this.rootKey\",\n                                            \"isLoading\": false,\n                                            \"loading\": false,\n                                            \"loadingBindVar\": null,\n                                            \"loadingText\": null,\n                                            \"loadingTextBindVar\": null,\n                                            \"showTooltip\": false,\n                                            \"tooltip\": null,\n                                            \"tooltipBindVar\": null,\n                                            \"className\": \"\",\n                                            \"css\": \":root{}\",\n                                            \"loop\": {\n                                                \"dataBindVar\": null,\n                                                \"key\": \"index\",\n                                                \"item\": \"item\",\n                                                \"index\": \"index\",\n                                                \"pagination\": {\n                                                    \"show\": true,\n                                                    \"pageSize\": 20\n                                                },\n                                                \"isLoading\": false,\n                                                \"event\": {\n                                                    \"builtIn\": {\n                                                        \"type\": \"url\",\n                                                        \"isSingleService\": true,\n                                                        \"urlAction\": {\n                                                            \"url\": null,\n                                                            \"blank\": true\n                                                        },\n                                                