                        \"message\": \"英文名不能为空\"\n                                                },\n                                                {\n                                                    \"validatorBindVar\": \"function callback(value, callback) {\\r\\n    var _nameRegExp = new RegExp(\\\"^[a-zA-Z][a-zA-Z0-9_${}]*$\\\");\\r\\n    if (!_nameRegExp.test(value)) {\\r\\n        callback('只包含数字、字母、下划线、$、{、}, 只能以字母开头!');\\r\\n    }\\r\\n}\"\n                                                },\n                                                {\n                                                    \"validatorBindVar\": \"function callback(value, callback) {\\r\\n    if($this.parent.treeDataForEdit.some(item=>{\\r\\n        return item.parent==$this.formData.parent&&item.nameAlias==value&&item.id!=$this.formData.id;\\r\\n    })){\\r\\n        callback('节点英文名重复');\\r\\n    }\\r\\n}\"\n                                                },\n                                                {\n                                                    \"validatorBindVar\": \"function callback(value, callback) {\\r\\n    return $this.datasourceMap.checkCodeAliasUniq().then(resp => {\\r\\n        if (resp.data.data.result) {\\r\\n        } else {\\r\\n            callback(resp.data.data.msg);\\r\\n        }\\r\\n    }).catch(err => {\\r\\n        console.error(err);\\r\\n        callback('节点英文名唯一性校验失败!');\\r\\n    });\\r\\n}\"\n                                                }\n                                            ],\n                                            \"maxLength\": \"60\",\n                                            \"showWordLimit\": true,\n                                            \"disabledBindVar\": \"$this.formData.namingRule\"\n                                        },\n                                        \"labelBindVar\": \"$i18n('英文名')\",\n                                        \"children\": []\n                                    },\n       