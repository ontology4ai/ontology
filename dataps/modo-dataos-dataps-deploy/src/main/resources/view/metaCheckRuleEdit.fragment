\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"keyWords\\\",\\n            \\\"label\\\": \\\"关键字检查\\\"\\n        }];\\n    } else if ($this.ruleForm.ruleType == \\\"attrCheck\\\") {\\n        ruleSubTypeOptions = [{\\n            \\\"value\\\": \\\"notNull\\\",\\n            \\\"label\\\": \\\"非空\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"length\\\",\\n            \\\"label\\\": \\\"长度\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"format\\\",\\n            \\\"label\\\": \\\"格式\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"content\\\",\\n            \\\"label\\\": \\\"内容检查\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"firstLetter\\\",\\n            \\\"label\\\": \\\"以字母开头\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"firstSpecChar\\\",\\n            \\\"label\\\": \\\"以指定字符开头\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"containChinese\\\",\\n            \\\"label\\\": \\\"必须包含中文名\\\"\\n        }];\\n    } else if ($this.ruleForm.ruleType == \\\"logicCheck\\\") {\\n        ruleSubTypeOptions = [{\\n            \\\"value\\\": \\\"storageField\\\",\\n            \\\"label\\\": \\\"生命周期与字段检查\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"tempLvlDs\\\",\\n            \\\"label\\\": \\\"临时层次/数据源检查\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"targetTabConsistency\\\",\\n            \\\"label\\\": \\\"程序输出表与实际配置一致\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"sourceTabConsistency\\\",\\n            \\\"label\\\": \\\"来源表检查\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"kpiTabConsistency\\\",\\n            \\\"label\\\": \\\"质量指标结果表检查\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"stepsSpecChar\\\",\\n            \\\"label\\\": \\\"SQL语句不能包含指定字符串\\\"\\n        },\\n        {\\n            \\\"value\\\": \\\"stepsExactDate\\\",\\n            \\\"label\\\": \\\"不包含指定时间日期\\\"\\n       