r\\n        $utils.message.warning('未选择团队！');\\r\\n        return;\\r\\n    }\\r\\n\\r\\n    const filters = $this.$refs.jobMonitorFilterForm.getFieldsValue();\\r\\n\\r\\n    var jobCode = '';\\r\\n    var batchTypes = '';\\r\\n\\r\\n    $this.setSearching(true)\\r\\n    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/findModoLogicJobPages',\\r\\n        {\\r\\n            params:\\r\\n            {\\r\\n                pageNum: 0,\\r\\n                pageSize: 20,\\r\\n                jobCode: jobCode,\\r\\n                batchType: batchTypes,\\r\\n                teamName: $identity.teamName,\\r\\n                taskType: 'all',\\r\\n                desc: 'desc',\\r\\n                sortColumn: 'jobCode',\\r\\n                readTeamNames: $identity.teamName\\r\\n            }\\r\\n        }).then(res => {\\r\\n            var data = res.data.data;\\r\\n            $this.setLogicJobListData(data);\\r\\n            $this.setSearching(false)\\r\\n        }).catch(function (error) {\\r\\n            console.log(error);\\r\\n            $this.setSearching(false)\\r\\n        });\\r\\n\\r\\n\\r\\n    // 获取责任人列表\\r\\n    $utils.axios.get('/_api/_/teamMember/find', {\\r\\n        params: {\\r\\n            teamName: $identity.teamName\\r\\n        }\\r\\n    }).then(function (response) {\\r\\n        var data = response.data;\\r\\n\\r\\n        $this.setMemberList(data.data);\\r\\n    }).catch(function (error) {\\r\\n        console.log(error);\\r\\n    });\\r\\n\\r\\n\\r\\n\\r\\n}\\r\\n\\r\\n\"}},\"type\":\"one-screen-layout\",\"titleVisible\":false,\"vars\":[{\"name\":\"logicJobListData\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"jobMonitorFilterFormData\",\"descr\":null,\"value\":\"[]\"},{\"name\":\"filterHistory\",\"descr\":null,\"value\":\"{}\"},{\"name\":\"memberList\",\"descr\":\"责任人列表\",\"value\":\"[]\"},{\"name\":\"searching\",\"descr\":null,\"value\":\"false\"}],\"models\":[],\"services\":[{\"name\":\"refreshListData\",\"stateName\":\