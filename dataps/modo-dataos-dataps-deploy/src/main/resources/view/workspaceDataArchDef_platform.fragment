\n        return;\\r\\n    }\\r\\n    if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.hasChildren) {\\r\\n        $utils.modal.confirm({\\r\\n            title: '警告',\\r\\n            content: '确认删除该结点及其下属结点吗？',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            onOk: () => {\\r\\n                const keyMap = {};\\r\\n                $this.treeData.forEach(item => {\\r\\n                    item.children = [];\\r\\n                    keyMap[item.key] = item;\\r\\n                });\\r\\n                $this.treeData.forEach(item => {\\r\\n                    if (item.parent && keyMap[item.parent]) {\\r\\n                        keyMap[item.parent].children.push(item);\\r\\n                    }\\r\\n                });\\r\\n                const toRemove = [$this.$refs.treeDef.treeChartRef.current.getSelection().data.key];\\r\\n                const getChildren = function (children, keyList) {\\r\\n                    children.forEach(item => {\\r\\n                        keyList.push(item.key);\\r\\n                        if (item.children && item.children.length > 0) {\\r\\n                            getChildren(item.children, keyList);\\r\\n                        }\\r\\n                    });\\r\\n                }\\r\\n                getChildren(keyMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children, toRemove);\\r\\n                $this.treeData = $this.treeData.filter(item => {\\r\\n                    return toRemove.indexOf(item.key) == -1;\\r\\n                });\\r\\n                $this.$refs.treeDef.treeChartRef.current.loadData($this.treeData);\\r\\n            }\\r\\n        });\\r\\n    } else {\\r\\n        $utils.modal.confirm({\\r\\n            title: '警告',\\r\\n            content: '确认删除该结点吗？',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            onOk: () => {\\r\\n            