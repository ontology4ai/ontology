beginDateArgs\\\": data.beginDateArgs,\\n            \\\"endDateArgs\\\": endDateArgs,\\n            \\\"priority\\\": data.priority,\\n            \\\"batchType\\\": data.batchType,\\n            \\\"isSkipDepend\\\": data.isSkipDepend,\\n            \\\"teamName\\\": $identity.teamName,\\n            \\\"userId\\\": $identity.userId\\n        })\\n    };\\n    console.log('redoData, rowType', dataArr,)\\n    let isRequired_ = filtersEndDateArgs(dataArr);\\n    console.log('isRequired-----', isRequired_);\\n    if (!isRequired_) {//符合要求的情况下才能发送请求\\n        $this.setIsSpin(true);\\n        $utils.axios.defaults.timeout = 600000;\\n        $utils.axios.post('/oneplusn-federation/open/dataflow/monitor/manualTask', dataArr).then(res => {\\n            $this.close();\\n            $this.setIsSpin(false);\\n            if (res.data.success === true) {\\n                $utils.message.success('手工任务成功！')\\n\\n                if ($this.operType === 'logic') {\\n                    const filters = $this.parent.$refs.jobMonitorFilterForm.getFieldsValue();\\n                    var current = $this.parent.$refs.logicJobMonitorTab.state.current;\\n                    var pageSize = $this.parent.$refs.logicJobMonitorTab.state.pageSize;\\n\\n                    var jobLabel = '';\\n                    var batchTypes = 'daily';\\n                    var batchNo = '';\\n                    var memberName = '';\\n                    var runState = '';\\n                    var jobType = '';\\n                    var priority = '';\\n                    var runStateNum = 1;\\n                    var tag = '';\\n                    var brokerWorkgroup = '';\\n                    var batchNoZone = '';\\n\\n                    for (var f in filters) {\\n                        if (f == 'jobLabel' && filters[f]) {\\n                            jobLabel = filters[f];\\n                        }\\n                        if (f == 'batchTypes' && filters[f]) {\\n\\n                            batchTypes = filters[f].join(',');\\n                        }\\n                        if (f == 'batchNoZone' && filters[f]) {\\n                            batchNo = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n                            batchNoZone = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n                        }\\n                        if (f == 'batchNo' && filters[f] && batchNoZone == '') {\\n                            batchNo = filters[f].replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\");\\n                        }\\n                        if (f == 'dUser' && filters[f]) {\\n                            memberName = filters[f];\\n                        }\\n                        if (f == 'runState' && filters[f]) {\\n                            runState = filters[f];\\n                        }\\n                        if (f == 'jobType' && filters[f]) {\\n                            jobType = filters[f];\\n                        }\\n                        if (f == 'priority' && filters[f]) {\\n                            priority = filters[f];\\n                        }\\n                        //runStateNum: true\\n                        if (f == 'runStateNum' && filters[f]) {\\n                            if (filters[f] == true) {\\n                                runStateNum = 0;\\n\\n                            } else if (filters[f] == false) {\\n                                runStateNum = 1;\\n                            }\\n\\n                        }\\n                        if (f == 'tag' && filters[f]) {\\n                            tag = filters[f];\\n                        }\\n                        if (f == 'brokerWorkgroup' && filters[f]) {\\n                            brokerWorkgroup = filters[f];\\n                        }\\n                        // if (f == 'cycle' && filters[f]) {\\n                        //     vars.params.cycle = '~%' + filters[f] + '%'\\n                        // }\\n                    }\\n\\n                    let state = '';\\n                    let queryType = '0';\\n                    if ($this.parent.jobState2.length == 0) {\\n                        if ($this.parent.jobState.indexOf('ALL') == -1) {\\n                            state = $this.parent.jobState.join(',');\\n                            queryType = '0';\\n\\n                        }\\n                    } else {\\n                        if ($this.parent.jobState2.indexOf('ALL') == -1) {\\n                            state = $this.parent.jobState2.join(',');\\n                            queryType = '1';\\n                        }\\n                    }\\n\\n\\n                    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/getStatisticsCollectData',\\n                        {\\n                            params:\\n                            {\\n                                jobLabel: jobLabel,\\n                                batchTypes: batchTypes,\\n                                batchNo: batchNo,\\n                                teamName: $identity.teamName,\\n                                memberName: memberName,\\n                                runState: runState,\\n                                jobType: jobType,\\n                                priority: priority,\\n                                runStateNum: runStateNum,\\n                                tag: tag,\\n                                brokerWorkgroup: brokerWorkgroup\\n                            }\\n                        }).then(res => {\\n                            $this.setJobS(res.data.data);\\n                            if (res.data.data.jtFinish != null && res.data.data.jtSum != null) {\\n                                $this.parent.setJobSuccessRate(Math.round((res.data.data.jtFinish / res.data.data.jtSum) * 100))\\n                            } else {\\n                                $this.parent.setJobSuccessRate(0);\\n                            }\\n\\n\\n                        }).catch(function (error) {\\n                            $this.setIsSpin(false)\\n                            console.log(error);\\n                        });\\n\\n\\n                    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/v2/getStatisticsTableData',\\n                        {\\n                            params:\\n                            {\\n                                pageNum: current - 1,\\n                                pageSize: pageSize,\\n                                jobLabel: jobLabel,\\n                                batchTypes: batchTypes,\\n                                batchNo: batchNo,\\n                                teamName: $identity.teamName,\\n                                taskType: 'all',\\n                                desc: 'desc',\\n                                sortColumn: 'jobCode',\\n                                memberName: memberName,\\n                                runState: runState,\\n                                jobType: jobType,\\n                                priority: priority,\\n                                readTeamNames: $identity.teamName,\\n                                jobState: state,\\n                                queryType: queryType,\\n                                runStateNum: runStateNum,\\n                                tag: tag,\\n                                brokerWorkgroup: brokerWorkgroup\\n                            }\\n                        }).then(res => {\\n                            var data = res.data.data;\\n                            $this.parent.setLogicJobTriggerListData(data);\\n\\n                        }).catch(function (error) {\\n                            $this.setIsSpin(false)\\n                            console.log(error);\\n                        });\\n                } else {\\n                    if ($this.parent.parentCode != '') {\\n                        var current = $this.parent.$refs.job_trigger_tab.state.current;\\n                        var pageSize = $this.parent.$refs.job_trigger_tab.state.pageSize;\\n                        $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/getTableData',\\n                            {\\n                                params:\\n                                {\\n                                    pageNum: current - 1,\\n                                    pageSize: pageSize,\\n                                    parentCode: $this.parent.parentCode,\\n                                    batchTypes: $this.parent.batchType,\\n                                    batchNo: $this.parent.batchNo,\\n                                    teamName: $identity.teamName,\\n                                    taskType: 'all',\\n                                    desc: 'desc',\\n                                    sortColumn: 'jobCode',\\n                                    readTeamNames: $identity.teamName,\\n                                    runStateNum: $this.parent.runStateNum\\n                                }\\n                            }).then(res => {\\n                                var data = res.data.data;\\n\\n                                $this.parent.setJobTriggerListData(data);\\n\\n                            }).catch(function (error) {\\n                                $this.setIsSpin(false)\\n                                console.log(error);\\n                            });\\n                    }\\n                }\\n            } else {\\n                $utils.message.error('手工任务失败！' + res.data.msg)\\n            }\\n\\n\\n        }).catch(function (error) {\\n            $this.setIsSpin(false)\\n            console.log(error);\\n        });\\n    }\\n\\n}\\nfunction filtersEndDateArgs(redoData) {\\n    \\n    console.log('redoData', redoData)\\n    //beginDateArgs 必填  endDateArgs必填，填写的日期不能大于当前的日期\\n    // let rowType = 'minutely';//minutely 分钟 hourly 小时  daily 日 monthly 月\\n    //$utils.moment\\n    let isRequired = false;\\n    const time = new Date(new Date().getTime());\\n    // let value = '';\\n    // switch (rowType) {\\n    //     case 'minutely':\\n    //         const minute = new Date(new Date().getTime())\\n    //         value = $utils.moment(minute).format('yyyyMMDDHHmm')\\n    //         break;\\n    //     case 'hourly':\\n    //         const hour = new Date(new Date().getTime())\\n    //         value = $utils.moment(hour).format('yyyyMMDDHH')\\n    //         break;\\n    //     case 'daily':\\n    //         const day = new Date(new Date().getTime())\\n    //         value = $utils.moment(day).format('yyyyMMDD')\\n    //         break;\\n    //     case 'monthly':\\n    //         const month = new Date(new Date().getTime())\\n    //         value = $utils.moment(month).format('yyyyMM')\\n    //         break;\\n    //     default:\\n    //         value = ''\\n    // }\\n    for (let item of redoData) {\\n        console.log('item', item.endDateArgs)\\n        if ((item.beginDateArgs && item.beginDateArgs != '') && (item.endDateArgs && item.endDateArgs != '')) {\\n            if (item.beginDateArgs) {\\n                let beginDateArg = '';\\n                let diff = null;\\n                //输入时间 2023 05 19 10 23 \\n                let beginDateArgs_ = item.beginDateArgs || '';\\n                if (item.batchType == 'minutely' && beginDateArgs_.length == 12) {\\n                    let value = $utils.moment(time).format('yyyyMMDDHHmm');\\n                    beginDateArg = $utils.moment(beginDateArgs_).format('yyyyMMDDHHmm');\\n                    diff = $utils.moment(value).diff($utils.moment(beginDateArg), 'minutely')\\n                } else if (item.batchType == 'hourly' && beginDateArgs_.length == 10) {\\n                    let value = $utils.moment(time).format('yyyyMMDDHH')\\n                    beginDateArg = $utils.moment(beginDateArgs_).format('yyyyMMDDHH');\\n                    diff = $utils.moment(value).diff($utils.moment(beginDateArg), 'hourly')\\n                } else if (item.batchType == 'daily' && beginDateArgs_.length == 8) {\\n                    let value = $utils.moment(time).format('yyyyMMDD')\\n                    beginDateArg = $utils.moment(beginDateArgs_).format('yyyyMMDD');\\n                    diff = $utils.moment(value).diff($utils.moment(beginDateArg), 'daily')\\n                } else if (item.batchType == 'monthly' && beginDateArgs_.length == 6) {\\n                    let value = $utils.moment(time).format('yyyyMM')\\n                    beginDateArg = $utils.moment(beginDateArgs_).format('yyyyMM');\\n                    diff = $utils.moment(value).diff($utils.moment(beginDateArg), 'monthly');\\n                } else {\\n                    $utils.notification.error({\\n                        title: 'Error',\\n                        content: '请检查' + item.jobCode + '日期批次格式是否正确!',\\n                    })\\n                    isRequired = true;\\n                    break;\\n                }\\n                console.log('表格输入的时间', beginDateArg, beginDateArgs_.length);\\n                console.log('diff1', diff);\\n                if (diff < 0) {//等于0日期相等,大于0符合需求,小于0输入的时间大于当前时间，\\n                    $utils.notification.error({\\n                        title: 'Error',\\n                        content: item.jobCode + ',日期批次不能大于当前日期!',\\n                    })\\n                    isRequired = true;\\n                    break;\\n                }\\n\\n\\n            }\\n            let endDateArgs = '';\\n            let diff = null;\\n            //输入时间 2023 05 19 10 23 \\n            let endDateArgs_ = item.endDateArgs || '';\\n            if (item.batchType == 'minutely' && endDateArgs_.length == 12) {\\n                let value = $utils.moment(time).format('yyyyMMDDHHmm');\\n                endDateArgs = $utils.moment(endDateArgs_).format('yyyyMMDDHHmm');\\n                diff = $utils.moment(value).diff($utils.moment(endDateArgs), 'minutely')\\n            } else if (item.batchType == 'hourly' && endDateArgs_.length == 10) {\\n                let value = $utils.moment(time).format('yyyyMMDDHH')\\n                endDateArgs = $utils.moment(endDateArgs_).format('yyyyMMDDHH');\\n                console.log('hourly-endDateArgs', endDateArgs)\\n                diff = $utils.moment(value).diff($utils.moment(endDateArgs), 'hourly')\\n            } else if (item.batchType == 'daily' && endDateArgs_.length == 8) {\\n                let value = $utils.moment(time).format('yyyyMMDD')\\n                endDateArgs = $utils.moment(endDateArgs_).format('yyyyMMDD');\\n                diff = $utils.moment(value).diff($utils.moment(endDateArgs), 'daily')\\n            } else if (item.batchType == 'monthly' && endDateArgs_.length == 6) {\\n                let value = $utils.moment(time).format('yyyyMM')\\n                endDateArgs = $utils.moment(endDateArgs_).format('yyyyMM');\\n                diff = $utils.moment(value).diff($utils.moment(endDateArgs), 'monthly');\\n            } else {\\n                $utils.notification.error({\\n                    title: 'Error',\\n                    content: '请检查' + item.jobCode + '日期批次格式是否正确!',\\n                })\\n                isRequired = true;\\n                break;\\n            }\\n            console.log('表格输入的时间', endDateArgs, endDateArgs_.length);\\n            console.log('diff1', diff);\\n            if (diff < 0) {//等于0日期相等,大于0符合需求,小于0输入的时间大于当前时间，\\n                $utils.notification.error({\\n                    title: 'Error',\\n                    content: item.jobCode + ',日期批次不能大于当前日期!',\\n                })\\n                isRequired = true;\\n                break;\\n            }\\n        } else {\\n            $utils.notification.error({\\n                title: 'Error',\\n                content: item.jobCode + ',日期批次不能为空!',\\n            })\\n            isRequired = true;\\n            break;\\n        }\\n    }\\n    return isRequired;\\n\\n}\\n\\n\\n\"}},\"type\":\"primary\"},\"defaultOptions\":{\"css\":\":root {\\n\\n}\"},\"children\":[]}]}]}]}]}]","inputVars":null,"viewPlugins":null,"version":133,"createUser":"xiacj3","createDt":null,"lastupd":null,"updateUser":null,"digest":null,"versionInfo":"","appName":"dataps","createUserName":null}