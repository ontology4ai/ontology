{\n                    \"builtIn\": {\n                        \"type\": \"url\",\n                        \"isSingleService\": true,\n                        \"urlAction\": {\n                            \"url\": null,\n                            \"blank\": true\n                        },\n                        \"viewActions\": [\n                            {\n                                \"condition\": \"true\",\n                                \"showType\": \"modal\",\n                                \"viewName\": null,\n                                \"before\": \"function beforeCallback() {}\",\n                                \"width\": \"50%\",\n                                \"top\": \"15vh\",\n                                \"fullscreen\": false,\n                                \"size\": \"50%\",\n                                \"tabViewName\": null,\n                                \"tabParams\": \"\",\n                                \"tabKey\": \"\",\n                                \"tabLabel\": \"\"\n                            }\n                        ],\n                        \"actions\": []\n                    },\n                    \"callback\": \"function callback() {}\"\n                }\n            },\n            \"eventMap\": {\n                \"onMount\": {\n                    \"builtIn\": {\n                        \"type\": \"url\",\n                        \"isSingleService\": true,\n                        \"urlAction\": {\n                            \"url\": null,\n                            \"blank\": true\n                        },\n                        \"viewActions\": [\n                            {\n                                \"condition\": \"true\",\n                                \"showType\": \"modal\",\n                                \"viewName\": null,\n                                \"before\": \"function beforeCallback() {}\",\n                                \"width\": \"50%\",\n                                \"top\": \"15vh\",\n                                \"fullscreen\": false,\n                                \"size\": \"50%\",\n                                \"tabViewName\": null,\n                                \"tabParams\": \"\",\n                                \"tabKey\": \"\",\n                                \"tabLabel\": \"\"\n                            }\n                        ],\n                        \"actions\": []\n                    },\n                    \"callback\": \"function callback() {\\r\\n    if(!$this.parent&&!$this.workspaceId) {\\r\\n        $this.workspaceId = 'testWorkspaceId';\\r\\n    }\\r\\n    if ($this.workspaceId) {\\r\\n        $this.datasourceMap.getDataArchDefTree();\\r\\n    } else {\\r\\n        $utils.modal.confirm({\\r\\n            title: '警告',\\r\\n            content: '工作空间ID不允许为空！',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            onOk: () => {\\r\\n            }\\r\\n        });\\r\\n    }\\r\\n}\"\n                }\n            },\n            \"type\": \"one-screen-layout\",\n            \"titleVisible\": false,\n            \"vars\": [\n                {\n                    \"name\": \"treeData\",\n                    \"descr\": \"工作空间架构树数据\",\n                    \"value\": \"[]\"\n                },\n                {\n                    \"name\": \"loading\",\n                    \"descr\": null,\n                    \"value\": \"false\"\n                },\n                {\n                    \"name\": \"srcArchMap\",\n                    \"descr\": null,\n                    \"value\": \"{}\"\n                },\n                {\n                    \"name\": \"archMap\",\n                    \"descr\": null,\n                    \"value\": \"{}\"\n                },\n                {\n                    \"name\": \"filterForm\",\n                    \"descr\": null,\n                    \"value\": \"{}\"\n                },\n                {\n                    \"name\": \"cascaderOptions\",\n                    \"descr\": null,\n                    \"value\": \"[]\"\n                }\n            ],\n            \"models\": [],\n            \"services\": [\n                {\n                    \"name\": \"getDataArchDefTree\",\n                    \"stateName\": \"treeData\",\n                    \"descr\": \"\",\n                    \"autoLoad\": false,\n                    \"serviceId\": \"176049917920980992\",\n                    \"method\": \"GET\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": [],\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    $this.setLoading(true);\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    const map = {};\\r\\n    const srcMap = {};\\r\\n    const roots = [];\\r\\n    const parentPrivs = [];\\r\\n    data.data.forEach(item => {\\r\\n        if(!item.descr){\\r\\n            item.descr = '';\\r\\n        }\\r\\n        srcMap[item.key] = _.extend({}, item);\\r\\n        if(item.key&&!item.id){\\r\\n            item.id = item.key;\\r\\n        }\\r\\n        item.priv='1';\\r\\n        item.children = [];\\r\\n        map[item.key] = item;\\r\\n        if (item.parent&&item.parent=='root') {\\r\\n            roots.push(item);\\r\\n        }\\r\\n        if(item.priv=='1') {\\r\\n            parentPrivs.push(item);\\r\\n        }\\r\\n        if(!item.parent){\\r\\n            delete item.parent;\\r\\n        }\\r\\n    });\\r\\n    $this.setSrcArchMap(map);\\r\\n    $this.setArchMap(map);\\r\\n    data.data.forEach(item => {\\r\\n        if (map[item.parent]) {\\r\\n            map[item.parent].children.push(item);\\r\\n        }\\r\\n    });\\r\\n    const loadChildrenPriv = function(arr) {\\r\\n        arr.forEach(item=>{\\r\\n            item.priv = '1';\\r\\n            if(item.children&&item.children.length>0){\\r\\n                loadChildrenPriv(item.children);\\r\\n            }\\r\\n        })\\r\\n    }\\r\\n    parentPrivs.forEach(item=>{\\r\\n        if(item.children&&item.children.length>0){\\r\\n            loadChildrenPriv(item.children);\\r\\n        }\\r\\n    });\\r\\n    $this.setLoading(false);\\r\\n    $this.setCascaderOptions(data.data.filter(item=>{\\r\\n        return item.parent&&item.parent=='root';\\r\\n    }));\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\n                    \"callback\": \"\"\n                },\n                {\n                    \"name\": \"saveDataArch\",\n                    \"stateName\": \"\",\n                    \"descr\": \"\",\n                    \"autoLoad\": false,\n                    \"serviceId\": \"176053281901219840\",\n                    \"method\": \"POST\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    vars.data.archData = $this.treeData.filter(item=>{\\r\\n        return item.changeState!='delete';\\r\\n    });\\r\\n    vars.data.updateUser = $identity.userId;\\r\\n    $this.setLoading(true);\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    $this.setLoading(false);\\r\\n    $utils.notification.success({\\r\\n        title: '成功',\\r\\n        content: '数据编目保存成功！',\\r\\n    });\\r\\n    $this.datasourceMap.syncLvlToDatago();\\r\\n    $this.datasourceMap.getDataArchDefTree();\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n     $this.setLoading(false);\\r\\n     $utils.notification.error({\\r\\n        title: '失败',\\r\\n        content: '数据编目保存失败！',\\r\\n    });\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\n                    \"callback\": \"\"\n                },\n                {\n                    \"name\": \"syncLvlToDatago\",\n                    \"stateName\": \"\",\n                    \"descr\": \"同步层次信息到datago\",\n                    \"autoLoad\": false,\n                    \"serviceId\": \"192649463703851008\",\n                    \"method\": \"POST\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    vars.data.lvls = $this.treeData.filter(item=>{\\r\\n        return item.changeState!='delete'&&item.type=='lvl'&&item.name!='lvl';\\r\\n    });\\r\\n    vars.data.lvls.forEach(item=>{\\r\\n        item.version = \\\"1\\\";\\r\\n    });\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\n                    \"callback\": \"\"\n                }\n            ],\n            \"i18n\": {\n                \"zh-CN\": \"{\\r\\n    \\\"数据编目\\\":\\\"数据编目\\\",\\r\\n    \\\"历史版本\\\":\\\"历史版本\\\",\\r\\n    \\\"编辑\\\":\\\"编辑\\\",\\r\\n    \\\"授权\\\":\\\"授权\\\",\\r\\n    \\\"输入节点关键字\\\":\\\"输入节点关键字\\\",\\r\\n    \\\"数据编目编辑\\\":\\\"数据编目编辑\\\"\\r\\n}\",\n                \"en-US\": \"{\\r\\n    \\\"数据编目\\\":\\\"Catalog Management\\\",\\r\\n    \\\"历史版本\\\":\\\"History\\\",\\r\\n    \\\"编辑\\\":\\\"Edit\\\",\\r\\n    \\\"授权\\\":\\\"Auth\\\",\\r\\n    \\\"输入节点关键字\\\":\\\"KeyWord\\\",\\r\\n    \\\"数据编目编辑\\\":\\\