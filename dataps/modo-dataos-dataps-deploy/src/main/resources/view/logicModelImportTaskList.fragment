s[f]){\\r\\n            vars.params[f] = filters[f];\\r\\n        }\\r\\n    }\\r\\n    if(!vars.params||vars.params.limit==undefined){\\r\\n        vars.params.limit = $this.limit;\\r\\n    }\\r\\n    if(!vars.params||vars.params.offset==undefined){\\r\\n        vars.params.offset = $this.offset;\\r\\n    }\\r\\n    vars.params.teamName = $identity.teamName;\\r\\n    vars.params.type = 'import';\\r\\n    $this.setLoading(true);\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    $this.setLoading(false);\\r\\n    data.data.data.content.forEach(item=>{\\r\\n        item.operType = item.type=='import'?'导入':'导出';\\r\\n        item.importEndTime = $this.utils.moment(new Date(item.importEndTime)).format('yyyy-MM-DD HH:mm:ss');\\r\\n        if(item.state=='uploading'){\\r\\n            item.stateLabel = '导入中';\\r\\n        }else if(item.state=='finish'){\\r\\n            item.stateLabel = '完成';\\r\\n        }else if(item.state=='waiting'){\\r\\n            item.stateLabel = '等待';\\r\\n        }else if(item.state=='error'){\\r\\n            item.stateLabel = '失败';\\r\\n        }else if(item.state=='checking'){\\r\\n            item.stateLabel = '校验模板中';\\r\\n        }else if(item.state=='checkingData'){\\r\\n            item.stateLabel = '校验数据中';\\r\\n        }else if(item.state=='stoping'){\\r\\n            item.stateLabel = '终止中';\\r\\n        }else if(item.state=='stoped'){\\r\\n            item.stateLabel = '已终止';\\r\\n        }else if(item.state=='exportTemp'){\\r\\n            item.stateLabel = '导出文件';\\r\\n        }else if(item.state=='uploadTemp'){\\r\\n            item.stateLabel = '上传文件';\\r\\n        }else if(item.state=='deleteTemp'){\\r\\n            item.stateLabel = '清理缓存';\\r\\n        }\\r\\n    });\\r\\n    return data.data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n}\",\n                    \"callback\": \"\"\n                },\n