{"id":"dataps-139382522042880039","module":"236063466669670400","moduleLabel":null,"name":"tabDevCheckResult","label":"模型开发质量检查结果","descr":"模型开发质量检查结果","type":"fragment","state":"1","parameters":"[{\"id\":\"0\",\"name\":\"0\",\"label\":\"页面\",\"type\":\"view\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltipText\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"data\":null,\"dataBindVar\":null,\"var\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onMount\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\r\\n    if ($this.checkTabId) {\\r\\n        $this.datasourceMap.getCheckResult();\\r\\n    } else {\\r\\n        $this.parent.datasourceMap.getSrcData(saveData => {\\r\\n            var indexDataTypeMap = {};\\r\\n            for (var index in saveData.datapsLogicModelFieldDraftList) {\\r\\n                var field = saveData.datapsLogicModelFieldDraftList[index];\\r\\n                if (field.length) {\\r\\n                    field.length = field.length + '';\\r\\n                }\\r\\n                if (field.precisionVal) {\\r\\n                    field.precisionVal = field.precisionVal + '';\\r\\n                }\\r\\n                if (field.dataType) {\\r\\n                    indexDataTypeMap[index] = field.dataType;\\r\\n                }\\r\\n            };\\r\\n            $this.setIndexDataTypeMap(indexDataTypeMap);\\r\\n            $this.setCheckRow(saveData);\\r\\n            $this.datasourceMap.devCheck();\\r\\n        });\\r\\n    }\\r\\n}\"}},\"type\":\"one-screen-layout\",\"titleVisible\":false,\"vars\":[{\"name\":\"checkRow\",\"descr\":null,\"value\":\"{\\r\\n    checkDetail:{\\r\\n        tableDtl:[],\\r\\n        fieldDtl:[],\\r\\n        fieldStdDtl:[]\\r\\n    }\\r\\n}\"},{\"name\":\"loading\",\"descr\":null,\"value\":\"false\"},{\"name\":\"indexDataTypeMap\",\"descr\":null,\"value\":\"{}\"},{\"name\":\"recNameMap\",\"descr\":null,\"value\":\"{}\"},{\"name\":\"recLabelMap\",\"descr\":null,\"value\":\"{}\"},{\"name\":\"checkTabId\",\"descr\":null,\"value\":\"''\"}],\"models\":[],\"services\":[{\"name\":\"devCheck\",\"stateName\":\"\",\"descr\":\"\",\"autoLoad\":false,\"serviceId\":\"179297810120495104\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    vars.data = $this.checkRow;\\r\\n    vars.data.name = vars.data.modelName;\\r\\n    vars.data.tabName = vars.data.modelName;\\r\\n    vars.data.tabLabel = vars.data.modelLabel;\\r\\n    vars.data.tabDescr = vars.data.modelDescr;\\r\\n    vars.data.cycleType = vars.data.updateCycle;\\r\\n    if(vars.data.lvlArr&&vars.data.lvlArr.length>0){\\r\\n        vars.data.lvl = vars.data.lvlArr[vars.data.lvlArr.length-1];\\r\\n    }\\r\\n    vars.data.goMetaTabFieldList = [];\\r\\n    vars.data.datapsLogicModelFieldDraftList.forEach(field=>{\\r\\n        const item = _.extend({}, field);\\r\\n        vars.data.goMetaTabFieldList.push(item);\\r\\n        item.fieldSensLvl = item.sensLvl;\\r\\n        if(!$this.parent.lengthPrecisionLimit.lengthRequire||($this.parent.lengthPrecisionLimit.lengthRequire&&$this.parent.lengthPrecisionLimit.lengthRequire.indexOf(item.dataType)==-1)){\\r\\n            if(!item.length){\\r\\n                item.length = 'notRequire';\\r\\n            }\\r\\n        }\\r\\n        if(!$this.parent.lengthPrecisionLimit.precisionRequire||($this.parent.lengthPrecisionLimit.precisionRequire&&$this.parent.lengthPrecisionLimit.precisionRequire.indexOf(item.dataType)==-1)){\\r\\n            if(!item.precisionVal){\\r\\n                item.precisionVal = 'notRequire';\\r\\n            }\\r\\n        }\\r\\n    });\\r\\n    $this.setLoading(true);\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    $this.setLoading(false);\\r\\n    data.data.tableDtl.forEach(tdt => {\\r\\n        if (tdt.checkResult == 'ok') {\\r\\n            tdt.checkResult = '通过';\\r\\n        } else if (tdt.checkResult == 'warning') {\\r\\n            tdt.checkResult = '警告';\\r\\n        } else if (tdt.checkResult == 'error') {\\r\\n            tdt.checkResult = '不通过';\\r\\n        }\\r\\n    });\\r\\n    // data.data.tableDtl = data.data.tableDtl.filter(item => {\\r\\n    //     if (item.funcCode == 'attrCheckNotNull' && (item.funcPara.indexOf('label.value') > -1 || item.funcPara.indexOf('name.value') > -1)) {\\r\\n    //         return false;\\r\\n    //     }\\r\\n    //     return true;\\r\\n    // });\\r\\n    for (var i = 0; i < data.data.fieldDtl.length; i++) {\\r\\n        if (data.data.fieldDtl[i].checkResult == 'ok') {\\r\\n            data.data.fieldDtl[i].checkResult = '通过';\\r\\n        } else if (data.data.fieldDtl[i].checkResult == 'warning') {\\r\\n            data.data.fieldDtl[i].checkResult = '警告';\\r\\n        } else if (data.data.fieldDtl[i].checkResult == 'error') {\\r\\n            data.data.fieldDtl[i].checkResult = '不通过';\\r\\n        }\\r\\n        var sucLen = 0;\\r\\n        for (var j = 0; j < data.data.fieldDtl[i].fieldDtl.length; j++) {\\r\\n            if (data.data.fieldDtl[i].fieldDtl[j].checkResult == 'ok') {\\r\\n                sucLen++;\\r\\n                data.data.fieldDtl[i].fieldDtl[j].checkResult = '通过';\\r\\n            } else if (data.data.fieldDtl[i].fieldDtl[j].checkResult == 'warning') {\\r\\n                data.data.fieldDtl[i].fieldDtl[j].checkResult = '警告';\\r\\n            } else if (data.data.fieldDtl[i].fieldDtl[j].checkResult == 'error') {\\r\\n                data.data.fieldDtl[i].fieldDtl[j].checkResult = '不通过';\\r\\n            }\\r\\n        }\\r\\n        data.data.fieldDtl[i].fieldCheckDescr = sucLen + '/' + data.data.fieldDtl[i].fieldDtl.length;\\r\\n    }\\r\\n    // data.data.fieldDtl = data.data.fieldDtl.filter(item => {\\r\\n    //     return !item.fieldDtl.some(jtem => {\\r\\n    //         if (jtem.funcCode == 'attrCheckNotNull' && (jtem.funcPara.indexOf('label.value') > -1 || jtem.funcPara.indexOf('name.value') > -1)) {\\r\\n    //             return true;\\r\\n    //         }\\r\\n    //         return false;\\r\\n    //     })\\r\\n    // });\\r\\n    data.data.fieldDtl.forEach(item => {\\r\\n        for (var index in item.fieldDtl) {\\r\\n            var jtem = item.fieldDtl[index];\\r\\n            if (jtem.funcCode == 'attrCheckNotNull' && jtem.funcPara.indexOf('length.value') > -1) {\\r\\n                if (jtem.checkDescr.indexOf('notRequire') > -1) {\\r\\n                    if ($this.indexDataTypeMap[index]) {\\r\\n                        jtem.checkDescr = $this.indexDataTypeMap[index] + '长度允许空';\\r\\n                    } else {\\r\\n                        jtem.checkDescr = '长度允许空';\\r\\n                    }\\r\\n                }else if(jtem.checkDescr=='被检查的值为空!'&&$this.indexDataTypeMap[index]){\\r\\n                    jtem.checkDescr = $this.indexDataTypeMap[index] + '长度不允许为空';\\r\\n                }\\r\\n            }\\r\\n            if (jtem.funcCode == 'attrCheckNotNull' && jtem.funcPara.indexOf('precisionVal.value') > -1) {\\r\\n                if (jtem.checkDescr.indexOf('notRequire') > -1) {\\r\\n                    if ($this.indexDataTypeMap[index]) {\\r\\n                        jtem.checkDescr = $this.indexDataTypeMap[index] + '精度允许空';\\r\\n                    } else {\\r\\n                        jtem.checkDescr = '精度允许空';\\r\\n                    }\\r\\n                }else if(jtem.checkDescr=='被检查的值为空!'&&$this.indexDataTypeMap[index]){\\r\\n                    jtem.checkDescr = $this.indexDataTypeMap[index] + '精度不允许为空';\\r\\n                }\\r\\n            }\\r\\n        };\\r\\n    });\\r\\n    const target = _.extend({}, $this.checkRow);\\r\\n    target.checkDetail = data.data;\\r\\n    if (data.data.sum.checkResult == 'OK') {\\r\\n        target.checkResult = '通过';\\r\\n    } else if (data.data.sum.checkResult == 'WARNING') {\\r\\n        target.checkResult = '警告';\\r\\n    } else {\\r\\n        target.checkResult = '不通过';\\r\\n    }\\r\\n    $this.setCheckRow(target);\\r\\n    $this.datasourceMap.recommend();\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n}\",\"callback\":\"\"},{\"name\":\"recommend\",\"stateName\":\"\",\"descr\":\"标准字段推荐\",\"autoLoad\":false,\"serviceId\":\"179197626464129024\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    const toRecData = [];\\r\\n    $this.checkRow.datapsLogicModelFieldDraftList.forEach(item => {\\r\\n        toRecData.push({\\r\\n            fieldName:item.fieldName,\\r\\n            fieldLabel:item.fieldLabel,\\r\\n            dataType:item.dataType\\r\\n        });\\r\\n    });\\r\\n    vars.data = {fields:toRecData};\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    const recData = [];\\r\\n    for (let i = 0; i < data.data.length; i++) {\\r\\n        let item = data.data[i];\\r\\n        const row = {\\r\\n            dataType: item.dataType,\\r\\n            useStd:'0',\\r\\n            fieldName: item.fieldName,\\r\\n            fieldLabel: item.fieldLabel,\\r\\n            stdCode:item.stdCode,\\r\\n            nameOptions: [],\\r\\n            labelOptions: [],\\r\\n            recName: '--',\\r\\n            recLabel: '--',\\r\\n            isMatch: '否'\\r\\n        };\\r\\n        if (item.nameIsStd) {\\r\\n            row.nameOptions.push({\\r\\n                label: item.fieldName + '(已匹配字段标准)',\\r\\n                value: item.fieldName\\r\\n            });\\r\\n            row.labelOptions.push({\\r\\n                label: item.recLabel + '(字段标准推荐)',\\r\\n                value: item.recLabel\\r\\n            });\\r\\n        }\\r\\n        //  else if (item.splitNameIsStd) {\\r\\n        //     row.nameOptions.push({\\r\\n        //         label: item.fieldName + '(已匹配词汇标准)',\\r\\n        //         value: item.fieldName\\r\\n        //     });\\r\\n        //     row.labelOptions.push({\\r\\n        //         label: item.recLabel + '(词汇标准推荐)',\\r\\n        //         value: item.recLabel\\r\\n        //     });\\r\\n        // }\\r\\n        item.otherStds.forEach(jtem => {\\r\\n            if (jtem.nameIsStd) {\\r\\n                row.nameOptions.push({\\r\\n                    label: item.fieldName + '(已匹配字段标准)',\\r\\n                    value: item.fieldName\\r\\n                });\\r\\n                row.labelOptions.push({\\r\\n                    label: jtem.recLabel + '(字段标准推荐)',\\r\\n                    value: jtem.recLabel\\r\\n                });\\r\\n            }\\r\\n            //  else if (jtem.splitNameIsStd) {\\r\\n            //     row.nameOptions.push({\\r\\n            //         label: item.fieldName + '(已匹配词汇标准)',\\r\\n            //         value: item.fieldName\\r\\n            //     });\\r\\n            //     row.labelOptions.push({\\r\\n            //         label: jtem.recLabel + '(词汇标准推荐)',\\r\\n            //         value: jtem.recLabel\\r\\n            //     });\\r\\n            // }\\r\\n        });\\r\\n        if (item.labelIsStd) {\\r\\n            row.labelOptions.push({\\r\\n                label: item.fieldLabel + '(已匹配字段标准)',\\r\\n                value: item.fieldLabel\\r\\n            });\\r\\n            row.nameOptions.push({\\r\\n                label: item.recName + '(字段标准推荐)',\\r\\n                value: item.recName\\r\\n            });\\r\\n        }\\r\\n        //  else if (item.splitLabelIsStd) {\\r\\n        //     row.labelOptions.push({\\r\\n        //         label: item.fieldLabel + '(已匹配词汇标准)',\\r\\n        //         value: item.fieldLabel\\r\\n        //     });\\r\\n        //     row.nameOptions.push({\\r\\n        //         label: item.recName + '(词汇标准推荐)',\\r\\n        //         value: item.recName\\r\\n        //     });\\r\\n        // }\\r\\n        item.otherStds.forEach(jtem => {\\r\\n            if (jtem.labelIsStd) {\\r\\n                row.labelOptions.push({\\r\\n                    label: item.fieldLabel + '(已匹配字段标准)',\\r\\n                    value: item.fieldLabel\\r\\n                });\\r\\n                row.nameOptions.push({\\r\\n                    label: jtem.recName + '(字段标准推荐)',\\r\\n                    value: jtem.recName\\r\\n                });\\r\\n            }\\r\\n            //  else if (jtem.splitLabelIsStd) {\\r\\n            //     row.labelOptions.push({\\r\\n            //         label: item.fieldLabel + '(已匹配词汇标准)',\\r\\n            //         value: item.fieldLabel\\r\\n            //     });\\r\\n            //     row.nameOptions.push({\\r\\n            //         label: jtem.recName + '(词汇标准推荐)',\\r\\n            //         value: jtem.recName\\r\\n            //     });\\r\\n            // }\\r\\n        });\\r\\n        if (row.nameOptions.length > 0) {\\r\\n            row.isMatch = '是';\\r\\n            $this.recNameMap[i] = row.nameOptions[0].value;\\r\\n            row.recName = row.nameOptions[0].value;\\r\\n            $this.setRecNameMap($utils._.extend({}, $this.recNameMap));\\r\\n            $this.recLabelMap[i] = row.labelOptions[0].value;\\r\\n            row.recLabel = row.labelOptions[0].value;\\r\\n            $this.setRecLabelMap($utils._.extend({}, $this.recLabelMap));\\r\\n        }\\r\\n        recData.push(row);\\r\\n    };\\r\\n    const notStds = recData.filter(item=>{\\r\\n        return item.isMatch!='是'||(item.isMatch=='是'&&(item.recName!=item.fieldName||item.recLabel!=item.fieldLabel));\\r\\n    });\\r\\n    const target = _.extend({}, $this.checkRow);\\r\\n    target.checkDetail.fieldStdDtl = [{\\r\\n        ruleName:'字段标准检查',\\r\\n        checkResult:notStds.length>0?'不通过':'通过',\\r\\n        fieldCheckDescr:(recData.length-notStds.length)+'/'+recData.length,\\r\\n        fieldDtl:[]\\r\\n    }];\\r\\n    recData.forEach(item=>{\\r\\n        const targetRes = {\\r\\n            objName:item.fieldName,\\r\\n            ruleName:'字段标准检查',\\r\\n            checkResult:(item.isMatch=='是'&&item.recName==item.fieldName&&item.recLabel==item.fieldLabel)?'通过':'不通过',\\r\\n            checkDescr:''\\r\\n        };\\r\\n        if(item.isMatch!='是'){\\r\\n            targetRes.checkDescr= '未匹配标准';\\r\\n        }else if(item.recName!=item.fieldName){\\r\\n            targetRes.checkDescr= '字段英文名不标准，标准英文名为：'+item.recName;\\r\\n        }else if(item.recLabel!=item.fieldLabel){\\r\\n            targetRes.checkDescr= '字段中文名不标准，标准中文名为：'+item.recLabel;\\r\\n        }else{\\r\\n            targetRes.checkDescr= '已匹配标准';\\r\\n        }\\r\\n        \\r\\n        target.checkDetail.fieldStdDtl[0].fieldDtl.push(targetRes);\\r\\n    });\\r\\n    $this.setCheckRow(target);\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error) {\\r\\n    $this.setLoading(false);\\r\\n    if (error.data.devMsg) {\\r\\n        $utils.notification.error({\\r\\n            title: '失败',\\r\\n            content: error.data.devMsg\\r\\n        });\\r\\n    } else {\\r\\n        $utils.notification.error({\\r\\n            title: '失败',\\r\\n            content: '标准推荐失败！'\\r\\n        });\\r\\n    }\\r\\n}\",\"callback\":\"\"},{\"name\":\"getCheckResult\",\"stateName\":\"\",\"descr\":\"\",\"autoLoad\":false,\"serviceId\":\"220166051286528000\",\"method\":\"get\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\n    $this.setLoading(true);\\n    vars.params.tabId = $this.checkTabId;\\n}\",\"success\":\"function successCallback(data) {\\n    $this.setLoading(false);\\n    data.data.tableDtl.forEach(tdt => {\\n        if (tdt.checkResult == 'ok') {\\n            tdt.checkResult = '通过';\\n        } else if (tdt.checkResult == 'warning') {\\n            tdt.checkResult = '警告';\\n        } else if (tdt.checkResult == 'error') {\\n            tdt.checkResult = '不通过';\\n        }\\n    });\\n    // data.data.tableDtl = data.data.tableDtl.filter(item => {\\n    //     if (item.funcCode == 'attrCheckNotNull' && (item.funcPara.indexOf('label.value') > -1 || item.funcPara.indexOf('name.value') > -1)) {\\n    //         return false;\\n    //     }\\n    //     return true;\\n    // });\\n    for (var i = 0; i < data.data.fieldDtl.length; i++) {\\n        if (data.data.fieldDtl[i].checkResult == 'ok') {\\n            data.data.fieldDtl[i].checkResult = '通过';\\n        } else if (data.data.fieldDtl[i].checkResult == 'warning') {\\n            data.data.fieldDtl[i].checkResult = '警告';\\n        } else if (data.data.fieldDtl[i].checkResult == 'error') {\\n            data.data.fieldDtl[i].checkResult = '不通过';\\n        }\\n        var sucLen = 0;\\n        for (var j = 0; j < data.data.fieldDtl[i].fieldDtl.length; j++) {\\n            if (data.data.fieldDtl[i].fieldDtl[j].checkResult == 'ok') {\\n                sucLen++;\\n                data.data.fi