{"id":"dataps-139382526769860611","module":"86147935318020096","moduleLabel":null,"name":"procManage","label":"程序管理","descr":"","type":"activity","state":"1","parameters":"[{\"id\":\"0\",\"name\":\"0\",\"label\":\"页面\",\"type\":\"view\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltipText\":null,\"className\":\"\",\"css\":\":root {\\n    background-color: var(--color-gray-2);\\n    padding: 10px 12px;\\n}\",\"loop\":{\"data\":null,\"dataBindVar\":null,\"var\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onMount\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\n\\n    $this.setSearching(true)\\n    if ($identity.teamName != null && $identity.teamName != undefined) {\\n        $utils.axios.get('/_api/modelTeamWorkspace/find?teamName=' + $identity.teamName).then(res => {\\n            var content = res.data.data;\\n\\n            var workspaceIds = '';\\n            for (let row of content) {\\n\\n                workspaceIds += row.workspaceId + ',';\\n            }\\n\\n            $this.modelWorkspaceRepo.find({ id: workspaceIds });\\n        }).catch(function (error) {\\n            console.log(error);\\n        });\\n\\n    } else {\\n        // $this.modelWorkspaceRepo.list();\\n        $utils.message.warning('未获取到团队信息，请选择团队！');\\n    }\\n\\n\\n    // $this.modoProcRepo.search();\\n\\n    $utils.axios.get('/_api/_/modoDsType/listByCategory?dsCategory=bigdata').then(res => {\\n        var content = res.data.data;\\n        var bigdataArr = [];\\n        for (let row of content) {\\n            var obj = {};\\n            obj.value = row.dsType;\\n            obj.label = row.dsTypeLabel;\\n            bigdataArr.push(obj);\\n        }\\n        $utils.axios.get('/_api/_/modoDsType/listByCategory?dsCategory=rdb').then(res => {\\n            var content = res.data.data;\\n            var rdbArr = [];\\n            for (let row of content) {\\n                var obj = {};\\n                obj.value = row.dsType;\\n                obj.label = row.dsTypeLabel;\\n                rdbArr.push(obj);\\n            }\\n            $utils.axios.get('/_api/_/modoDsType/listByCategory?dsCategory=analytic').then(res => {\\n                var content = res.data.data;\\n                var analyticArr = [];\\n                for (let row of content) {\\n                    var obj = {};\\n                    obj.value = row.dsType;\\n                    obj.label = row.dsTypeLabel;\\n                    analyticArr.push(obj);\\n                }\\n\\n                var typeOptions = [{\\n                    value: '编排开发',\\n                    label: '编排开发',\\n                    children: [{\\n                        value: 'dp',\\n                        label: '离线开发'\\n                    }, {\\n                        value: 'stream',\\n                        label: '实时开发'\\n                    }]\\n                },\\n                {\\n                    value: 'SQL JDBC',\\n                    label: 'SQL JDBC',\\n                    children: [{\\n                        value: 'bigdata',\\n                        label: '大数据',\\n                        children: bigdataArr\\n                    }, {\\n                        value: 'rdb',\\n                        label: '关系数据库',\\n                        children: rdbArr\\n                    }, {\\n                        value: 'analytic',\\n                        label: '分析数据库',\\n                        children: analyticArr\\n                    }]\\n                }, {\\n                    value: 'SQL Submit',\\n                    label: 'SQL Submit',\\n                    children: [{\\n                        value: 'spark-submit',\\n                        label: 'Spark'\\n                    }, {\\n                        value: 'flink-submit',\\n                        label: 'Flink'\\n                    }]\\n                }, {\\n                    value: '工程',\\n                    label: '工程',\\n                    children: [{\\n                        value: 'python',\\n                        label: 'Python'\\n                    }, {\\n                        value: 'pySpark',\\n                        label: 'PySpark'\\n                    }, {\\n                        value: 'pyFlink',\\n                        label: 'PyFlink'\\n                    }, {\\n                        value: 'shell',\\n                        label: 'Shell'\\n                    }]\\n                }, {\\n                    value: 'JAR',\\n                    label: 'JAR',\\n                    children: [{\\n                        value: 'sparkJar',\\n                        label: 'SparkJar'\\n                    }, {\\n                        value: 'flinkJar',\\n                        label: 'FlinkJar'\\n                    }, {\\n                        value: 'customJar',\\n                        label: '自定义Jar'\\n                    }]\\n                }]\\n\\n\\n                $this.setTypeOptions(typeOptions);\\n\\n            }).catch(function (error) {\\n                console.log(error);\\n            });\\n\\n        }).catch(function (error) {\\n            console.log(error);\\n        });\\n\\n\\n    }).catch(function (error) {\\n        console.log(error);\\n    });\\n\\n\\n\\n    // $utils.axios.get('/_api/_/modoProc/search?offset=0&limit=10').then(res => {\\n\\n\\n    //     var content = res.data.data.content;\\n\\n\\n    //     debugger\\n    //     $this.setProc_listData(res.data.data);\\n\\n\\n\\n\\n    // }).catch(function (error) {\\n    //     console.log(error);\\n    // });\\n}\"}},\"type\":\"one-screen-layout\",\"titleVisible\":false,\"vars\":[{\"name\":\"workspaceDirData\",\"descr\":\"树形结构数据\",\"value\":\"[]\"},{\"name\":\"wsSelectForm\",\"descr\":\"开发空间选择表单\",\"value\":\"{}\"},{\"name\":\"workspaceName\",\"descr\":\"工作空间名称\",\"value\":\"''\"},{\"name\":\"typeOptions\",\"descr\":\"类型选项\",\"value\":\"[]\"},{\"name\":\"workspaceId\",\"descr\":\"工作空间ID\",\"value\":\"''\"},{\"name\":\"dirId\",\"descr\":\"树节点id\",\"value\":\"''\"},{\"name\":\"procId\",\"descr\":\"程序Id\",\"value\":\"''\"},{\"name\":\"searching\",\"descr\":null,\"value\":\"false\"}],\"models\":[{\"id\":\"54952326569627648\",\"modelId\":null,\"namespace\":\"io.github.suanchou.driver.domain\",\"doc\":\"工作空间表\",\"topic\":\"54562042241323008\",\"loc\":\"601.4285714285716 -38.5714285714285\",\"appName\":\"datamodel\",\"language\":\"zh-cn\",\"expand\":false,\"type\":\"record\",\"name\":\"ModelWorkspace\",\"modelType\":\"domain\",\"modelSubType\":\"\",\"valueObjectSql\":\"\",\"tableName\":\"model_workspace\",\"oneToMany\":[\"ModelTeamWorkspace\",\"ModelWorkspaceDir\",\"ModelWorkspacePriv\",\"ModelWorkspaceDevCategory\",\"ModelWorkspaceDevComp\"],\"oneToOne\":[],\"manyToMany\":null,\"fields\":[{\"name\":\"id\",\"columnName\":\"\",\"doc\":\"ID\",\"type\":\"string\",\"length\":\"--\",\"primary\":false,\"renderType\":\"input\",\"defaultValue\":null},{\"name\":\"label\",\"columnName\":\"\"