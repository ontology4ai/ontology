{"id":"dataps-139382522042880003","module":"53562681944412160","moduleLabel":null,"name":"workSpaceEditStep3","label":"工作空间编辑步骤3","descr":"","type":"fragment","state":"1","parameters":"[{\"id\":\"0\",\"name\":\"0\",\"label\":\"页面\",\"type\":\"view\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltipText\":null,\"className\":\"\",\"css\":\":root {\\n}\",\"loop\":{\"data\":null,\"dataBindVar\":null,\"var\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"onMount\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\r\\n    if ($this.currRow.type == 2 && $this.currRow.dataDevMode == 2) {\\r\\n        $this.setHideDirBoundBtn(true);\\r\\n    }\\r\\n\\r\\n    var hasChange = false;\\r\\n\\r\\n    var cur = $this.currRow;\\r\\n\\r\\n    if (cur.dirBound == undefined || cur.dirBound == null || cur.dirBound == '') {\\r\\n        cur.dirBound = '1';\\r\\n    }\\r\\n    if (cur.dir == undefined || cur.dir == null || cur.dir == '') {\\r\\n        cur.dir = 'mgr';\\r\\n    }\\r\\n    if (cur.procAndModel == undefined || cur.procAndModel == null || cur.procAndModel == '') {\\r\\n        cur.procAndModel = 'mgr';\\r\\n    }\\r\\n    \\r\\n\\r\\n    if (hasChange) {\\r\\n        $this.setCurrRow(cur);\\r\\n    }\\r\\n\\r\\n    let modelWorkspaceDirList = cur.modelWorkspaceDirList;\\r\\n    if (modelWorkspaceDirList != undefined && modelWorkspaceDirList.length > 0) {\\r\\n        $this.setWorkspaceDirData(listToTree(modelWorkspaceDirList));\\r\\n    }\\r\\n\\r\\n    let c = {\\r\\n        name: 'topDir',\\r\\n        label: '数据开发目录'\\r\\n\\r\\n    }\\r\\n    $this.setCurrentNode(c);\\r\\n}\\r\\n\\r\\nfunction listToTree(data, idName, parentIdName) {\\r\\n    if (!idName) {\\r\\n        idName = 'name';\\r\\n    }\\r\\n    if (!parentIdName) {\\r\\n        parentIdName = 'parentName';\\r\\n    }\\r\\n\\r\\n    // * 先生成parent建立父子关系\\r\\n    const obj = {};\\r\\n    data.forEach((item) => {\\r\\n        obj[item[idName]] = item;\\r\\n    });\\r\\n    const parentList = [];\\r\\n    data.forEach((item) => {\\r\\n        // item.hasChildren = false;\\r\\n        item.key = item.name;\\r\\n        item.title = item.label;\\r\\n        const parent = obj[item[parentIdName]];\\r\\n        if (parent) {\\r\\n            // * 当前项有父节点\\r\\n            parent.children = parent.children || [];\\r\\n            parent.children.push(item);\\r\\n            // parent.hasChildren = true;\\r\\n        } else {\\r\\n            // * 当前项没有父节点 -> 顶层\\r\\n            parentList.push(item);\\r\\n        }\\r\\n    });\\r\\n    return parentList;\\r\\n}\"}},\"type\":\"one-screen-layout\",\"titleVisible\":false,\"vars\":[{\"name\":\"hideDirBoundBtn\",\"descr\":null,\"value\":\"false\"},{\"name\":\"workspaceDirData\",\"descr\":null,\"value\":\"[\\r\\n    {\\r\\n        key: 'topDir',\\r\\n        title: '数据开发目录',\\r\\n        children: []\\r\\n    }\\r\\n]\"},{\"name\":\"currRow\",\"descr\":null,\"value\":\"{}\"},{\"name\":\"currentNode\",\"descr\":null,\"value\"