e\": \"50%\",\n                                \"tabViewName\": null,\n                                \"tabParams\": \"\",\n                                \"tabKey\": \"\",\n                                \"tabLabel\": \"\"\n                            }\n                        ],\n                        \"actions\": []\n                    },\n                    \"callback\": \"function callback() {\\r\\n    window.windowTargetMap = {};\\r\\n    window.windowCatalogMap = {};\\r\\n    window.windowTarget = [];\\r\\n}\"\n                }\n            },\n            \"type\": \"one-screen-layout\",\n            \"titleVisible\": false,\n            \"vars\": [\n                {\n                    \"name\": \"treeData\",\n                    \"descr\": null,\n                    \"value\": \"[]\"\n                },\n                {\n                    \"name\": \"formData\",\n                    \"descr\": null,\n                    \"value\": \"{privUser:''}\"\n                },\n                {\n                    \"name\": \"loading\",\n                    \"descr\": null,\n                    \"value\": \"false\"\n                },\n                {\n                    \"name\": \"srcCatalogMap\",\n                    \"descr\": null,\n                    \"value\": \"{}\"\n                },\n                {\n                    \"name\": \"filterForm\",\n                    \"descr\": null,\n                    \"value\": \"{}\"\n                },\n                {\n                    \"name\": \"cascaderOptions\",\n                    \"descr\": null,\n                    \"value\": \"[]\"\n                },\n                {\n                    \"name\": \"archType\",\n                    \"descr\": null,\n                    \"value\": \"''\"\n                },\n                {\n                    \"name\": \"impl\",\n                    \"descr\": null,\n                    \"value\": \"''\"\n                },\n                {\n                    \"name\": \"rootKey\",\n                    \"descr\": null,\n                    \"value\": \"''\"\n                },\n                {\n                    \"name\": \"treeDataForEdit\",\n                    \"descr\": null,\n                    \"value\": null\n                }\n            ],\n            \"models\": [],\n            \"services\": [\n                {\n                    \"name\": \"getUserOptions\",\n                    \"stateName\": \"userOptions\",\n                    \"descr\": \"\",\n                    \"autoLoad\": true,\n                    \"serviceId\": \"223768182076424192\",\n                    \"method\": \"get\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    // data.data.b = 1; 修改返回数据结构中的 b 字段为1\\r\\n    if(data.data.length>0){\\r\\n        $this.setFormData({\\\"privUser\\\":data.data[0].userId});\\r\\n        $this.datasourceMap.getPrivDataArch();\\r\\n    }\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\n                    \"callback\": \"\"\n                },\n                {\n                    \"name\": \"getPrivDataArch\",\n                    \"stateName\": \"\",\n                    \"descr\": \"\",\n                    \"autoLoad\": false,\n                    \"serviceId\": \"176049917920980992\",\n                    \"method\": \"get\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    vars.params.privUser = $this.formData.privUser;\\r\\n    vars.params.archType = $this.archType || null;\\r\\n    vars.params.impl = $this.impl || null;\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    let map = {};\\r\\n    let roots = [];\\r\\n    let parentPrivs = [];\\r\\n    let rootKey = '';\\r\\n    data.data.forEach(item=>{\\r\\n        delete item.busiActivities;\\r\\n        delete item.l3Identities;\\r\\n        delete item.approvers;\\r\\n        delete item.l3Props;\\r\\n        delete item.children;\\r\\n        if(!item.parent){\\r\\n            rootKey = item.id;\\r\\n        }\\r\\n    });\\r\\n    $this.setRootKey(rootKey);\\r\\n    data.data.forEach(item => {\\r\\n        if(!item.id&&item.key){\\r\\n            item.id = item.key;\\r\\n        }\\r\\n        item.children = [];\\r\\n        map[item.key] = item;\\r\\n        if (item.parent&&item.parent==rootKey) {\\r\\n            roots.push(item);\\r\\n        }\\r\\n        if(item.priv=='1') {\\r\\n            parentPrivs.push(item);\\r\\n            item.checked = true;\\r\\n        }else{\\r\\n            item.checked = false;\\r\\n        }\\r\\n    });\\r\\n    data.data.forEach(item => {\\r\\n        if (map[item.parent]) {\\r\\n            map[item.parent].children.push(item);\\r\\n        }\\r\\n    });\\r\\n    let loadChildrenPriv = function(arr) {\\r\\n        arr.forEach(item=>{\\r\\n            item.priv = '1';\\r\\n            item.checked = true;\\r\\n            if(item.children&&item.children.length>0){\\r\\n                loadChildrenPriv(item.children);\\r\\n            }\\r\\n        })\\r\\n    }\\r\\n    parentPrivs.forEach(item=>{\\r\\n        if(item.children&&item.children.length>0){\\r\\n            loadChildrenPriv(item.children);\\r\\n        }\\r\\n    });\\r\\n    let srcMap = {};\\r\\n    data.data.forEach(item=>{\\r\\n        delete item.children;\\r\\n        srcMap[item.key] = _.extend({}, item);\\r\\n    });\\r\\n    $this.setSrcCatalogMap(srcMap);\\r\\n    debugger;\\r\\n    const targetData = JSON.parse(JSON.stringify(data.data));\\r\\n    $this.setTreeData(targetData);\\r\\n    $this.setTreeDataForEdit(targetData);\\r\\n    targetData.forEach(item=>{\\r\\n        $this.$refs.treeDef.treeChartRef.current.updateNodeData(item, item.id);\\r\\n    });\\r\\n    let catalogMap = {};\\r\\n    let newItems = [];\\r\\n    data.data.forEach(item => {\\r\\n        var newItem = _.extend({}, item);\\r\\n        newItems.push(newItem);\\r\\n        catalogMap[item.key] = newItem;\\r\\n    });\\r\\n    newItems.forEach(item => {\\r\\n        if (item.parent && catalogMap[item.parent]) {\\r\\n            if (!catalogMap[item.parent].children) {\\r\\n                catalogMap[item.parent].children = [];\\r\\n            }\\r\\n            catalogMap[item.parent].children.push(item);\\r\\n        }\\r\\n    });\\r\\n    $this.setCascaderOptions(newItems.filter(item=>{\\r\\n        return item.parent&&item.parent==rootKey;\\r\\n    }));\\r\\n\\r\\n    map = null;\\r\\n    roots = null;\\r\\n    parentPrivs = null;\\r\\n    rootKey = null;\\r\\n    srcMap = null;\\r\\n    catalogMap = null;\\r\\n    newItems = null;\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\n                    \"callback\": \"\"\n                },\n                {\n                    \"name\": \"saveSysDataArchEditPriv\",\n                    \"stateName\": \"\",\n                    \"descr\": \"\",\n                    \"autoLoad\": false,\n                    \"serviceId\": \"182122533602140160\",\n                    \"method\": \"POST\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    const nodes = [];\\r\\n    $this.treeDataForEdit.forEach(item=>{\\r\\n        if(item.priv=='1'){\\r\\n            nodes.push({\\r\\n                nodeId:item.key,\\r\\n                nodeName:item.name,\\r\\n                nodeLabel:item.label\\r\\n            });\\r\\n        }\\r\\n    });\\r\\n    vars.data.nodes = nodes;\\r\\n    vars.data.privUser = $this.formData.privUser;\\r\\n    vars.data.operator = $identity.userId;\\r\\n    $this.setLoading(true);\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    $this.setLoading(false);\\r\\n    $utils.notification.success({\\r\\n        title: '成功',\\r\\n        content: '数据编目授权成功！',\\r\\n    });\\r\\n    $this.datasourceMap.getPrivDataArch();\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n    $utils.notification.error({\\r\\n        title: '失败',\\r\\n        content: '数据编目授权失败！',\\r\\n    });\\r\\n}\",\n                    \"callback\": \"\"\n                }\n            ],\n            \"i18n\": {\n                \"zh-CN\": \"{}\",\n                \"en-US\": \"{}\"\n            }\n        },\n        \"children\": [\n            {\n                \"id\": \"f2393fd6e89d869e\",\n                \"name\": \"f2393fd6e89d869e\",\n                \"label\": \"flex布局\",\n                \"type\": \"flexLayout\",\n                \"options\": {\n                    \"hidden\": false,\n                    \"hiddenBindVar\": null,\n                    \"isLoading\": true,\n                    \"loading\": false,\n                    \"loadingBindVar\": \"$this.loading\",\n                    \"loadingText\": null,\n                    \"loadingTextBindVar\": null,\n                    \"showTooltip\": false,\n                    \"tooltip\": null,\n                    \"tooltipBindVar\": null,\n                    \