                           },\n                                                \"viewActions\": [\n                                                    {\n                                                        \"condition\": \"true\",\n                                                        \"showType\": \"modal\",\n                                                        \"viewName\": null,\n                                                        \"before\": \"function beforeCallback() {}\",\n                                                        \"width\": \"50%\",\n                                                        \"top\": \"15vh\",\n                                                        \"fullscreen\": false,\n                                                        \"size\": \"50%\",\n                                                        \"tabViewName\": null,\n                                                        \"tabParams\": \"\",\n                                                        \"tabKey\": \"\",\n                                                        \"tabLabel\": \"\"\n                                                    }\n                                                ],\n                                                \"actions\": []\n                                            },\n                                            \"callback\": \"function callback() {}\"\n                                        }\n                                    },\n                                    \"eventMap\": {}\n                                },\n                                \"defaultOptions\": {\n                                    \"css\": \":root {\\nheight: 200px;\\n}\"\n                                },\n                                \"children\": [\n                                    {\n                                        \"id\": \"278bbd70238ffcc6\",\n                                        \"name\": \"treeDef\",\n                                        \"label\": \"树状图\",\n                                        \"type\": \"treeChart\",\n                                        \"options\": {\n                                            \"hidden\": false,\n                                            \"hiddenBindVar\": null,\n                                            \"isLoading\": false,\n                                            \"loading\": false,\n                                            \"loadingBindVar\": null,\n                                            \"loadingText\": null,\n                                            \"loadingTextBindVar\": null,\n                                            \"showTooltip\": false,\n                                            \"tooltip\": null,\n                                            \"tooltipBindVar\": null,\n                                            \"className\": \"\",\n                                            \"css\": \":root {\\n  height: 100%;\\n}\",\n                                            \"loop\": {\n                                                \"isLoading\": false,\n                                                \"loading\": false,\n                                                \"loadingBindVar\": null,\n                                                \"data\": null,\n                                                \"dataBindVar\": null,\n                                                \"item\": \"item\",\n                                                \"index\": \"index\",\n                                                \"key\": \"index\",\n                                                \"paginationVisible\": true,\n                                                \"disabled\": false,\n                                                \"pagination\": {\n                                                    \"style\": {\n                                                        \"display\": \"block\"\n                                                    },\n                                                    \"sizeOptions\": [\n                                                        10,\n                                                        20,\n                                                        30,\n                                                        40,\n                                                        50\n                                                    ],\n                                                    \"show\": true,\n                                                    \"showTotal\": true,\n                                                    \"pageSizeChangeResetCurrent\": true,\n                                                    \"sizeCanChange\": true,\n                                                    \"total\": 0,\n                                                    \"pageSize\": 20,\n                                                    \"current\": 1\n                                                },\n                                                \"event\": {\n                                                    \"builtIn\": {\n                                                        \"type\": \"url\",\n                                                        \"isSingleService\": true,\n                                                        \"urlAction\": {\n                                                            \"url\": null,\n                                                            \"blank\": true\n                                                        },\n                                                        \"viewActions\": [\n                                                            {\n                                                                \"condition\": \"true\",\n                                                                \"showType\": \"modal\",\n                                                                \"viewName\": null,\n                                                                \"before\": \"function beforeCallback() {}\",\n                                                                \"width\": \"50%\",\n                                                                \"top\": \"15vh\",\n                                                                \"fullscreen\": false,\n                                                                \"size\": \"50%\",\n                                                                \"tabViewName\": null,\n                                                                \"tabParams\": \"\",\n                                                                \"tabKey\": \"\",\n                                                                \"tabLabel\": \"\"\n                                                            }\n                                                        ],\n                                                        \"actions\": []\n                                                    },\n                                                    \"callback\": \"function callback() {}\"\n                                                }\n                                            },\n                                            \"eventMap\": {\n                                                \"checked\": {\n                                                    \"builtIn\": {\n                                                        \"type\": \"url\",\n                                                        \"isSingleService\": true,\n                                                        \"urlAction\": {\n                                                            \"url\": null,\n                                                            \"blank\": true\n                                                        },\n                                                        \"viewActions\": [\n                                                            {\n                                                                \"condition\": \"true\",\n                                                                \"showType\": \"modal\",\n                                                                \"viewName\": null,\n                                                                \"before\": \"function beforeCallback() {}\",\n                                                                \"width\": \"50%\",\n                                                                \"top\": \"15vh\",\n                                                                \"fullscreen\": false,\n                                                                \"size\": \"50%\",\n                                                                \"tabViewName\": null,\n                                                                \"tabParams\": \"\",\n                                                                \"tabKey\": \"\",\n                                                                \"tabLabel\": \"\"\n                                                            }\n                                                        ],\n                                                        \"actions\": []\n                                                    },\n                                                    \"callback\": \"function callback(checked, targetNode) {\\r\\n    windowCatalogMap = {};\\r\\n    windowTargetMap = {};\\r\\n    windowTarget = [];\\r\\n    $this.treeDataForEdit.forEach(item => {\\r\\n        windowCatalogMap[item.key] = item;\\r\\n    });\\r\\n    $this.treeDataForEdit.forEach(item => {\\r\\n        if (item.parent && windowCatalogMap[item.parent]) {\\r\\n            if (!windowCatalogMap[item.parent].children) {\\r\\n                windowCatalogMap[item.parent].children = [];\\r\\n            }\\r\\n            windowCatalogMap[item.parent].children.push(item);\\r\\n        }\\r\\n    });\\r\\n    let getChildren = function (node, arr) {\\r\\n        arr.push(node.key);\\r\\n        if (node.children) {\\r\\n            node.children.forEach(child => {\\r\\n                getChildren(child, arr);\\r\\n            });\\r\\n        }\\r\\n    }\\r\\n    let getParents = function (node, map, arr) {\\r\\n        arr.push(node.key);\\r\\n        if (node.parent && map[node.parent]) {\\r\\n            getParents(map[node.parent], map, arr);\\r\\n        }\\r\\n    }\\r\\n    let ids = [];\\r\\n    let parentIds = [];\\r\\n    getChildren(windowCatalogMap[targetNode.data.key], ids);\\r\\n    getParents(targetNode.data, windowCatalogMap, parentIds);\\r\\n    let isDelete = false;\\r\\n    $this.treeDataForEdit.forEach(node => {\\r\\n        let item = _.extend({}, node);\\r\\n        if (ids.indexOf(item.key) > -1) {\\r\\n            if (targetNode.data.priv == '1') {\\r\\n                if ($this.srcCatalogMap[item.key] && $this.srcCatalogMap[item.key].priv == '1') {\\r\\n                    item.changeState = 'delete';\\r\\n                } else {\\r\\n                    item.changeState = '';\\r\\n                }\\r\\n                item.priv = '0';\\r\\n                isDelete = true;\\r\\n                item.checked = false;\\r\\n            } else {\\r\\n                if ($this.srcCatalogMap[item.key] && $this.srcCatalogMap[item.key].priv == '0') {\\r\\n                    item.changeState = 'add';\\r\\n                } else {\\r\\n                    item.changeState = '';\\r\\n                }\\r\\n                item.priv = '1';\\r\\n                item.checked = true;\\r\\n            }\\r\\n        }\\r\\n        windowTarget.push(item);\\r\\n        windowTargetMap[item.key] = item;\\r\\n    });\\r\\n    if (isDelete) {\\r\\n        parentIds.forEach(pi => {\\r\\n            if ($this.srcCatalogMap[pi] && $this.srcCatalogMap[pi].priv == '1') {\\r\\n                windowTargetMap[pi].changeState = 'delete';\