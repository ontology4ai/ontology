ell\":true,\"columns\":[{\"title\":\"列族名\",\"dataIndex\":\"name\",\"__ORIGIN_DATA\":{\"title\":\"列族\",\"dataIndex\":\"name\",\"__ORIGIN_DATA\":{\"title\":\"Name\",\"dataIndex\":\"name\"}},\"tagColors\":[],\"renderBindVar\":\"function render(col, item, index) {\\r\\n  const obj = {\\r\\n    children: React.createElement(\\r\\n      'span',\\r\\n      {},\\r\\n      col\\r\\n    ),\\r\\n    props: {},\\r\\n  };\\r\\n  obj.props.rowSpan = 0;\\r\\n  if (item.rowSpan > 0) {\\r\\n    obj.props.rowSpan = item.rowSpan;\\r\\n  }\\r\\n  return obj;\\r\\n}\"},{\"title\":\"参数名\",\"titleBindVar\":\"\",\"dataIndex\":\"paramKey\",\"__ORIGIN_DATA\":{\"title\":\"属性名\",\"titleBindVar\":\"\",\"dataIndex\":\"paramKey\",\"__ORIGIN_DATA\":{\"title\":\"属性名\",\"titleBindVar\":\"\",\"dataIndex\":\"\",\"__ORIGIN_DATA\":{\"title\":\"\",\"titleBindVar\":\"\",\"dataIndex\":\"\"}}}},{\"title\":\"参数值\",\"titleBindVar\":\"\",\"dataIndex\":\"paramValue\",\"__ORIGIN_DATA\":{\"title\":\"\",\"titleBindVar\":\"\",\"dataIndex\":\"paramValue\",\"__ORIGIN_DATA\":{\"title\":\"\",\"titleBindVar\":\"\",\"dataIndex\":\"\"}}}],\"data\":[{\"key\":\"1\",\"name\":\"Jane Doe\",\"salary\":23000,\"address\":\"32 Park Road, London\",\"email\":\"jane.doe@example.com\"}],\"actions\":[{\"label\":\"\",\"labelBindVar\":\"\",\"__ORIGIN_DATA\":{\"label\":\"\",\"labelBindVar\":\"\"},\"icon\":\"IconEdit\",\"tooltip\":\"编辑\",\"event\":{\"builtIn\":{\"type\":\"view\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":\"hbaseColumnFamilyEdit\",\"before\":\"function beforeCallback() { }\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\",\"title\":\"列族属性编辑\",\"params\":\"{\\r\\n    formData:$this.$refs.hbaseColumn.currentRow\\r\\n}\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},{\"label\":\"\",\"labelBindVar\":\"\",\"tooltip\":\"删除\",\"icon\":\"IconDelete\",\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\r\\n    const justDelete = function () {\\r\\n        const target = $this.formData.hbaseColumnData.filter(item => {\\r\\n            return !(item.name == $this.$refs.hbaseColumn.currentRow.name && item.paramKey == $this.$refs.hbaseColumn.currentRow.paramKey);\\r\\n        });\\r\\n        const nameNumMap = {};\\r\\n        target.forEach(row => {\\r\\n            if (!nameNumMap.hasOwnProperty(row.name)) {\\r\\n                nameNumMap[row.name] = 1;\\r\\n            } else {\\r\\n                nameNumMap[row.name] = nameNumMap[row.name] + 1;\\r\\n            }\\r\\n        });\\r\\n        target.forEach(row => {\\r\\n            if (nameNumMap.hasOwnProperty(row.name)) {\\r\\n                row.rowSpan = nameNumMap[row.name];\\r\\n                delete nameNumMap[row.name];\\r\\n            }\\r\\n        });\\r\\n        const targetNames = [];\\r\\n        target.forEach(item => {\\r\\n            if (targetNames.indexOf(item.name) == -1) {\\r\\n                targetNames.push(item.name);\\r\\n            }\\r\\n        });\\r\\n        const targetOptions = [];\\r\\n        targetNames.forEach(item => {\\r\\n            targetOptions.push({\\r\\n                label: item,\\r\\n                value: item\\r\\n            });\\r\\n        });\\r\\n        if ($this.parent.getChildren(\\\"fields\\\")) {\\r\\n            $this.parent.getChildren(\\\"fields\\\").setColumnFamilyOptions(targetOptions);\\r\\n            const targetFields = [];\\r\\n            $this.parent.getChildren(\\\"fields\\\").formData.fields.forEach(row => {\\r\\n                const targetField = _.extend({}, row);\\r\\n                if (targetNames.indexOf(targetField.columnFamily) == -1) {\\r\\n                    targetField.columnFamily = '';\\r\\n                }\\r\\n                targetFields.push(targetField);\\r\\n            });\\r\\n            $this.parent.getChildren(\\\"fields\\\").$refs.fieldsForm.formRef.current.clearFields();\\r\\n            $this.parent.getChildren(\\\"fields\\\").setFormData({ fields: targetFields });\\r\\n        }\\r\\n        $this.setFormData({ hbaseColumnData: target });\\r\\n    }\\r\\n    \\r\\n    const deletePropOnly = function () {\\r\\n        const targetItems = [];\\r\\n        $this.formData.hbaseColumnData.forEach(item => {\\r\\n            const targetItem = _.extend({}, item);\\r\\n            if(item.name == $this.$refs.hbaseColumn.currentRow.name && item.paramKey == $this.$refs.hbaseColumn.currentRow.paramKey){\\r\\n                targetItem.paramKey = '';\\r\\n                targetItem.paramValue = '';\\r\\n            }\\r\\n            targetItems.push(targetItem);\\r\\n        });\\r\\n        $this.setFormData({ hbaseColumnData: targetItems });\\r\\n    }\\r\\n    debugger;\\r\\n    if (!$this.formData.hbaseColumnData.some(item => {\\r\\n        return item.name == $this.$refs.hbaseColumn.currentRow.name && item.paramKey != $this.$refs.hbaseColumn.currentRow.paramKey;\\r\\n    })) {\\r\\n        $utils.modal.confirm({\\r\\n            title: '警告',\\r\\n            content: '删除属性时，是否同时删除列族？',\\r\\n            okButtonProps: {\\r\\n                status: 'warning',\\r\\n            },\\r\\n            onOk: () => {\\r\\n                justDelete();\\r\\n            },\\r\\n            onCancel: () => {\\r\\n                deletePropOnly();\\r\\n            }\\r\\n        });\\r\\n    } else {\\r\\n        justDelete();\\r\\n    }\\r\\n\\r\\n}\"}}],\"actionShowNumber\":2,\"actionMoreShowType\":\"icon\",\"action