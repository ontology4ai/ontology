\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root,\\r\\n:root .modo-filter-form-content {\\r\\n    height: auto;\\r\\n}\\r\\n:root .tag-list {\\r\\n    white-space: normal;\\r\\n}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{\"search\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {\\n    // $this.dacpDataflowLogicJobDRepo.search();\\n    const filters = $this.$refs.jobMonitorFilterForm.getFieldsValue();\\n    var current = $this.$refs.logicJobMonitorTab.state.current;\\n    var pageSize = $this.$refs.logicJobMonitorTab.state.pageSize;\\n    if (!ifCompare(filters, $this.filterHistory)) {\\n        current = 1;\\n    }\\n    $this.setFilterHistory(filters);\\n    var jobLabel = '';\\n    var batchTypes = 'daily';\\n    var batchNo = '';\\n    var memberName = '';\\n    var runState = '';\\n    var jobType = '';\\n    var priority = '';\\n    for (var f in filters) {\\n        if (f == 'jobLabel' && filters[f]) {\\n            jobLabel = filters[f];\\n        }\\n        if (f == 'batchTypes' && filters[f]) {\\n            if (filters[f] == '') {\\n                $utils.message.warning('请选择周期！');\\n                return;\\n            }\\n            batchTypes = filters[f].join(',');\\n        } if (f == 'batchNoZone' && filters[f]) {\\n            batchNo = filters[f].join(',').replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\").replaceAll(\\\",\\\", \\\"-\\\");\\n        }\\n        if (f == 'batchNo' && filters[f]) {\\n            batchNo = filters[f].replaceAll(\\\"-\\\", \\\"\\\").replaceAll(\\\" \\\", \\\"\\\").replaceAll(\\\":\\\", \\\"\\\");\\n        }\\n        if (f == 'dUser' && filters[f]) {\\n            memberName = filters[f];\\n        }\\n        if (f == 'runState' && filters[f]) {\\n            runState = filters[f];\\n        }\\n        if (f == 'jobType' && filters[f]) {\\n            jobType = filters[f];\\n        }\\n        if (f == 'priority' && filters[f]) {\\n            priority = filters[f];\\n        }\\n        // if (f == 'cycle' && filters[f]) {\\n        //     vars.params.cycle = '~%' + filters[f] + '%'\\n        // }\\n    }\\n\\n    //&tags=&jobType=&total=4&readTeamNames=team_yaxin&createDate=\\n    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/getStatisticsCollectData',\\n        {\\n            params:\\n            {\\n                jobLabel: jobLabel,\\n                batchTypes: batchTypes,\\n                batchNo: batchNo,\\n                teamName: 'team_yaxin',\\n                memberName: memberName,\\n                runState: runState,\\n                jobType: jobType,\\n                priority: priority\\n            }\\n        }).then(res => {\\n            $this.setJobS(res.data.data);\\n            $this.setJobSuccessRate(Math.round((res.data.data.jtFinish / res.data.data.jtSum) * 100))\\n        }).catch(function (error) {\\n            console.log(error);\\n        });\\n\\n    let state = '';\\n    let queryType = '0';\\n    if ($this.jobState2.length == 0) {\\n        if ($this.jobState2.indexOf('ALL') == -1) {\\n            state = $this.jobState2.join(',');\\n            queryType = '1';\\n\\n        }\\n    } else {\\n        if ($this.jobState.indexOf('ALL') == -1) {\\n            state = $this.jobState.join(',');\\n        }\\n    }\\n\\n\\n    $utils.axios.get('/oneplusn-federation/open/dataflow/monitor/modo/v2/getStatisticsTableData',\\n        {\\n            params:\\n            {\\n                pageNum: current - 1,\\n                pageSize: pageSize,\\n                jobLabel: jobLabel,\\n                batchTypes: batchTypes,\\n                batchNo: batchNo,\\n                teamName: 'team_yaxin',\\n                taskType: 'all',\\n                desc: 'desc',\\n                sortColumn: 'jobCode',\\n                memberName: memberName,\\n                runState: runState,\\n                jobType: jobType,\\n                priority: priority,\\n                readTeamNames: 'team_yaxin',\\n                jobState: state,\\n                queryType: queryType\\n            }\\n        }).then(res => {\\n            var data = res.data.data;\\n            $this.setLogicJobTriggerListData(data);\\n        }).catch(function (error) {\\n            console.log(error);\\n        });\\n}\\n\\nfunction ifCompare(object1, object2) {\\n    var o1keys = Object.keys(object1);\\n    var o2keys = Object.keys(object2);\\n    if (o2keys.length !== o1keys.length) return false;\\n    for (let i = 0; i <= o1keys.length - 1; i++) {\\n        let key = o1keys[i];\\n        if (!o2keys.includes(key)) return false;\\n        if (object2[key] !== object1[key]) return false;\\n\\n    }\\n    return true;\\n\\n}\"}},\"labelFlex\":\"60px\",\"modelName\":\"DacpDataflowLogicJobD\",\"min\":3,\"layout\":\"inline\",\"valuesBindVar\":\"$this.jobMonitorFilterFormData\",\"initialValuesBindVar\":\"{ batchTypes: ['daily'] }\"},\"children\":[{\"id\":\"e044e964b7acf191\",\"name\":\"e044e964b7acf191\",\"label\":\"任务\",\"type\":\"input\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root{}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"url\":null,\"blank\":true},\"viewActions\":[{\"condition\":\"true\",\"showType\":\"modal\",\"viewName\":null,\"before\":\"function beforeCallback() {}\",\"width\":\"50%\",\"top\":\"15vh\",\"fullscreen\":false,\"size\":\"50%\",\"tabViewName\":null,\"tabParams\":\"\",\"tabKey\":\"\",\"tabLabel\":\"\"}],\"actions\":[]},\"callback\":\"function callback() {}\"}},\"eventMap\":{},\"span\":\"8\",\"labelFlex\":\"84px\",\"placeholder\":\"任务名称或编码\"},\"children\":[]},{\"id\":\"dab474648cbee2ce\",\"name\":\"dab474648cbee2ce\",\"label\":\"周期\",\"type\":\"select\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"to