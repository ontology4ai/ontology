\\n    } else {\\r\\n        vars.params.offset = (vars.params.pageNum - 1) * vars.params.limit;\\r\\n        delete vars.params.pageNum;\\r\\n    }\\r\\n    $this.setSearching(true);\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    $this.setSearching(false);\\r\\n    data.data.content.forEach(item=>{\\r\\n        if(item.state=='1'){\\r\\n            item.stateLabel = '生效';\\r\\n        }else{\\r\\n            item.stateLabel = '失效';\\r\\n        }\\r\\n    });\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $this.setSearching(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"},{\"name\":\"deleteById\",\"stateName\":\"\",\"descr\":\"根据ID删除稽核规则\",\"autoLoad\":false,\"loadType\":\"1\",\"serviceId\":\"/_api/datapsMetaCheckRule/delete/{id}\",\"method\":\"POST\",\"dataBindVar\":\"\",\"placeholders\":[],\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    var url = config.url;\\r\\n    config.url = url.replace('{id}', $this.$refs.ruleTable.currentRow.id);\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    $utils.notification.success({\\r\\n        title: '成功',\\r\\n        content: '稽核规则删除成功！',\\r\\n    });\\r\\n    $this.datasourceMap.getPage();\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    $utils.notification.error({\\r\\n        title: '失败',\\r\\n        content: '稽核规则删除失败！',\\r\\n    });\\r\\n}\",\"callback\":\"\"},{\"name\":\"getMetaCheckRuleScopes\",\"stateName\":\"\",\"descr\":\"\",\"autoLoad\":true,\"serviceId\":\"173730315785256960\",\"method\":\"GET\",\"dataBindVar\":\"\",\"placeholders\":\"[]\",\"condition\":true,\"conditionBindVar\":\"\",\"before\":\"function beforeCallback(vars, config) {\\r\\n    // 通过 vars.params 可以更改查询参数\\r\\n    // 通过 vars.data 可以更改requestdata\\r\\n    // 通过 config.header 可以更改 header\\r\\n    // 通过 config.url 可以更改  url\\r\\n    /* vars.data = {\\r\\n    } */\\r\\n    // console.log(vars, config);\\r\\n    // 可以查看还有哪些参数可以修改。\\r\\n}\",\"success\":\"function successCallback(data) {\\r\\n    const scopeMap = {};\\r\\n    $this.scopeOptions.forEach(item => {\\r\\n        scopeMap[item.value] = item.label\\r\\n    });\\r\\n    const target = [];\\r\\n    for (var k in data.data) {\\r\\n        if (scopeMap[k]) {\\r\\n            const temp = {\\r\\n                label: scopeMap[k],\\r\\n                value: k,\\r\\n                children: []\\r\\n            };\\r\\n            data.data[k].forEach(item => {\\r\\n                temp.children.push({\\r\\n                    label: item,\\r\\n                    value: item\\r\\n                });\\r\\n            });\\r\\n            target.push(temp);\\r\\n        }\\r\\n    }\\r\\n    $this.setScopeCascaders(target);\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\"fail\":\"function failCallback(error){\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\"callback\":\"\"}],\"i18n\":{\"zh-CN\":\"{}\",\"en-US\":\"{}\"}},\"children\":[{\"id\":\"bf46594a704487c7\",\"name\":\"bf46594a704487c7\",\"label\":\"flex布局\",\"type\":\"flexLayout\",\"options\":{\"hidden\":false,\"hiddenBindVar\":null,\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"loadingText\":null,\"loadingTextBindVar\":null,\"showTooltip\":false,\"tooltip\":null,\"tooltipBindVar\":null,\"className\":\"\",\"css\":\":root{}\",\"loop\":{\"isLoading\":false,\"loading\":false,\"loadingBindVar\":null,\"data\":null,\"dataBindVar\":null,\"item\":\"item\",\"index\":\"index\",\"key\":\"index\",\"paginationVisible\":true,\"disabled\":false,\"pagination\":{\"style\":{\"display\":\"block\"},\"sizeOptions\":[10,20,30,40,50],\"show\":true,\"showTotal\":true,\"pageSizeChangeResetCurrent\":true,\"sizeCanChange\":true,\"total\":0,\"pageSize\":20,\"current\":1},\"event\":{\"builtIn\":{\"type\":\"url\",\"isSingleService\":true,\"urlAction\":{\"u