    }\\r\\n    if (cur.procAndModel == undefined || cur.procAndModel == null || cur.procAndModel == '') {\\r\\n        cur.procAndModel = 'mgr';\\r\\n    }\\r\\n    if (cur.procAndModel == undefined || cur.procAndModel == null || cur.procAndModel == '') {\\r\\n        cur.procAndModel = 'mgr';\\r\\n    }\\r\\n\\r\\n  \\r\\n    if (hasChange) {\\r\\n        $this.setCurrRow(cur);\\r\\n    }\\r\\n\\r\\n    let modelWorkspaceDirList = cur.modelWorkspaceDirList;\\r\\n    if (modelWorkspaceDirList != undefined && modelWorkspaceDirList.length > 0) {\\r\\n        debugger;\\r\\n        $this.setWorkspaceDirData(listToTree(modelWorkspaceDirList));\\r\\n    }\\r\\n}\\r\\n\\r\\nfunction listToTree(data, idName, parentIdName) {\\r\\n    if (!idName) {\\r\\n        idName = 'name';\\r\\n    }\\r\\n    if (!parentIdName) {\\r\\n        parentIdName = 'parentName';\\r\\n    }\\r\\n\\r\\n    // * 先生成parent建立父子关系\\r\\n    const obj = {};\\r\\n    data.forEach((item) => {\\r\\n        obj[item[idName]] = item;\\r\\n    });\\r\\n    const parentList = [];\\r\\n    data.forEach((item) => {\\r\\n        // item.hasChildren = false;\\r\\n        item.key = item.name;\\r\\n        item.title = item.label;\\r\\n        const parent = obj[item[parentIdName]];\\r\\n        if (parent) {\\r\\n            // * 当前项有父节点\\r\\n            parent.children = parent.children || [];\\r\\n            parent.children.push(item);\\r\\n            // parent.hasChildren = true;\\r\\n        } else {\\r\\n            // * 当前项没有父节点 -> 顶层\\r\\n            parentList.push(item);\\r\\n        }\\r\\n    });\\r\\n    return parentList;\\r\\n}\"}},\"type\":\"one-screen-layout\",\"titleVisible\":false,\"vars\":[{\"name\":\"hideDirBoundBtn\",\"descr\":null,\"value\":\"false\"},{\"name\":\"workspaceDirData\",\"descr\":null,\"value\":\"[\\r\\n    {\\r\\n        key: 'topDir',\\r\\n        title: '工作空间目录',\\r\\n        children: []\\r\\n    }\\r\\n]\"},{\"name\":\"currRow\",\"descr\":null,\"value\":\"{}\"},{\"name\":