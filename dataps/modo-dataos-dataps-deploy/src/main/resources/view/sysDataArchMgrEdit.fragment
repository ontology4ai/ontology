\\n    vars.params.impl = $this.impl||null;\\r\\n    $this.setLoading(true);\\r\\n}\",\n                    \"success\": \"function successCallback(data) {\\r\\n    const map = {};\\r\\n    data.data.forEach(item => {\\r\\n        map[item.key] = item;\\r\\n    });\\r\\n    const target = [];\\r\\n    $this.treeDataForEdit.forEach(item => {\\r\\n        const tempNode = _.extend({}, item);\\r\\n        if (map[tempNode.key]) {\\r\\n            tempNode.lvlModelNum = map[tempNode.key].lvlModelNum;\\r\\n            tempNode.modelNum = map[tempNode.key].modelNum;\\r\\n            tempNode.archModelNum = map[tempNode.key].archModelNum;\\r\\n        }\\r\\n        target.push(tempNode);\\r\\n    });\\r\\n    $this.setTreeData(target);\\r\\n    $this.setLoading(false);\\r\\n    return data.data; // 重要，需返回 data\\r\\n}\",\n                    \"fail\": \"function failCallback(error){\\r\\n    $this.setLoading(false);\\r\\n    // console.log(error);\\r\\n    // 可以在这里做弹框提示等操作\\r\\n}\",\n                    \"callback\": \"\"\n                },\n                {\n                    \"name\": \"saveDataArch\",\n                    \"stateName\": \"\",\n                    \"descr\": \"\",\n                    \"autoLoad\": false,\n                    \"serviceId\": \"238333507393593344\",\n                    \"method\": \"POST\",\n                    \"dataBindVar\": \"\",\n                    \"placeholders\": \"[]\",\n                    \"condition\": true,\n                    \"conditionBindVar\": \"\",\n                    \"before\": \"function beforeCallback(vars, config) {\\r\\n    vars.data.archData = $this.treeDataForEdit.filter(item=>{\\r\\n        item.archType = $this.archType;\\r\\n        return item.changeState!='delete';\\r\\n    });\\r\\n    vars.data.updateUser = $identity.userId;\\r\\n    vars.data.archType = $this.archType||null;\\r\\n    vars.data.impl = $this.impl||null;\\r\\n    $this.setLoading(true);\\r\\n}\",\n                    \"success\": \"f