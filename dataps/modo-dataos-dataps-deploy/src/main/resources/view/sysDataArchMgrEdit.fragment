                                   \"loading\": false,\n                                        \"loadingBindVar\": null,\n                                        \"data\": null,\n                                        \"dataBindVar\": null,\n                                        \"item\": \"item\",\n                                        \"index\": \"index\",\n                                        \"key\": \"index\",\n                                        \"paginationVisible\": true,\n                                        \"disabled\": false,\n                                        \"pagination\": {\n                                            \"style\": {\n                                                \"display\": \"block\"\n                                            },\n                                            \"sizeOptions\": [\n                                                10,\n                                                20,\n                                                30,\n                                                40,\n                                                50\n                                            ],\n                                            \"show\": true,\n                                            \"showTotal\": true,\n                                            \"pageSizeChangeResetCurrent\": true,\n                                            \"sizeCanChange\": true,\n                                            \"total\": 0,\n                                            \"pageSize\": 20,\n                                            \"current\": 1\n                                        },\n                                        \"event\": {\n                                            \"builtIn\": {\n                                                \"type\": \"url\",\n                                                \"isSingleService\": true,\n                                                \"urlAction\": {\n                                                    \"url\": null,\n                                                    \"blank\": true\n                                                },\n                                                \"viewActions\": [\n                                                    {\n                                                        \"condition\": \"true\",\n                                                        \"showType\": \"modal\",\n                                                        \"viewName\": null,\n                                                        \"before\": \"function beforeCallback() {}\",\n                                                        \"width\": \"50%\",\n                                                        \"top\": \"15vh\",\n                                                        \"fullscreen\": false,\n                                                        \"size\": \"50%\",\n                                                        \"tabViewName\": null,\n                                                        \"tabParams\": \"\",\n                                                        \"tabKey\": \"\",\n                                                        \"tabLabel\": \"\"\n                                                    }\n                                                ],\n                                                \"actions\": []\n                                            },\n                                            \"callback\": \"function callback() {}\"\n                                        }\n                                    },\n                                    \"eventMap\": {}\n                                },\n                                \"defaultOptions\": {\n                                    \"css\": \":root {\\nheight: 200px;\\n}\"\n                                },\n                                \"children\": [\n                                    {\n                                        \"id\": \"c14a6f0a56584a4d\",\n                                        \"name\": \"treeDef\",\n                                        \"label\": \"树状图\",\n                                        \"type\": \"treeChart\",\n                                        \"options\": {\n                                            \"hidden\": false,\n                                            \"hiddenBindVar\": null,\n                                            \"isLoading\": false,\n                                            \"loading\": false,\n                                            \"loadingBindVar\": null,\n                                            \"loadingText\": null,\n                                            \"loadingTextBindVar\": null,\n                                            \"showTooltip\": false,\n                                            \"tooltip\": null,\n                                            \"tooltipBindVar\": null,\n                                            \"className\": \"\",\n                                            \"css\": \":root {\\n    height:100%;\\n}\",\n                                            \"loop\": {\n                                                \"isLoading\": false,\n                                                \"loading\": false,\n                                                \"loadingBindVar\": null,\n                                                \"data\": null,\n                                                \"dataBindVar\": null,\n                                                \"item\": \"item\",\n                                                \"index\": \"index\",\n                                                \"key\": \"index\",\n                                                \"paginationVisible\": true,\n                                                \"disabled\": false,\n                                                \"pagination\": {\n                                                    \"style\": {\n                                                        \"display\": \"block\"\n                                                    },\n                                                    \"sizeOptions\": [\n                                                        10,\n                                                        20,\n                                                        30,\n                                                        40,\n                                                        50\n                                                    ],\n                                                    \"show\": true,\n                                                    \"showTotal\": true,\n                                                    \"pageSizeChangeResetCurrent\": true,\n                                                    \"sizeCanChange\": true,\n                                                    \"total\": 0,\n                                                    \"pageSize\": 20,\n                                                    \"current\": 1\n                                                },\n                                                \"event\": {\n                                                    \"builtIn\": {\n                                                        \"type\": \"url\",\n                                                        \"isSingleService\": true,\n                                                        \"urlAction\": {\n                                                            \"url\": null,\n                                                            \"blank\": true\n                                                        },\n                                                        \"viewActions\": [\n                                                            {\n                                                                \"condition\": \"true\",\n                                                                \"showType\": \"modal\",\n                                                                \"viewName\": null,\n                                                                \"before\": \"function beforeCallback() {}\",\n                                                                \"width\": \"50%\",\n                                                                \"top\": \"15vh\",\n                                                                \"fullscreen\": false,\n                                                                \"size\": \"50%\",\n                                                                \"tabViewName\": null,\n                                                                \"tabParams\": \"\",\n                                                                \"tabKey\": \"\",\n                                                                \"tabLabel\": \"\"\n                                                            }\n                                                        ],\n                                                        \"actions\": []\n                                                    },\n                                                    \"callback\": \"function callback() {}\"\n                                                }\n                                            },\n                                            \"eventMap\": {\n                                                \"dblclick\": {\n                                                    \"builtIn\": {\n                                                        \"type\": \"view\",\n                                                        \"isSingleService\": true,\n                                                        \"urlAction\": {\n                                                            \"url\": null,\n                                                            \"blank\": true\n                                                        },\n                                                        \"viewActions\": [\n                                                            {\n                                                                \"condition\": \"['lvl'].indexOf($this.$refs.treeDef.treeChartRef.current.getSelection().data.name)==-1\",\n                                                                \"showType\": \"modal\",\n                                                                \"viewName\": \"workspaceDataArchNodeEdit\",\n                                                                \"before\": \"function beforeCallback() { }\",\n                                                                \"width\": \"50%\",\n                                                                \"top\": \"15vh\",\n                                                                \"fullscreen\": false,\n                                                                \"size\": \"50%\",\n                                                                \"tabViewName\": null,\n                                                                \"tabParams\": \"\",\n                                                                \"tabKey\": \"\",\n                                                                \"tabLabel\": \"\",\n                                                                \"title\": \"编辑编目节点\",\n                                                                \"params\": \"{\\r\\n    archType: $this.archType,\\r\\n        impl: $this.impl,\\r\\n            rootKey: $this.rootKey,\\r\\n                isMgr: '1', formData: _.extend({ parentNode: $this.srcArchMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.parent] }, $this.$refs.treeDef.treeChartRef.current.getSelection().data)\\r\\n}\"\n                                                            }\n                                                        ],\n                                                        \"actions\": []\n                                                    },\n                                                    \"callback\": \"function callback() {\\r\\n    if (['lvl'].indexOf($this.$refs.treeDef.treeChartRef.current.getSelection().data.name) > -1) {\\r\\n        $this.utils.modal.warning({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '层次不允许编辑！',\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n}\"\n                                                }\n                                            },\n                                            \"data\": [\n                                                {\n                                                    \"key\": \"root\",\n                                                    \"name\": \"root\",\n                                                    \"label\": \"数据架构定义\",\n                                                    \"descr\": \"数据架构定义描述\"\n                                                },\n                                                {\n                                                    \"key\": \"topic\",\n                                                    \"name\": \"topic\",\n                                                    \"label\": \"主题\",\n                                                    \"descr\": \"主题描述\",\n                                                    \"parent\": \"root\"\n                                                },\n                                                {\n                                                    \"key\": \"lvl\",\n                                                    \"name\": \"lvl\",\n                                                    \"label\": \"层次\",\n                                                    \"descr\": \"层次描述\",\n                                                    \"parent\": \"root\"\n                                                },\n                                                {\n                                                    \"key\": \"sys\",\n                                                    \"name\": \"sys\",\n                                                    \"label\": \"系统\",\n                                                    \"descr\": \"系统描述\",\n                                                    \"parent\": \"root\"\n                                                },\n                                                {\n                                                    \"key\": \"db\",\n                                                    \"name\": \"db\",\n                                                    \"label\": \"数据库\",\n                                                    \"descr\": \"数据库描述\",\n                                                    \"parent\": \"root\"\n                                                }\n                                            ],\n                                            \"dataBindVar\": \"$this.treeData\",\n                                            \"contextMenus\": [\n                                                {\n                                                    \"label\": \"添加下级\",\n                                                    \"__ORIGIN_DATA\": {\n                                                        \"label\": \"\"\n                                                    },\n                                                    \"event\": {\n                                                        \"builtIn\": {\n                                                            \"type\": \"view\",\n                                                            \"isSingleService\": true,\n                                                            \"urlAction\": {\n                                                                \"url\": null,\n                                                                \"blank\": true\n                                                            },\n                                                            \"viewActions\": [\n                                                                {\n                                                                    \"condition\": \"true\",\n                                                                    \"showType\": \"modal\",\n                                                                    \"viewName\": \"workspaceDataArchNodeEdit\",\n                                                                    \"before\": \"function beforeCallback() { }\",\n                                                                    \"width\": \"50%\",\n                                                                    \"top\": \"15vh\",\n                                                                    \"fullscreen\": false,\n                                                                    \"size\": \"50%\",\n                                                                    \"tabViewName\": null,\n                                                                    \"tabParams\": \"\",\n                                                                    \"tabKey\": \"\",\n                                                                    \"tabLabel\": \"\",\n                                                                    \"params\": \"{\\r\\n    archType: $this.archType,\\r\\n        impl: $this.impl,\\r\\n            rootKey: $this.rootKey,\\r\\n                isMgr: '1', formData: { parentNode: $this.$refs.treeDef.treeChartRef.current.getSelection().data, parent: $this.$refs.treeDef.treeChartRef.current.getSelection().data.key, parentLabel: $this.$refs.treeDef.treeChartRef.current.getSelection().data.label, priv: '1', type: $this.$refs.treeDef.treeChartRef.current.getSelection().data.parent == $this.rootKey ? $this.$refs.treeDef.treeChartRef.current.getSelection().data.name : ($this.$refs.treeDef.treeChartRef.current.getSelection().data.name == $this.rootKey ? '' : $this.$refs.treeDef.treeChartRef.current.getSelection().data.type) }\\r\\n}\",\n                                                                    \"title\": \"新增编目节点\"\n                                                                }\n                                                            ],\n                                                            \"actions\": []\n                                                        },\n                                                        \"callback\": \"function callback() { }\"\n                                                    }\n                                                },\n                                                {\n                                                    \"label\": \"添加同级\",\n                                                    \"__ORIGIN_DATA\": {\n                                                        \"label\": \"\"\n                                                    },\n                                                    \"event\": {\n                                                        \"builtIn\": {\n                                                            \"type\": \"view\",\n                                                            \"isSingleService\": true,\n                                                            \"urlAction\": {\n                                                                \"url\": null,\n                                                                \"blank\": true\n                                                            },\n                                                            \"viewActions\": [\n                                                                {\n                                                                    \"condition\": \"$this.$refs.treeDef.treeChartRef.current.getSelection().data.parent\",\n                                                                    \"showType\": \"modal\",\n                                                                    \"viewName\": \"workspaceDataArchNodeEdit\",\n                                                                    \"before\": \"function beforeCallback() { }\",\n                                                                    \"width\": \"50%\",\n                                                                    \"top\": \"15vh\",\n                                                                    \"fullscreen\": false,\n                                                                    \"size\": \"50%\",\n                                                                    \"tabViewName\": null,\n                                                                    \"tabParams\": \"\",\n                                                                    \"tabKey\": \"\",\n                                                                    \"tabLabel\": \"\",\n                                                                    \"title\": \"新增编目节点\",\n                                                                    \"params\": \"{\\r\\n    archType: $this.archType,\\r\\n        impl: $this.impl,\\r\\n            rootKey: $this.rootKey,\\r\\n                isMgr: '1', formData: { parentNode: $this.srcArchMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.parent], parent: $this.$refs.treeDef.treeChartRef.current.getSelection().data.parent, parentLabel: $this.$refs.treeDef.treeChartRef.current.getSelection().data.parentLabel, type: $this.$refs.treeDef.treeChartRef.current.getSelection().data.parent == $this.rootKey ? '' : $this.$refs.treeDef.treeChartRef.current.getSelection().data.type }\\r\\n}\"\n                                                                }\n                                                            ],\n                                                            \"actions\": []\n                                                        },\n                                                        \"callback\": \"function callback() {\\r\\n    if (!$this.$refs.treeDef.treeChartRef.current.getSelection().data.parent) {\\r\\n        $this.utils.modal.warning({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '根结点不允许添加同级结点！',\\r\\n        });\\r\\n    }\\r\\n}\"\n                                                    }\n                                                },\n                                                {\n                                                    \"label\": \"删除\",\n                                                    \"__ORIGIN_DATA\": {\n                                                        \"label\": \"\"\n                                                    },\n                                                    \"event\": {\n                                                        \"builtIn\": {\n                                                            \"type\": \"url\",\n                                                            \"isSingleService\": true,\n                                                            \"urlAction\": {\n                                                                \"url\": null,\n                                                                \"blank\": true\n                                                            },\n                                                            \"viewActions\": [\n                                                                {\n                                                                    \"condition\": \"true\",\n                                                                    \"showType\": \"modal\",\n                                                                    \"viewName\": null,\n                                                                    \"before\": \"function beforeCallback() {}\",\n                                                                    \"width\": \"50%\",\n                                                                    \"top\": \"15vh\",\n                                                                    \"fullscreen\": false,\n                                                                    \"size\": \"50%\",\n                                                                    \"tabViewName\": null,\n                                                                    \"tabParams\": \"\",\n                                                                    \"tabKey\": \"\",\n                                                                    \"tabLabel\": \"\"\n                                                                }\n                                                            ],\n                                                            \"actions\": []\n                                                        },\n                                                        \"callback\": \"function callback() {\\r\\n    const catalogMap = {};\\r\\n    $this.treeDataForEdit.forEach(item => {\\r\\n        catalogMap[item.key] = item;\\r\\n    });\\r\\n    $this.treeDataForEdit.forEach(item => {\\r\\n        if (item.parent && catalogMap[item.parent]) {\\r\\n            if (!catalogMap[item.parent].children) {\\r\\n                catalogMap[item.parent].children = [];\\r\\n            }\\r\\n            catalogMap[item.parent].children.push(item);\\r\\n        }\\r\\n    });\\r\\n    if (!$this.$refs.treeDef.treeChartRef.current.getSelection().data.parent) {\\r\\n        $this.utils.modal.warning({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '根结点不允许删除！',\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n    if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.namingRule) {\\r\\n        $this.utils.modal.warning({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '已配置命名规则，不允许删除！',\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n    if (['lvl'].indexOf($this.$refs.treeDef.treeChartRef.current.getSelection().data.name) > -1) {\\r\\n        $this.utils.modal.warning({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '层级不允许删除！',\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n    if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.archModelNum && $this.$refs.treeDef.treeChartRef.current.getSelection().data.archModelNum > 0) {\\r\\n        $this.utils.modal.confirm({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '节点下存在模型，请先修改模型编目！',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            onOk: () => {\\r\\n                $this.parent.$refs.sysDataArch.addTab('changeModelArch', '模型编目修改', '', 'logicModelArchMove', {\\r\\n                    dirIds: [$this.$refs.treeDef.treeChartRef.current.getSelection().data.key]\\r\\n                })\\r\\n            }\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n    if ($this.$refs.treeDef.treeChartRef.current.getSelection().data.lvlModelNum && $this.$refs.treeDef.treeChartRef.current.getSelection().data.lvlModelNum > 0) {\\r\\n        $this.utils.modal.confirm({\\r\\n            title: '提示',\\r\\n            content:\\r\\n                '层级下存在模型，不允许删除！',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            okText: '查看',\\r\\n            onOk: () => {\\r\\n                $this.parent.$refs.sysDataArch.addTab('logicModelLvlView', '模型层级查看', '', 'logicModelLvlView', {\\r\\n                    lvls: [$this.$refs.treeDef.treeChartRef.current.getSelection().data.name]\\r\\n                })\\r\\n            }\\r\\n        });\\r\\n        return;\\r\\n    }\\r\\n    const filterModelDirs = function (nodes, dirs, dirIds, filterProp) {\\r\\n        nodes.forEach(item => {\\r\\n            if (item[filterProp] && item[filterProp] > 0) {\\r\\n                if (dirIds.indexOf(item.key) == -1) {\\r\\n                    dirs.push(item.label);\\r\\n                    dirIds.push(item.key);\\r\\n                }\\r\\n            }\\r\\n            if (item.children) {\\r\\n                filterModelDirs(item.children, dirs, dirIds, filterProp);\\r\\n            }\\r\\n        });\\r\\n    }\\r\\n    const filterModelLvlDirs = function (nodes, dirs, lvls, filterProp) {\\r\\n        nodes.forEach(item => {\\r\\n            if (item[filterProp] && item[filterProp] > 0) {\\r\\n                if (lvls.indexOf(item.name) == -1) {\\r\\n                    dirs.push(item.label);\\r\\n                    lvls.push(item.name);\\r\\n                }\\r\\n            }\\r\\n            if (item.children) {\\r\\n                filterModelLvlDirs(item.children, dirs, lvls, filterProp);\\r\\n            }\\r\\n        });\\r\\n    }\\r\\n    if (catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children) {\\r\\n        let modelDirs = [];\\r\\n        let modelDirIds = [];\\r\\n        filterModelDirs(catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children, modelDirs, modelDirIds, 'archModelNum');\\r\\n        if (modelDirs.length > 0) {\\r\\n            $this.utils.modal.confirm({\\r\\n                title: '提示',\\r\\n                content:\\r\\n                    '子节点“' + modelDirs.join(',') + '”下存在模型，请先修改模型编目！',\\r\\n                okButtonProps: {\\r\\n                    status: 'danger',\\r\\n                },\\r\\n                onOk: () => {\\r\\n                    $this.parent.$refs.sysDataArch.addTab('changeModelArch', '模型编目修改', '', 'logicModelArchMove', {\\r\\n                        dirIds: modelDirIds\\r\\n                    })\\r\\n                }\\r\\n            });\\r\\n            return;\\r\\n        }\\r\\n        modelDirs = [];\\r\\n        const modelLvls = [];\\r\\n        filterModelLvlDirs(catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children, modelDirs, modelLvls, 'lvlModelNum');\\r\\n        if (modelDirs.length > 0) {\\r\\n            $this.utils.modal.confirm({\\r\\n                title: '提示',\\r\\n                content:\\r\\n                    '子层级“' + modelDirs.join(',') + '”下存在模型，不允许删除！',\\r\\n                okButtonProps: {\\r\\n                    status: 'danger',\\r\\n                },\\r\\n                onOk: () => {\\r\\n                    $this.parent.$refs.sysDataArch.addTab('logicModelLvlView', '模型层级查看', '', 'logicModelLvlView', {\\r\\n                        lvls: modelLvls\\r\\n                    })\\r\\n                }\\r\\n            });\\r\\n            return;\\r\\n        }\\r\\n    }\\r\\n\\r\\n    const target = [];\\r\\n    if (catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key] && catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children && catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children.length > 0) {\\r\\n        $utils.modal.confirm({\\r\\n            title: '警告',\\r\\n            content: '确认删除该结点及其下属结点吗？',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            onOk: () => {\\r\\n                const toRemove = [$this.$refs.treeDef.treeChartRef.current.getSelection().data.key];\\r\\n                const getChildren = function (children, keyList) {\\r\\n                    children.forEach(item => {\\r\\n                        keyList.push(item.key);\\r\\n                        if (item.children && item.children.length > 0) {\\r\\n                            getChildren(item.children, keyList);\\r\\n                        }\\r\\n                    });\\r\\n                }\\r\\n                getChildren(catalogMap[$this.$refs.treeDef.treeChartRef.current.getSelection().data.key].children, toRemove);\\r\\n                $this.treeDataForEdit.forEach(item => {\\r\\n                    if (toRemove.indexOf(item.key) > -1) {\\r\\n                        if (item.changeState != 'add') {\\r\\n                            item.changeState = 'delete';\\r\\n                            target.push(item);\\r\\n                            $this.$refs.treeDef.treeChartRef.current.updateNodeData(item, item.id);\\r\\n                        } else {\\r\\n                            $this.$refs.treeDef.treeChartRef.current.deleteNode(item.id);\\r\\n                        }\\r\\n                    } else {\\r\\n                        target.push(item);\\r\\n                    }\\r\\n                });\\r\\n                target.forEach(item => {\\r\\n                    delete item.children;\\r\\n                })\\r\\n                $this.setTreeDataForEdit(target);\\r\\n                // $this.setTreeData(target);\\r\\n                // $this.$refs.treeDef.treeChartRef.current.loadData(target);\\r\\n                // setTimeout(() => {\\r\\n                //     $this.$refs.treeDef.scrollToNode($this.$refs.treeDef.treeChartRef.current.getSelection().data.key);\\r\\n                //     $this.$refs.treeDef.treeChartRef.current.diagram.select($this.$refs.treeDef.treeChartRef.current.diagram.findNodeForKey($this.$refs.treeDef.treeChartRef.current.getSelection().data.id));\\r\\n                // }, 500);\\r\\n            }\\r\\n        });\\r\\n    } else {\\r\\n        $utils.modal.confirm({\\r\\n            title: '警告',\\r\\n            content: '确认删除该结点吗？',\\r\\n            okButtonProps: {\\r\\n                status: 'danger',\\r\\n            },\\r\\n            onOk: () => {\\r\\n                $this.treeDataForEdit.forEach(item => {\\r\\n                    if (item.key == $this.$refs.treeDef.treeChartRef.current.getSelection().data.key) {\\r\\n                        if (item.changeState != 'add') {\\r\\n                            item.changeState = 'delete';\\r\\n             