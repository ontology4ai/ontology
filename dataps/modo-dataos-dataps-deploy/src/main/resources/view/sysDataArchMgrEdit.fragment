\r\\n    let rootKey = '';\\r\\n    data.data.forEach(item=>{\\r\\n        if(!item.parent){\\r\\n            rootKey = item.key;\\r\\n            $this.setRootKey(item.key);\\r\\n        }\\r\\n    });\\r\\n    const map = {};\\r\\n    const srcMap = {};\\r\\n    const roots = [];\\r\\n    const parentPrivs = [];\\r\\n    data.data.forEach(item => {\\r\\n        if (!item.descr) {\\r\\n            item.descr = '';\\r\\n        }\\r\\n        srcMap[item.key] = _.extend({}, item);\\r\\n        if (item.key && !item.id) {\\r\\n            item.id = item.key;\\r\\n        }\\r\\n        item.priv = '1';\\r\\n        item.children = [];\\r\\n        map[item.key] = item;\\r\\n        if (item.parent && item.parent == rootKey) {\\r\\n            roots.push(item);\\r\\n        }\\r\\n        if (item.priv == '1') {\\r\\n            parentPrivs.push(item);\\r\\n        }\\r\\n        if (!item.parent) {\\r\\n            delete item.parent;\\r\\n        }\\r\\n    });\\r\\n    $this.setSrcArchMap(map);\\r\\n    $this.setArchMap(map);\\r\\n    data.data.forEach(item => {\\r\\n        if (map[item.parent]) {\\r\\n            map[item.parent].children.push(item);\\r\\n        }\\r\\n    });\\r\\n    const loadChildrenPriv = function (arr) {\\r\\n        arr.forEach(item => {\\r\\n            item.priv = '1';\\r\\n            if (item.children && item.children.length > 0) {\\r\\n                loadChildrenPriv(item.children);\\r\\n            }\\r\\n        })\\r\\n    }\\r\\n    parentPrivs.forEach(item => {\\r\\n        if (item.children && item.children.length > 0) {\\r\\n            loadChildrenPriv(item.children);\\r\\n        }\\r\\n    });\\r\\n    $this.setLoading(false);\\r\\n    if (data.data.length == 0) {\\r\\n        data.data = [\\r\\n            {\\r\\n                \\\"key\\\": \\\"root\\\",\\r\\n                \\\"priv\\\": \\\"1\\\",\\r\\n                \\\"label\\\": \\\"编目\\\",\\r\\n                \\\"name\\\": \\\"root\\\",\\r\\n                \\\"t