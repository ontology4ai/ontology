  "scripts": {
    "start": "npm run dev",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 webpack serve --progress --config config/webpack.dev.js --mode development",
    "build": "webpack --config config/webpack.prod.js --mode production && npm run copy:static",
    "inter:dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 webpack serve --progress --config config/webpack.inter.dev.js --mode development",
    "inter:build": "webpack --config config/webpack.inter.prod.js --mode production && npm run copy:static",
    "prebuild": "npm run build:clean",
    "build:clean": "rimraf ./dist",
    "prettify": "prettier --write",
    "pretty-quick": "pretty-quick",
    "lint:eslint:fix": "eslint --ext .ts,.tsx --no-error-on-unmatched-pattern --quiet --fix",
    "lint:style": "stylelint --fix \"src/**/*.less\" --syntax less",
    "lint": "npm run lint:eslint:fix && npm run lint:style",
    "serve": "serve --no-clipboard --single --listen 3000 dist",
    "copy:static": "node config/getStaticResource",
    "test": "jest",
    "test-c": "jest --coverage",
    "test:clean": "rimraf ./coverage"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "browserslist": [
    "last 1 versions",
    "> 2%",
    "not dead"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run lint:eslint:fix",
      "git add --force"
    ],
    "*.{md,json}": [
      "pretty-quick --staged",
      "git add --force"
    ]
  },
